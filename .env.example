# 环境变量模板 — 复制为 .env 并填入真实值
# .env 已在 .gitignore 中，不会被提交

# ===== 数据库 =====
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:13306/smartrecord?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_db_password

# ===== Redis =====
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=16379

# ===== JWT =====
JWT_SECRET=your_long_random_jwt_secret

# ===== 存储 Provider =====
# 可选值：cloudbase（默认，微信云存储）/ aliyun（阿里云 OSS）/ cos（腾讯云 COS）
STORAGE_PROVIDER=cloudbase

# ===== 阿里云 OSS =====
# STORAGE_PROVIDER=aliyun 时需要填写
OSS_ENDPOINT=oss-cn-region.aliyuncs.com
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET_NAME=your_oss_bucket_name

# ===== LLM =====
LLM_API_URL=https://your-llm-provider.example/v1/chat/completions
LLM_API_KEY=your_llm_api_key
LLM_MODEL=your_llm_model

# ===== 微信小程序 =====
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# ===== TTS =====
TTS_EDGE_TTS_CMD=edge-tts
TTS_MIMO_VOICE=冰糖

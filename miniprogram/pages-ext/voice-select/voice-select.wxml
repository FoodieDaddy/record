<view class="page {{!animationEnabled ? 'reduce-motion' : ''}}">
  <!-- HUD 状态条 -->
  <view class="sync-hud {{hudVisible ? 'sync-hud--show' : ''}} {{hudType === 'error' ? 'sync-hud--error' : hudType === 'warning' ? 'sync-hud--warning' : ''}}">
    <view class="sync-hud__dot"></view>
    <text class="sync-hud__text">{{hudText}}</text>
  </view>

  <!-- 蒙层 -->
  <view class="mask {{showSheet ? 'visible' : ''}}" bindtap="closeSheet"></view>

  <!-- 底部抽屉 -->
  <view class="sheet {{showSheet ? 'slide-up' : ''}}">
    <!-- 把手 -->
    <view class="handle"></view>

    <!-- Header -->
    <view class="header">
      <view>
        <text class="header-title">通讯频道校准</text>
      </view>
      <view class="fi fi--close" bindtap="closeSheet"></view>
    </view>

    <!-- 内容区：左右分栏 -->
    <view class="content">
      <!-- 左侧分类栏 -->
      <scroll-view class="sidebar" scroll-y>
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="sr-t-fast sidebar-item {{activeTab === index ? 'active' : ''}}"
          bindtap="switchTab"
          data-index="{{index}}"
        >
          <view class="sidebar-icon sidebar-icon--{{item.id}}"></view>
          <text class="sr-t-fast sidebar-name">{{item.name}}</text>
        </view>
      </scroll-view>

      <!-- 右侧音色列表 -->
      <scroll-view class="voice-list" scroll-y scroll-into-view="{{scrollTo}}">
        <!-- 当前频道标题 -->
        <view class="section-title">{{categories[activeTab].name}} 频道</view>

        <block wx:for="{{categories[activeTab].voices}}" wx:key="id">
          <view
            id="v-{{item.id}}"
            class="sr-t-fast voice-card {{selectedId === item.id ? 'selected' : ''}} {{playingId === item.id ? 'playing' : ''}}"
            bindtap="playVoice"
            data-id="{{item.id}}"
            data-file="{{item.file}}"
          >
            <view class="voice-status-dot" wx:if="{{selectedId === item.id}}"></view>
            <view class="voice-info">
              <view class="voice-name">{{item.name}}</view>
              <view class="voice-desc">{{item.desc}}</view>
            </view>
            <view class="voice-action">
              <view wx:if="{{selectedId === item.id}}" class="check-icon"></view>
              <view wx:elif="{{playingId === item.id}}" class="play-icon spin"></view>
              <view wx:else class="play-icon"></view>
            </view>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>
</view>

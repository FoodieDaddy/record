<scroll-view
  class="page-container {{!animationEnabled ? 'reduce-motion' : ''}}"
  style="height: {{pageHeight}}px;"
  scroll-y
  enhanced
  show-scrollbar="{{false}}"
  refresher-enabled
  refresher-triggered="{{loading}}"
  bindrefresherrefresh="onPullDownRefresh"
>

  <!-- 终端标题 -->
  <view class="terminal-header">
    <text class="terminal-title">航迹回放</text>
    <view class="terminal-line"></view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading && records.length === 0}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在读取航迹索引</text>
  </view>

  <!-- 加载失败 -->
  <view class="error-state" wx:elif="{{loadError}}">
    <text class="error-text">航迹索引读取失败</text>
    <view class="error-retry" bindtap="loadSamples">
      <text class="error-retry-text">重新读取</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading && records.length === 0}}">
    <view class="empty-box">
      <view class="empty-box-inner"></view>
    </view>
    <text class="empty-text">航迹档案尚未写入样本</text>
    <text class="empty-hint">完成一次航程封存后，回放索引将自动点亮</text>
  </view>

  <!-- 航程样本列表 -->
  <block wx:if="{{records.length > 0}}">
    <view class="section-header">
      <text class="section-label">航程样本</text>
    </view>

    <view class="sample-list">
      <view
        class="sample-card"
        wx:for="{{records}}"
        wx:key="roomId"
        data-room-id="{{item.roomId}}"
        bindtap="onSampleTap"
      >
        <view class="sample-card__left">
          <view class="sample-card__id-row">
            <text class="sample-card__prefix">样本</text>
            <text class="sample-card__room">{{item.roomNo}}</text>
          </view>
          <text class="sample-card__time">{{item.settledAt}} 已封存</text>
        </view>
        <view class="sample-card__right">
          <text class="sample-card__score {{item.myScore > 0 ? 'score-positive' : item.myScore < 0 ? 'score-negative' : 'score-zero'}}">
            {{item.myScore > 0 ? '+' : ''}}{{item.myScore}}
          </text>
          <text class="sample-card__rank">#{{item.myRank}} / {{item.memberCount}}</text>
        </view>
        <view class="sample-card__action">
          <text class="sample-card__action-text">回放</text>
          <view class="svg-icon svg-icon--arrow-sm"></view>
        </view>
      </view>
    </view>
  </block>

</scroll-view>

<view class="playback-mask" wx:if="{{playbackVisible}}" bindtap="closePlayback">
  <view class="playback-panel" catchtap="">
    <pulse-stream
      records="{{playbackRecords}}"
      live="{{false}}"
      loading="{{playbackLoading}}"
      title="航程 {{playbackRoomNo}} 脉冲回放"
      max-rows="{{12}}"
      show-close
      bind:close="closePlayback"
    />
  </view>
</view>

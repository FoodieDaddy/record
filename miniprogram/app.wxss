/* 动效协议 token */
@import './styles/motion.wxss';

/* ===== 全局主题：冷蓝终端色阶 ===== */
page {
  /* — 背景 — */
  --bg-deep: #05070A;
  --bg-primary: #0A0A0A;
  --bg-secondary: #0A0F18;
  --bg-panel: rgba(8, 18, 28, 0.72);
  --bg-panel-soft: rgba(10, 24, 36, 0.50);
  --bg-card: rgba(255, 255, 255, 0.035);
  --glass-bg: rgba(255, 255, 255, 0.045);
  --glass-bg-hover: rgba(255, 255, 255, 0.08);

  /* — 文字（冷蓝白色阶） — */
  --text-primary: rgba(226, 242, 255, 0.90);
  --text-secondary: rgba(176, 208, 235, 0.62);
  --text-tertiary: rgba(140, 176, 205, 0.42);
  --text-disabled: rgba(126, 156, 180, 0.26);

  /* — 线框 — */
  --line-subtle: rgba(120, 190, 255, 0.10);
  --line-cyan: rgba(0, 200, 255, 0.24);
  --line-danger: rgba(255, 69, 58, 0.36);
  --glass-border: rgba(10, 132, 255, 0.16);
  --glass-border-light: rgba(255, 255, 255, 0.08);

  /* — 语义色 — */
  --color-primary: #0A84FF;
  --color-cyan: #00C8FF;
  --color-purple: #5E5CE6;
  --color-green: #30D158;
  --color-orange: #FF9F0A;
  --color-red: #FF453A;
  --accent: #0A84FF;
  --accent-glow: rgba(10, 132, 255, 0.22);
  --accent-light: rgba(10, 132, 255, 0.10);
  --success: #30D158;
  --success-glow: rgba(48, 209, 88, 0.12);
  --danger: #FF453A;
  --danger-glow: rgba(255, 69, 58, 0.10);
  --warning: #FF9F0A;

  /* — 排名 — */
  --gold: #FF9F0A;
  --silver: rgba(176, 208, 235, 0.56);
  --bronze: rgba(140, 176, 205, 0.38);

  /* — 阴影 — */
  --glass-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  --glass-shadow-lg: 0 16rpx 48rpx rgba(0, 0, 0, 0.4);

  /* — 圆角/间距 — */
  --border-radius: 28rpx;
  --border-radius-sm: 16rpx;
  --border-radius-xs: 12rpx;
  --spacing-xs: 12rpx;
  --spacing-sm: 20rpx;
  --spacing-md: 32rpx;
  --spacing-lg: 48rpx;
  --spacing-xl: 64rpx;

  background:
    radial-gradient(circle at 20% 0%, rgba(10,132,255,0.12), transparent 32%),
    radial-gradient(circle at 90% 18%, rgba(94,92,230,0.08), transparent 30%),
    var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  min-height: 100vh;
}

/* ===== 舱位状态 Tab：四个主 tab 共用 ===== */
.bay-status-tab {
  position: relative;
  z-index: 5;
  align-self: flex-start;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  height: 44rpx;
  min-width: 178rpx;
  box-sizing: border-box;
  padding: 0 20rpx 0 14rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  clip-path: polygon(
    12rpx 0, calc(100% - 8rpx) 0,
    100% 8rpx, 100% 100%,
    8rpx 100%, 0 calc(100% - 8rpx),
    0 8rpx
  );
  border: 1rpx solid rgba(120, 190, 255, 0.12);
  background: linear-gradient(90deg, rgba(6, 16, 28, 0.82), rgba(3, 8, 14, 0.28));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
  transform-origin: left center;
  animation: bayStatusEnter 0.42s cubic-bezier(0.23, 1, 0.32, 1) both;
}

.bay-status-tab::after {
  content: '';
  position: absolute;
  left: -42%;
  top: 0;
  bottom: 0;
  width: 42%;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.13), transparent);
  animation: bayStatusSweep 2.8s ease-in-out infinite;
  pointer-events: none;
}

.bay-status-tab__dot {
  position: relative;
  z-index: 1;
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: rgba(126, 156, 180, 0.35);
  box-shadow: 0 0 8rpx rgba(126, 156, 180, 0.20);
}

.bay-status-tab__label {
  position: relative;
  z-index: 1;
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: rgba(176, 208, 235, 0.62);
  white-space: nowrap;
}

.bay-status-tab--standby {
  border-color: rgba(120, 190, 255, 0.10);
  background: linear-gradient(90deg, rgba(6, 16, 28, 0.72), rgba(3, 8, 14, 0.22));
}

.bay-status-tab--starting {
  border-color: rgba(0, 200, 255, 0.24);
  background: linear-gradient(90deg, rgba(0, 104, 180, 0.16), rgba(3, 8, 14, 0.24));
}

.bay-status-tab--starting .bay-status-tab__dot {
  background: var(--color-cyan);
  box-shadow: 0 0 12rpx rgba(0, 200, 255, 0.52);
  animation: bayStatusPulse 1.15s ease-in-out infinite;
}

.bay-status-tab--starting .bay-status-tab__label {
  color: rgba(0, 200, 255, 0.82);
}

.bay-status-tab--online {
  border-color: rgba(48, 209, 88, 0.20);
  background: linear-gradient(90deg, rgba(48, 209, 88, 0.10), rgba(3, 8, 14, 0.24));
}

.bay-status-tab--online .bay-status-tab__dot {
  background: var(--color-green);
  box-shadow: 0 0 12rpx rgba(48, 209, 88, 0.45);
  animation: bayStatusPulse 2s ease-in-out infinite;
}

.bay-status-tab--online .bay-status-tab__label {
  color: rgba(88, 224, 126, 0.78);
}

@keyframes bayStatusEnter {
  from { opacity: 0; transform: translateX(-16rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes bayStatusSweep {
  0%, 44% { transform: translateX(0); opacity: 0; }
  52% { opacity: 1; }
  76%, 100% { transform: translateX(350%); opacity: 0; }
}

@keyframes bayStatusPulse {
  0%, 100% { opacity: 0.55; transform: scale(0.9); }
  50% { opacity: 1; transform: scale(1.14); }
}

.reduce-motion .bay-status-tab,
.reduce-motion .bay-status-tab::after,
.reduce-motion .bay-status-tab__dot {
  animation: none !important;
  transition: none !important;
}

/* ===== 毛玻璃卡片 ===== */
.glass-card {
  background: var(--glass-bg);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius);
  box-shadow: var(--glass-shadow);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  position: relative;
  overflow: hidden;
}

/* 带顶部光晕的卡片 */
.glass-card-glow {
  background: var(--glass-bg);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius);
  box-shadow: var(--glass-shadow);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  position: relative;
  overflow: hidden;
}
.glass-card-glow::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.35), transparent);
}

/* 紧凑卡片 */
.glass-card-compact {
  background: var(--glass-bg);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius-sm);
  padding: 24rpx;
  margin-bottom: var(--spacing-xs);
}

/* ===== 区域标题（统一） ===== */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
  letter-spacing: 0.5rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 24rpx;
}

/* ===== 主按钮（终端风格） ===== */
.btn-primary {
  background: linear-gradient(135deg, rgba(10,132,255,0.22), rgba(0,200,255,0.08));
  color: var(--color-cyan);
  border: 1rpx solid rgba(10,132,255,0.45);
  border-radius: var(--border-radius-sm);
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 4rpx;
  transition: opacity 0.2s, background-color 0.2s, border-color 0.2s;
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 24rpx rgba(10,132,255,0.08);
}
.btn-primary::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.45), transparent);
}
.btn-primary:active {
  background: linear-gradient(135deg, rgba(10,132,255,0.32), rgba(0,200,255,0.14));
}
.btn-primary[disabled] {
  background: rgba(10, 132, 255, 0.10);
  color: var(--text-disabled);
  border-color: rgba(10,132,255,0.18);
  box-shadow: none;
}

/* 小型主按钮 */
.btn-primary-sm {
  background: linear-gradient(135deg, rgba(10,132,255,0.22), rgba(0,200,255,0.08));
  color: var(--color-cyan);
  border: 1rpx solid rgba(10,132,255,0.45);
  border-radius: var(--border-radius-xs);
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  text-align: center;
}
.btn-primary-sm:active { opacity: 0.85; }

/* ===== 次要按钮 ===== */
.btn-secondary {
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 1rpx solid var(--glass-border-light);
  border-radius: var(--border-radius-sm);
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  letter-spacing: 3rpx;
}
.btn-secondary:active {
  background: var(--glass-bg);
}

/* 小型次要按钮 */
.btn-secondary-sm {
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 1rpx solid var(--glass-border-light);
  border-radius: var(--border-radius-xs);
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
}

/* ===== 危险按钮（透明底 + 红色细描边） ===== */
.btn-danger {
  background: rgba(255,69,58,0.06);
  color: var(--danger);
  border: 1rpx solid rgba(255,69,58,0.35);
  border-radius: var(--border-radius-sm);
  text-align: center;
}
.btn-danger:active {
  background: rgba(255,69,58,0.14);
}

/* ===== 输入框 ===== */
.input-glass {
  background: var(--glass-bg);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius-sm);
  padding: 24rpx 32rpx;
  color: var(--text-primary);
  font-size: 30rpx;
  transition: border-color 0.2s;
}
.input-glass:focus {
  border-color: rgba(10, 132, 255, 0.4);
}
.input-glass::placeholder {
  color: var(--text-tertiary);
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: var(--glass-border);
  margin: var(--spacing-md) 0;
}

/* 渐变分割线 */
.divider-glow {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--glass-border-light), transparent);
  margin: var(--spacing-md) 0;
}

/* ===== 文字工具 ===== */
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }
.text-accent { color: var(--accent); }
.text-success { color: var(--success); }
.text-danger { color: var(--danger); }
.text-warning { color: var(--warning); }
.text-center { text-align: center; }
.text-bold { font-weight: 600; }
.text-xs { font-size: 22rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 44rpx; }
.text-3xl { font-size: 52rpx; }

/* ===== Flex 工具 ===== */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-1 { flex: 1; }
.gap-xs { gap: 8rpx; }
.gap-sm { gap: 12rpx; }
.gap-md { gap: 16rpx; }
.gap-lg { gap: 24rpx; }

/* ===== 数字滚动 ===== */
.score-number {
  font-variant-numeric: tabular-nums;
  font-feature-settings: "tnum";
}

/* ===== 头像 ===== */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid var(--glass-border);
  flex-shrink: 0;
}
.avatar-sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.avatar-lg {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 3rpx solid var(--glass-border);
  flex-shrink: 0;
}

/* ===== 徽章 ===== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.4;
}
.badge-accent {
  background: var(--accent-light);
  color: var(--accent);
}
.badge-success {
  background: var(--success-glow);
  color: var(--success);
}
.badge-danger {
  background: var(--danger-glow);
  color: var(--danger);
}
.badge-warning {
  background: rgba(255, 159, 10, 0.12);
  color: var(--warning);
}

/* ===== 动画 ===== */
@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateX(-16rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.anim-fade-up {
  animation: fadeSlideUp 0.35s ease both;
}

/* ===== 骨架屏 ===== */
.skeleton {
  background: linear-gradient(90deg, rgba(255,255,255,0.025) 25%, rgba(255,255,255,0.06) 50%, rgba(255,255,255,0.025) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--border-radius-xs);
}

/* ===== 安全区域 ===== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 中英文层级工具 ===== */
.zh-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-cyan);
  letter-spacing: 2rpx;
}

.en-kicker {
  display: block;
  margin-top: 8rpx;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(226,242,255,0.34);
}

.page-zh-title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 3rpx;
}

.page-en-kicker {
  display: block;
  margin-top: 12rpx;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(10,132,255,0.48);
}

/* ===== 赛博终端通用组件 (sr-*) ===== */

.sr-card {
  position: relative;
  border-radius: 28rpx;
  border: 1rpx solid rgba(10,132,255,0.18);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.018));
  box-shadow:
    0 0 0 1rpx rgba(255,255,255,0.025) inset,
    0 0 36rpx rgba(10,132,255,0.045);
  overflow: hidden;
}

.sr-card::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.65), transparent);
  opacity: 0.7;
}

.sr-card-secondary {
  position: relative;
  border-radius: 24rpx;
  border: 1rpx solid var(--glass-border-light);
  background: var(--bg-card);
  overflow: hidden;
}

.sr-section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 22rpx;
}

.sr-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--color-cyan);
}

.sr-kicker {
  display: block;
  margin-top: 8rpx;
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: rgba(226,242,255,0.34);
}

.sr-status-code {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(48,209,88,0.28);
  background: rgba(48,209,88,0.08);
  color: var(--success);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.sr-divider {
  height: 1rpx;
  margin: 24rpx 0;
  background: linear-gradient(90deg, rgba(10,132,255,0.18), rgba(255,255,255,0.05), transparent);
}

.sr-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(10,132,255,0.28);
  background: rgba(10,132,255,0.06);
  color: var(--accent);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.sr-terminal-label {
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: rgba(10,132,255,0.48);
}

.sr-scanline {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.68), transparent);
  opacity: 0.5;
}

.sr-primary-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(10,132,255,0.45);
  background:
    linear-gradient(135deg, rgba(10,132,255,0.22), rgba(0,200,255,0.08));
  color: var(--color-cyan);
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 5rpx;
  box-shadow: 0 0 32rpx rgba(10,132,255,0.10);
  text-align: center;
}

.sr-secondary-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--glass-border-light);
  background: var(--bg-card);
  color: var(--text-secondary);
  font-size: 28rpx;
  letter-spacing: 4rpx;
  text-align: center;
}

/* ===== 统一模块标题：蓝色中文 + 灰色英文 ===== */
.module-head {
  margin-bottom: 24rpx;
}

.module-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
  color: var(--color-cyan);
  letter-spacing: 2rpx;
}

.module-kicker {
  display: block;
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.2;
  letter-spacing: 5rpx;
  color: rgba(226,242,255,0.34);
}

/* ===== 页面主标题：白色中文 + 蓝色英文 ===== */
.page-title-block {
  margin-bottom: 40rpx;
}

.page-main-title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 3rpx;
}

.page-main-kicker {
  display: block;
  margin-top: 12rpx;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(10,132,255,0.48);
}

/* ===== 小状态码 ===== */
.status-pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(48,209,88,0.26);
  background: rgba(48,209,88,0.08);
  color: var(--success);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

/* ===== 卡片内分割线（蓝色渐变） ===== */
.sr-card-line {
  height: 1rpx;
  margin-top: 14rpx;
  background: linear-gradient(90deg, rgba(0, 175, 255, 0.20), rgba(0, 175, 255, 0.06), transparent);
}

/* ===== 终端卡片（全局） ===== */
.terminal-card {
  position: relative;
  border-radius: 28rpx;
  border: 1rpx solid rgba(10,132,255,0.18);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.018));
  box-shadow:
    0 0 0 1rpx rgba(255,255,255,0.025) inset,
    0 0 36rpx rgba(10,132,255,0.045);
  overflow: hidden;
}

.terminal-card::before {
  content: '';
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 0;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(0,200,255,0.52),
    transparent
  );
  opacity: 0.72;
}

/* ===== 终端交互过渡（统一 5 属性） ===== */
.sr-t-base {
  transition: opacity 0.3s ease, transform 0.3s ease, background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
}
.sr-t-fast {
  transition: opacity 0.2s ease, transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
}

/* ===== 全局动效静默兜底 ===== */
.reduce-motion view,
.reduce-motion text,
.reduce-motion button,
.reduce-motion image,
.reduce-motion scroll-view,
.reduce-motion swiper,
.reduce-motion input,
.reduce-motion textarea,
.reduce-motion canvas {
  animation: none !important;
  transition: none !important;
}

/* ==========================================================
   飞控座舱风格 — 全局控件 token
   ========================================================== */

/* ===== 飞控主按钮 ===== */
.flight-primary {
  position: relative;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(10,132,255,0.45);
  background: linear-gradient(135deg, rgba(10,132,255,0.22), rgba(0,200,255,0.08));
  color: var(--color-cyan);
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 5rpx;
  box-shadow: 0 0 32rpx rgba(10,132,255,0.10);
  text-align: center;
  overflow: hidden;
}
.flight-primary::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.55), transparent);
}
.flight-primary:active {
  background: linear-gradient(135deg, rgba(10,132,255,0.32), rgba(0,200,255,0.14));
}
.flight-primary.is-loading {
  color: transparent;
}
.flight-primary.is-loading .flight-loading {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid rgba(0,200,255,0.3);
  border-top-color: #00C8FF;
  border-radius: 50%;
  animation: fpSpin 0.8s linear infinite;
}
@keyframes fpSpin {
  to { transform: translate(-50%, -50%) rotate(360deg); }
}

/* ===== 飞控次按钮 ===== */
.flight-secondary {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--glass-border-light);
  background: var(--bg-card);
  color: var(--text-secondary);
  font-size: 28rpx;
  letter-spacing: 4rpx;
  text-align: center;
}
.flight-secondary:active {
  background: var(--glass-bg);
}

/* ===== 飞控危险按钮 ===== */
.flight-danger {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,69,58,0.35);
  background: rgba(255,69,58,0.06);
  color: var(--danger);
  font-size: 28rpx;
  letter-spacing: 4rpx;
  text-align: center;
}
.flight-danger:active {
  background: rgba(255,69,58,0.14);
}

/* ===== 飞控拨片 ===== */
.flight-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--glass-border-light);
  background: var(--bg-card);
  color: var(--text-secondary);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}
.flight-chip.is-active {
  border-color: rgba(10,132,255,0.45);
  color: var(--color-cyan);
  background: rgba(10,132,255,0.08);
}
.flight-chip.is-active::before {
  content: '';
  display: inline-block;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-cyan);
  margin-right: 10rpx;
  box-shadow: 0 0 8rpx rgba(0,200,255,0.6);
}

/* ===== 航电开关 ===== */
.avionics-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}
.avionics-switch__track {
  position: relative;
  width: 96rpx;
  height: 48rpx;
  border-radius: 24rpx;
  border: 1rpx solid var(--glass-border-light);
  background: var(--glass-bg);
  transition: border-color 0.25s, background-color 0.25s;
}
.avionics-switch__track.is-on {
  border-color: rgba(10,132,255,0.45);
  background: rgba(10,132,255,0.12);
}
.avionics-switch__thumb {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: rgba(226,242,255,0.35);
  transition: transform 0.25s, background-color 0.25s;
}
.avionics-switch__track.is-on .avionics-switch__thumb {
  transform: translateX(48rpx);
  background: var(--accent);
  box-shadow: 0 0 12rpx rgba(10,132,255,0.5);
}
.avionics-switch__label {
  font-size: 28rpx;
  color: var(--text-primary);
}
.avionics-switch__status {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  margin-left: 12rpx;
  color: rgba(226,242,255,0.34);
}
.avionics-switch__track.is-on .avionics-switch__status {
  color: var(--accent);
}

/* ===== 飞控线图标 ===== */
.fi {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--glass-border-light);
  background: var(--bg-card);
  color: var(--text-secondary);
  font-size: 28rpx;
}
.fi:active {
  background: var(--glass-bg);
}
.fi--close::before,
.fi--copy::before,
.fi--share::before,
.fi--scan::before,
.fi--arrow::before,
.fi--random::before {
  content: '';
  display: block;
}
/* 关闭图标：X 线条 */
.fi--close {
  position: relative;
}
.fi--close::before,
.fi--close::after {
  content: '';
  position: absolute;
  width: 20rpx;
  height: 2rpx;
  background: currentColor;
  top: 50%;
  left: 50%;
}
.fi--close::before { transform: translate(-50%, -50%) rotate(45deg); }
.fi--close::after { transform: translate(-50%, -50%) rotate(-45deg); }

/* ===== 飞控底部主控条 ===== */
.flight-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent, rgba(10,10,10,0.95) 30%);
  z-index: 100;
}

/* ===== 终端弹窗遮罩 ===== */
.terminal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.72);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.terminal-modal {
  width: 640rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(10,132,255,0.22);
  background: linear-gradient(180deg, rgba(30,30,30,0.98), rgba(18,18,18,0.98));
  box-shadow: 0 0 48rpx rgba(10,132,255,0.08);
  padding: 48rpx 40rpx;
  position: relative;
}
.terminal-modal::before {
  content: '';
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.5), transparent);
}
.terminal-modal__kicker {
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: rgba(10,132,255,0.48);
  margin-bottom: 12rpx;
}
.terminal-modal__title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}
.terminal-modal__content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 40rpx;
}
.terminal-modal__actions {
  display: flex;
  gap: 20rpx;
}
.terminal-modal__actions .flight-primary,
.terminal-modal__actions .flight-secondary,
.terminal-modal__actions .flight-danger {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
}

/* ===== 全局主题：暗黑 + 毛玻璃 ===== */
page {
  --bg-primary: #0a0a0a;
  --bg-secondary: #141414;
  --bg-card: rgba(255, 255, 255, 0.05);
  --glass-bg: rgba(255, 255, 255, 0.06);
  --glass-bg-hover: rgba(255, 255, 255, 0.1);
  --glass-border: rgba(255, 255, 255, 0.1);
  --glass-border-light: rgba(255, 255, 255, 0.15);
  --glass-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  --glass-shadow-lg: 0 16rpx 48rpx rgba(0, 0, 0, 0.4);
  --text-primary: #ffffff;
  --text-secondary: rgba(255, 255, 255, 0.55);
  --text-tertiary: rgba(255, 255, 255, 0.3);
  --accent: #4f8cff;
  --accent-glow: rgba(79, 140, 255, 0.25);
  --accent-light: rgba(79, 140, 255, 0.12);
  --success: #34d399;
  --success-glow: rgba(52, 211, 153, 0.15);
  --danger: #f87171;
  --danger-glow: rgba(248, 113, 113, 0.12);
  --warning: #fbbf24;
  --gold: #fbbf24;
  --silver: #94a3b8;
  --bronze: #d97706;
  --border-radius: 24rpx;
  --border-radius-sm: 16rpx;
  --border-radius-xs: 12rpx;
  --spacing-xs: 12rpx;
  --spacing-sm: 20rpx;
  --spacing-md: 32rpx;
  --spacing-lg: 48rpx;
  --spacing-xl: 64rpx;

  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  min-height: 100vh;
}

/* ===== 毛玻璃卡片 ===== */
.glass-card {
  background: var(--glass-bg);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius);
  box-shadow: var(--glass-shadow);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  position: relative;
  overflow: hidden;
}

/* 带顶部光晕的卡片 */
.glass-card-glow {
  background: var(--glass-bg);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius);
  box-shadow: var(--glass-shadow);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  position: relative;
  overflow: hidden;
}
.glass-card-glow::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
}

/* 紧凑卡片 */
.glass-card-compact {
  background: var(--glass-bg);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius-sm);
  padding: 24rpx;
  margin-bottom: var(--spacing-xs);
}

/* ===== 区域标题（统一） ===== */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
  letter-spacing: 0.5rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 24rpx;
}

/* ===== 主按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, #5a9bff, #3d7aed);
  color: #ffffff;
  border: none;
  border-radius: var(--border-radius-sm);
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  transition: opacity 0.2s;
  position: relative;
  overflow: hidden;
}
.btn-primary::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.15), transparent);
  opacity: 0;
  transition: opacity 0.2s;
}
.btn-primary:active {
  opacity: 0.85;
}
.btn-primary:active::after {
  opacity: 1;
}
.btn-primary[disabled] {
  background: rgba(79, 140, 255, 0.25);
  color: rgba(255, 255, 255, 0.35);
}

/* 小型主按钮 */
.btn-primary-sm {
  background: linear-gradient(135deg, #5a9bff, #3d7aed);
  color: #ffffff;
  border: none;
  border-radius: var(--border-radius-xs);
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}
.btn-primary-sm:active { opacity: 0.85; }

/* ===== 次要按钮 ===== */
.btn-secondary {
  background: var(--glass-bg);
  color: var(--text-primary);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius-sm);
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}
.btn-secondary:active {
  background: var(--glass-bg-hover);
}

/* 小型次要按钮 */
.btn-secondary-sm {
  background: var(--glass-bg);
  color: var(--text-primary);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius-xs);
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
}

/* ===== 危险按钮 ===== */
.btn-danger {
  background: var(--danger-glow);
  color: var(--danger);
  border: 1rpx solid rgba(248, 113, 113, 0.2);
  border-radius: var(--border-radius-sm);
  text-align: center;
}
.btn-danger:active {
  background: rgba(248, 113, 113, 0.2);
}

/* ===== 输入框 ===== */
.input-glass {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius-sm);
  padding: 24rpx 32rpx;
  color: var(--text-primary);
  font-size: 30rpx;
  transition: border-color 0.2s;
}
.input-glass:focus {
  border-color: rgba(79, 140, 255, 0.4);
}
.input-glass::placeholder {
  color: var(--text-tertiary);
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: var(--glass-border);
  margin: var(--spacing-md) 0;
}

/* 渐变分割线 */
.divider-glow {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--glass-border-light), transparent);
  margin: var(--spacing-md) 0;
}

/* ===== 文字工具 ===== */
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }
.text-accent { color: var(--accent); }
.text-success { color: var(--success); }
.text-danger { color: var(--danger); }
.text-warning { color: var(--warning); }
.text-center { text-align: center; }
.text-bold { font-weight: 600; }
.text-xs { font-size: 22rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 44rpx; }
.text-3xl { font-size: 52rpx; }

/* ===== Flex 工具 ===== */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-1 { flex: 1; }
.gap-xs { gap: 8rpx; }
.gap-sm { gap: 12rpx; }
.gap-md { gap: 16rpx; }
.gap-lg { gap: 24rpx; }

/* ===== 数字滚动 ===== */
.score-number {
  font-variant-numeric: tabular-nums;
  font-feature-settings: "tnum";
}

/* ===== 头像 ===== */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid var(--glass-border);
  flex-shrink: 0;
}
.avatar-sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.avatar-lg {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 3rpx solid var(--glass-border);
  flex-shrink: 0;
}

/* ===== 徽章 ===== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.4;
}
.badge-accent {
  background: var(--accent-light);
  color: var(--accent);
}
.badge-success {
  background: var(--success-glow);
  color: var(--success);
}
.badge-danger {
  background: var(--danger-glow);
  color: var(--danger);
}
.badge-warning {
  background: rgba(251, 191, 36, 0.12);
  color: var(--warning);
}

/* ===== 动画 ===== */
@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateX(-16rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.anim-fade-up {
  animation: fadeSlideUp 0.35s ease both;
}

/* ===== 骨架屏 ===== */
.skeleton {
  background: linear-gradient(90deg, var(--glass-bg) 25%, rgba(255,255,255,0.08) 50%, var(--glass-bg) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--border-radius-xs);
}

/* ===== 安全区域 ===== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 中英文层级工具 ===== */
.zh-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #00C8FF;
  letter-spacing: 2rpx;
}

.en-kicker {
  display: block;
  margin-top: 8rpx;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(255,255,255,0.34);
}

.page-zh-title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.94);
  letter-spacing: 3rpx;
}

.page-en-kicker {
  display: block;
  margin-top: 12rpx;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(10,132,255,0.56);
}

/* ===== 赛博终端通用组件 (sr-*) ===== */

.sr-card {
  position: relative;
  border-radius: 28rpx;
  border: 1rpx solid rgba(10,132,255,0.18);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.018));
  box-shadow:
    0 0 0 1rpx rgba(255,255,255,0.025) inset,
    0 0 36rpx rgba(10,132,255,0.045);
  overflow: hidden;
}

.sr-card::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.65), transparent);
  opacity: 0.7;
}

.sr-section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 22rpx;
}

.sr-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #00C8FF;
}

.sr-kicker {
  display: block;
  margin-top: 8rpx;
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: rgba(255,255,255,0.34);
}

.sr-status-code {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(48,209,88,0.28);
  background: rgba(48,209,88,0.08);
  color: #30D158;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.sr-divider {
  height: 1rpx;
  margin: 24rpx 0;
  background: linear-gradient(90deg, rgba(10,132,255,0.18), rgba(255,255,255,0.05), transparent);
}

.sr-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(10,132,255,0.28);
  background: rgba(10,132,255,0.06);
  color: #0A84FF;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.sr-terminal-label {
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: rgba(10,132,255,0.48);
}

.sr-scanline {
  position: absolute;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.68), transparent);
  opacity: 0.5;
}

.sr-primary-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(10,132,255,0.45);
  background:
    linear-gradient(135deg, rgba(10,132,255,0.22), rgba(0,200,255,0.08));
  color: #00C8FF;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 5rpx;
  box-shadow: 0 0 32rpx rgba(10,132,255,0.10);
  text-align: center;
}

.sr-secondary-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.10);
  background: rgba(255,255,255,0.025);
  color: rgba(255,255,255,0.62);
  font-size: 28rpx;
  letter-spacing: 4rpx;
  text-align: center;
}

/* ===== 统一模块标题：蓝色中文 + 灰色英文 ===== */
.module-head {
  margin-bottom: 24rpx;
}

.module-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #00C8FF;
  letter-spacing: 2rpx;
}

.module-kicker {
  display: block;
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.2;
  letter-spacing: 5rpx;
  color: rgba(255,255,255,0.34);
}

/* ===== 页面主标题：白色中文 + 蓝色英文 ===== */
.page-title-block {
  margin-bottom: 40rpx;
}

.page-main-title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.94);
  letter-spacing: 3rpx;
}

.page-main-kicker {
  display: block;
  margin-top: 12rpx;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(10,132,255,0.56);
}

/* ===== 小状态码 ===== */
.status-pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(48,209,88,0.26);
  background: rgba(48,209,88,0.08);
  color: #30D158;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

/* ===== 终端卡片（全局） ===== */
.terminal-card {
  position: relative;
  border-radius: 28rpx;
  border: 1rpx solid rgba(10,132,255,0.18);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.018));
  box-shadow:
    0 0 0 1rpx rgba(255,255,255,0.025) inset,
    0 0 36rpx rgba(10,132,255,0.045);
  overflow: hidden;
}

.terminal-card::before {
  content: '';
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  top: 0;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(0,200,255,0.52),
    transparent
  );
  opacity: 0.72;
}

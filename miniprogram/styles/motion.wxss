/**
 * 动效协议 token — 全站统一的动画时长、缓动和层级。
 * 在 app.wxss 中 @import './styles/motion.wxss' 引入。
 */

:root {
  /* 时长 */
  --sr-duration-fast: 120ms;
  --sr-duration-normal: 240ms;
  --sr-duration-slow: 400ms;
  --sr-duration-pulse: 680ms;

  /* 缓动 */
  --sr-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --sr-ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
  --sr-spring: cubic-bezier(0.34, 1.56, 0.64, 1);

  /* 层级 */
  --sr-z-overlay: 100;
  --sr-z-modal: 200;
  --sr-z-toast: 300;
  --sr-z-motion: 60;
}

/* 通用入场 */
.motion-fade-in {
  animation: motionFadeIn var(--sr-duration-normal) var(--sr-ease-out) both;
}

.motion-slide-up {
  animation: motionSlideUp var(--sr-duration-normal) var(--sr-ease-out) both;
}

/* 分数冲击反馈 */
.motion-score-impact {
  animation: scoreImpact 220ms var(--sr-spring) both;
}

/* 脉冲飞线 */
.pulse-flight-layer {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: var(--sr-z-motion);
}

.pulse-flight-dot {
  position: absolute;
  opacity: 0;
  transform: translate3d(0, 0, 0) scale(0.96);
  will-change: transform, opacity;
}

.pulse-flight-dot.is-playing {
  animation: pulseFlightMove var(--sr-duration-pulse) var(--sr-ease-out) forwards;
}

/* reduce-motion 兜底 */
.reduce-motion .motion-fade-in,
.reduce-motion .motion-slide-up,
.reduce-motion .motion-score-impact,
.reduce-motion .pulse-flight-dot.is-playing {
  animation: none !important;
}

@keyframes motionFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes motionSlideUp {
  from { opacity: 0; transform: translate3d(0, 24rpx, 0); }
  to { opacity: 1; transform: translate3d(0, 0, 0); }
}

@keyframes scoreImpact {
  0% { transform: scale(1); }
  45% { transform: scale(1.08); }
  100% { transform: scale(1); }
}

@keyframes pulseFlightMove {
  0% { opacity: 0; transform: translate3d(0, 0, 0) scale(0.88); }
  12% { opacity: 1; }
  70% { opacity: 1; }
  100% { opacity: 0; transform: translate3d(var(--dx, 0), var(--dy, 0), 0) scale(1.08); }
}

/* ===== 全局跨页切换动效 (HUD Booting) ===== */

/* 1. 扫描遮罩层：从上到下扫描后消失 */
.route-transition-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  pointer-events: none;
  background: linear-gradient(to bottom, rgba(10,132,255,0.02) 0%, rgba(0,200,255,0.15) 50%, transparent 100%);
  background-size: 100% 200%;
  opacity: 0;
}

.route-transition-mask.is-animating {
  animation: hudMaskScan 450ms cubic-bezier(0.23, 1, 0.32, 1) forwards;
}

@keyframes hudMaskScan {
  0% { background-position: 0% -100%; opacity: 0; }
  20% { opacity: 1; }
  80% { opacity: 1; }
  100% { background-position: 0% 200%; opacity: 0; }
}

/* 2. 主体容器：配合遮罩产生轻微缩放淡入和数据抖动感 */
.route-transition-enter {
  opacity: 1;
}

.route-transition-enter.is-preparing {
  opacity: 0;
}

.route-transition-enter.is-animating {
  animation: hudContentEnter 450ms cubic-bezier(0.23, 1, 0.32, 1) both;
}

@keyframes hudContentEnter {
  0% { opacity: 0; transform: scale(0.98) translateY(16rpx); filter: blur(4px); }
  100% { opacity: 1; transform: scale(1) translateY(0); filter: blur(0); }
}

/* 兜底 */
.reduce-motion .route-transition-mask { display: none !important; }
.reduce-motion .route-transition-enter.is-animating { animation: none !important; opacity: 1 !important; transform: none !important; filter: none !important; }

<view class="login-page">
  <!-- 背景装饰层 -->
  <view class="bg-layer">
    <view class="bg-glow bg-glow-1"></view>
    <view class="bg-glow bg-glow-2"></view>
    <view class="bg-grid"></view>
    <view class="particle particle-1"></view>
    <view class="particle particle-2"></view>
    <view class="particle particle-3"></view>
    <view class="particle particle-4"></view>
    <view class="particle particle-5"></view>
  </view>

  <!-- Logo 区域 -->
  <view class="logo-section">
    <view class="logo-ring">
      <view class="logo-icon-wrap">
        <text class="logo-icon">🀄</text>
      </view>
    </view>
    <text class="logo-title">Happy记分器</text>
    <view class="logo-divider"></view>
    <text class="logo-subtitle text-secondary">细致记分 · 实时同步</text>
    <view class="feature-tags">
      <view class="tag">
        <text class="tag-dot"></text>
        <text>多人房间</text>
      </view>
      <view class="tag">
        <text class="tag-dot"></text>
        <text>实时排行</text>
      </view>
      <view class="tag">
        <text class="tag-dot"></text>
        <text>成绩海报</text>
      </view>
    </view>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <view class="card-border-glow"></view>
    <view class="card-inner">
      <button class="login-btn" bindtap="onLogin" loading="{{loading}}">
        <text class="btn-icon">💬</text>
        <text>微信一键登录</text>
      </button>
      <view class="login-footer">
        <text class="text-tertiary login-tip">首次登录将自动生成昵称头像</text>
      </view>
    </view>
  </view>

  <!-- 隐藏 canvas，用于生成头像 -->
  <canvas type="2d" id="avatarCanvas" style="position:fixed;left:-999rpx;top:-999rpx;width:200rpx;height:200rpx;"></canvas>

  <!-- 底部版本 -->
  <text class="version-text text-tertiary">v1.0.0</text>
</view>

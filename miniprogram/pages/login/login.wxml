<view class="login-page">
  <!-- 背景扫描线 -->
  <view class="scanline"></view>

  <!-- Logo 区域 -->
  <view class="brand">
    <view class="logo-mark">
      <view class="logo-ring">
        <view class="logo-inner">
          <view class="logo-s">
            <view class="s-top"></view>
            <view class="s-bottom"></view>
          </view>
        </view>
      </view>
      <view class="logo-glow"></view>
    </view>

    <text class="terminal-title">TERMINAL ACCESS</text>
    <text class="terminal-subtitle">终端接入</text>

    <view class="terminal-divider">
      <view class="div-line"></view>
      <text class="div-label">记录 · 分析 · 推演</text>
      <view class="div-line"></view>
    </view>

    <view class="terminal-tags">
      <text class="tag-item">多人房间</text>
      <text class="tag-sep">|</text>
      <text class="tag-item">人格镜像</text>
      <text class="tag-sep">|</text>
      <text class="tag-item">策略灵感</text>
    </view>
  </view>

  <!-- 系统状态 -->
  <view class="system-status">
    <view class="status-header">
      <view class="status-line"></view>
      <text class="status-label">SYSTEM STATUS</text>
      <view class="status-line"></view>
    </view>

    <view class="status-grid">
      <view class="status-row">
        <view class="status-dot"></view>
        <text class="status-module">ROOM MODULE</text>
        <text class="status-value">ONLINE</text>
      </view>
      <view class="status-row">
        <view class="status-dot"></view>
        <text class="status-module">PERSONA MODULE</text>
        <text class="status-value">ONLINE</text>
      </view>
      <view class="status-row">
        <view class="status-dot"></view>
        <text class="status-module">ORACLE MODULE</text>
        <text class="status-value">ONLINE</text>
      </view>
    </view>
  </view>

  <!-- 身份认证 -->
  <view class="auth-section" wx:if="{{!connecting}}">
    <view class="auth-header">
      <view class="auth-line"></view>
      <text class="auth-label">IDENTITY AUTH</text>
      <view class="auth-line"></view>
    </view>

    <button
      class="login-btn {{loading ? 'is-loading' : ''}}"
      hover-class="login-btn--hover"
      hover-stay-time="100"
      bindtap="onLogin"
    >
      <text class="btn-text">微信授权接入</text>
      <view wx:if="{{loading}}" class="btn-loading">
        <view class="spinner"></view>
      </view>
    </button>

    <text class="auth-hint">首次接入后自动创建身份档案</text>
  </view>

  <!-- 登录动画 -->
  <view class="connecting-overlay" wx:if="{{connecting}}">
    <view class="connecting-box">
      <text class="connecting-title">TERMINAL CONNECTING</text>
      <view class="connecting-divider"></view>

      <view class="connecting-steps">
        <view class="step-row" wx:for="{{steps}}" wx:key="index">
          <text class="step-text">{{item.text}}</text>
          <text class="step-check" wx:if="{{item.done}}">[OK]</text>
        </view>
      </view>

      <view class="connecting-divider" wx:if="{{accessGranted}}"></view>
      <text class="access-granted" wx:if="{{accessGranted}}">ACCESS GRANTED</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="bottom-info">
    <text class="build-info">BUILD 1.0.0</text>
    <view class="bottom-divider"></view>
    <text class="brand-terminal">Record Terminal</text>
  </view>
</view>

.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  position: relative;
  overflow: hidden;
}

/* ===== 背景装饰层 ===== */
.bg-layer {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
}

.bg-glow-1 {
  top: -15%;
  left: 50%;
  transform: translateX(-50%);
  width: 120%;
  height: 50%;
  background: radial-gradient(ellipse, rgba(79, 140, 255, 0.15) 0%, transparent 70%);
}

.bg-glow-2 {
  bottom: -10%;
  right: -20%;
  width: 60%;
  height: 40%;
  background: radial-gradient(ellipse, rgba(79, 140, 255, 0.06) 0%, transparent 70%);
}

.bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1rpx, transparent 1rpx);
  background-size: 80rpx 80rpx;
  opacity: 0.5;
}

/* 装饰粒子 */
.particle {
  position: absolute;
  border-radius: 50%;
  background: var(--accent);
  opacity: 0;
  animation: float 6s ease-in-out infinite;
}

.particle-1 {
  width: 6rpx; height: 6rpx;
  top: 20%; left: 15%;
  animation-delay: 0s;
  opacity: 0.3;
}
.particle-2 {
  width: 8rpx; height: 8rpx;
  top: 35%; right: 20%;
  animation-delay: 1.2s;
  opacity: 0.2;
}
.particle-3 {
  width: 5rpx; height: 5rpx;
  top: 60%; left: 25%;
  animation-delay: 2.4s;
  opacity: 0.25;
}
.particle-4 {
  width: 7rpx; height: 7rpx;
  top: 15%; right: 30%;
  animation-delay: 3.6s;
  opacity: 0.15;
}
.particle-5 {
  width: 4rpx; height: 4rpx;
  top: 75%; left: 40%;
  animation-delay: 4.8s;
  opacity: 0.2;
}

@keyframes float {
  0%, 100% {
    opacity: 0;
    transform: translateY(0);
  }
  20% { opacity: 0.3; }
  50% {
    opacity: 0.15;
    transform: translateY(-40rpx);
  }
  80% { opacity: 0.25; }
}

/* ===== Logo 区域 ===== */
.logo-section {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(79, 140, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  position: relative;
  background: radial-gradient(circle, rgba(79, 140, 255, 0.08) 0%, transparent 70%);
}

.logo-ring::before {
  content: '';
  position: absolute;
  inset: -8rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(79, 140, 255, 0.08);
}

.logo-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(79, 140, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 80rpx;
}

.logo-title {
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(180deg, #ffffff, rgba(255,255,255,0.7));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.logo-divider {
  width: 64rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  margin-bottom: 16rpx;
}

.logo-subtitle {
  font-size: 26rpx;
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
}

/* 功能标签 */
.feature-tags {
  display: flex;
  gap: 24rpx;
}

.tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.tag-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--accent);
  opacity: 0.6;
}

/* ===== 登录卡片 ===== */
.login-card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 600rpx;
}

.card-border-glow {
  position: absolute;
  inset: 0;
  border-radius: 28rpx;
  padding: 1rpx;
  background: linear-gradient(135deg, rgba(79,140,255,0.3), rgba(79,140,255,0.05), rgba(79,140,255,0.15));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

.card-inner {
  background: var(--glass-bg);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 预览头像昵称 */
.preview-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
  padding: 24rpx;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 16rpx;
  margin-bottom: 28rpx;
}

.preview-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.preview-char {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.preview-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.preview-nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.btn-refresh {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0;
}
.btn-refresh:active {
  background: rgba(79, 140, 255, 0.15);
}

.refresh-icon {
  font-size: 28rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #5a9bff, #3d7aed);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  position: relative;
  overflow: hidden;
}

.login-btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.12), transparent);
}

.login-btn:active {
  opacity: 0.9;
}

.btn-icon {
  font-size: 36rpx;
  position: relative;
  z-index: 1;
}

.login-footer {
  margin-top: 28rpx;
  text-align: center;
}

.login-tip {
  font-size: 24rpx;
}

/* ===== 底部版本 ===== */
.version-text {
  position: absolute;
  bottom: 60rpx;
  font-size: 22rpx;
  z-index: 1;
}

/* ===== 登录页：极致暗黑 + 毛玻璃 ===== */

.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 56rpx;
  position: relative;
  overflow: hidden;
  background: #0A0A0A;
}

/* ===== 环境光 ===== */
.atmosphere {
  position: absolute;
  top: -20%;
  left: 50%;
  transform: translateX(-50%);
  width: 160%;
  height: 70%;
  background: radial-gradient(ellipse at center, rgba(10, 132, 255, 0.12) 0%, rgba(10, 132, 255, 0.04) 35%, transparent 70%);
  pointer-events: none;
}

/* ===== 品牌展示区 ===== */
.brand {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 96rpx;
}

/* --- Logo 几何标记 --- */
.logo-mark {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
}

.logo-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(10, 132, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.logo-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(10, 132, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 抽象 S 形：两段圆弧组成 */
.logo-s {
  width: 56rpx;
  height: 80rpx;
  position: relative;
}

.s-top {
  position: absolute;
  top: 0;
  left: 0;
  width: 56rpx;
  height: 44rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.85);
  border-bottom: none;
  border-radius: 28rpx 28rpx 0 0;
}

.s-bottom {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 56rpx;
  height: 44rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.85);
  border-top: none;
  border-radius: 0 0 28rpx 28rpx;
}

.logo-glow {
  position: absolute;
  inset: -20rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(10, 132, 255, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

/* --- 主标题 --- */
.brand-name {
  font-family: -apple-system, "SF Pro Display", "Helvetica Neue", sans-serif;
  font-size: 56rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

/* --- 副标题 --- */
.brand-tagline {
  font-size: 26rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 36rpx;
}

/* --- 功能标签 --- */
.brand-features {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.feature-item {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 1rpx;
}

.feature-sep {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.12);
  font-weight: 200;
}

/* ===== 登录卡片（毛玻璃） ===== */
.login-card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 32rpx;
  overflow: hidden;
}

.card-shine {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 50%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
  pointer-events: none;
}

.card-body {
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ===== 登录按钮（绝对防抖设计） ===== */
.login-btn {
  width: 100%;
  height: 100rpx;
  background: #0A84FF;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
  border-radius: 20rpx;
  padding: 0;
  margin: 0;
  /* 核心：flex 居中 + relative 定位 */
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

/* 移除微信默认 button 伪元素 */
.login-btn::after {
  display: none;
}

/* 按压态 */
.login-btn--hover {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 按钮内容容器：始终绝对居中 */
.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  /* 不受 loading 影响 */
  position: relative;
  z-index: 2;
}

.btn-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* --- 微信图标（纯 CSS 单色线框） --- */
.btn-icon-wrap {
  width: 40rpx;
  height: 36rpx;
  position: relative;
  flex-shrink: 0;
}

.wechat-icon {
  width: 40rpx;
  height: 36rpx;
  position: relative;
}

.wc-bubble {
  border: 2rpx solid #FFFFFF;
  border-radius: 50%;
  position: absolute;
}

.wc-bubble--lg {
  width: 22rpx;
  height: 18rpx;
  top: 0;
  left: 0;
}

.wc-bubble--sm {
  width: 16rpx;
  height: 13rpx;
  top: 5rpx;
  right: 0;
}

.wc-dot {
  width: 3rpx;
  height: 3rpx;
  border-radius: 50%;
  background: #FFFFFF;
  position: absolute;
}

.wc-dot--1 { bottom: 6rpx; left: 3rpx; }
.wc-dot--2 { bottom: 4rpx; left: 9rpx; }
.wc-dot--3 { bottom: 2rpx; left: 15rpx; }
.wc-dot--4 { bottom: 6rpx; right: 3rpx; }
.wc-dot--5 { bottom: 4rpx; right: 8rpx; }
.wc-dot--6 { bottom: 2rpx; right: 13rpx; }

/* --- Loading 圈：绝对定位，不影响文字 --- */
.btn-loading {
  position: absolute;
  left: 48rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
}

.spinner {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* loading 时隐藏图标避免重叠 */
.login-btn.is-loading .btn-icon-wrap {
  visibility: hidden;
}

/* --- 底部提示 --- */
.login-hint {
  margin-top: 28rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  text-align: center;
}

/* ===== 底部版本 ===== */
.version {
  position: absolute;
  bottom: 60rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.2);
  z-index: 1;
}

/* ===== 登录页：终端接入 ===== */

.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 56rpx;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 30%, rgba(0, 21, 45, 0.8) 0%, transparent 50%),
    radial-gradient(circle at 50% 50%, rgba(10, 132, 255, 0.04) 0%, transparent 40%),
    #05070A;
}

/* ===== 扫描线 ===== */
.scanline {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 3rpx,
    rgba(255, 255, 255, 0.015) 3rpx,
    rgba(255, 255, 255, 0.015) 4rpx
  );
  pointer-events: none;
  z-index: 0;
}

/* ===== 识别区 ===== */
.brand {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 56rpx;
}

/* --- Logo --- */
.logo-mark {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 36rpx;
}

.logo-ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(10, 132, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.logo-inner {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: rgba(10, 132, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.logo-s {
  width: 48rpx;
  height: 68rpx;
  position: relative;
}

.s-top {
  position: absolute;
  top: 0;
  left: 0;
  width: 48rpx;
  height: 38rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.85);
  border-bottom: none;
  border-radius: 24rpx 24rpx 0 0;
}

.s-bottom {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 38rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.85);
  border-top: none;
  border-radius: 0 0 24rpx 24rpx;
}

.logo-glow {
  position: absolute;
  inset: -24rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(10, 132, 255, 0.15) 0%, transparent 70%);
  pointer-events: none;
  animation: breathe 3s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.08); }
}

/* --- 终端标题 --- */
.terminal-title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: rgba(255, 255, 255, 0.94);
  margin-bottom: 12rpx;
}

.terminal-kicker {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: rgba(10,132,255,0.56);
  margin-bottom: 28rpx;
}

/* --- 分隔线 --- */
.terminal-divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  width: 100%;
  max-width: 480rpx;
}

.div-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
}

.div-label {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: rgba(10, 132, 255, 0.6);
  white-space: nowrap;
}

/* --- 标签 --- */
.terminal-tags {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tag-item {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.32);
  letter-spacing: 1rpx;
}

.tag-sep {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.1);
}

/* ===== 系统状态 ===== */
.system-status {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 480rpx;
  margin-bottom: 48rpx;
}

.status-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.status-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.06);
}

.status-label-cn {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.62);
  white-space: nowrap;
}

.status-label {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(10, 132, 255, 0.45);
  white-space: nowrap;
}

.status-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 8rpx;
}

.status-dot {
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #30D158;
  box-shadow: 0 0 14rpx rgba(48, 209, 88, 0.78);
  flex-shrink: 0;
}

.status-module {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.45);
  flex: 1;
}

.status-value {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: #30D158;
}

/* ===== 身份认证 ===== */
.auth-section {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 480rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 28rpx;
  width: 100%;
}

.auth-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.06);
}

.auth-label-cn {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.62);
  white-space: nowrap;
}

.auth-label {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(10, 132, 255, 0.45);
  white-space: nowrap;
}

/* --- 登录按钮 --- */
.login-btn {
  width: 100%;
  height: 88rpx;
  background: transparent;
  color: #0A84FF;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.35);
  border-radius: 12rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  transition: border-color 0.2s, box-shadow 0.2s;
  box-shadow: 0 0 12rpx rgba(10, 132, 255, 0.08);
}

.login-btn::after {
  display: none;
}

.login-btn--hover {
  border-color: rgba(10, 132, 255, 0.6);
  box-shadow: 0 0 20rpx rgba(10, 132, 255, 0.15);
}

.login-btn.is-loading {
  opacity: 0.7;
}

.btn-text {
  color: #0A84FF;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
}

/* --- Loading --- */
.btn-loading {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
}

.spinner {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid rgba(10, 132, 255, 0.2);
  border-top-color: #0A84FF;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.auth-hint {
  margin-top: 20rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.28);
  letter-spacing: 1rpx;
}

/* ===== 登录动画遮罩 ===== */
.connecting-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(5, 7, 10, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.connecting-box {
  width: 80%;
  max-width: 520rpx;
  padding: 48rpx 40rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.2);
  border-radius: 16rpx;
  background: rgba(10, 15, 24, 0.8);
}

.connecting-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: rgba(255, 255, 255, 0.92);
}

.connecting-kicker {
  display: block;
  text-align: center;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(10, 132, 255, 0.68);
  margin-bottom: 24rpx;
}

.connecting-divider {
  height: 1rpx;
  background: rgba(10, 132, 255, 0.15);
  margin: 20rpx 0;
}

.connecting-steps {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 8rpx 0;
}

.step-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.step-text {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.55);
}

.step-check {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: #30D158;
}

.access-granted {
  display: block;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #30D158;
  margin-top: 4rpx;
  animation: grantPulse 0.6s ease-in-out;
}

.access-granted-kicker {
  display: block;
  text-align: center;
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: rgba(48, 209, 88, 0.52);
  margin-top: 8rpx;
}

@keyframes grantPulse {
  0% { opacity: 0; transform: scale(0.95); }
  50% { opacity: 1; transform: scale(1.02); }
  100% { opacity: 1; transform: scale(1); }
}

/* ===== 底部信息 ===== */
.bottom-info {
  position: absolute;
  bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  z-index: 1;
}

.build-info {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.22);
}

.bottom-divider {
  width: 48rpx;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.08);
}

.brand-terminal {
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.18);
}

.gallery-page {
  padding: var(--spacing-md);
  min-height: 100vh;
}

/* ===== 头部 ===== */
.gallery-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.gallery-title {
  font-size: 36rpx;
  font-weight: 700;
}

/* ===== 骨架屏加载 ===== */
.loading-state {
  padding-top: 8rpx;
}

.skeleton-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.skeleton-item {
  width: calc(33.33% - 6rpx);
  aspect-ratio: 1;
  border-radius: 8rpx;
}

/* ===== 空状态 ===== */
.empty-gallery {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-illustration {
  margin-bottom: 32rpx;
}

.empty-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(79, 140, 255, 0.06);
  border: 1rpx solid rgba(79, 140, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 56rpx;
}

/* ===== 图片网格 ===== */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.grid-item {
  position: relative;
  width: calc(33.33% - 6rpx);
  aspect-ratio: 1;
  border-radius: 8rpx;
  overflow: hidden;
}
.grid-item:active {
  opacity: 0.85;
}

.grid-img {
  width: 100%;
  height: 100%;
}

.grid-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 10rpx 10rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.55));
  text-align: center;
}

.grid-date {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.85);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3);
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 32rpx;
}
.load-more:active {
  opacity: 0.7;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid var(--glass-border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 结束标记 ===== */
.end-marker {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 0;
}

.end-line {
  flex: 1;
  height: 1rpx;
  background: var(--glass-border);
}

.gallery-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gallery-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.gallery-empty-icon {
  width: 96rpx;
  height: 96rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  position: relative;
}

.gallery-empty-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 40rpx;
  height: 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 4rpx;
}

.gallery-empty-icon::after {
  content: '';
  position: absolute;
  top: 35%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 50%;
}

.gallery-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 12rpx;
}

.gallery-empty-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.25);
}

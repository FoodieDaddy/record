  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
  animation: fadeIn 0.8s ease-out 0.5s both;
}

.idle-hint-main {
  font-size: 28rpx;
  color: rgba(200, 230, 250, 0.55);
  letter-spacing: 4rpx;
  font-family: "Courier New", Courier, monospace;
}

.idle-hint-sub {
  font-size: 22rpx;
  color: rgba(160, 210, 235, 0.32);
  letter-spacing: 2rpx;
  font-family: "Courier New", Courier, monospace;
}


/* ===== 0. 跨 Tab 骨架屏 ===== */
.page-skeleton {
  position: fixed;

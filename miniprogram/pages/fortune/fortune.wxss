/* ===== 1. 全局容器 ===== */
.strategy-page {
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.08), transparent 50%),
    radial-gradient(circle at 20% 80%, rgba(5, 11, 18, 0.8), transparent 60%),
    #02060A;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  position: relative;
  /* 自定义 tabbar 140rpx + Home Indicator + 操作栏预留 */
  padding: 24rpx;
}

.strategy-page--overlay-active {
  overflow: hidden;
  filter: brightness(0.85) blur(2px);
  transition: filter 300ms ease;
}

.strategy-page--completed .directive-projection {
  position: relative;
  z-index: 3;
}
.strategy-page--completed .directive-projection::before {
  content: '';
  position: absolute;
  inset: -20rpx -12rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(2, 8, 14, 0.06), rgba(2, 8, 14, 0.12));
  z-index: -1;
}

/* ===== 星图舷窗 — 三层结构 ===== */
.nav-map-window {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: 0;
  pointer-events: none;
  opacity: 0.45;
  filter: saturate(0.6) brightness(0.8);
  transition:
    opacity 600ms cubic-bezier(0.22, 1, 0.36, 1),
    filter 600ms cubic-bezier(0.22, 1, 0.36, 1);
}

/* === 第一层：宇宙背景 + 星尘 === */
.nav-map-cosmos {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 72% 28%, rgba(85, 255, 170, 0.08), transparent 22%),
    radial-gradient(circle at 28% 68%, rgba(0, 180, 255, 0.08), transparent 26%),
    radial-gradient(circle at 50% 50%, rgba(0, 60, 120, 0.06), transparent 40%),
    linear-gradient(180deg, rgba(4, 18, 30, 0.72), rgba(2, 8, 14, 0.88));
}

/* 星尘噪点纹理（伪元素） */
.nav-map-cosmos::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      0deg,
      transparent 0,
      transparent 2rpx,
      rgba(200, 230, 255, 0.012) 2rpx,
      rgba(200, 230, 255, 0.012) 3rpx
    ),
    repeating-linear-gradient(
      90deg,
      transparent 0,
      transparent 3rpx,
      rgba(200, 230, 255, 0.008) 3rpx,
      rgba(200, 230, 255, 0.008) 4rpx
    );
  opacity: 0.7;
}

/* 星尘粒子 */
.nav-dust {
  position: absolute;
  border-radius: 50%;
  background: rgba(200, 230, 255, 0.8);
  animation: dustDrift 80s linear infinite;
}

@keyframes dustDrift {
  0%   { transform: translate(0, 0); }
  25%  { transform: translate(3rpx, -5rpx); }
  50%  { transform: translate(-2rpx, -8rpx); }
  75%  { transform: translate(4rpx, -3rpx); }
  100% { transform: translate(0, 0); }
}

/* === 第二层：主星图元素 === */

/* 轨道弧线（动态数据驱动） */
.nav-map-orbit {
  position: absolute;
  border: 1rpx solid rgba(0, 190, 255, 0.12);
  border-radius: 50%;
  animation: orbitBreathe var(--orbit-dur, 10s) ease-in-out infinite alternate;
  animation-delay: var(--orbit-delay, 0s);
}

@keyframes orbitBreathe {
  0%   { opacity: var(--orbit-opacity, 0.08); transform: rotate(var(--orbit-rot, 0deg)) scale(1); }
  100% { opacity: calc(var(--orbit-opacity, 0.08) + 0.04); transform: rotate(var(--orbit-rot, 0deg)) scale(1.03); }
}

/* 连接线 */
.nav-conn-line {
  position: absolute;
  background: linear-gradient(90deg, rgba(0, 200, 255, 0.15), rgba(0, 200, 255, 0.04));
  transform-origin: left center;
}

/* 随机航线 */
.nav-route-line {
  position: absolute;
  height: 2rpx;
  background: linear-gradient(
    90deg,
    rgba(0, 210, 255, 0.10),
    rgba(0, 210, 255, 0.32),
    rgba(88, 255, 160, 0.40)
  );
  transform-origin: left center;
}

/* 主航线 */
.nav-map-route {
  position: absolute;
  left: 150rpx;
  bottom: 118rpx;
  width: 390rpx;
  height: 2rpx;
  transform: rotate(-32deg);
  transform-origin: left center;
  background: linear-gradient(
    90deg,
    rgba(0, 210, 255, 0.16),
    rgba(0, 210, 255, 0.42),
    rgba(88, 255, 160, 0.58)
  );
  opacity: 0.28;
}

/* 光晕 */
.nav-glow {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 200, 255, 0.30), transparent 70%);
  filter: blur(20rpx);
}

/* 星点 */
.nav-star {
  position: absolute;
  border-radius: 50%;
  background: rgba(200, 230, 255, 0.9);
  box-shadow: 0 0 4rpx rgba(200, 230, 255, 0.4);
  animation: starTwinkle 3s ease-in-out infinite alternate;
  animation-delay: var(--flicker-delay, 0s);
}

@keyframes starTwinkle {
  0%   { opacity: 0.4; transform: scale(0.9); }
  100% { opacity: 1; transform: scale(1.1); }
}

/* 能量节点 */
.nav-energy-node {
  position: absolute;
  border-radius: 50%;
  background: rgba(0, 210, 255, 0.6);
  box-shadow:
    0 0 8rpx rgba(0, 210, 255, 0.4),
    0 0 20rpx rgba(0, 210, 255, 0.15);
  animation: nodePulse var(--pulse-dur, 4s) ease-in-out infinite;
  animation-delay: var(--pulse-delay, 0s);
}

@keyframes nodePulse {
  0%, 100% { opacity: 0.5; transform: scale(1); box-shadow: 0 0 8rpx rgba(0, 210, 255, 0.3); }
  50%      { opacity: 0.9; transform: scale(1.3); box-shadow: 0 0 16rpx rgba(0, 210, 255, 0.6); }
}

/* 扫描波纹 */
.nav-scan-wave {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  margin-left: -30rpx;
  margin-top: -30rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.12);
  border-radius: 50%;
  animation: scanWavePulse 3s ease-out infinite;
}

.nav-scan-wave::after {
  content: '';
  position: absolute;
  inset: -20rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.06);
  border-radius: 50%;
}

@keyframes scanWavePulse {
  0%   { transform: scale(0.8); opacity: 0.6; }
  100% { transform: scale(2); opacity: 0; }
}

/* 星体 */
.nav-planet {
  position: absolute;
  width: 38rpx;
  height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-planet-core {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(0, 210, 255, 0.9);
  box-shadow:
    0 0 16rpx rgba(0, 210, 255, 0.55),
    0 0 34rpx rgba(0, 150, 255, 0.22);
}

.nav-planet--origin {
  left: 128rpx;
  bottom: 96rpx;
}

.nav-planet--target {
  right: 128rpx;
  top: 96rpx;
}

.nav-planet--target .nav-planet-core {
  width: 16rpx;
  height: 16rpx;
  background: var(--target-color, rgba(88, 255, 160, 0.96));
  box-shadow:
    0 0 20rpx var(--target-color, rgba(88, 255, 160, 0.70)),
    0 0 46rpx rgba(88, 255, 160, 0.24);
}

.nav-planet-lock {
  position: absolute;
  inset: -6rpx;
  border: 1rpx solid var(--target-color, rgba(88, 255, 160, 0.35));
  border-radius: 50%;
  opacity: 0;
}

/* 中央星点 */
.nav-center-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 6rpx;
  height: 6rpx;
  margin: -3rpx 0 0 -3rpx;
  border-radius: 50%;
  background: rgba(70, 255, 145, 0.7);
  box-shadow: 0 0 10rpx rgba(70, 255, 145, 0.3);
}

/* === 第三层：HUD 氛围 === */

/* 坐标网格（极淡，边缘渐隐） */
.nav-hud-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0, 200, 255, 0.025) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 200, 255, 0.025) 1rpx, transparent 1rpx);
  background-size: 80rpx 80rpx;
  mask-image: radial-gradient(circle at 50% 50%, transparent 30%, rgba(0,0,0,0.5) 70%, transparent 95%);
  -webkit-mask-image: radial-gradient(circle at 50% 50%, transparent 30%, rgba(0,0,0,0.5) 70%, transparent 95%);
}

/* 边缘刻度线 */
.nav-hud-ticks {
  position: absolute;
  inset: 0;
  border-top: 1rpx solid transparent;
  border-bottom: 1rpx solid transparent;
  background:
    repeating-linear-gradient(90deg, rgba(0, 200, 255, 0.06) 0, rgba(0, 200, 255, 0.06) 1rpx, transparent 1rpx, transparent 40rpx) top left / 100% 8rpx no-repeat,
    repeating-linear-gradient(90deg, rgba(0, 200, 255, 0.06) 0, rgba(0, 200, 255, 0.06) 1rpx, transparent 1rpx, transparent 40rpx) bottom left / 100% 8rpx no-repeat,
    repeating-linear-gradient(0deg, rgba(0, 200, 255, 0.06) 0, rgba(0, 200, 255, 0.06) 1rpx, transparent 1rpx, transparent 40rpx) top left / 8rpx 100% no-repeat,
    repeating-linear-gradient(0deg, rgba(0, 200, 255, 0.06) 0, rgba(0, 200, 255, 0.06) 1rpx, transparent 1rpx, transparent 40rpx) top right / 8rpx 100% no-repeat;
}

/* 雷达扫描光圈 */
.nav-hud-radar {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  margin-left: -100rpx;
  margin-top: -100rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(0, 200, 255, 0.06);
  overflow: hidden;
}

.nav-hud-radar::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    transparent 0deg,
    rgba(0, 200, 255, 0.08) 30deg,
    transparent 60deg
  );
  animation: radarSweep 6s linear infinite;
}

.nav-hud-radar::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 4rpx;
  height: 4rpx;
  margin: -2rpx;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.25);
}

@keyframes radarSweep {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* 四角辉光 */
.nav-hud-edge-glow {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 0% 0%, rgba(0, 200, 255, 0.04), transparent 20%),
    radial-gradient(circle at 100% 0%, rgba(0, 200, 255, 0.03), transparent 18%),
    radial-gradient(circle at 0% 100%, rgba(0, 200, 255, 0.03), transparent 18%),
    radial-gradient(circle at 100% 100%, rgba(0, 200, 255, 0.04), transparent 20%);
}

/* ===== 舷窗状态驱动 ===== */

/* idle: 中等亮度 */
.nav-map-window--idle {
  opacity: 0.45;
  filter: saturate(0.5) brightness(0.75);
}

.nav-map-window--idle .nav-map-route {
  opacity: 0.18;
}

/* starting: 启动中，亮度提升 */
.nav-map-window--starting {
  opacity: 0.55;
  filter: saturate(0.7) brightness(0.95);
}

/* calibrating: 校准中，最亮 + 扫描效果 */
.nav-map-window--calibrating {
  opacity: 0.55;
  filter: saturate(0.7) brightness(0.9);
}

.nav-map-window--calibrating .nav-map-route {
  opacity: 0.66;
  animation: routeEnergy 1200ms ease-in-out infinite;
}

.nav-map-window--calibrating .nav-planet-lock {
  opacity: 1;
  animation: targetLockPulse 1500ms ease-in-out infinite;
}

/* calibrating 态扫描横掠 */
.nav-map-window--calibrating::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  height: 40%;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(0, 200, 255, 0.06) 40%,
    rgba(0, 200, 255, 0.10) 50%,
    rgba(0, 200, 255, 0.06) 60%,
    transparent 100%
  );
  animation: mapScanSweep 2.2s ease-in-out infinite;
  pointer-events: none;
  z-index: 5;
}

/* calibrating 态星点逐个点亮 */
.nav-map-window--calibrating .nav-star {
  animation: starSearchLight 600ms ease-out forwards;
}

@keyframes starSearchLight {
  0%   { opacity: 0.08; transform: scale(0.5); }
  60%  { opacity: 1; transform: scale(1.3); }
  100% { opacity: var(--star-opacity, 0.6); transform: scale(1); }
}

/* calibrating 态轨道流动 */
.nav-map-window--calibrating .nav-map-orbit {
  animation: orbitFlow 8s linear infinite;
}

@keyframes orbitFlow {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

@keyframes mapScanSweep {
  0%   { top: -40%; }
  100% { top: 100%; }
}

@keyframes routeEnergy {
  0%, 100% { opacity: 0.50; }
  50%      { opacity: 0.78; }
}

/* completing + completed: 降低亮度保证文字清晰 */
.nav-map-window--completing,
.nav-map-window--completed {
  opacity: 0.32;
  filter: saturate(0.8) brightness(1);
}

.nav-map-window--completing .nav-map-route,
.nav-map-window--completed .nav-map-route {
  opacity: 0.78;
}

.nav-map-window--completing .nav-planet-lock,
.nav-map-window--completed .nav-planet-lock {
  opacity: 0.86;
}

/* completing 态：星图短暂提亮后回落 */
.nav-map-window--completing {
  animation: completingFlash 700ms ease-out forwards;
}

/* 完成态：TARGET 星体锁定脉冲 */
.nav-map-window--completed .nav-planet-lock {
  animation: resultLockPulse 2s ease-in-out infinite;
}

/* 完成态：中心光波扩散 */
.nav-map-window--completed::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 100rpx;
  height: 100rpx;
  margin: -50rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 200, 255, 0.20), transparent 70%);
  animation: resultRevealWave 1.2s ease-out forwards;
  pointer-events: none;
  z-index: 5;
}

@keyframes resultRevealWave {
  0%   { transform: scale(0); opacity: 0.6; }
  100% { transform: scale(12); opacity: 0; }
}

@keyframes resultLockPulse {
  0%, 100% { opacity: 0.60; transform: scale(1); }
  50%      { opacity: 1; transform: scale(1.18); }
}

@keyframes targetLockPulse {
  0%, 100% { opacity: 0.45; transform: scale(0.92); }
  50%      { opacity: 1; transform: scale(1.08); }
}

/* reduce-motion: 舷窗静态化 */
.reduce-motion .nav-planet-lock,
.reduce-motion .nav-map-route,
.reduce-motion .nav-star,
.reduce-motion .nav-energy-node,
.reduce-motion .nav-scan-wave,
.reduce-motion .nav-dust,
.reduce-motion .nav-map-orbit,
.reduce-motion .nav-hud-radar::before {
  animation: none !important;
}
.reduce-motion .nav-map-window--calibrating::after,
.reduce-motion .nav-map-window--completed::before {
  animation: none !important;
  display: none;
}

/* ===== 中央星核 ===== */
.star-core {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.star-core-glow {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 200, 255, 0.08), transparent 70%);
  animation: coreGlowPulse 4s ease-in-out infinite;
}

.star-core-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(0, 200, 255, 0.10);
}

.star-core-ring--1 {
  width: 80rpx;
  height: 80rpx;
  animation: coreRingPulse 3s ease-in-out infinite;
}

.star-core-ring--2 {
  width: 140rpx;
  height: 140rpx;
  opacity: 0.5;
  animation: coreRingPulse 3s ease-in-out infinite;
  animation-delay: 0.5s;
}

.star-core-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: rgba(0, 210, 255, 0.85);
  box-shadow:
    0 0 16rpx rgba(0, 210, 255, 0.50),
    0 0 40rpx rgba(0, 150, 255, 0.20);
  animation: coreDotPulse 3s ease-in-out infinite;
  z-index: 2;
}

.star-core-scan {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 200, 255, 0.30);
  animation: coreScanWave 2s ease-out infinite;
}

@keyframes coreGlowPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50%      { transform: scale(1.15); opacity: 1; }
}

@keyframes coreRingPulse {
  0%, 100% { transform: scale(1); opacity: 0.4; }
  50%      { transform: scale(1.08); opacity: 0.7; }
}

@keyframes coreDotPulse {
  0%, 100% { transform: scale(1); box-shadow: 0 0 16rpx rgba(0, 210, 255, 0.4); }
  50%      { transform: scale(1.15); box-shadow: 0 0 28rpx rgba(0, 210, 255, 0.7); }
}

@keyframes coreScanWave {
  0%   { transform: scale(0.5); opacity: 0.7; }
  100% { transform: scale(4); opacity: 0; }
}

/* starting 态：星核激活 */
.star-core--starting .star-core-dot {
  animation: startingCoreBrighten 600ms ease-out forwards;
}

.star-core--starting .star-core-glow {
  animation: igniteGlowExpand 1.8s ease-in-out forwards;
}

.star-core--starting .star-core-ring {
  animation: coreRingSpin 1.2s linear infinite;
}

@keyframes startingCoreBrighten {
  0%   { width: 20rpx; height: 20rpx; box-shadow: 0 0 16rpx rgba(0, 210, 255, 0.4); }
  100% { width: 30rpx; height: 30rpx; box-shadow: 0 0 50rpx rgba(0, 210, 255, 0.8); }
}

@keyframes igniteDotExpand {
  0%   { width: 20rpx; height: 20rpx; box-shadow: 0 0 16rpx rgba(0, 210, 255, 0.4); }
  50%  { width: 36rpx; height: 36rpx; box-shadow: 0 0 50rpx rgba(0, 210, 255, 0.8); }
  100% { width: 28rpx; height: 28rpx; box-shadow: 0 0 60rpx rgba(0, 210, 255, 0.5); }
}

@keyframes igniteGlowExpand {
  0%   { width: 120rpx; height: 120rpx; opacity: 0.6; }
  100% { width: 200rpx; height: 200rpx; opacity: 0.8; }
}

@keyframes coreRingSpin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ===== 启动按钮 ===== */
.nav-launch-btn-area {
  display: flex;
  justify-content: center;
  margin-top: 36rpx;
}

.nav-launch-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 400rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: rgba(4, 18, 30, 0.50);
  border: 1rpx solid rgba(0, 190, 255, 0.24);
  box-shadow: 0 0 20rpx rgba(0, 170, 255, 0.06), inset 0 1rpx 0 rgba(255, 255, 255, 0.03);
  color: rgba(230, 246, 255, 0.88);
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  transition: all 200ms ease;
}

.nav-launch-btn:active {
  transform: scale(0.98);
  background: rgba(4, 18, 30, 0.65);
  border-color: rgba(0, 190, 255, 0.36);
  box-shadow: 0 0 28rpx rgba(0, 170, 255, 0.12);
}

/* ===== 状态指示线 ===== */
.nav-status-line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.nav-status-indicator {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(160, 210, 235, 0.3);
  box-shadow: 0 0 6rpx rgba(0, 190, 255, 0.2);
}

.nav-status-indicator--starting {
  background: rgba(0, 200, 255, 0.7);
  animation: statusPulse 2s ease-in-out infinite;
}

.nav-status-indicator--online {
  background: rgba(50, 215, 75, 0.7);
}

.nav-status-indicator--idle {
  background: rgba(160, 210, 235, 0.3);
}

.nav-status-text {
  font-size: 22rpx;
  color: rgba(160, 210, 235, 0.45);
  letter-spacing: 3rpx;
  font-family: 'Courier New', monospace;
}

/* 导航栏状态点 --starting（页面级覆盖） */
.css-status-dot--starting {
  background: rgba(0, 200, 255, 0.65);
  box-shadow: 0 0 8rpx rgba(0, 200, 255, 0.3);
  animation: statusPulse 2s ease-in-out infinite;
}

/* ===== 星核卫星点 ===== */
.star-core-satellite {
  position: absolute;
  left: calc(50% + var(--sat-x));
  top: calc(50% + var(--sat-y));
  width: var(--sat-size);
  height: var(--sat-size);
  border-radius: 50%;
  background: rgba(180, 220, 255, var(--sat-opacity));
  box-shadow: 0 0 6rpx rgba(100, 200, 255, 0.3);
  animation: satelliteTwinkle 3s ease-in-out infinite alternate;
  animation-delay: calc(var(--sat-delay) * 1s);
}

@keyframes satelliteTwinkle {
  0%   { opacity: var(--sat-opacity); transform: scale(1); }
  100% { opacity: calc(var(--sat-opacity) * 0.4); transform: scale(0.7); }
}

/* ===== 校准阶段文案 ===== */
.calibration-phase-text {
  text-align: center;
  margin-top: 32rpx;
  animation: fadeIn 0.4s ease-out both;
}

.calibration-phase-text text {
  font-size: 24rpx;
  color: rgba(0, 200, 255, 0.55);
  letter-spacing: 3rpx;
  font-family: 'Courier New', monospace;
}

/* calibrating 态：星核持续扫描 */
.star-core--calibrating .star-core-dot {
  width: 24rpx;
  height: 24rpx;
  box-shadow: 0 0 30rpx rgba(0, 210, 255, 0.6);
}

.star-core--calibrating .star-core-ring {
  animation: coreRingSpin 3s linear infinite;
  border-color: rgba(0, 200, 255, 0.18);
}

/* reduce-motion */
.reduce-motion .star-core-dot,
.reduce-motion .star-core-glow,
.reduce-motion .star-core-ring,
.reduce-motion .star-core-scan {
  animation: none !important;
}

/* ===== idle 态状态文案 ===== */
.idle-status-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
  animation: fadeIn 0.8s ease-out 0.5s both;
}

.idle-hint-main {
  font-size: 28rpx;
  color: rgba(200, 230, 250, 0.55);
  letter-spacing: 4rpx;
  font-family: "Courier New", Courier, monospace;
}

.idle-hint-sub {
  font-size: 22rpx;
  color: rgba(160, 210, 235, 0.32);
  letter-spacing: 2rpx;
  font-family: "Courier New", Courier, monospace;
}


/* ===== 0. 跨 Tab 骨架屏 ===== */
.page-skeleton {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: #0a0a0a;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.page-skeleton-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #00c8ff;
  box-shadow: 0 0 16rpx rgba(0, 200, 255, 0.45);
}

.page-skeleton-text {
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

/* ===== 2. reduce-motion 静默模式 ===== */
.reduce-motion .deck-line,
.reduce-motion .flight-heartbeat-dot,
.reduce-motion .flight-log-line,
.reduce-motion .flight-log-typing,
.reduce-motion .flight-log-dot,
.reduce-motion .strategy-insight,
.reduce-motion .strategy-section,
.reduce-motion .strategy-actions,
.reduce-motion .poster-gen-dot,
.reduce-motion .projection-card {
  animation: none !important;
  transition-duration: 0ms !important;
  opacity: 1 !important;
}

.reduce-motion .flight-heartbeat-dot {
  opacity: 0.6;
}

.reduce-motion .flight-deck--calibrating {
  transition-duration: 0ms !important;
}

/* reduce-motion: 结果直接可见 */
.reduce-motion .directive-projection.dp-visible {
  opacity: 1;
  transform: none;
}
.reduce-motion .directive-projection .projection-card {
  opacity: 1;
  transform: none;
  animation: none !important;
}

/* ===== 3. 可见性工具类 ===== */
.fdh-visible {
  opacity: 1;
  pointer-events: auto;
}
.fdh-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}
.fdi-visible {
  opacity: 1;
  pointer-events: auto;
}
.fdi-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}
.dhb-visible {
  opacity: 1;
  pointer-events: auto;
}
.dhb-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}

/* ===== 4. 飞控核心通用元素 ===== */
.core-inner {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.core-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.core-ring--1 {
  width: 200rpx;
  height: 200rpx;
  border-color: rgba(10, 132, 255, 0.12);
}

.core-ring--2 {
  width: 130rpx;
  height: 130rpx;
  border-color: rgba(10, 132, 255, 0.08);
}

.core-ring--3 {
  width: 60rpx;
  height: 60rpx;
  border-color: rgba(10, 132, 255, 0.06);
}

/* 能量辉光 */
.core-glow {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(10, 132, 255, 0.25),
    transparent 70%
  );
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: coreGlowPulse 3s ease-in-out infinite;
  z-index: 1;
}

/* (coreGlowPulse defined above in star-core section) */

/* 能量点 */
.core-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(10, 132, 255, 0.6);
  box-shadow: 0 0 12rpx rgba(10, 132, 255, 0.4);
  position: relative;
  z-index: 2;
  animation: coreDotPulse 2s ease-in-out infinite;
}

/* (coreDotPulse defined above in star-core section) */

/* ===== 5. 扫描环 ===== */
.scan-ring {
  position: absolute;
  width: 340rpx;
  height: 340rpx;
  border-radius: 50%;
  border: 1px solid rgba(0, 175, 255, 0.18);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
  box-shadow: 0 0 12rpx rgba(0, 175, 255, 0.06);
}

.scan-ring::after {
  content: "";
  position: absolute;
  inset: -2rpx;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    transparent 0deg,
    transparent 300deg,
    rgba(10, 132, 255, 0.3) 340deg,
    transparent 360deg
  );
  mask: radial-gradient(transparent 48%, black 49%, black 51%, transparent 52%);
  -webkit-mask: radial-gradient(
    transparent 48%,
    black 49%,
    black 51%,
    transparent 52%
  );
}

.scan-ring--idle {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--idle::after {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--gen {
  animation: scanRotate 6s linear infinite;
}

.scan-ring--gen::after {
  animation: scanRotate 6s linear infinite;
}

@keyframes scanRotate {
  from {
    transform: translate(-50%, -50%) rotate(0deg);
  }
  to {
    transform: translate(-50%, -50%) rotate(360deg);
  }
}

/* ===== 6. 甲板透视线 ===== */
.deck-perspective {
  position: absolute;
  bottom: 130rpx;
  left: 0;
  right: 0;
  height: 300rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.deck-line {
  position: absolute;
  bottom: 0;
  height: 200rpx;
  width: 1rpx;
  background: linear-gradient(to top, rgba(10, 132, 255, 0.08), transparent);
  transform-origin: bottom center;
  transition: opacity 0.8s ease;
}

.deck-line--1 {
  left: 8%;
  transform: perspective(300rpx) rotateX(50deg) rotate(-16deg);
}
.deck-line--2 {
  left: 25%;
  transform: perspective(300rpx) rotateX(50deg) rotate(-8deg);
}
.deck-line--3 {
  left: 50%;
  transform: perspective(300rpx) rotateX(50deg) rotate(0deg);
  background: linear-gradient(to top, rgba(10, 132, 255, 0.14), transparent);
}
.deck-line--4 {
  left: 75%;
  transform: perspective(300rpx) rotateX(50deg) rotate(8deg);
}
.deck-line--5 {
  left: 92%;
  transform: perspective(300rpx) rotateX(50deg) rotate(16deg);
}


/* ===== 7. 暗色渐变遮罩层 ===== */
.page-dark-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background:
    radial-gradient(circle at 50% 20%, rgba(0, 190, 255, 0.10), transparent 42%),
    linear-gradient(to bottom,
      rgba(0, 8, 12, 0.15) 0%,
      rgba(0, 4, 8, 0.40) 40%,
      rgba(0, 4, 8, 0.75) 100%
    );
  z-index: 0;
  pointer-events: none;
}

/* ===== 8. 飞行甲板统一舞台 ===== */
.flight-deck {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 320rpx 40rpx 80rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  transition: padding-top 500ms cubic-bezier(0.22, 1, 0.36, 1);
}

.flight-deck--idle,
.flight-deck--starting {
  padding-top: 360rpx;
}

.flight-deck--calibrating {
  padding-top: 280rpx;
}

.flight-deck--completing {
  padding-top: 180rpx;
}

.flight-deck--completed {
  padding-top: 140rpx;
}

.flight-deck--regenerating {
  padding-top: 360rpx;
}

.flight-deck > .bay-status-tab {
  position: absolute;
  top: 24rpx;
  left: 28rpx;
  margin-bottom: 0;
}

/* --- 顶部标题 --- */
.flight-deck-header {
  text-align: center;
  margin-bottom: 48rpx;
  transition:
    opacity 0.4s ease,
    height 0.4s ease,
    margin 0.4s ease;
}

.fdh-visible {
  opacity: 1;
  animation: fadeInDown 0.8s ease forwards;
}

.flight-deck-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 6rpx;
}

.flight-deck-date {
  display: block;
  font-family: "Courier New", Courier, monospace;
  font-size: 18rpx;
  color: rgba(126, 156, 180, 0.12);
  margin-top: 4rpx;
}



/* ===== 10. 底部说明 ===== */
.flight-deck-info {
  text-align: center;
  margin-bottom: 24rpx;
  transition:
    opacity 0.4s ease,
    height 0.4s ease;
}

.fdi-visible {
  opacity: 0;
  animation: fadeIn 0.6s ease 0.9s forwards;
}

/* entered 态：跳过入场动画延迟（重新点火用） */
.fdi-entered {
  animation: none !important;
  opacity: 1 !important;
}

.flight-deck-info-text {
  display: block;
  font-family: "Courier New", Courier, monospace;
  font-size: 22rpx;
  color: rgba(126, 156, 180, 0.38);
  letter-spacing: 3rpx;
  line-height: 1.8;
}

/* ===== 待机页下方舱体刻度（pseudo 增强） ===== */
.flight-deck-info::after {
  content: '';
  display: flex;
  gap: 6rpx;
  margin-top: 28rpx;
  justify-content: center;
  height: 2rpx;
  width: 280rpx;
  margin-left: auto;
  margin-right: auto;
  background:
    repeating-linear-gradient(
      90deg,
      rgba(0, 180, 255, 0.14) 0,
      rgba(0, 180, 255, 0.14) 8rpx,
      transparent 8rpx,
      transparent 20rpx
    );
  opacity: 0.65;
}

.fdi-hidden::after {
  display: none;
}


/* ===== 12. 飞行阶段联动动画 ===== */

/* completed: 核心淡出退到背景 */
.strategy-page--completed .nav-core-stage,
.flight-deck--completed .nav-core-stage {
  opacity: 0.02 !important;
  animation: none !important;
  transform: translateY(-72rpx) scale(0.56) !important;
  pointer-events: none !important;
  min-height: 0 !important;
  max-height: 40rpx !important;
  margin-bottom: -20rpx !important;
  transition:
    opacity 720ms ease,
    transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
    margin-bottom 720ms ease;
  z-index: 0 !important;
}


/* entered 态：跳过入场动画，立即可见（重新点火用） */
.nav-core-stage--entered {
  animation: none !important;
  opacity: 1 !important;
  transform: none !important;
}

/* compact 态：done 阶段核心进一步收缩（优先级高于 entered） */
.nav-core-stage--compact {
  opacity: 0.02 !important;
  animation: none !important;
  transform: translateY(-72rpx) scale(0.56) !important;
  pointer-events: none !important;
  min-height: 0 !important;
  max-height: 40rpx !important;
  margin-bottom: -20rpx !important;
  transition:
    opacity 720ms ease,
    transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
    margin-bottom 720ms ease;
}

.flight-deck--completed .nav-core-rings {
  opacity: 0;
}

.flight-deck--completed .deck-perspective {
  opacity: 0;
  transition: opacity 0.4s ease;
}


/* ===== 14. heartbeat ===== */
.flight-heartbeat {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.heartbeat-visible {
  opacity: 1;
}

.flight-heartbeat-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(0, 175, 255, 0.5);
  animation: heartbeatDot 1.2s ease-in-out infinite;
}

@keyframes heartbeatDot {
  0%,
  100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.flight-heartbeat-text {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(0, 175, 255, 0.5);
  letter-spacing: 2rpx;
}

/* ##### 飞船导航系统 HUD 重构 - 终极版 (修复版) ##### */

.directive-projection {
  width: 100%;
  max-width: 680rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 40rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  opacity: 0;
  transform: translateY(8rpx);
  transition:
    opacity 300ms ease,
    transform 340ms cubic-bezier(0.22, 1, 0.36, 1);
  pointer-events: none;
  flex-shrink: 0;
  position: relative;
  /* 增加背景动态数据流 */
  background-image:
    radial-gradient(
      circle at 50% 50%,
      rgba(0, 200, 255, 0.04) 0%,
      transparent 80%
    ),
    linear-gradient(rgba(0, 200, 255, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 200, 255, 0.05) 1px, transparent 1px);
  background-size:
    100% 100%,
    60rpx 60rpx,
    60rpx 60rpx;
  animation: bgDataStream 40s linear infinite;
  z-index: 10;
}

.strategy-page--completed .directive-projection {
  margin-top: -28rpx;
}

.dp-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.projection-card {
  opacity: 0;
  transform: translateY(6rpx);
}

.dp-visible .projection-card {
  animation: projectionCardIn 260ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.dp-visible .projection-card:nth-child(1) { animation-delay: 20ms; }
.dp-visible .projection-card:nth-child(2) { animation-delay: 45ms; }
.dp-visible .projection-card:nth-child(3) { animation-delay: 70ms; }
.dp-visible .projection-card:nth-child(n+4) { animation-delay: 90ms; }

@keyframes projectionCardIn {
  from {
    opacity: 0;
    transform: translateY(6rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes bgDataStream {
  from {
    background-position:
      center,
      0 0,
      0 0;
  }
  to {
    background-position:
      center,
      0 600rpx,
      600rpx 0;
  }
}

.directive-projection::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      rgba(18, 16, 16, 0) 0,
      rgba(18, 16, 16, 0) 2rpx,
      rgba(0, 0, 0, 0.15) 2rpx,
      rgba(0, 0, 0, 0.15) 4rpx
    ),
    linear-gradient(
      90deg,
      rgba(255, 0, 0, 0.04),
      rgba(0, 255, 0, 0.02),
      rgba(0, 0, 255, 0.04)
    );
  pointer-events: none;
  z-index: 100;
  opacity: 0.18;
}

.nav-telemetry-points {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.tele-point {
  position: absolute;
  font-family: "Courier New", Courier, monospace;
  font-size: 12rpx;
  color: rgba(0, 200, 255, 0.2);
  letter-spacing: 1rpx;
}
.tele-point.p1 {
  top: 20rpx;
  left: 20rpx;
}
.tele-point.p2 {
  top: 20rpx;
  right: 20rpx;
}
.tele-point.p3 {
  bottom: 180rpx;
  left: 20rpx;
}
.tele-point.p4 {
  bottom: 180rpx;
  right: 20rpx;
}

.nav-hud-deco {
  width: 100%;
  max-width: 640rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
  position: relative;
  padding: 0 10rpx;
  height: 64rpx;
  z-index: 5;
}

.nav-deco-left,
.nav-deco-right {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* ##### HUD 数据面板 ##### */

/* 玻璃 HUD 面板 */
.result-panel {
  width: 640rpx;
  border-radius: 20rpx;
  background: rgba(3, 20, 28, 0.52);
  border: 1rpx solid rgba(0, 190, 255, 0.12);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  padding: 28rpx 32rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 角标装饰 */
.result-panel::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 28rpx;
  height: 28rpx;
  border-top: 2rpx solid rgba(0, 200, 255, 0.25);
  border-left: 2rpx solid rgba(0, 200, 255, 0.25);
  border-top-left-radius: 20rpx;
}

.result-panel::after {
  content: '';
  position: absolute;
  bottom: 0;
  right: 0;
  width: 28rpx;
  height: 28rpx;
  border-bottom: 2rpx solid rgba(0, 200, 255, 0.18);
  border-right: 2rpx solid rgba(0, 200, 255, 0.18);
  border-bottom-right-radius: 20rpx;
}

/* 状态胶囊 */
.rp-status-capsule {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(10, 80, 50, 0.35);
  border: 1rpx solid rgba(80, 255, 170, 0.18);
  margin-bottom: 20rpx;
}

.rp-status-capsule text {
  font-size: 20rpx;
  color: rgba(80, 255, 170, 0.80);
  letter-spacing: 2rpx;
}

.rp-capsule-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(80, 255, 170, 0.80);
  box-shadow: 0 0 6rpx rgba(80, 255, 170, 0.4);
}

/* 主标题 */
.rp-verdict {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(230, 246, 255, 0.92);
  line-height: 1.5;
  text-align: center;
  margin-bottom: 16rpx;
}

/* 副标签 */
.rp-tags {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.rp-tag-pill {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(0, 190, 255, 0.08);
  border: 1rpx solid rgba(0, 190, 255, 0.15);
  font-size: 20rpx;
  color: rgba(0, 200, 255, 0.58);
  letter-spacing: 2rpx;
}

/* 细分割线 */
.rp-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 190, 255, 0.14), transparent);
  margin: 20rpx 0;
}

/* 参数区 */
.rp-params {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rp-param-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rp-param-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: rgba(160, 210, 235, 0.48);
  letter-spacing: 3rpx;
}

.rp-param-dot {
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
}

.rp-param-dot--buff {
  background: rgba(80, 255, 170, 0.6);
  box-shadow: 0 0 4rpx rgba(80, 255, 170, 0.3);
}

.rp-param-dot--debuff {
  background: rgba(255, 160, 60, 0.6);
  box-shadow: 0 0 4rpx rgba(255, 160, 60, 0.3);
}

.rp-param-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.rp-param-card {
  flex: 1 1 calc(50% - 6rpx);
  min-width: 0;
  background: rgba(0, 20, 30, 0.35);
  border: 1rpx solid rgba(0, 190, 255, 0.06);
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.rp-param-card text {
  font-size: 24rpx;
  color: rgba(220, 240, 255, 0.78);
  line-height: 1.4;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rp-param-indicator {
  width: 4rpx;
  height: 20rpx;
  border-radius: 2rpx;
  background: rgba(80, 255, 170, 0.5);
  flex-shrink: 0;
}

.rp-param-indicator--warn {
  background: rgba(255, 160, 60, 0.5);
}

/* 底部稳定度进度线 */
.rp-stability-bar {
  height: 3rpx;
  background: rgba(0, 190, 255, 0.08);
  border-radius: 1.5rpx;
  margin-top: 24rpx;
  overflow: visible;
  position: relative;
}

.rp-stability-fill {
  height: 100%;
  background: linear-gradient(90deg, rgba(0, 200, 255, 0.40), rgba(80, 255, 170, 0.50));
  border-radius: 1.5rpx;
  transition: width 800ms cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
}

.rp-stability-fill::after {
  content: '';
  position: absolute;
  right: -3rpx;
  top: -2rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: rgba(80, 255, 170, 0.9);
  box-shadow: 0 0 10rpx rgba(80, 255, 170, 0.5);
}

.rp-stability-label {
  text-align: right;
  margin-top: 8rpx;
}

.rp-stability-label text {
  font-size: 18rpx;
  color: rgba(160, 210, 235, 0.35);
  letter-spacing: 2rpx;
  font-family: 'Courier New', monospace;
}

/* 操作按钮区 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
  width: 100%;
  margin-top: 24rpx;
}

.result-primary-btn {
  width: 520rpx;
  height: 100rpx;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.10), transparent 60%),
    rgba(4, 18, 30, 0.50);
  border: 1rpx solid rgba(0, 190, 255, 0.28);
  box-shadow:
    0 0 20rpx rgba(0, 170, 255, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(230, 246, 255, 0.92);
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  transition: transform 180ms ease, box-shadow 300ms ease;
  animation: btnGlowPulse 3s ease-in-out infinite;
}

.result-primary-btn:active {
  transform: translateY(2rpx) scale(0.99);
  box-shadow: 0 0 10rpx rgba(0, 170, 255, 0.15);
}

@keyframes btnGlowPulse {
  0%, 100% { box-shadow: 0 0 20rpx rgba(0, 170, 255, 0.08); }
  50%      { box-shadow: 0 0 30rpx rgba(0, 170, 255, 0.16); }
}

.result-secondary-link {
  width: 380rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(4, 18, 30, 0.30);
  border: 1rpx solid rgba(0, 190, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: rgba(160, 210, 235, 0.48);
  letter-spacing: 2rpx;
  transition: transform 180ms ease, color 200ms ease;
}

.result-secondary-link:active {
  transform: translateY(2rpx) scale(0.99);
  color: rgba(160, 210, 235, 0.72);
}

.result-secondary-link--loading {
  opacity: 0.6;
  pointer-events: none;
}

.result-secondary-link--loading::after {
  content: '';
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.5);
  margin-left: 8rpx;
  animation: btnPulse 1s ease-in-out infinite;
}

@keyframes btnPulse {
  0%, 100% { opacity: 0.3; }
  50%      { opacity: 1; }
}

.strategy-result-spacer {
  flex: 1;
  min-height: 40rpx;
}

/* ===== 全局禁止圆形 spinner ===== */
.strategy-page .loading-spinner,
.strategy-page .spinner,
.strategy-page .circle-loading {
  display: none !important;
}

/* ===== 15. reduce-motion 强制兜底 ===== */
.reduce-motion .directive-projection,
.reduce-motion .projection-card {
  animation: none !important;
  transition: none !important;
  filter: none !important;
}

.reduce-motion .directive-projection,
.reduce-motion .directive-projection.dp-visible,
.reduce-motion .projection-card {
  opacity: 1 !important;
  transform: none !important;
}

/* ===== 海报弹层（CSS 控制显隐，始终挂载） ===== */
.poster-mask {
  position: fixed;
  inset: 0;
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  background: rgba(0, 0, 0, 0);
  backdrop-filter: blur(0px);
  -webkit-backdrop-filter: blur(0px);
  transition: background 350ms ease,
              backdrop-filter 350ms ease,
              -webkit-backdrop-filter 350ms ease;
}

.poster-mask--visible {
  pointer-events: auto;
  background: rgba(0, 0, 0, 0.50);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.poster-mask--hidden {
  pointer-events: none;
  background: rgba(0, 0, 0, 0);
  backdrop-filter: blur(0px);
  -webkit-backdrop-filter: blur(0px);
}

.poster-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  width: 600rpx;
  max-height: 85vh;
  opacity: 0;
  transform: scale(0.96) translateY(16rpx);
  transition: opacity 350ms cubic-bezier(0.22, 1, 0.36, 1),
              transform 400ms cubic-bezier(0.22, 1, 0.36, 1);
}

.poster-mask--visible .poster-container {
  opacity: 1;
  transform: scale(1) translateY(0);
}

/* 生成中 */
.poster-gen {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.poster-gen-dots {
  display: flex;
  gap: 16rpx;
}

.poster-gen-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.6);
  animation: posterDotPulse 1.2s ease-in-out infinite;
}
.poster-gen-dot:nth-child(2) { animation-delay: 0.2s; }
.poster-gen-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes posterDotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

.poster-gen-text {
  font-size: 24rpx;
  color: rgba(180, 215, 235, 0.52);
  letter-spacing: 2rpx;
  animation: posterTextBreath 2s ease-in-out infinite;
}

@keyframes posterTextBreath {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 0.9; }
}

/* 预览 */
.poster-preview {
  width: 600rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.poster-image {
  width: 100%;
  display: block;
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 190, 255, 0.18);
}

/* 错误 */
.poster-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.poster-error-text {
  font-size: 26rpx;
  color: rgba(255, 160, 60, 0.82);
}

.poster-error-actions {
  display: flex;
  gap: 24rpx;
}

.poster-error-btn {
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  color: rgba(180, 215, 235, 0.68);
  border: 1rpx solid rgba(0, 190, 255, 0.18);
  border-radius: 8rpx;
}

/* 操作按钮 */
.poster-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.poster-actions--three {
  justify-content: center;
}

.poster-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(220, 240, 255, 0.88);
  background: rgba(8, 24, 38, 0.82);
  border: 1rpx solid rgba(0, 190, 255, 0.18);
  border-radius: 12rpx;
  letter-spacing: 2rpx;
}

.poster-btn--save {
  background: rgba(0, 175, 255, 0.12);
  border-color: rgba(0, 190, 255, 0.28);
}

.poster-btn--share {
  margin: 0;
  padding: 0;
  line-height: normal;
}
.poster-btn--share::after { border: none; }

.poster-btn--close {
  color: rgba(160, 210, 235, 0.52);
  border-color: rgba(160, 210, 235, 0.14);
}

/* Canvas 离屏 */
.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}

.reduce-motion .poster-gen-dot {
  animation: none !important;
  opacity: 0.6;
}

.reduce-motion .poster-gen-text {
  animation: none !important;
  opacity: 0.7;
}

/* ===== 通用 fadeIn / fadeInDown ===== */
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ===== 星图色相偏移 ===== */
.nav-map-window--tint-cyan .nav-star       { /* 默认青蓝，无需偏移 */ }
.nav-map-window--tint-blue-green .nav-star  { filter: hue-rotate(15deg); }
.nav-map-window--tint-blue .nav-star        { filter: hue-rotate(-15deg); }
.nav-map-window--tint-teal .nav-star        { filter: hue-rotate(30deg); }

/* ===== 底部导航渐变遮罩 ===== */
.flight-deck {
  position: relative;
}

.flight-deck::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(to bottom, transparent, rgba(2, 8, 14, 0.6));
  pointer-events: none;
  z-index: 0;
}

/* ===== 新增动画 reduce-motion 覆盖 ===== */
.reduce-motion .star-core-satellite,
.reduce-motion .calibration-phase-text {
  animation: none !important;
}

/* ===== 星图 crossfade ===== */
.nav-map-window--crossfade-out {
  animation: crossfadeOut 800ms ease-out forwards;
}

.nav-map-window--crossfade-in {
  /* crossfade-in 只在 seed 变化时触发，默认状态保持正常 */
}

@keyframes crossfadeOut {
  0%   { opacity: 0.45; }
  100% { opacity: 0; }
}

@keyframes crossfadeIn {
  0%   { opacity: 0; }
  100% { opacity: 0.45; }
}

/* ===== completing 转场动画 ===== */
@keyframes completingFlash {
  0%   { opacity: 0.55; filter: saturate(0.7) brightness(0.9); }
  30%  { opacity: 0.65; filter: saturate(0.8) brightness(1.1); }
  100% { opacity: 0.32; filter: saturate(0.8) brightness(1); }
}

/* completing 星核聚光脉冲 */
.star-core--completing .star-core-dot {
  animation: completingCorePulse 700ms ease-out forwards;
}

@keyframes completingCorePulse {
  0%   { width: 24rpx; box-shadow: 0 0 30rpx rgba(0, 210, 255, 0.6); }
  40%  { width: 40rpx; box-shadow: 0 0 80rpx rgba(0, 210, 255, 1); }
  100% { width: 16rpx; box-shadow: 0 0 12rpx rgba(0, 210, 255, 0.3); }
}

/* completing 光波扩散（从星核） */
.nav-map-window--completing::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 40%;
  width: 40rpx;
  height: 40rpx;
  margin: -20rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 210, 255, 0.5), transparent 70%);
  animation: completionWave 700ms ease-out forwards;
  pointer-events: none;
  z-index: 5;
}

@keyframes completionWave {
  0%   { transform: scale(0); opacity: 0.7; }
  100% { transform: scale(18); opacity: 0; }
}

/* completing 连接线闪烁 */
.nav-map-window--completing .nav-conn-line {
  animation: connFlash 300ms ease-out;
}

@keyframes connFlash {
  0%   { opacity: 0.5; }
  100% { opacity: var(--conn-opacity, 0.08); }
}

/* ===== regenerating 星核重构脉冲 ===== */
.star-core--regenerating .star-core-dot {
  animation: regenerateCorePulse 800ms ease-out forwards;
}

@keyframes regenerateCorePulse {
  0%   { width: 8rpx; opacity: 0.3; box-shadow: 0 0 4rpx rgba(0, 210, 255, 0.2); }
  50%  { width: 36rpx; opacity: 1; box-shadow: 0 0 60rpx rgba(0, 210, 255, 0.9); }
  100% { width: 20rpx; opacity: 1; box-shadow: 0 0 16rpx rgba(0, 210, 255, 0.4); }
}

/* ===== starting 按钮淡出 ===== */
.flight-deck--starting .nav-launch-btn-area {
  animation: btnFadeOut 400ms ease-out forwards;
}

@keyframes btnFadeOut {
  to { opacity: 0; transform: translateY(12rpx); }
}

/* ===== reduce-motion: 转场动画禁用 ===== */
.reduce-motion .nav-map-window--completing,
.reduce-motion .nav-map-window--completing::before,
.reduce-motion .nav-map-window--crossfade-out,
.reduce-motion .star-core--completing .star-core-dot,
.reduce-motion .star-core--regenerating .star-core-dot,
.reduce-motion .flight-deck--starting .nav-launch-btn-area {
  animation: none !important;
}

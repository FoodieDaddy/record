/* ===== 全局容器 ===== */
.page-container {
  height: 100vh;
  background: #0A0A0A;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* reduce-motion 静默模式（WXSS 不支持 * 通配符，显式列出动画类） */
.reduce-motion .tactical-card,
.reduce-motion .draw-header,
.reduce-motion .draw-prompt,
.reduce-motion .calc-screen,
.reduce-motion .calc-card--spinning,
.reduce-motion .calc-glow-ring,
.reduce-motion .calc-pulse-ring,
.reduce-motion .log-line,
.reduce-motion .blinking-cursor,
.reduce-motion .reveal-content,
.reduce-motion .card-face-icon {
  animation: none !important;
  transition-duration: 0ms !important;
}

/* ===========================
   Phase 1: 盲抽仪式
   =========================== */
.draw-screen {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx 40rpx;
  box-sizing: border-box;
}

.draw-header {
  text-align: center;
  margin-bottom: 60rpx;
  opacity: 0;
  animation: fadeInDown 0.8s ease forwards;
}

.draw-subtitle {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.25);
  letter-spacing: 6rpx;
  text-transform: uppercase;
  margin-bottom: 12rpx;
}

.draw-date {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.12);
  letter-spacing: 4rpx;
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ----- 卡片舞台 ----- */
.cards-stage {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
  padding: 0 10rpx;
  box-sizing: border-box;
}

/* ----- 战术盲盒卡片（背面） ----- */
.tactical-card {
  width: 120rpx;
  height: 200rpx;
  position: relative;
  border-radius: 16rpx;
  background: linear-gradient(165deg, #1a1a2e 0%, #0d0d1a 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.6),
    0 1rpx 0 rgba(255, 255, 255, 0.06) inset;
  overflow: hidden;
  cursor: pointer;
  opacity: 0;
  animation: cardEntrance 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards;
  animation-delay: var(--delay, 0s);
  transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1),
              box-shadow 0.4s ease,
              opacity 0.4s ease;
}

@keyframes cardEntrance {
  from {
    opacity: 0;
    transform: translateY(60rpx) scale(0.8);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.tactical-card:active {
  transform: scale(0.95);
}

/* 牌背几何暗纹 */
.card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-back-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.card-back-ring--1 {
  width: 140rpx;
  height: 140rpx;
  border-color: rgba(255, 255, 255, 0.06);
}

.card-back-ring--2 {
  width: 90rpx;
  height: 90rpx;
  border-color: rgba(255, 255, 255, 0.05);
}

.card-back-ring--3 {
  width: 40rpx;
  height: 40rpx;
  border-color: rgba(255, 255, 255, 0.04);
}

.card-back-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  position: relative;
  z-index: 1;
}

/* 选中态 */
.tactical-card--selected {
  transform: translateY(-60rpx) scale(1.12) !important;
  border-color: #00BFFF;
  box-shadow: 0 0 8rpx rgba(0, 191, 255, 0.15);
  z-index: 10;
}

.tactical-card--selected .card-back-dot {
  background: #00BFFF;
  box-shadow: 0 0 2px #00BFFF;
}

.tactical-card--selected .card-back-ring--1 {
  border-color: rgba(0, 191, 255, 0.2);
}

/* 未选中淡出 */
.tactical-card--fade {
  opacity: 0.15 !important;
  transform: scale(0.9) !important;
}

/* 提示文案 */
.draw-prompt {
  margin-top: 80rpx;
  text-align: center;
  opacity: 0;
  animation: fadeIn 0.6s ease 0.8s forwards;
}

@keyframes fadeIn {
  to { opacity: 1; }
}

.prompt-line {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 6rpx;
  line-height: 2;
}

.prompt-line--dim {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.2);
}

/* ===========================
   Phase 2: 数据推演（旋转卡片 + 滚动日志）
   =========================== */
.calc-screen {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: #000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  animation: fadeIn 0.3s ease forwards;
}

.calc-fade-out {
  animation: fadeOut 0.4s ease forwards;
}

@keyframes fadeOut {
  to { opacity: 0; }
}

/* 中央旋转卡片 */
.calc-card-area {
  position: relative;
  width: 240rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 80rpx;
}

.calc-card {
  width: 200rpx;
  height: 340rpx;
  border-radius: 20rpx;
  background: linear-gradient(165deg, #1a1a2e 0%, #0d0d1a 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  overflow: hidden;
  position: relative;
  z-index: 2;
}

.calc-card--spinning {
  animation: cardSpin 3s ease-in-out infinite;
}

@keyframes cardSpin {
  0%, 100% { transform: rotateY(0deg) scale(1); }
  25% { transform: rotateY(90deg) scale(0.85); }
  50% { transform: rotateY(180deg) scale(1); }
  75% { transform: rotateY(270deg) scale(0.85); }
}

.calc-card .card-back-ring--1 { width: 200rpx; height: 200rpx; }
.calc-card .card-back-ring--2 { width: 130rpx; height: 130rpx; }
.calc-card .card-back-ring--3 { width: 60rpx; height: 60rpx; }
.calc-card .card-back-dot { width: 12rpx; height: 12rpx; }

.calc-glow-ring {
  position: absolute;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  border: 1px solid rgba(0, 191, 255, 0.12);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: ringExpand 2s ease-in-out infinite;
  z-index: 1;
}

@keyframes ringExpand {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
  50% { transform: translate(-50%, -50%) scale(1.3); opacity: 0; }
}

.calc-pulse-ring {
  position: absolute;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  border: 1px solid rgba(0, 191, 255, 0.06);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: ringExpand 2s ease-in-out 1s infinite;
  z-index: 1;
}

/* 赛博终端消散日志 */
.terminal-bar {
  position: absolute;
  bottom: 80rpx;
  left: 40rpx;
  right: 40rpx;
  overflow: hidden;
  height: 250rpx;
  -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 35%, #000 100%);
  mask-image: linear-gradient(to bottom, transparent 0%, #000 35%, #000 100%);
}

.terminal-bar__inner {
  transition: transform 0.25s ease-out;
}

.log-line {
  display: flex;
  align-items: baseline;
  padding: 2rpx 0;
  line-height: 1.6;
  animation: logSlideIn 0.2s ease-out;
}

@keyframes logSlideIn {
  from { transform: translateY(8rpx); }
  to { transform: translateY(0); }
}

.log-time {
  flex-shrink: 0;
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.2);
  margin-right: 16rpx;
  letter-spacing: 1rpx;
}

.log-msg {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.55);
  letter-spacing: 1rpx;
  word-break: break-all;
}

.log-msg--warn {
  color: #FF9F0A;
}

.log-msg--success {
  color: #34C759;
}

.cursor-line {
  padding: 4rpx 0;
}

.blinking-cursor {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  animation: blink 0.8s step-end infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* ===========================
   Phase 3: 策略揭晓弹窗
   =========================== */
.reveal-modal {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reveal-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
}

.reveal-content {
  position: relative;
  z-index: 1;
  width: 88vw;
  max-height: 85vh;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  opacity: 0;
  transform: scale(0.85);
  animation: revealScale 0.5s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}

@keyframes revealScale {
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* ----- 战术原型卡面 ----- */
.reveal-card-face {
  width: 320rpx;
  min-height: 500rpx;
  background: linear-gradient(180deg, rgba(26, 26, 46, 0.95) 0%, rgba(13, 13, 26, 0.98) 100%);
  border: 1px solid var(--accent, #00BFFF);
  border-radius: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 顶部高光线 */
.reveal-card-face::after {
  content: '';
  position: absolute;
  top: 0;
  left: 10%;
  right: 10%;
  height: 1px;
  background: rgba(255, 255, 255, 0.10);
  border-radius: 1px;
}

/* 背景辉光 */
.reveal-card-face::before {
  content: '';
  position: absolute;
  top: -30%;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: var(--accent, #00BFFF);
  opacity: 0.04;
  filter: blur(40px);
  pointer-events: none;
}

.card-face-top-line {
  width: 80%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--accent, #00BFFF), transparent);
  opacity: 0.4;
  margin-bottom: 32rpx;
}

.card-face-bottom-line {
  margin-bottom: 0;
  margin-top: 32rpx;
}

.card-face-number {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.2);
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

.card-face-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #F5F5F7;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.card-face-archetype {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.25);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 32rpx;
}

.card-face-symbol {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-face-icon {
  font-size: 100rpx;
  line-height: 1;
  opacity: 0.7;
}

.card-face-verdict {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
  line-height: 1.6;
  letter-spacing: 2rpx;
  max-width: 90%;
}

/* ----- 策略数据面板 ----- */
.reveal-strategy-panel {
  width: 100%;
  margin-top: 32rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  box-sizing: border-box;
}

.strategy-tag-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.strategy-tag {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  padding: 6rpx 18rpx;
  border-radius: 2rpx;
  border: 1px solid;
}

.strategy-source {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.2);
  letter-spacing: 2rpx;
}

.strategy-section {
  margin-bottom: 24rpx;
}

.strategy-section:last-of-type {
  margin-bottom: 0;
}

.strategy-section-title {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
  text-transform: uppercase;
}

.strategy-section-title--buff {
  color: #34C759;
}

.strategy-section-title--debuff {
  color: #FF453A;
}

.strategy-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.strategy-item-prefix {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  flex-shrink: 0;
  width: 36rpx;
  text-align: center;
}

.strategy-item-prefix--buff {
  color: #34C759;
}

.strategy-item-prefix--debuff {
  color: #FF453A;
}

.strategy-item-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 1rpx;
}

.strategy-meta {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
  text-align: center;
}

.strategy-meta-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 2rpx;
}

/* ----- 打字机逐行出现动画 ----- */
.typewriter-line {
  opacity: 0;
  animation: typewriterFadeIn 0.3s ease forwards;
  animation-delay: var(--tw-delay, 0s);
}

.reduce-motion .typewriter-line {
  opacity: 1;
  animation: none;
}

@keyframes typewriterFadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ----- 底部操作区 ----- */
.reveal-actions {
  display: flex;
  gap: 48rpx;
  margin-top: 16rpx;
  margin-bottom: 12rpx;
}

/* ----- CTA 按钮（打字机完成后淡入） ----- */
.reveal-cta-btn {
  width: 100%;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
  padding: 28rpx 0;
  background: transparent;
  border: 1px solid #00BFFF;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.5s ease-in;
}

.reveal-cta-btn--visible {
  opacity: 1;
}

.reduce-motion .reveal-cta-btn {
  transition-duration: 0ms;
}

.reveal-cta-btn:active {
  transform: scale(0.97);
}

.cta-btn-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 28rpx;
  font-weight: 600;
  color: #00BFFF;
  letter-spacing: 4rpx;
}

.reveal-action-btn {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 2rpx;
  padding: 12rpx 32rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 2rpx;
  transition: opacity 0.15s ease;
}

.reveal-action-btn:active {
  opacity: 0.5;
}

.reveal-action-btn--primary {
  color: #00BFFF;
  border-color: rgba(0, 191, 255, 0.3);
}

/* ===========================
   错误态
   =========================== */
.error-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.error-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 69, 58, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Courier New', Courier, monospace;
  font-size: 36rpx;
  color: #FF453A;
  margin-bottom: 32rpx;
}

.error-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 2rpx;
  margin-bottom: 48rpx;
  text-align: center;
}

.error-btn {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: #00BFFF;
  letter-spacing: 4rpx;
  padding: 16rpx 48rpx;
  border: 1px solid rgba(0, 191, 255, 0.3);
  border-radius: 4rpx;
}

.error-btn:active {
  opacity: 0.6;
}

/* ===========================
   状态刷新倒计时
   =========================== */
.countdown-bar {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  width: 100%;
  text-align: center;
  z-index: 50;
}

.countdown-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.30);
  letter-spacing: 4rpx;
}

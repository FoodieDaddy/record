/* ===== 1. 全局容器 ===== */
.strategy-page {
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.08), transparent 50%),
    radial-gradient(circle at 20% 80%, rgba(5, 11, 18, 0.8), transparent 60%),
    #02060A;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  position: relative;
  /* 自定义 tabbar 140rpx + Home Indicator + 操作栏预留 */
  padding: 24rpx;
}

.strategy-page--modal-open {
  overflow: hidden;
}

.strategy-page--result .directive-projection {
  position: relative;
  z-index: 3;
}
.strategy-page--result .directive-projection::before {
  content: '';
  position: absolute;
  inset: -20rpx -12rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(2, 8, 14, 0.42), rgba(2, 8, 14, 0.68));
  z-index: -1;
}

/* ===== 星图舷窗 ===== */
.nav-map-window {
  position: relative;
  width: 640rpx;
  height: 420rpx;
  margin: 180rpx auto 44rpx;
  border-radius: 44rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 72% 28%, rgba(85, 255, 170, 0.10), transparent 20%),
    radial-gradient(circle at 28% 68%, rgba(0, 180, 255, 0.10), transparent 24%),
    linear-gradient(180deg, rgba(4, 18, 30, 0.72), rgba(2, 8, 14, 0.86));
  border: 1rpx solid rgba(0, 190, 255, 0.16);
  box-shadow:
    inset 0 0 60rpx rgba(0, 180, 255, 0.06),
    0 0 42rpx rgba(0, 140, 220, 0.08);
}

.nav-map-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0, 200, 255, 0.055) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 200, 255, 0.055) 1rpx, transparent 1rpx);
  background-size: 72rpx 72rpx;
  opacity: 0.8;
  mask-image: radial-gradient(circle at 50% 50%, black 0%, black 62%, transparent 92%);
  -webkit-mask-image: radial-gradient(circle at 50% 50%, black 0%, black 62%, transparent 92%);
}

.nav-map-orbit {
  position: absolute;
  border: 1rpx solid rgba(0, 190, 255, 0.11);
  border-radius: 50%;
}
.nav-map-orbit--1 {
  width: 480rpx;
  height: 200rpx;
  right: 20rpx;
  top: 60rpx;
  transform: rotate(-14deg);
}
.nav-map-orbit--2 {
  width: 380rpx;
  height: 160rpx;
  left: 60rpx;
  top: 200rpx;
  transform: rotate(18deg);
  opacity: 0.6;
}

.nav-map-route {
  position: absolute;
  left: 150rpx;
  bottom: 118rpx;
  width: 390rpx;
  height: 2rpx;
  transform: rotate(-32deg);
  transform-origin: left center;
  background: linear-gradient(
    90deg,
    rgba(0, 210, 255, 0.16),
    rgba(0, 210, 255, 0.42),
    rgba(88, 255, 160, 0.58)
  );
  opacity: 0.28;
}

.nav-planet {
  position: absolute;
  width: 38rpx;
  height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-planet-core {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(0, 210, 255, 0.9);
  box-shadow:
    0 0 16rpx rgba(0, 210, 255, 0.55),
    0 0 34rpx rgba(0, 150, 255, 0.22);
}

.nav-planet--origin {
  left: 128rpx;
  bottom: 96rpx;
}

.nav-planet--target {
  right: 128rpx;
  top: 96rpx;
}

.nav-planet--target .nav-planet-core {
  width: 16rpx;
  height: 16rpx;
  background: var(--target-color, rgba(88, 255, 160, 0.96));
  box-shadow:
    0 0 20rpx var(--target-color, rgba(88, 255, 160, 0.70)),
    0 0 46rpx rgba(88, 255, 160, 0.24);
}

.nav-planet-lock {
  position: absolute;
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(88, 255, 160, 0.30);
  box-shadow:
    inset 0 0 20rpx rgba(88, 255, 160, 0.08),
    0 0 24rpx rgba(88, 255, 160, 0.14);
  opacity: 0;
  transition: opacity 500ms ease;
}

/* 信标/航迹状态灯 */
.nav-map-status {
  position: absolute;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(0, 18, 30, 0.52);
  border: 1rpx solid rgba(0, 190, 255, 0.10);
  color: rgba(180, 225, 245, 0.62);
  font-size: 20rpx;
  font-weight: 600;
}

.nav-map-status--beacon {
  left: 32rpx;
  top: 32rpx;
}

.nav-map-status--trace {
  right: 32rpx;
  bottom: 32rpx;
}

.nav-map-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.85);
  box-shadow: 0 0 12rpx rgba(0, 200, 255, 0.48);
}

.nav-map-status-dot--green {
  background: rgba(80, 255, 150, 0.9);
  box-shadow: 0 0 12rpx rgba(80, 255, 150, 0.52);
}

/* 中央读数 */
.nav-center-readout {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  min-width: 260rpx;
  height: 86rpx;
  padding: 0 44rpx;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 220, 255, 0.14), transparent 58%),
    linear-gradient(180deg, rgba(4, 28, 42, 0.92), rgba(2, 12, 22, 0.96));
  border: 1rpx solid rgba(0, 200, 255, 0.22);
  box-shadow:
    inset 0 0 26rpx rgba(0, 200, 255, 0.10),
    0 0 28rpx rgba(0, 170, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.nav-center-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(70, 255, 145, 0.9);
  box-shadow: 0 0 14rpx rgba(70, 255, 145, 0.65);
}

.nav-center-value {
  font-family: 'Courier New', monospace;
  font-size: 40rpx;
  font-weight: 700;
  color: rgba(230, 246, 255, 0.94);
  letter-spacing: 4rpx;
  text-shadow: 0 0 14rpx rgba(0, 200, 255, 0.28);
}

.nav-center-value--zh {
  font-family: system-ui, -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-size: 34rpx;
  letter-spacing: 2rpx;
}

/* SYNC 状态条 */
.nav-sync-strip {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 28rpx;
}

.nav-sync-strip text {
  font-family: 'Courier New', monospace;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: rgba(120, 170, 200, 0.28);
  transition: color 300ms ease;
}

.nav-sync-strip text.on {
  color: rgba(80, 255, 170, 0.82);
  text-shadow: 0 0 10rpx rgba(80, 255, 170, 0.35);
}

/* 主操作按钮 */
.nav-launch-btn-area {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 36rpx;
}

.nav-launch-btn {
  width: 440rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.12), transparent 62%),
    linear-gradient(180deg, rgba(4, 22, 34, 0.94), rgba(2, 10, 18, 0.98));
  border: 1rpx solid rgba(0, 190, 255, 0.26);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.05),
    inset 0 -14rpx 26rpx rgba(0,0,0,0.32),
    0 0 28rpx rgba(0, 170, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(230, 246, 255, 0.92);
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  transition: transform 180ms ease;
}

.nav-launch-btn:active {
  transform: translateY(2rpx) scale(0.99);
}

.nav-launch-btn--loading {
  border-color: rgba(88, 255, 160, 0.22);
  opacity: 0.72;
}

/* ===== 舷窗状态驱动 ===== */
.nav-map-window--idle .nav-map-route {
  opacity: 0.18;
}

.nav-map-window--sync .nav-map-route {
  opacity: 0.66;
  animation: routeEnergy 1200ms ease-in-out infinite;
}

.nav-map-window--sync .nav-planet-lock {
  opacity: 1;
  animation: targetLockPulse 1500ms ease-in-out infinite;
}

.nav-map-window--project .nav-map-route,
.nav-map-window--result .nav-map-route {
  opacity: 0.78;
}

.nav-map-window--project .nav-planet-lock,
.nav-map-window--result .nav-planet-lock {
  opacity: 0.86;
}

/* 舷窗动画 */
@keyframes targetLockPulse {
  0%, 100% {
    opacity: 0.45;
    transform: scale(0.92);
  }
  50% {
    opacity: 1;
    transform: scale(1.08);
  }
}

@keyframes routeEnergy {
  0%, 100% { opacity: 0.50; }
  50%       { opacity: 0.78; }
}

/* reduce-motion: 舷窗静态化 */
.reduce-motion .nav-planet-lock {
  animation: none !important;
}
.reduce-motion .nav-map-route {
  animation: none !important;
  transition: none !important;
}


/* ===== 0. 跨 Tab 骨架屏 ===== */
.page-skeleton {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: #0a0a0a;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.page-skeleton-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #00c8ff;
  box-shadow: 0 0 16rpx rgba(0, 200, 255, 0.45);
}

.page-skeleton-text {
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

/* ===== 2. reduce-motion 静默模式 ===== */
.reduce-motion .deck-line,
.reduce-motion .flight-heartbeat-dot,
.reduce-motion .flight-log-line,
.reduce-motion .flight-log-typing,
.reduce-motion .flight-log-dot,
.reduce-motion .strategy-insight,
.reduce-motion .strategy-section,
.reduce-motion .strategy-actions,
.reduce-motion .poster-gen-dot,
.reduce-motion .projection-card {
  animation: none !important;
  transition-duration: 0ms !important;
  opacity: 1 !important;
}

.reduce-motion .flight-heartbeat-dot {
  opacity: 0.6;
}

.reduce-motion .flight-deck--syncing {
  transition-duration: 0ms !important;
}

/* reduce-motion: 结果直接可见 */
.reduce-motion .directive-projection.dp-visible {
  opacity: 1;
  transform: none;
}
.reduce-motion .directive-projection .projection-card {
  opacity: 1;
  transform: none;
  animation: none !important;
}

/* ===== 3. 可见性工具类 ===== */
.fdh-visible {
  opacity: 1;
  pointer-events: auto;
}
.fdh-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}
.fdi-visible {
  opacity: 1;
  pointer-events: auto;
}
.fdi-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}
.dhb-visible {
  opacity: 1;
  pointer-events: auto;
}
.dhb-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}

/* ===== 4. 飞控核心通用元素 ===== */
.core-inner {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.core-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.core-ring--1 {
  width: 200rpx;
  height: 200rpx;
  border-color: rgba(10, 132, 255, 0.12);
}

.core-ring--2 {
  width: 130rpx;
  height: 130rpx;
  border-color: rgba(10, 132, 255, 0.08);
}

.core-ring--3 {
  width: 60rpx;
  height: 60rpx;
  border-color: rgba(10, 132, 255, 0.06);
}

/* 能量辉光 */
.core-glow {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(10, 132, 255, 0.25),
    transparent 70%
  );
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: coreGlowPulse 3s ease-in-out infinite;
  z-index: 1;
}

@keyframes coreGlowPulse {
  0%,
  100% {
    opacity: 0.3;
    transform: translate(-50%, -50%) scale(0.8);
  }
  50% {
    opacity: 0.7;
    transform: translate(-50%, -50%) scale(1.2);
  }
}

/* 能量点 */
.core-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(10, 132, 255, 0.6);
  box-shadow: 0 0 12rpx rgba(10, 132, 255, 0.4);
  position: relative;
  z-index: 2;
  animation: coreDotPulse 2s ease-in-out infinite;
}

@keyframes coreDotPulse {
  0%,
  100% {
    opacity: 0.4;
  }
  50% {
    opacity: 0.9;
  }
}

/* ===== 5. 扫描环 ===== */
.scan-ring {
  position: absolute;
  width: 340rpx;
  height: 340rpx;
  border-radius: 50%;
  border: 1px solid rgba(0, 175, 255, 0.18);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
  box-shadow: 0 0 12rpx rgba(0, 175, 255, 0.06);
}

.scan-ring::after {
  content: "";
  position: absolute;
  inset: -2rpx;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    transparent 0deg,
    transparent 300deg,
    rgba(10, 132, 255, 0.3) 340deg,
    transparent 360deg
  );
  mask: radial-gradient(transparent 48%, black 49%, black 51%, transparent 52%);
  -webkit-mask: radial-gradient(
    transparent 48%,
    black 49%,
    black 51%,
    transparent 52%
  );
}

.scan-ring--idle {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--idle::after {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--gen {
  animation: scanRotate 6s linear infinite;
}

.scan-ring--gen::after {
  animation: scanRotate 6s linear infinite;
}

@keyframes scanRotate {
  from {
    transform: translate(-50%, -50%) rotate(0deg);
  }
  to {
    transform: translate(-50%, -50%) rotate(360deg);
  }
}

/* ===== 6. 甲板透视线 ===== */
.deck-perspective {
  position: absolute;
  bottom: 130rpx;
  left: 0;
  right: 0;
  height: 300rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.deck-line {
  position: absolute;
  bottom: 0;
  height: 200rpx;
  width: 1rpx;
  background: linear-gradient(to top, rgba(10, 132, 255, 0.08), transparent);
  transform-origin: bottom center;
  transition: opacity 0.8s ease;
}

.deck-line--1 {
  left: 8%;
  transform: perspective(300rpx) rotateX(50deg) rotate(-16deg);
}
.deck-line--2 {
  left: 25%;
  transform: perspective(300rpx) rotateX(50deg) rotate(-8deg);
}
.deck-line--3 {
  left: 50%;
  transform: perspective(300rpx) rotateX(50deg) rotate(0deg);
  background: linear-gradient(to top, rgba(10, 132, 255, 0.14), transparent);
}
.deck-line--4 {
  left: 75%;
  transform: perspective(300rpx) rotateX(50deg) rotate(8deg);
}
.deck-line--5 {
  left: 92%;
  transform: perspective(300rpx) rotateX(50deg) rotate(16deg);
}


/* ===== 8. 飞行甲板统一舞台 ===== */
.flight-deck {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 120rpx 40rpx 80rpx;
  box-sizing: border-box;
  position: relative;
  flex-shrink: 0;
  transition: padding-top 560ms cubic-bezier(0.22, 1, 0.36, 1);
}

.flight-deck--idle,
.flight-deck--arming,
.flight-deck--pressed,
.flight-deck--plasma,
.flight-deck--lifting {
  padding-top: 80rpx;
}

.flight-deck--syncing {
  padding-top: 60rpx;
}

.flight-deck--projecting {
  padding-top: 40rpx;
}

.flight-deck--done {
  padding-top: 24rpx;
}

.flight-deck > .bay-status-tab {
  position: absolute;
  top: 24rpx;
  left: 28rpx;
  margin-bottom: 0;
}

/* --- 顶部标题 --- */
.flight-deck-header {
  text-align: center;
  margin-bottom: 48rpx;
  transition:
    opacity 0.4s ease,
    height 0.4s ease,
    margin 0.4s ease;
}

.fdh-visible {
  opacity: 1;
  animation: fadeInDown 0.8s ease forwards;
}

.flight-deck-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 6rpx;
}

.flight-deck-date {
  display: block;
  font-family: "Courier New", Courier, monospace;
  font-size: 18rpx;
  color: rgba(126, 156, 180, 0.12);
  margin-top: 4rpx;
}



/* ===== 10. 底部说明 ===== */
.flight-deck-info {
  text-align: center;
  margin-bottom: 24rpx;
  transition:
    opacity 0.4s ease,
    height 0.4s ease;
}

.fdi-visible {
  opacity: 0;
  animation: fadeIn 0.6s ease 0.9s forwards;
}

/* entered 态：跳过入场动画延迟（重新点火用） */
.fdi-entered {
  animation: none !important;
  opacity: 1 !important;
}

.flight-deck-info-text {
  display: block;
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(126, 156, 180, 0.28);
  letter-spacing: 3rpx;
  line-height: 1.8;
}

/* ===== 待机页下方舱体刻度（pseudo 增强） ===== */
.flight-deck-info::after {
  content: '';
  display: flex;
  gap: 6rpx;
  margin-top: 28rpx;
  justify-content: center;
  height: 2rpx;
  width: 280rpx;
  margin-left: auto;
  margin-right: auto;
  background:
    repeating-linear-gradient(
      90deg,
      rgba(0, 180, 255, 0.14) 0,
      rgba(0, 180, 255, 0.14) 8rpx,
      transparent 8rpx,
      transparent 20rpx
    );
  opacity: 0.65;
}

.fdi-hidden::after {
  display: none;
}


/* ===== 12. 飞行阶段联动动画 ===== */

/* pressed: 核心边框增亮、能量点扩大、辉光扩大 */
.flight-deck--pressed .core-dot {
  animation: igniteDotExpand 1.8s ease-in-out forwards !important;
}

@keyframes igniteDotExpand {
  0% {
    width: 10rpx;
    height: 10rpx;
    opacity: 0.6;
    box-shadow: 0 0 12rpx rgba(10, 132, 255, 0.4);
  }
  50% {
    width: 28rpx;
    height: 28rpx;
    opacity: 1;
    box-shadow: 0 0 40rpx rgba(10, 132, 255, 0.7);
  }
  100% {
    width: 20rpx;
    height: 20rpx;
    opacity: 0.9;
    box-shadow: 0 0 60rpx rgba(10, 132, 255, 0.5);
  }
}

.flight-deck--pressed .core-glow {
  animation: igniteGlowExpand 1.8s ease-in-out forwards !important;
}

@keyframes igniteGlowExpand {
  0% {
    width: 40rpx;
    height: 40rpx;
    opacity: 0.3;
  }
  60% {
    width: 120rpx;
    height: 120rpx;
    opacity: 0.8;
  }
  100% {
    width: 160rpx;
    height: 160rpx;
    opacity: 0.6;
  }
}

.flight-deck--pressed .nav-core-rings {
  transition: box-shadow 0.6s ease;
}

.flight-deck--pressed .scan-ring--idle {
  animation: scanRotate 3s linear infinite !important;
}

.flight-deck--pressed .scan-ring--idle::after {
  animation: scanRotate 3s linear infinite !important;
}

/* pressed: 甲板透视线后撤 */
.flight-deck--pressed .deck-line {
  opacity: 0.04;
  transition: opacity 0.8s ease;
}

.flight-deck--pressed .deck-line--3 {
  opacity: 0.08;
}

/* plasma: 短暂高亮 */
.flight-deck--plasma .core-dot {
  animation: plasmaDotFlash 0.6s ease-in-out forwards !important;
}

@keyframes plasmaDotFlash {
  0% {
    opacity: 1;
    box-shadow: 0 0 80rpx rgba(0, 200, 255, 0.9);
  }
  100% {
    opacity: 0.9;
    box-shadow: 0 0 40rpx rgba(10, 132, 255, 0.5);
  }
}

/* lifting: 光束拉长、核心上浮（限制幅度） */
.flight-deck--lifting .nav-core-beam {
  width: 6rpx;
  height: 160rpx;
  opacity: 0.8;
  animation: igniteBeam 1.2s ease-in-out forwards;
}

@keyframes igniteBeam {
  0% {
    opacity: 0;
    height: 0;
  }
  30% {
    opacity: 0.8;
    height: 80rpx;
  }
  70% {
    opacity: 0.6;
    height: 160rpx;
  }
  100% {
    opacity: 0.3;
    height: 200rpx;
  }
}

.flight-deck--lifting .nav-core-stage {
  transform: translateY(-24rpx) scale(1.04);
}

/* syncing: 核心进入生成位置（限制幅度） */
.flight-deck--syncing .nav-core-stage {
  transform: translateY(-36rpx) scale(0.92);
  opacity: 0.8;
}

.flight-deck--syncing .nav-core-beam {
  width: 4rpx;
  height: 120rpx;
  opacity: 0.4;
  animation: beamPulse 2s ease-in-out infinite;
}

@keyframes beamPulse {
  0%,
  100% {
    opacity: 0.3;
    height: 100rpx;
  }
  50% {
    opacity: 0.7;
    height: 140rpx;
  }
}

/* loading: 核心在计算中保持清晰 */
.strategy-page--loading .nav-core-stage {
  opacity: 0.9;
  transform: translateY(-12rpx) scale(0.96);
}

/* projecting: 核心轻微缩小变暗（限制幅度） */
.flight-deck--projecting .nav-core-stage {
  opacity: 0.35;
  transform: translateY(-52rpx) scale(0.82);
}

/* done / result: 核心淡出退到背景，缩窄高度以防遮挡标题 */
.strategy-page--result .nav-core-stage,
.flight-deck--done .nav-core-stage {
  opacity: 0.02 !important;
  animation: none !important;
  transform: translateY(-72rpx) scale(0.56) !important;
  pointer-events: none !important;
  min-height: 0 !important;
  max-height: 40rpx !important;
  margin-bottom: -20rpx !important;
  transition:
    opacity 720ms ease,
    transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
    margin-bottom 720ms ease;
  z-index: 0 !important;
}


/* entered 态：跳过入场动画，立即可见（重新点火用） */
.nav-core-stage--entered {
  animation: none !important;
  opacity: 1 !important;
  transform: none !important;
}

/* compact 态：done 阶段核心进一步收缩（优先级高于 entered） */
.nav-core-stage--compact {
  opacity: 0.02 !important;
  animation: none !important;
  transform: translateY(-72rpx) scale(0.56) !important;
  pointer-events: none !important;
  min-height: 0 !important;
  max-height: 40rpx !important;
  margin-bottom: -20rpx !important;
  transition:
    opacity 720ms ease,
    transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
    margin-bottom 720ms ease;
}

.flight-deck--done .nav-core-rings {
  opacity: 0;
}

.flight-deck--done .deck-perspective {
  opacity: 0;
  transition: opacity 0.4s ease;
}


/* ===== 14. heartbeat ===== */
.flight-heartbeat {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.heartbeat-visible {
  opacity: 1;
}

.flight-heartbeat-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(0, 175, 255, 0.5);
  animation: heartbeatDot 1.2s ease-in-out infinite;
}

@keyframes heartbeatDot {
  0%,
  100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.flight-heartbeat-text {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(0, 175, 255, 0.5);
  letter-spacing: 2rpx;
}

/* ##### 飞船导航系统 HUD 重构 - 终极版 (修复版) ##### */

.directive-projection {
  width: 100%;
  max-width: 680rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 40rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  opacity: 0;
  transform: translateY(8rpx);
  transition:
    opacity 300ms ease,
    transform 340ms cubic-bezier(0.22, 1, 0.36, 1);
  pointer-events: none;
  flex-shrink: 0;
  position: relative;
  /* 增加背景动态数据流 */
  background-image:
    radial-gradient(
      circle at 50% 50%,
      rgba(0, 200, 255, 0.04) 0%,
      transparent 80%
    ),
    linear-gradient(rgba(0, 200, 255, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 200, 255, 0.05) 1px, transparent 1px);
  background-size:
    100% 100%,
    60rpx 60rpx,
    60rpx 60rpx;
  animation: bgDataStream 40s linear infinite;
  z-index: 10;
}

.strategy-page--result .directive-projection {
  margin-top: -28rpx;
}

.dp-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.projection-card {
  opacity: 0;
  transform: translateY(6rpx);
}

.dp-visible .projection-card {
  animation: projectionCardIn 260ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.dp-visible .projection-card:nth-child(1) { animation-delay: 20ms; }
.dp-visible .projection-card:nth-child(2) { animation-delay: 45ms; }
.dp-visible .projection-card:nth-child(3) { animation-delay: 70ms; }
.dp-visible .projection-card:nth-child(n+4) { animation-delay: 90ms; }

@keyframes projectionCardIn {
  from {
    opacity: 0;
    transform: translateY(6rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes bgDataStream {
  from {
    background-position:
      center,
      0 0,
      0 0;
  }
  to {
    background-position:
      center,
      0 600rpx,
      600rpx 0;
  }
}

.directive-projection::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      rgba(18, 16, 16, 0) 0,
      rgba(18, 16, 16, 0) 2rpx,
      rgba(0, 0, 0, 0.15) 2rpx,
      rgba(0, 0, 0, 0.15) 4rpx
    ),
    linear-gradient(
      90deg,
      rgba(255, 0, 0, 0.04),
      rgba(0, 255, 0, 0.02),
      rgba(0, 0, 255, 0.04)
    );
  pointer-events: none;
  z-index: 100;
  opacity: 0.4;
}

.nav-telemetry-points {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.tele-point {
  position: absolute;
  font-family: "Courier New", Courier, monospace;
  font-size: 12rpx;
  color: rgba(0, 200, 255, 0.2);
  letter-spacing: 1rpx;
}
.tele-point.p1 {
  top: 20rpx;
  left: 20rpx;
}
.tele-point.p2 {
  top: 20rpx;
  right: 20rpx;
}
.tele-point.p3 {
  bottom: 180rpx;
  left: 20rpx;
}
.tele-point.p4 {
  bottom: 180rpx;
  right: 20rpx;
}

.nav-hud-deco {
  width: 100%;
  max-width: 640rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
  position: relative;
  padding: 0 10rpx;
  height: 64rpx;
  z-index: 5;
}

.nav-deco-left,
.nav-deco-right {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* ##### 极简飞船导航 HUD (重构版) ##### */

/* 核心判决 */
.nav-main-verdict {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.nav-tag-minimal {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
  text-transform: uppercase;
}

.nav-verdict-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.48;
  letter-spacing: 1rpx;
  text-align: center;
  max-width: 560rpx;
  margin: 0 auto;
}

.nav-reading-tags {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.nav-mini-tag {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(0, 200, 255, 0.6);
  letter-spacing: 1rpx;
}

/* 指令组 */
.nav-execution-params {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.nav-param-group {
  width: 100%;
}

.nav-group-title {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
  padding-left: 16rpx;
  border-left: 2rpx solid rgba(0, 200, 255, 0.4);
}

.nav-param-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.nav-param-item {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

/* 终端按钮 */
.nav-terminal-actions {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  align-items: center;
  width: 100%;
  margin-top: 60rpx;
  position: relative;
  z-index: 20;
}

.result-primary-btn {
  width: 440rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.12), transparent 62%),
    linear-gradient(180deg, rgba(4, 22, 34, 0.94), rgba(2, 10, 18, 0.98));
  border: 1rpx solid rgba(0, 190, 255, 0.26);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.05),
    inset 0 -14rpx 26rpx rgba(0,0,0,0.32),
    0 0 28rpx rgba(0, 170, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(230, 246, 255, 0.92);
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  transition: transform 180ms ease;
}

.result-primary-btn:active {
  transform: translateY(2rpx) scale(0.99);
}

.result-secondary-link {
  font-size: 26rpx;
  color: rgba(160, 210, 235, 0.52);
  letter-spacing: 2rpx;
  padding: 12rpx 24rpx;
}

.result-secondary-link:active {
  color: rgba(160, 210, 235, 0.78);
}

.strategy-result-spacer {
  flex: 1;
  min-height: 40rpx;
}

/* ===== 全局禁止圆形 spinner ===== */
.strategy-page .loading-spinner,
.strategy-page .spinner,
.strategy-page .circle-loading {
  display: none !important;
}

/* ===== 15. reduce-motion 强制兜底 ===== */
.reduce-motion .directive-projection,
.reduce-motion .projection-card {
  animation: none !important;
  transition: none !important;
  filter: none !important;
}

.reduce-motion .directive-projection,
.reduce-motion .directive-projection.dp-visible,
.reduce-motion .projection-card {
  opacity: 1 !important;
  transform: none !important;
}

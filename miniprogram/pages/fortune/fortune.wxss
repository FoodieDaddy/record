/* ===== 全局容器 ===== */
.page-container {
  min-height: 100vh;
  background: #0A0A0A;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.reduce-motion .holo-card-float,
.reduce-motion .holo-card,
.reduce-motion .holo-card::before,
.reduce-motion .loading-text,
.reduce-motion .blinking-cursor,
.reduce-motion .loading-fade-out {
  animation: none !important;
  transition: none !important;
}

/* ===== 加载态：赛博终端 ===== */
.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.cyber-loading-container {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.loading-text {
  font-family: monospace;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  text-shadow: 0 0 4px rgba(255, 255, 255, 0.08);
  animation: flicker 3s ease-in-out infinite;
}

@keyframes flicker {
  0%, 100% { opacity: 0.6; text-shadow: 0 0 4px rgba(255, 255, 255, 0.08); }
  30% { opacity: 0.55; text-shadow: 0 0 2px rgba(255, 255, 255, 0.04); }
  50% { opacity: 0.65; text-shadow: 0 0 6px rgba(255, 255, 255, 0.12); }
  70% { opacity: 0.5; text-shadow: 0 0 3px rgba(255, 255, 255, 0.06); }
}

.blinking-cursor {
  font-family: monospace;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  animation: blink 0.8s step-end infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

.loading-fade-out {
  animation: fadeOut 0.3s ease-out forwards;
  pointer-events: none;
}

@keyframes fadeOut {
  0% { opacity: 1; }
  100% { opacity: 0; }
}

/* ===== 3D 全息卡片 ===== */
.fortune-wrapper {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.holo-card-float {
  width: 100%;
  animation: cardFloat 6s ease-in-out infinite;
}

.holo-card {
  position: relative;
  width: 100%;
  padding: 60rpx 48rpx;
  background: rgba(255, 255, 255, 0.02);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 32rpx;
  box-sizing: border-box;
  transform-style: preserve-3d;
  transition: transform 0.1s ease-out;
  overflow: hidden;
}

/* 呼吸底光伪元素 */
.holo-card::before {
  content: '';
  position: absolute;
  top: -20%;
  left: 20%;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: var(--glow-color, rgba(10, 132, 255, 0.5));
  filter: blur(50px);
  pointer-events: none;
  z-index: 0;
  animation: glowBreath 4s ease-in-out infinite alternate;
}

@keyframes glowBreath {
  0% { opacity: 0.4; }
  100% { opacity: 0.8; }
}

/* 卡片悬浮呼吸 */
@keyframes cardFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

/* 内部光球 */
.glow-orb {
  position: absolute;
  top: -30%;
  left: 50%;
  transform: translateX(-50%);
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.glow-border {
  position: absolute;
  inset: -1rpx;
  border: 1px solid;
  border-radius: 32rpx;
  pointer-events: none;
  z-index: 0;
}

/* 判词区 */
.verdict-area {
  position: relative;
  z-index: 1;
  text-align: center;
  margin-bottom: 48rpx;
}

.verdict-label {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 24rpx;
}

.verdict-text {
  font-size: 40rpx;
  font-weight: 500;
  color: #F5F5F7;
  letter-spacing: 2rpx;
  line-height: 1.6;
}

/* 分享按钮 */
.share-btn {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.share-btn:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.9);
}


/* 标签区 */
.tag-area {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.tag {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  border: 1px solid;
  text-transform: uppercase;
}

.tag-green {
  color: #34C759;
  border-color: rgba(52, 199, 89, 0.3);
  background: rgba(52, 199, 89, 0.08);
}

.tag-orange {
  color: #FF9F0A;
  border-color: rgba(255, 159, 10, 0.3);
  background: rgba(255, 159, 10, 0.08);
}

.tag-red {
  color: #FF2D55;
  border-color: rgba(255, 45, 85, 0.3);
  background: rgba(255, 45, 85, 0.08);
}

.tag-blue {
  color: #0A84FF;
  border-color: rgba(10, 132, 255, 0.3);
  background: rgba(10, 132, 255, 0.08);
}

.source-label {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.2);
  letter-spacing: 2rpx;
}

.env-tag {
  color: rgba(255, 255, 255, 0.15);
}

/* ===== 数据面板 ===== */
.data-panel {
  width: 100%;
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.data-section {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.02);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
}

.section-header {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  text-transform: uppercase;
  margin-bottom: 24rpx;
}

.buff-header {
  color: #34C759;
}

.debuff-header {
  color: #FF453A;
}

.data-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  position: relative;
}

/* 隐藏旧的圆点指示器 */
.item-indicator {
  display: none;
}

/* BUFF 行：绿色 [+] 前缀 */
.data-section:first-child .data-item::before {
  content: '[+]';
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  color: #34C759;
  flex-shrink: 0;
  width: 52rpx;
  letter-spacing: 0;
  margin-right: 12rpx;
}

/* DEBUFF 行：红色 [-] 前缀 */
.data-section:last-child .data-item::before {
  content: '[-]';
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  color: #FF453A;
  flex-shrink: 0;
  width: 52rpx;
  letter-spacing: 0;
  margin-right: 12rpx;
}

.item-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* ===== 建房接驳链接 ===== */
.action-hook {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  color: #0A84FF;
  text-shadow: 0 0 10px rgba(10, 132, 255, 0.5);
  text-align: center;
  margin-top: 40rpx;
  letter-spacing: 2rpx;
  padding: 20rpx 0;
}

.action-hook:active {
  opacity: 0.6;
}

/* ===== 刷新按钮 ===== */
.refresh-bar {
  margin-top: 60rpx;
  padding: 20rpx 48rpx;
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.02);
  box-shadow: 0 4px 20px rgba(255, 255, 255, 0.05);
  transition: transform 0.15s ease, background 0.15s ease;
}

.refresh-bar:active {
  background: rgba(255, 255, 255, 0.06);
  transform: scale(0.96);
}

.refresh-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 6rpx;
  text-transform: uppercase;
  text-align: center;
}

/* ===== 磁场重置倒计时 ===== */
.countdown-bar {
  margin-top: 40rpx;
  text-align: center;
}

.countdown-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 4rpx;
}

/* ===== 错误态 ===== */
.error-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.error-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 2rpx;
  margin-bottom: 40rpx;
}

/* ===== 海报预览模态框 ===== */
.poster-modal {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
}

.poster-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: posterScaleUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

.poster-img {
  width: 75vw;
  border-radius: 16rpx;
  box-shadow: 0 0 30px rgba(10, 132, 255, 0.2);
}

.poster-actions {
  display: flex;
  gap: 48rpx;
  margin-top: 48rpx;
}

.poster-btn {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  padding: 16rpx 0;
  background: none;
  border: none;
}

.poster-btn-save {
  color: #0A84FF;
}

.poster-btn-cancel {
  color: rgba(255, 255, 255, 0.3);
}

.poster-btn:active {
  opacity: 0.5;
}

@keyframes posterScaleUp {
  0% {
    opacity: 0;
    transform: scale(0.7);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

.reduce-motion .poster-content {
  animation: none !important;
}

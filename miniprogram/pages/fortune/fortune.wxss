/* ===== 1. 全局容器 ===== */
.strategy-page {
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.08), transparent 50%),
    radial-gradient(circle at 20% 80%, rgba(5, 11, 18, 0.8), transparent 60%),
    #02060A;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  position: relative;
  /* 自定义 tabbar 140rpx + Home Indicator + 操作栏预留 */
  padding: 24rpx;
}

.strategy-page--modal-open {
  overflow: hidden;
}

/* ===== 0. 跨 Tab 骨架屏 ===== */
.page-skeleton {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: #0a0a0a;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.page-skeleton-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #00c8ff;
  box-shadow: 0 0 16rpx rgba(0, 200, 255, 0.45);
}

.page-skeleton-text {
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

/* ===== 2. reduce-motion 静默模式 ===== */
.reduce-motion .nav-dashboard-dot,
.reduce-motion .nav-dashboard-main-btn,
.reduce-motion .nav-dashboard-side-button,
.reduce-motion .deck-line,
.reduce-motion .hud-mark,
.reduce-motion .flight-heartbeat-dot,
.reduce-motion .flight-log-line,
.reduce-motion .flight-log-typing,
.reduce-motion .flight-log-dot,
.reduce-motion .strategy-tag-pill,
.reduce-motion .strategy-insight,
.reduce-motion .strategy-section,
.reduce-motion .strategy-actions,
.reduce-motion .poster-gen-dot,
.reduce-motion .poster-gen-text,
.reduce-motion .projection-line,
.reduce-motion .sync-chip,
.reduce-motion .sync-chip-dot,
.reduce-motion .sync-bar-line,
.reduce-motion .projection-card,
.reduce-motion .generation-status-dot,
.reduce-motion .wait-step {
  animation: none !important;
  transition-duration: 0ms !important;
  opacity: 1 !important;
}

.reduce-motion .flight-heartbeat-dot {
  opacity: 0.6;
}

.reduce-motion .projection-line {
  display: none !important;
}
.reduce-motion .sync-bar-line {
  display: none !important;
}

.reduce-motion .flight-deck--syncing {
  transition-duration: 0ms !important;
}

/* reduce-motion: 结果直接可见 */
.reduce-motion .directive-projection.dp-visible {
  opacity: 1;
  transform: none;
}
.reduce-motion .directive-projection .projection-card {
  opacity: 1;
  transform: none;
  animation: none !important;
}

/* ===== 3. 可见性工具类 ===== */
.fdh-visible {
  opacity: 1;
  pointer-events: auto;
}
.fdh-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}
.fdi-visible {
  opacity: 1;
  pointer-events: auto;
}
.fdi-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}
.dhb-visible {
  opacity: 1;
  pointer-events: auto;
}
.dhb-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}

/* ===== 4. 飞控核心通用元素 ===== */
.core-inner {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.core-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.core-ring--1 {
  width: 200rpx;
  height: 200rpx;
  border-color: rgba(10, 132, 255, 0.12);
}

.core-ring--2 {
  width: 130rpx;
  height: 130rpx;
  border-color: rgba(10, 132, 255, 0.08);
}

.core-ring--3 {
  width: 60rpx;
  height: 60rpx;
  border-color: rgba(10, 132, 255, 0.06);
}

/* 能量辉光 */
.core-glow {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(10, 132, 255, 0.25),
    transparent 70%
  );
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: coreGlowPulse 3s ease-in-out infinite;
  z-index: 1;
}

@keyframes coreGlowPulse {
  0%,
  100% {
    opacity: 0.3;
    transform: translate(-50%, -50%) scale(0.8);
  }
  50% {
    opacity: 0.7;
    transform: translate(-50%, -50%) scale(1.2);
  }
}

/* 能量点 */
.core-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(10, 132, 255, 0.6);
  box-shadow: 0 0 12rpx rgba(10, 132, 255, 0.4);
  position: relative;
  z-index: 2;
  animation: coreDotPulse 2s ease-in-out infinite;
}

@keyframes coreDotPulse {
  0%,
  100% {
    opacity: 0.4;
  }
  50% {
    opacity: 0.9;
  }
}

/* ===== 5. 扫描环 ===== */
.scan-ring {
  position: absolute;
  width: 340rpx;
  height: 340rpx;
  border-radius: 50%;
  border: 1px solid rgba(0, 175, 255, 0.18);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
  box-shadow: 0 0 12rpx rgba(0, 175, 255, 0.06);
}

.scan-ring::after {
  content: "";
  position: absolute;
  inset: -2rpx;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    transparent 0deg,
    transparent 300deg,
    rgba(10, 132, 255, 0.3) 340deg,
    transparent 360deg
  );
  mask: radial-gradient(transparent 48%, black 49%, black 51%, transparent 52%);
  -webkit-mask: radial-gradient(
    transparent 48%,
    black 49%,
    black 51%,
    transparent 52%
  );
}

.scan-ring--idle {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--idle::after {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--gen {
  animation: scanRotate 6s linear infinite;
}

.scan-ring--gen::after {
  animation: scanRotate 6s linear infinite;
}

@keyframes scanRotate {
  from {
    transform: translate(-50%, -50%) rotate(0deg);
  }
  to {
    transform: translate(-50%, -50%) rotate(360deg);
  }
}

/* ===== 6. 甲板透视线 ===== */
.deck-perspective {
  position: absolute;
  bottom: 130rpx;
  left: 0;
  right: 0;
  height: 300rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.deck-line {
  position: absolute;
  bottom: 0;
  height: 200rpx;
  width: 1rpx;
  background: linear-gradient(to top, rgba(10, 132, 255, 0.08), transparent);
  transform-origin: bottom center;
  transition: opacity 0.8s ease;
}

.deck-line--1 {
  left: 8%;
  transform: perspective(300rpx) rotateX(50deg) rotate(-16deg);
}
.deck-line--2 {
  left: 25%;
  transform: perspective(300rpx) rotateX(50deg) rotate(-8deg);
}
.deck-line--3 {
  left: 50%;
  transform: perspective(300rpx) rotateX(50deg) rotate(0deg);
  background: linear-gradient(to top, rgba(10, 132, 255, 0.14), transparent);
}
.deck-line--4 {
  left: 75%;
  transform: perspective(300rpx) rotateX(50deg) rotate(8deg);
}
.deck-line--5 {
  left: 92%;
  transform: perspective(300rpx) rotateX(50deg) rotate(16deg);
}

/* ===== 7. HUD 刻度线 ===== */
.hud-marks {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 3;
}

.hud-marks--left {
  left: 48rpx;
}
.hud-marks--right {
  right: 48rpx;
}

.hud-mark {
  width: 12rpx;
  height: 2rpx;
  background: rgba(10, 132, 255, 0.2);
  animation: hudMarkPulse 3s ease-in-out infinite;
}

.hud-marks--left .hud-mark:nth-child(2) {
  width: 8rpx;
  animation-delay: 0.3s;
}
.hud-marks--left .hud-mark:nth-child(3) {
  width: 16rpx;
  animation-delay: 0.6s;
}
.hud-marks--left .hud-mark:nth-child(4) {
  width: 6rpx;
  animation-delay: 0.9s;
}

.hud-marks--right .hud-mark:nth-child(2) {
  width: 8rpx;
  animation-delay: 0.3s;
}
.hud-marks--right .hud-mark:nth-child(3) {
  width: 16rpx;
  animation-delay: 0.6s;
}
.hud-marks--right .hud-mark:nth-child(4) {
  width: 6rpx;
  animation-delay: 0.9s;
}

@keyframes hudMarkPulse {
  0%,
  100% {
    opacity: 0.3;
  }
  50% {
    opacity: 0.8;
  }
}

/* ===== 8. 飞行甲板统一舞台 ===== */
.flight-deck {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 120rpx 40rpx 80rpx;
  box-sizing: border-box;
  position: relative;
  flex-shrink: 0;
  transition: padding-top 560ms cubic-bezier(0.22, 1, 0.36, 1);
}

.flight-deck--idle,
.flight-deck--arming,
.flight-deck--pressed,
.flight-deck--plasma,
.flight-deck--lifting {
  padding-top: 210rpx;
}

.flight-deck--syncing {
  padding-top: 170rpx;
}

.flight-deck--projecting {
  padding-top: 110rpx;
}

.flight-deck--done {
  padding-top: 48rpx;
}

.flight-deck > .bay-status-tab {
  position: absolute;
  top: 24rpx;
  left: 28rpx;
  margin-bottom: 0;
}

/* --- 顶部标题 --- */
.flight-deck-header {
  text-align: center;
  margin-bottom: 48rpx;
  transition:
    opacity 0.4s ease,
    height 0.4s ease,
    margin 0.4s ease;
}

.fdh-visible {
  opacity: 1;
  animation: fadeInDown 0.8s ease forwards;
}

.flight-deck-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 6rpx;
}

.flight-deck-date {
  display: block;
  font-family: "Courier New", Courier, monospace;
  font-size: 18rpx;
  color: rgba(126, 156, 180, 0.12);
  margin-top: 4rpx;
}

/* --- 舰桥中控仪表盘 --- */
.nav-dashboard {
  width: 640rpx;
  min-height: 220rpx;
  position: relative;
  margin: 20rpx auto 32rpx;
  border-radius: 72rpx 72rpx 28rpx 28rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.12), transparent 56%),
    linear-gradient(180deg, rgba(4, 20, 32, 0.94), rgba(2, 8, 14, 0.98));
  border: 1rpx solid rgba(0, 180, 255, 0.16);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.05),
    inset 0 -20rpx 48rpx rgba(0,0,0,0.42),
    0 0 38rpx rgba(0, 170, 255, 0.08);
  overflow: hidden;
  box-sizing: border-box;
  opacity: 0;
  animation: dashboardEntrance 0.7s cubic-bezier(0.23, 1, 0.32, 1) 0.3s forwards;
  transition: all 300ms cubic-bezier(0.22, 1, 0.36, 1);
  z-index: 5;
}

.nav-dashboard.nav-dashboard--entered {
  animation: none !important;
  opacity: 1;
}

@keyframes dashboardEntrance {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.nav-dashboard::before {
  content: '';
  position: absolute;
  left: 36rpx;
  right: 36rpx;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,.48), transparent);
  opacity: .7;
}

/* 中间胶囊显示屏 */
.nav-dashboard-screen {
  width: 420rpx;
  height: 92rpx;
  margin: 38rpx auto 0;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 50% 20%, rgba(0, 220, 255, 0.16), transparent 56%),
    linear-gradient(180deg, rgba(4, 32, 46, 0.96), rgba(2, 14, 24, 0.98));
  border: 1rpx solid rgba(0, 200, 255, 0.22);
  box-shadow:
    inset 0 0 24rpx rgba(0, 200, 255, 0.12),
    0 0 26rpx rgba(0, 170, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 180ms ease;
}

.nav-dashboard-value {
  font-family: 'Courier New', monospace;
  font-size: 42rpx;
  font-weight: 700;
  color: rgba(230, 246, 255, 0.92);
  text-shadow: 0 0 16rpx rgba(0, 200, 255, 0.36);
  letter-spacing: 4rpx;
  transition: all 180ms ease;
}

/* 状态小光点 */
.nav-dashboard-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(55, 220, 110, 0.75);
  box-shadow: 0 0 10rpx rgba(55, 220, 110, 0.6);
  margin-right: 14rpx;
  transition: all 0.3s ease;
}

.nav-dashboard-dot--syncing {
  background: rgba(0, 200, 255, 0.8);
  box-shadow: 0 0 12rpx rgba(0, 200, 255, 0.8);
  animation: navDotBreathe 1s infinite alternate;
}

@keyframes navDotBreathe {
  0% { opacity: 0.4; }
  100% { opacity: 1; }
}

/* 左右实体按钮 */
.nav-dashboard-side-button {
  position: absolute;
  top: 52rpx;
  width: 116rpx;
  height: 116rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.12), transparent 55%),
    linear-gradient(180deg, rgba(4, 18, 28, 0.96), rgba(2, 8, 14, 0.98));
  border: 1rpx solid rgba(0, 200, 255, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.04),
    inset 0 -16rpx 28rpx rgba(0,0,0,0.42),
    0 0 18rpx rgba(0, 170, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(210, 238, 255, 0.78);
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  transition: all 150ms ease;
  z-index: 10;
}

.nav-dashboard-side-button:active {
  transform: translateY(2rpx) scale(0.96);
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.16), transparent 55%),
    linear-gradient(180deg, rgba(2, 12, 20, 0.98), rgba(1, 4, 8, 0.99));
  box-shadow:
    inset 0 4rpx 10rpx rgba(0,0,0,0.6),
    0 0 10rpx rgba(0, 170, 255, 0.04);
}

.nav-dashboard-side-button--left {
  left: 28rpx;
}

.nav-dashboard-side-button--right {
  right: 28rpx;
  border-color: rgba(55, 220, 110, 0.14);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.04),
    inset 0 -16rpx 28rpx rgba(0,0,0,0.42),
    0 0 18rpx rgba(55, 220, 110, 0.08);
}

.nav-dashboard-side-button--right:active {
  box-shadow:
    inset 0 4rpx 10rpx rgba(0,0,0,0.6),
    0 0 10rpx rgba(55, 220, 110, 0.04);
}

/* 压缩版仪表盘（结果态） */
.nav-dashboard.nav-dashboard--compact {
  width: 640rpx;
  min-height: 120rpx;
  border-radius: 28rpx;
  margin: 10rpx auto 20rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.08), transparent 50%),
    linear-gradient(180deg, rgba(4, 18, 28, 0.96), rgba(2, 8, 14, 0.98));
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.03),
    inset 0 -10rpx 24rpx rgba(0,0,0,0.42),
    0 0 20rpx rgba(0, 170, 255, 0.04);
}

.nav-dashboard.nav-dashboard--compact .nav-dashboard-screen {
  width: 380rpx;
  height: 72rpx;
  margin: 24rpx auto;
  background:
    radial-gradient(circle at 50% 20%, rgba(0, 220, 255, 0.08), transparent 56%),
    linear-gradient(180deg, rgba(4, 24, 36, 0.96), rgba(2, 10, 18, 0.98));
  border-color: rgba(0, 200, 255, 0.16);
}

.nav-dashboard.nav-dashboard--compact .nav-dashboard-value {
  font-size: 32rpx;
}

/* ===== 9. 投影线（核心与内容之间的连接线） ===== */
/* 使用 scaleX 替代 width 动画，避免重排 */
.projection-line {
  width: 560rpx;
  height: 2rpx;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(0, 200, 255, 0.4),
    transparent
  );
  margin-bottom: 24rpx;
  opacity: 0;
  transform: scaleX(0);
  transform-origin: center;
  transition: none;
}

.flight-deck--projecting .projection-line {
  animation: projectionLineIn 0.5s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}

.flight-deck--done .projection-line {
  opacity: 0;
  height: 0;
  margin: 0;
}

@keyframes projectionLineIn {
  from {
    opacity: 0;
    transform: scaleX(0);
  }
  to {
    opacity: 0.55;
    transform: scaleX(1);
  }
}

/* ===== 10. 底部说明 ===== */
.flight-deck-info {
  text-align: center;
  margin-bottom: 24rpx;
  transition:
    opacity 0.4s ease,
    height 0.4s ease;
}

.fdi-visible {
  opacity: 0;
  animation: fadeIn 0.6s ease 0.9s forwards;
}

/* entered 态：跳过入场动画延迟（重新点火用） */
.fdi-entered {
  animation: none !important;
  opacity: 1 !important;
}

.flight-deck-info-text {
  display: block;
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(126, 156, 180, 0.28);
  letter-spacing: 3rpx;
  line-height: 1.8;
}

/* --- 仪表台下方主操作按键区 --- */
.nav-dashboard-actions {
  width: 640rpx;
  margin: 32rpx auto;
  display: flex;
  justify-content: center;
  z-index: 10;
}

.nav-dashboard-main-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(180deg, rgba(4, 28, 44, 0.9), rgba(2, 12, 22, 0.95));
  border: 1rpx solid rgba(0, 200, 255, 0.22);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05),
    inset 0 -8rpx 16rpx rgba(0, 0, 0, 0.4),
    0 0 24rpx rgba(0, 170, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 180ms ease;
  padding: 0;
  margin: 0;
}

.nav-dashboard-main-btn::after {
  border: none;
}

.nav-dashboard-main-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(230, 246, 255, 0.92);
  text-shadow: 0 0 12rpx rgba(0, 200, 255, 0.35);
  letter-spacing: 4rpx;
}

/* 按下效果 */
.nav-dashboard-main-btn:active {
  transform: translateY(2rpx) scale(0.99);
  box-shadow:
    inset 0 4rpx 8rpx rgba(0, 0, 0, 0.6),
    0 0 12rpx rgba(0, 170, 255, 0.06);
}

/* 正在计算/校准中状态 */
.nav-dashboard-main-btn--loading {
  border-color: rgba(55, 220, 110, 0.22);
  background: linear-gradient(180deg, rgba(4, 26, 18, 0.9), rgba(2, 10, 8, 0.95));
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.03),
    inset 0 -8rpx 16rpx rgba(0, 0, 0, 0.4),
    0 0 20rpx rgba(55, 220, 110, 0.15);
  opacity: 0.85;
}

.nav-dashboard-main-btn--loading .nav-dashboard-main-btn-text {
  color: rgba(170, 245, 190, 0.8);
  text-shadow: 0 0 10rpx rgba(55, 220, 110, 0.25);
}

/* ===== 12. 飞行阶段联动动画 ===== */

/* pressed: 核心边框增亮、能量点扩大、辉光扩大 */
.flight-deck--pressed .core-dot {
  animation: igniteDotExpand 1.8s ease-in-out forwards !important;
}

@keyframes igniteDotExpand {
  0% {
    width: 10rpx;
    height: 10rpx;
    opacity: 0.6;
    box-shadow: 0 0 12rpx rgba(10, 132, 255, 0.4);
  }
  50% {
    width: 28rpx;
    height: 28rpx;
    opacity: 1;
    box-shadow: 0 0 40rpx rgba(10, 132, 255, 0.7);
  }
  100% {
    width: 20rpx;
    height: 20rpx;
    opacity: 0.9;
    box-shadow: 0 0 60rpx rgba(10, 132, 255, 0.5);
  }
}

.flight-deck--pressed .core-glow {
  animation: igniteGlowExpand 1.8s ease-in-out forwards !important;
}

@keyframes igniteGlowExpand {
  0% {
    width: 40rpx;
    height: 40rpx;
    opacity: 0.3;
  }
  60% {
    width: 120rpx;
    height: 120rpx;
    opacity: 0.8;
  }
  100% {
    width: 160rpx;
    height: 160rpx;
    opacity: 0.6;
  }
}

.flight-deck--pressed .nav-core-rings {
  transition: box-shadow 0.6s ease;
}

.flight-deck--pressed .scan-ring--idle {
  animation: scanRotate 3s linear infinite !important;
}

.flight-deck--pressed .scan-ring--idle::after {
  animation: scanRotate 3s linear infinite !important;
}

/* pressed: 甲板透视线后撤 */
.flight-deck--pressed .deck-line {
  opacity: 0.04;
  transition: opacity 0.8s ease;
}

.flight-deck--pressed .deck-line--3 {
  opacity: 0.08;
}

/* plasma: 短暂高亮 */
.flight-deck--plasma .core-dot {
  animation: plasmaDotFlash 0.6s ease-in-out forwards !important;
}

@keyframes plasmaDotFlash {
  0% {
    opacity: 1;
    box-shadow: 0 0 80rpx rgba(0, 200, 255, 0.9);
  }
  100% {
    opacity: 0.9;
    box-shadow: 0 0 40rpx rgba(10, 132, 255, 0.5);
  }
}

/* lifting: 光束拉长、核心上浮（限制幅度） */
.flight-deck--lifting .nav-core-beam {
  width: 6rpx;
  height: 160rpx;
  opacity: 0.8;
  animation: igniteBeam 1.2s ease-in-out forwards;
}

@keyframes igniteBeam {
  0% {
    opacity: 0;
    height: 0;
  }
  30% {
    opacity: 0.8;
    height: 80rpx;
  }
  70% {
    opacity: 0.6;
    height: 160rpx;
  }
  100% {
    opacity: 0.3;
    height: 200rpx;
  }
}

.flight-deck--lifting .nav-core-stage {
  transform: translateY(-24rpx) scale(1.04);
}

/* syncing: 核心进入生成位置（限制幅度） */
.flight-deck--syncing .nav-core-stage {
  transform: translateY(-36rpx) scale(0.92);
  opacity: 0.8;
}

.flight-deck--syncing .nav-core-beam {
  width: 4rpx;
  height: 120rpx;
  opacity: 0.4;
  animation: beamPulse 2s ease-in-out infinite;
}

@keyframes beamPulse {
  0%,
  100% {
    opacity: 0.3;
    height: 100rpx;
  }
  50% {
    opacity: 0.7;
    height: 140rpx;
  }
}

/* loading: 核心在计算中保持清晰 */
.strategy-page--loading .nav-core-stage {
  opacity: 0.9;
  transform: translateY(-12rpx) scale(0.96);
}

/* projecting: 核心轻微缩小变暗（限制幅度） */
.flight-deck--projecting .nav-core-stage {
  opacity: 0.35;
  transform: translateY(-52rpx) scale(0.82);
}

/* done / result: 核心淡出退到背景，缩窄高度以防遮挡标题 */
.strategy-page--result .nav-core-stage,
.flight-deck--done .nav-core-stage {
  opacity: 0.02 !important;
  animation: none !important;
  transform: translateY(-72rpx) scale(0.56) !important;
  pointer-events: none !important;
  min-height: 0 !important;
  max-height: 40rpx !important;
  margin-bottom: -20rpx !important;
  transition:
    opacity 720ms ease,
    transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
    margin-bottom 720ms ease;
  z-index: 0 !important;
}

.strategy-page--result .sync-bar,
.strategy-page--result .generation-status,
.strategy-page--result .wait-steps {
  display: none !important;
  opacity: 0 !important;
  pointer-events: none !important;
}

/* entered 态：跳过入场动画，立即可见（重新点火用） */
.nav-core-stage--entered {
  animation: none !important;
  opacity: 1 !important;
  transform: none !important;
}

/* compact 态：done 阶段核心进一步收缩（优先级高于 entered） */
.nav-core-stage--compact {
  opacity: 0.02 !important;
  animation: none !important;
  transform: translateY(-72rpx) scale(0.56) !important;
  pointer-events: none !important;
  min-height: 0 !important;
  max-height: 40rpx !important;
  margin-bottom: -20rpx !important;
  transition:
    opacity 720ms ease,
    transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
    margin-bottom 720ms ease;
}

.flight-deck--done .nav-core-rings {
  opacity: 0;
}

.flight-deck--done .deck-perspective {
  opacity: 0;
  transition: opacity 0.4s ease;
}
.flight-deck--done .hud-marks {
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
}

/* ===== 13. 日志接入条（轻量 chip 形式，紧贴核心下方） ===== */
.sync-bar {
  position: absolute;
  top: calc(50% + 72rpx);
  left: 50%;
  width: 430rpx;
  opacity: 0;
  transform: translate(-50%, 6rpx) scale(0.98);
  transition:
    opacity 180ms ease,
    transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  pointer-events: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 5;
}

.sync-bar--visible {
  opacity: 1;
  transform: translate(-50%, 0) scale(1);
}

.sync-bar--compact {
  opacity: 0.28;
  transform: translate(-50%, -4rpx) scale(0.94);
  width: 160rpx;
  padding: 8rpx 12rpx;
  justify-content: center;
  gap: 12rpx;
  background: transparent;
  border-color: transparent;
}

.sync-bar--compact .sync-chip {
  min-height: 14rpx;
  padding: 4rpx 6rpx;
  background: transparent;
  border-color: transparent;
}

.sync-bar--compact .sync-chip-dot {
  width: 8rpx;
  height: 8rpx;
}

.sync-bar--compact .sync-chip-text {
  display: none;
}

.sync-bar-line {
  width: 2rpx;
  height: 24rpx;
  background: linear-gradient(to bottom, rgba(0, 200, 255, 0.3), transparent);
  margin-bottom: 10rpx;
}

.sync-bar-chips {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  width: 100%;
}

.sync-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 175, 255, 0.03);
  border: 1rpx solid rgba(0, 175, 255, 0.06);
  border-radius: 6rpx;
  opacity: 0;
  transform: translateX(-8rpx);
  transition:
    opacity 0.3s ease,
    transform 0.3s ease;
}

.sync-chip--on {
  opacity: 1;
  transform: translateX(0);
}

.sync-chip-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(0, 175, 255, 0.5);
  flex-shrink: 0;
  animation: chipDotPulse 1.5s ease-in-out infinite;
}

@keyframes chipDotPulse {
  0%,
  100% {
    opacity: 0.3;
  }
  50% {
    opacity: 0.9;
  }
}

.generation-status {
  position: absolute;
  top: calc(50% + 230rpx);
  left: 50%;
  transform: translate(-50%, 8rpx);
  opacity: 0;
  z-index: 6;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 20rpx;
  border-radius: 10rpx;
  background: rgba(4, 18, 30, 0.86);
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  color: rgba(210, 238, 255, 0.82);
  font-size: 22rpx;
  letter-spacing: 1rpx;
  transition:
    opacity 180ms ease,
    transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
}

.generation-status--visible {
  opacity: 1;
  transform: translate(-50%, 0);
}

.sync-chip-text {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(140, 176, 205, 0.55);
  letter-spacing: 1rpx;
}

.sync-chip-typing {
  border-right: 2rpx solid rgba(10, 132, 255, 0.6);
  animation: blink 0.6s step-end infinite;
}

@keyframes blink {
  0%,
  100% {
    border-color: rgba(10, 132, 255, 0.6);
  }
  50% {
    border-color: transparent;
  }
}

/* ===== 14. heartbeat ===== */
.flight-heartbeat {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.heartbeat-visible {
  opacity: 1;
}

.flight-heartbeat-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(0, 175, 255, 0.5);
  animation: heartbeatDot 1.2s ease-in-out infinite;
}

@keyframes heartbeatDot {
  0%,
  100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.flight-heartbeat-text {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(0, 175, 255, 0.5);
  letter-spacing: 2rpx;
}

/* ##### 飞船导航系统 HUD 重构 - 终极版 (修复版) ##### */

.directive-projection {
  width: 100%;
  max-width: 680rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 40rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  opacity: 0;
  transform: translateY(8rpx);
  transition:
    opacity 300ms ease,
    transform 340ms cubic-bezier(0.22, 1, 0.36, 1);
  pointer-events: none;
  flex-shrink: 0;
  position: relative;
  /* 增加背景动态数据流 */
  background-image:
    radial-gradient(
      circle at 50% 50%,
      rgba(0, 200, 255, 0.04) 0%,
      transparent 80%
    ),
    linear-gradient(rgba(0, 200, 255, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 200, 255, 0.05) 1px, transparent 1px);
  background-size:
    100% 100%,
    60rpx 60rpx,
    60rpx 60rpx;
  animation: bgDataStream 40s linear infinite;
  z-index: 10;
}

.strategy-page--result .directive-projection {
  margin-top: -40rpx;
}

.dp-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.projection-card {
  opacity: 0;
  transform: translateY(6rpx);
}

.dp-visible .projection-card {
  animation: projectionCardIn 260ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.dp-visible .projection-card:nth-child(1) { animation-delay: 20ms; }
.dp-visible .projection-card:nth-child(2) { animation-delay: 45ms; }
.dp-visible .projection-card:nth-child(3) { animation-delay: 70ms; }
.dp-visible .projection-card:nth-child(n+4) { animation-delay: 90ms; }

@keyframes projectionCardIn {
  from {
    opacity: 0;
    transform: translateY(6rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes bgDataStream {
  from {
    background-position:
      center,
      0 0,
      0 0;
  }
  to {
    background-position:
      center,
      0 600rpx,
      600rpx 0;
  }
}

.directive-projection::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      rgba(18, 16, 16, 0) 0,
      rgba(18, 16, 16, 0) 2rpx,
      rgba(0, 0, 0, 0.15) 2rpx,
      rgba(0, 0, 0, 0.15) 4rpx
    ),
    linear-gradient(
      90deg,
      rgba(255, 0, 0, 0.04),
      rgba(0, 255, 0, 0.02),
      rgba(0, 0, 255, 0.04)
    );
  pointer-events: none;
  z-index: 100;
  opacity: 0.4;
}

.nav-telemetry-points {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.tele-point {
  position: absolute;
  font-family: "Courier New", Courier, monospace;
  font-size: 12rpx;
  color: rgba(0, 200, 255, 0.2);
  letter-spacing: 1rpx;
}
.tele-point.p1 {
  top: 20rpx;
  left: 20rpx;
}
.tele-point.p2 {
  top: 20rpx;
  right: 20rpx;
}
.tele-point.p3 {
  bottom: 180rpx;
  left: 20rpx;
}
.tele-point.p4 {
  bottom: 180rpx;
  right: 20rpx;
}

.nav-hud-deco {
  width: 100%;
  max-width: 640rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
  position: relative;
  padding: 0 10rpx;
  height: 64rpx;
  z-index: 5;
}

.nav-deco-left,
.nav-deco-right {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* ##### 极简飞船导航 HUD (重构版) ##### */

/* 核心判决 */
.nav-main-verdict {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.nav-tag-minimal {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
  text-transform: uppercase;
}

.nav-verdict-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.5;
  letter-spacing: 2rpx;
  text-align: center;
}

.nav-reading-tags {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.nav-mini-tag {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(0, 200, 255, 0.6);
  letter-spacing: 1rpx;
}

/* 指令组 */
.nav-execution-params {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.nav-param-group {
  width: 100%;
}

.nav-group-title {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
  padding-left: 16rpx;
  border-left: 2rpx solid rgba(0, 200, 255, 0.4);
}

.nav-param-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.nav-param-item {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

/* 终端按钮 */
.nav-terminal-actions {
  display: flex;
  gap: 32rpx;
  width: 100%;
  margin-top: 80rpx;
  position: relative;
  z-index: 20;
}

.nav-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  position: relative;
  transition: all 180ms ease;
  box-sizing: border-box;
  
  /* 深色内凹背景 */
  background: linear-gradient(180deg, rgba(2, 10, 18, 0.95), rgba(4, 16, 26, 0.92));
  border: 1rpx solid rgba(0, 200, 255, 0.12);
  color: rgba(170, 210, 230, 0.75);
  box-shadow:
    inset 0 4rpx 10rpx rgba(0, 0, 0, 0.6),
    0 0 12rpx rgba(0, 170, 255, 0.04);
}

.nav-btn:active {
  transform: translateY(2rpx) scale(0.99);
}

/* primary 按钮比 secondary 亮一点 */
.nav-btn--primary {
  border-color: rgba(0, 200, 255, 0.3);
  color: rgba(230, 246, 255, 0.95);
  box-shadow:
    inset 0 2rpx 8rpx rgba(0, 0, 0, 0.4),
    0 0 20rpx rgba(0, 200, 255, 0.15);
  background: linear-gradient(180deg, rgba(3, 16, 30, 0.95), rgba(6, 28, 48, 0.92));
}

.nav-btn--secondary {
  border-color: rgba(0, 200, 255, 0.15);
  color: rgba(170, 210, 230, 0.62);
}

.strategy-result-spacer {
  flex: 1;
  min-height: 40rpx;
}

/* ===== 15. reduce-motion 强制兜底 ===== */
.reduce-motion .directive-projection,
.reduce-motion .projection-card,
.reduce-motion .sync-bar,
.reduce-motion .generation-status,
.reduce-motion .wait-steps,
.reduce-motion .nav-dashboard,
.reduce-motion .nav-dashboard-actions {
  animation: none !important;
  transition: none !important;
  filter: none !important;
}

.reduce-motion .directive-projection,
.reduce-motion .directive-projection.dp-visible,
.reduce-motion .projection-card,
.reduce-motion .nav-dashboard {
  opacity: 1 !important;
  transform: none !important;
}

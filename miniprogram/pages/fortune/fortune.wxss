/* ===== 1. 全局容器 ===== */
.strategy-page {
  background:
    radial-gradient(circle at 20% 0%, rgba(0, 175, 255, 0.08), transparent 32%),
    radial-gradient(
      circle at 90% 18%,
      rgba(94, 92, 230, 0.05),
      transparent 30%
    ),
    #05070a;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  position: relative;
  /* 自定义 tabbar 140rpx + Home Indicator + 操作栏预留 */
  padding: 24rpx;
}

.strategy-page--modal-open {
  overflow: hidden;
}

/* ===== 0. 跨 Tab 骨架屏 ===== */
.page-skeleton {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: #0a0a0a;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.page-skeleton-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #00c8ff;
  box-shadow: 0 0 16rpx rgba(0, 200, 255, 0.45);
}

.page-skeleton-text {
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

/* ===== 2. reduce-motion 静默模式 ===== */
.reduce-motion .core-glow,
.reduce-motion .core-dot,
.reduce-motion .scan-ring,
.reduce-motion .deck-line,
.reduce-motion .hud-mark,
.reduce-motion .ignition-button,
.reduce-motion .ignition-led-dot,
.reduce-motion .ignition-bolt,
.reduce-motion .plasma-flame,
.reduce-motion .flight-heartbeat-dot,
.reduce-motion .flight-log-line,
.reduce-motion .flight-log-typing,
.reduce-motion .flight-log-dot,
.reduce-motion .strategy-tag-pill,
.reduce-motion .strategy-insight,
.reduce-motion .strategy-section,
.reduce-motion .strategy-actions,
.reduce-motion .poster-gen-dot,
.reduce-motion .poster-gen-text,
.reduce-motion .nav-core-beam,
.reduce-motion .projection-line,
.reduce-motion .sync-chip,
.reduce-motion .sync-chip-dot,
.reduce-motion .sync-bar-line,
.reduce-motion .ignition-arm-dot,
.reduce-motion .ignition-safety-rail,
.reduce-motion .rail-half,
.reduce-motion .projection-card,
.reduce-motion .generation-status-dot,
.reduce-motion .wait-step {
  animation: none !important;
  transition-duration: 0ms !important;
  opacity: 1 !important;
}

.reduce-motion .core-dot {
  opacity: 0.6;
}
.reduce-motion .core-glow {
  opacity: 0.3;
}
.reduce-motion .flight-heartbeat-dot {
  opacity: 0.6;
}

.reduce-motion .plasma-flame {
  display: none !important;
}
.reduce-motion .nav-core-beam {
  display: none !important;
}
.reduce-motion .projection-line {
  display: none !important;
}
.reduce-motion .sync-bar-line {
  display: none !important;
}

.reduce-motion .flight-deck--plasma,
.reduce-motion .flight-deck--lifting,
.reduce-motion .flight-deck--syncing {
  transition-duration: 0ms !important;
}

/* reduce-motion: 结果直接可见 */
.reduce-motion .directive-projection.dp-visible {
  opacity: 1;
  transform: none;
}
.reduce-motion .directive-projection .projection-card {
  opacity: 1;
  transform: none;
  animation: none !important;
}

/* ===== 3. 可见性工具类 ===== */
.fdh-visible {
  opacity: 1;
  pointer-events: auto;
}
.fdh-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}
.fdi-visible {
  opacity: 1;
  pointer-events: auto;
}
.fdi-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}
.dhb-visible {
  opacity: 1;
  pointer-events: auto;
}
.dhb-hidden {
  opacity: 0;
  pointer-events: none;
  height: 0;
  margin: 0;
  overflow: hidden;
}

/* ===== 4. 飞控核心通用元素 ===== */
.core-inner {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.core-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.core-ring--1 {
  width: 200rpx;
  height: 200rpx;
  border-color: rgba(10, 132, 255, 0.12);
}

.core-ring--2 {
  width: 130rpx;
  height: 130rpx;
  border-color: rgba(10, 132, 255, 0.08);
}

.core-ring--3 {
  width: 60rpx;
  height: 60rpx;
  border-color: rgba(10, 132, 255, 0.06);
}

/* 能量辉光 */
.core-glow {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(10, 132, 255, 0.25),
    transparent 70%
  );
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: coreGlowPulse 3s ease-in-out infinite;
  z-index: 1;
}

@keyframes coreGlowPulse {
  0%,
  100% {
    opacity: 0.3;
    transform: translate(-50%, -50%) scale(0.8);
  }
  50% {
    opacity: 0.7;
    transform: translate(-50%, -50%) scale(1.2);
  }
}

/* 能量点 */
.core-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(10, 132, 255, 0.6);
  box-shadow: 0 0 12rpx rgba(10, 132, 255, 0.4);
  position: relative;
  z-index: 2;
  animation: coreDotPulse 2s ease-in-out infinite;
}

@keyframes coreDotPulse {
  0%,
  100% {
    opacity: 0.4;
  }
  50% {
    opacity: 0.9;
  }
}

/* ===== 5. 扫描环 ===== */
.scan-ring {
  position: absolute;
  width: 340rpx;
  height: 340rpx;
  border-radius: 50%;
  border: 1px solid rgba(0, 175, 255, 0.18);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
  box-shadow: 0 0 12rpx rgba(0, 175, 255, 0.06);
}

.scan-ring::after {
  content: "";
  position: absolute;
  inset: -2rpx;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    transparent 0deg,
    transparent 300deg,
    rgba(10, 132, 255, 0.3) 340deg,
    transparent 360deg
  );
  mask: radial-gradient(transparent 48%, black 49%, black 51%, transparent 52%);
  -webkit-mask: radial-gradient(
    transparent 48%,
    black 49%,
    black 51%,
    transparent 52%
  );
}

.scan-ring--idle {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--idle::after {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--gen {
  animation: scanRotate 6s linear infinite;
}

.scan-ring--gen::after {
  animation: scanRotate 6s linear infinite;
}

@keyframes scanRotate {
  from {
    transform: translate(-50%, -50%) rotate(0deg);
  }
  to {
    transform: translate(-50%, -50%) rotate(360deg);
  }
}

/* ===== 6. 甲板透视线 ===== */
.deck-perspective {
  position: absolute;
  bottom: 130rpx;
  left: 0;
  right: 0;
  height: 300rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.deck-line {
  position: absolute;
  bottom: 0;
  height: 200rpx;
  width: 1rpx;
  background: linear-gradient(to top, rgba(10, 132, 255, 0.08), transparent);
  transform-origin: bottom center;
  transition: opacity 0.8s ease;
}

.deck-line--1 {
  left: 8%;
  transform: perspective(300rpx) rotateX(50deg) rotate(-16deg);
}
.deck-line--2 {
  left: 25%;
  transform: perspective(300rpx) rotateX(50deg) rotate(-8deg);
}
.deck-line--3 {
  left: 50%;
  transform: perspective(300rpx) rotateX(50deg) rotate(0deg);
  background: linear-gradient(to top, rgba(10, 132, 255, 0.14), transparent);
}
.deck-line--4 {
  left: 75%;
  transform: perspective(300rpx) rotateX(50deg) rotate(8deg);
}
.deck-line--5 {
  left: 92%;
  transform: perspective(300rpx) rotateX(50deg) rotate(16deg);
}

/* ===== 7. HUD 刻度线 ===== */
.hud-marks {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 3;
}

.hud-marks--left {
  left: 48rpx;
}
.hud-marks--right {
  right: 48rpx;
}

.hud-mark {
  width: 12rpx;
  height: 2rpx;
  background: rgba(10, 132, 255, 0.2);
  animation: hudMarkPulse 3s ease-in-out infinite;
}

.hud-marks--left .hud-mark:nth-child(2) {
  width: 8rpx;
  animation-delay: 0.3s;
}
.hud-marks--left .hud-mark:nth-child(3) {
  width: 16rpx;
  animation-delay: 0.6s;
}
.hud-marks--left .hud-mark:nth-child(4) {
  width: 6rpx;
  animation-delay: 0.9s;
}

.hud-marks--right .hud-mark:nth-child(2) {
  width: 8rpx;
  animation-delay: 0.3s;
}
.hud-marks--right .hud-mark:nth-child(3) {
  width: 16rpx;
  animation-delay: 0.6s;
}
.hud-marks--right .hud-mark:nth-child(4) {
  width: 6rpx;
  animation-delay: 0.9s;
}

@keyframes hudMarkPulse {
  0%,
  100% {
    opacity: 0.3;
  }
  50% {
    opacity: 0.8;
  }
}

/* ===== 8. 飞行甲板统一舞台 ===== */
.flight-deck {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 120rpx 40rpx 80rpx;
  box-sizing: border-box;
  position: relative;
  flex-shrink: 0;
  transition: padding-top 560ms cubic-bezier(0.22, 1, 0.36, 1);
}

.flight-deck--idle,
.flight-deck--arming,
.flight-deck--pressed,
.flight-deck--plasma,
.flight-deck--lifting {
  padding-top: 210rpx;
}

.flight-deck--syncing {
  padding-top: 170rpx;
}

.flight-deck--projecting {
  padding-top: 110rpx;
}

.flight-deck--done {
  padding-top: 48rpx;
}

.flight-deck > .bay-status-tab {
  position: absolute;
  top: 24rpx;
  left: 28rpx;
  margin-bottom: 0;
}

/* --- 顶部标题 --- */
.flight-deck-header {
  text-align: center;
  margin-bottom: 48rpx;
  transition:
    opacity 0.4s ease,
    height 0.4s ease,
    margin 0.4s ease;
}

.fdh-visible {
  opacity: 1;
  animation: fadeInDown 0.8s ease forwards;
}

.flight-deck-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 6rpx;
}

.flight-deck-date {
  display: block;
  font-family: "Courier New", Courier, monospace;
  font-size: 18rpx;
  color: rgba(126, 156, 180, 0.12);
  margin-top: 4rpx;
}

/* --- 共享航行核心 --- */
.nav-core-stage {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  opacity: 0;
  animation: coreEntrance 0.7s cubic-bezier(0.23, 1, 0.32, 1) 0.3s forwards;
  transition:
    transform 0.45s cubic-bezier(0.23, 1, 0.32, 1),
    opacity 0.4s ease;
}

@keyframes coreEntrance {
  from {
    opacity: 0;
    transform: translateY(60rpx) scale(0.85);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.nav-core-rings {
  width: 100%;
  height: 100%;
  position: relative;
  z-index: 2;
}

/* 推进光束（默认隐藏） */
.nav-core-beam {
  position: absolute;
  bottom: -60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  background: linear-gradient(
    to bottom,
    rgba(10, 132, 255, 0.5),
    rgba(10, 132, 255, 0.1),
    transparent
  );
  border-radius: 3rpx;
  z-index: 1;
  opacity: 0;
  pointer-events: none;
  transition: none;
}

/* ===== 9. 投影线（核心与内容之间的连接线） ===== */
/* 使用 scaleX 替代 width 动画，避免重排 */
.projection-line {
  width: 560rpx;
  height: 2rpx;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(0, 200, 255, 0.4),
    transparent
  );
  margin-bottom: 24rpx;
  opacity: 0;
  transform: scaleX(0);
  transform-origin: center;
  transition: none;
}

.flight-deck--projecting .projection-line {
  animation: projectionLineIn 0.5s cubic-bezier(0.23, 1, 0.32, 1) forwards;
}

.flight-deck--done .projection-line {
  opacity: 0;
  height: 0;
  margin: 0;
}

@keyframes projectionLineIn {
  from {
    opacity: 0;
    transform: scaleX(0);
  }
  to {
    opacity: 0.55;
    transform: scaleX(1);
  }
}

/* ===== 10. 底部说明 ===== */
.flight-deck-info {
  text-align: center;
  margin-bottom: 24rpx;
  transition:
    opacity 0.4s ease,
    height 0.4s ease;
}

.fdi-visible {
  opacity: 0;
  animation: fadeIn 0.6s ease 0.9s forwards;
}

/* entered 态：跳过入场动画延迟（重新点火用） */
.fdi-entered {
  animation: none !important;
  opacity: 1 !important;
}

.flight-deck-info-text {
  display: block;
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(126, 156, 180, 0.28);
  letter-spacing: 3rpx;
  line-height: 1.8;
}

/* ===== 11. 甲板点火控制器 ===== */
.ignition-console {
  margin-top: 32rpx;
  width: 520rpx;
  position: relative;
  padding: 36rpx 32rpx 24rpx;
  clip-path: polygon(
    20rpx 0,
    calc(100% - 20rpx) 0,
    100% 20rpx,
    100% calc(100% - 20rpx),
    calc(100% - 20rpx) 100%,
    20rpx 100%,
    0 calc(100% - 20rpx),
    0 20rpx
  );
  background: linear-gradient(
    170deg,
    rgba(6, 14, 24, 0.92) 0%,
    rgba(4, 6, 10, 0.96) 100%
  );
  z-index: 2;
  opacity: 0;
  animation: fadeIn 0.6s ease 0.5s forwards;
  will-change: transform, opacity, filter;
  transition:
    opacity 420ms ease,
    transform 520ms cubic-bezier(0.22, 1, 0.36, 1),
    filter 420ms ease;
}

/* 首次入场完成后：移除动画，保持可见 */
.ignition-console--entered {
  animation: none !important;
  opacity: 1 !important;
}

.ignition-console::before {
  content: "";
  position: absolute;
  inset: 0;
  clip-path: polygon(
    20rpx 0,
    calc(100% - 20rpx) 0,
    100% 20rpx,
    100% calc(100% - 20rpx),
    calc(100% - 20rpx) 100%,
    20rpx 100%,
    0 calc(100% - 20rpx),
    0 20rpx
  );
  border: 1rpx solid rgba(0, 200, 255, 0.12);
  pointer-events: none;
  transition: border-color 0.4s ease;
}

.ignition-console::after {
  content: "";
  position: absolute;
  inset: -1rpx;
  clip-path: polygon(
    20rpx 0,
    calc(100% - 20rpx) 0,
    100% 20rpx,
    100% calc(100% - 20rpx),
    calc(100% - 20rpx) 100%,
    20rpx 100%,
    0 calc(100% - 20rpx),
    0 20rpx
  );
  background: linear-gradient(170deg, rgba(0, 200, 255, 0.04), transparent 50%);
  pointer-events: none;
  z-index: -1;
}

/* 点火态：边框增亮 */
.ignition-console--active::before {
  border-color: rgba(0, 200, 255, 0.28);
}

/* 保险态：略微降低透明度 */
.ignition-console--arming {
  opacity: 0.86;
}

/* 淡出态：进一步降低透明度，缩小 */
.ignition-console--fading {
  opacity: 0;
  transform: translateY(28rpx) scale(0.94);
  filter: blur(8rpx);
  pointer-events: none;
}

/* 隐藏态：强制取消入场动画，完全隐藏 */
.ignition-console--hidden {
  animation: none !important;
  opacity: 0 !important;
  transform: translateY(28rpx) scale(0.94) !important;
  filter: blur(8rpx) !important;
  pointer-events: none;
}

/* 保险状态头 */
.ignition-arm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.ignition-arm-label {
  font-family: "Courier New", Courier, monospace;
  font-size: 18rpx;
  color: rgba(0, 200, 255, 0.45);
  letter-spacing: 4rpx;
  font-weight: 700;
}

.ignition-arm-dots {
  display: flex;
  gap: 8rpx;
}

.ignition-arm-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.2);
  animation: armDotPulse 2s ease-in-out infinite;
}

.ignition-arm-dot:nth-child(2) {
  animation-delay: 1s;
}

@keyframes armDotPulse {
  0%,
  100% {
    opacity: 0.2;
  }
  50% {
    opacity: 0.7;
  }
}

.ignition-console--active .ignition-arm-label {
  color: rgba(0, 200, 255, 0.8);
}

.ignition-console--active .ignition-arm-dot {
  background: rgba(0, 200, 255, 0.6);
  box-shadow: 0 0 6rpx rgba(0, 200, 255, 0.4);
}

/* 保险栅 */
.ignition-safety-rail {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 8rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.rail-half {
  height: 2rpx;
  width: 80rpx;
  background: rgba(0, 200, 255, 0.25);
  transition:
    transform 0.35s cubic-bezier(0.23, 1, 0.32, 1),
    opacity 0.35s ease;
}

.rail-gap {
  width: 40rpx;
  flex-shrink: 0;
}

.rail-open .rail-half--left {
  transform: translateX(-20rpx);
  opacity: 0.15;
}

.rail-open .rail-half--right {
  transform: translateX(20rpx);
  opacity: 0.15;
}

/* 四角铆点 */
.ignition-bolt {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.15);
  border: 1rpx solid rgba(0, 200, 255, 0.25);
  z-index: 5;
  transition:
    opacity 0.4s ease,
    transform 0.4s ease;
}

.ignition-bolt--tl {
  top: 14rpx;
  left: 14rpx;
}
.ignition-bolt--tr {
  top: 14rpx;
  right: 14rpx;
}
.ignition-bolt--bl {
  bottom: 14rpx;
  left: 14rpx;
}
.ignition-bolt--br {
  bottom: 14rpx;
  right: 14rpx;
}

.ignition-console--active .ignition-bolt {
  background: rgba(0, 200, 255, 0.35);
  border-color: rgba(0, 200, 255, 0.5);
  box-shadow: 0 0 6rpx rgba(0, 200, 255, 0.3);
}

/* 状态灯 */
.ignition-led {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  z-index: 5;
}

.ignition-led--left {
  left: 16rpx;
}
.ignition-led--right {
  right: 16rpx;
}

.ignition-led-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(10, 132, 255, 0.25);
  animation: ledPulse 3s ease-in-out infinite;
}

.ignition-led--left .ignition-led-dot:nth-child(2) {
  animation-delay: 1.5s;
}
.ignition-led--right .ignition-led-dot:nth-child(2) {
  animation-delay: 1.5s;
}

@keyframes ledPulse {
  0%,
  100% {
    opacity: 0.3;
  }
  50% {
    opacity: 0.8;
  }
}

.ignition-console--active .ignition-led-dot {
  background: rgba(0, 200, 255, 0.7);
  box-shadow: 0 0 8rpx rgba(0, 200, 255, 0.5);
  animation: ledFire 0.6s ease-in-out infinite;
}

@keyframes ledFire {
  0%,
  100% {
    opacity: 0.6;
  }
  50% {
    opacity: 1;
  }
}

/* 安全护框 */
.ignition-guard {
  padding: 6rpx;
  clip-path: polygon(
    14rpx 0,
    calc(100% - 14rpx) 0,
    100% 14rpx,
    100% calc(100% - 14rpx),
    calc(100% - 14rpx) 100%,
    14rpx 100%,
    0 calc(100% - 14rpx),
    0 14rpx
  );
  border: 1rpx solid rgba(0, 200, 255, 0.1);
  position: relative;
  transition: border-color 0.3s ease;
}

.ignition-guard::before {
  content: "";
  position: absolute;
  inset: 0;
  clip-path: polygon(
    14rpx 0,
    calc(100% - 14rpx) 0,
    100% 14rpx,
    100% calc(100% - 14rpx),
    calc(100% - 14rpx) 100%,
    14rpx 100%,
    0 calc(100% - 14rpx),
    0 14rpx
  );
  border: 1rpx solid rgba(0, 200, 255, 0.08);
  pointer-events: none;
}

.ignition-console--active .ignition-guard {
  border-color: rgba(0, 200, 255, 0.3);
}

/* 主点火按钮 */
.ignition-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  padding: 0 40rpx;
  clip-path: polygon(
    10rpx 0,
    calc(100% - 10rpx) 0,
    100% 10rpx,
    100% calc(100% - 10rpx),
    calc(100% - 10rpx) 100%,
    10rpx 100%,
    0 calc(100% - 10rpx),
    0 10rpx
  );
  background: rgba(10, 132, 255, 0.06);
  position: relative;
  transition:
    transform 0.15s ease,
    background 0.15s ease;
}

.ignition-button::before {
  content: "";
  position: absolute;
  inset: 0;
  clip-path: polygon(
    10rpx 0,
    calc(100% - 10rpx) 0,
    100% 10rpx,
    100% calc(100% - 10rpx),
    calc(100% - 10rpx) 100%,
    10rpx 100%,
    0 calc(100% - 10rpx),
    0 10rpx
  );
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  pointer-events: none;
  transition: border-color 0.3s ease;
}

.ignition-button:active {
  transform: translateY(6rpx) scale(0.985);
  background: rgba(10, 132, 255, 0.14);
}

/* 点火态按钮下沉 */
.ignition-console--active .ignition-button {
  transform: translateY(6rpx) scale(0.985);
  background: rgba(10, 132, 255, 0.12);
}

.ignition-console--active .ignition-button::before {
  border-color: rgba(0, 200, 255, 0.45);
  box-shadow: inset 0 0 20rpx rgba(0, 200, 255, 0.08);
}

.ignition-button-text {
  font-family: "Courier New", Courier, monospace;
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(0, 200, 255, 0.88);
  letter-spacing: 6rpx;
}

/* 离子火 */
.plasma-flame {
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 0;
  opacity: 0;
  pointer-events: none;
  z-index: 10;
  transition: none;
}

.plasma-flame--active {
  height: 80rpx;
  opacity: 1;
  animation: plasmaFlicker 0.15s ease-in-out infinite alternate;
}

@keyframes plasmaFlicker {
  0% {
    transform: translateX(-50%) scaleY(0.92) scaleX(0.96);
  }
  100% {
    transform: translateX(-50%) scaleY(1.08) scaleX(1.04);
  }
}

.plasma-flame-core {
  width: 100%;
  height: 100%;
  background:
    radial-gradient(
      circle at 50% 85%,
      rgba(255, 255, 255, 0.7),
      transparent 30%
    ),
    radial-gradient(circle at 50% 70%, rgba(0, 200, 255, 0.5), transparent 50%),
    linear-gradient(
      to top,
      rgba(10, 132, 255, 0.5),
      rgba(0, 200, 255, 0.15),
      transparent
    );
  clip-path: polygon(50% 0, 70% 35%, 62% 100%, 38% 100%, 30% 35%);
  border-radius: 50% 50% 20% 20%;
}

.plasma-flame--active .plasma-flame-core {
  animation: plasmaCore 0.3s ease-in-out infinite alternate;
}

@keyframes plasmaCore {
  0% {
    opacity: 0.8;
  }
  100% {
    opacity: 1;
  }
}

/* 底部能量槽 */
.ignition-energy-slot {
  margin-top: 16rpx;
  height: 4rpx;
  background: rgba(0, 200, 255, 0.06);
  border-radius: 2rpx;
  overflow: hidden;
}

.ignition-energy-fill {
  width: 0;
  height: 100%;
  background: linear-gradient(
    90deg,
    rgba(0, 200, 255, 0.1),
    rgba(0, 200, 255, 0.6),
    rgba(0, 200, 255, 0.1)
  );
  border-radius: 2rpx;
  transition: none;
}

.ignition-energy-fill--active {
  animation: energyFlow 1.2s ease-in-out forwards;
}

@keyframes energyFlow {
  0% {
    width: 0;
  }
  40% {
    width: 60%;
  }
  100% {
    width: 100%;
  }
}

/* 底部状态 */
.ignition-status {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 14rpx;
}

.ignition-status-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ignition-status-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(48, 209, 88, 0.4);
}

.ignition-status-text {
  font-family: "Courier New", Courier, monospace;
  font-size: 16rpx;
  color: rgba(126, 156, 180, 0.22);
  letter-spacing: 2rpx;
}

/* ===== 12. 飞行阶段联动动画 ===== */

/* pressed: 核心边框增亮、能量点扩大、辉光扩大 */
.flight-deck--pressed .core-dot {
  animation: igniteDotExpand 1.8s ease-in-out forwards !important;
}

@keyframes igniteDotExpand {
  0% {
    width: 10rpx;
    height: 10rpx;
    opacity: 0.6;
    box-shadow: 0 0 12rpx rgba(10, 132, 255, 0.4);
  }
  50% {
    width: 28rpx;
    height: 28rpx;
    opacity: 1;
    box-shadow: 0 0 40rpx rgba(10, 132, 255, 0.7);
  }
  100% {
    width: 20rpx;
    height: 20rpx;
    opacity: 0.9;
    box-shadow: 0 0 60rpx rgba(10, 132, 255, 0.5);
  }
}

.flight-deck--pressed .core-glow {
  animation: igniteGlowExpand 1.8s ease-in-out forwards !important;
}

@keyframes igniteGlowExpand {
  0% {
    width: 40rpx;
    height: 40rpx;
    opacity: 0.3;
  }
  60% {
    width: 120rpx;
    height: 120rpx;
    opacity: 0.8;
  }
  100% {
    width: 160rpx;
    height: 160rpx;
    opacity: 0.6;
  }
}

.flight-deck--pressed .nav-core-rings {
  transition: box-shadow 0.6s ease;
}

.flight-deck--pressed .scan-ring--idle {
  animation: scanRotate 3s linear infinite !important;
}

.flight-deck--pressed .scan-ring--idle::after {
  animation: scanRotate 3s linear infinite !important;
}

/* pressed: 甲板透视线后撤 */
.flight-deck--pressed .deck-line {
  opacity: 0.04;
  transition: opacity 0.8s ease;
}

.flight-deck--pressed .deck-line--3 {
  opacity: 0.08;
}

/* plasma: 短暂高亮 */
.flight-deck--plasma .core-dot {
  animation: plasmaDotFlash 0.6s ease-in-out forwards !important;
}

@keyframes plasmaDotFlash {
  0% {
    opacity: 1;
    box-shadow: 0 0 80rpx rgba(0, 200, 255, 0.9);
  }
  100% {
    opacity: 0.9;
    box-shadow: 0 0 40rpx rgba(10, 132, 255, 0.5);
  }
}

/* lifting: 光束拉长、核心上浮（限制幅度） */
.flight-deck--lifting .nav-core-beam {
  width: 6rpx;
  height: 160rpx;
  opacity: 0.8;
  animation: igniteBeam 1.2s ease-in-out forwards;
}

@keyframes igniteBeam {
  0% {
    opacity: 0;
    height: 0;
  }
  30% {
    opacity: 0.8;
    height: 80rpx;
  }
  70% {
    opacity: 0.6;
    height: 160rpx;
  }
  100% {
    opacity: 0.3;
    height: 200rpx;
  }
}

.flight-deck--lifting .nav-core-stage {
  transform: translateY(-24rpx) scale(1.04);
}

/* syncing: 核心进入生成位置（限制幅度） */
.flight-deck--syncing .nav-core-stage {
  transform: translateY(-36rpx) scale(0.92);
  opacity: 0.8;
}

.flight-deck--syncing .nav-core-beam {
  width: 4rpx;
  height: 120rpx;
  opacity: 0.4;
  animation: beamPulse 2s ease-in-out infinite;
}

@keyframes beamPulse {
  0%,
  100% {
    opacity: 0.3;
    height: 100rpx;
  }
  50% {
    opacity: 0.7;
    height: 140rpx;
  }
}

/* projecting: 核心轻微缩小变暗（限制幅度） */
.flight-deck--projecting .nav-core-stage {
  opacity: 0.35;
  transform: translateY(-52rpx) scale(0.82);
}

/* done: 核心淡出退到背景，保留最小占位 */
.flight-deck--done .nav-core-stage {
  opacity: 0.16 !important;
  animation: none !important;
  transform: translateY(-28rpx) scale(0.58) !important;
  pointer-events: none;
  min-height: 72rpx;
  max-height: 72rpx;
  margin-bottom: 4rpx;
  transition:
    opacity 720ms ease,
    transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
    margin-bottom 720ms ease;
}

/* entered 态：跳过入场动画，立即可见（重新点火用） */
.nav-core-stage--entered {
  animation: none !important;
  opacity: 1 !important;
  transform: none !important;
}

/* compact 态：done 阶段核心进一步收缩（优先级高于 entered） */
.nav-core-stage--compact {
  opacity: 0.12 !important;
  animation: none !important;
  transform: translateY(-28rpx) scale(0.58) !important;
  pointer-events: none;
  min-height: 72rpx;
  max-height: 72rpx;
  margin-bottom: 4rpx;
  transition:
    opacity 720ms ease,
    transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
    margin-bottom 720ms ease;
}

.flight-deck--done .nav-core-rings {
  opacity: 0;
}

.flight-deck--done .deck-perspective {
  opacity: 0;
  transition: opacity 0.4s ease;
}
.flight-deck--done .hud-marks {
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
}

/* ===== 13. 日志接入条（轻量 chip 形式，紧贴核心下方） ===== */
.sync-bar {
  position: absolute;
  top: calc(50% + 118rpx);
  left: 50%;
  width: 400rpx;
  margin-top: -4rpx;
  opacity: 0;
  transform: translate(-50%, -8rpx);
  transition:
    opacity 0.4s ease,
    transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  pointer-events: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 4;
}

.sync-bar--visible {
  opacity: 1;
  transform: translate(-50%, 0);
  pointer-events: auto;
}

.strategy-page--phase-bridge .sync-bar,
.strategy-page--phase-reveal .sync-bar {
  opacity: 0.28;
  transform: translate(-50%, -10rpx) scale(0.82);
  transition:
    opacity 420ms ease,
    transform 520ms cubic-bezier(0.22, 1, 0.36, 1);
}

.strategy-page--phase-stable .sync-bar {
  opacity: 0;
  transform: translate(-50%, -18rpx) scale(0.72);
  pointer-events: none;
  transition:
    opacity 420ms ease,
    transform 520ms cubic-bezier(0.22, 1, 0.36, 1);
}

/* compact 态：日志收缩为小型完成点 */
.sync-bar--compact {
  width: 160rpx;
  padding: 8rpx 12rpx;
  justify-content: center;
  gap: 12rpx;
  opacity: 0.52;
  background: transparent;
  border-color: transparent;
}

.sync-bar--compact .sync-chip {
  min-height: 14rpx;
  padding: 4rpx 6rpx;
  background: transparent;
  border-color: transparent;
}

.sync-bar--compact .sync-chip-dot {
  width: 8rpx;
  height: 8rpx;
}

.sync-bar--compact .sync-chip-text {
  display: none;
}

.sync-bar-line {
  width: 2rpx;
  height: 24rpx;
  background: linear-gradient(to bottom, rgba(0, 200, 255, 0.3), transparent);
  margin-bottom: 10rpx;
}

.sync-bar-chips {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  width: 100%;
}

.sync-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 175, 255, 0.03);
  border: 1rpx solid rgba(0, 175, 255, 0.06);
  border-radius: 6rpx;
  opacity: 0;
  transform: translateX(-8rpx);
  transition:
    opacity 0.3s ease,
    transform 0.3s ease;
}

.sync-chip--on {
  opacity: 1;
  transform: translateX(0);
}

.sync-chip-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(0, 175, 255, 0.5);
  flex-shrink: 0;
  animation: chipDotPulse 1.5s ease-in-out infinite;
}

@keyframes chipDotPulse {
  0%,
  100% {
    opacity: 0.3;
  }
  50% {
    opacity: 0.9;
  }
}

.sync-chip-text {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(140, 176, 205, 0.55);
  letter-spacing: 1rpx;
}

.sync-chip-typing {
  border-right: 2rpx solid rgba(10, 132, 255, 0.6);
  animation: blink 0.6s step-end infinite;
}

@keyframes blink {
  0%,
  100% {
    border-color: rgba(10, 132, 255, 0.6);
  }
  50% {
    border-color: transparent;
  }
}

/* ===== 14. heartbeat ===== */
.flight-heartbeat {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.heartbeat-visible {
  opacity: 1;
}

.flight-heartbeat-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(0, 175, 255, 0.5);
  animation: heartbeatDot 1.2s ease-in-out infinite;
}

@keyframes heartbeatDot {
  0%,
  100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.flight-heartbeat-text {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(0, 175, 255, 0.5);
  letter-spacing: 2rpx;
}

/* ##### 飞船导航系统 HUD 重构 - 终极版 (修复版) ##### */

.directive-projection {
  width: 100%;
  max-width: 680rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 40rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  opacity: 0;
  transform: translateY(12rpx) scale(0.985);
  filter: blur(10rpx);
  transition:
    opacity 620ms ease,
    transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
    filter 620ms ease;
  pointer-events: none;
  flex-shrink: 0;
  position: relative;
  /* 增加背景动态数据流 */
  background-image:
    radial-gradient(
      circle at 50% 50%,
      rgba(0, 200, 255, 0.04) 0%,
      transparent 80%
    ),
    linear-gradient(rgba(0, 200, 255, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 200, 255, 0.05) 1px, transparent 1px);
  background-size:
    100% 100%,
    60rpx 60rpx,
    60rpx 60rpx;
  animation: bgDataStream 40s linear infinite;
}

.dp-visible {
  opacity: 1;
  transform: translateY(0) scale(1);
  filter: blur(0);
  pointer-events: auto;
}

.projection-card {
  opacity: 0;
  transform: translateY(8rpx);
}

.dp-visible .projection-card {
  animation: projectionCardIn 520ms cubic-bezier(0.22, 1, 0.36, 1) both;
}

.dp-visible .projection-card:nth-child(1) { animation-delay: 80ms; }
.dp-visible .projection-card:nth-child(2) { animation-delay: 120ms; }
.dp-visible .projection-card:nth-child(3) { animation-delay: 160ms; }
.dp-visible .projection-card:nth-child(4) { animation-delay: 200ms; }
.dp-visible .projection-card:nth-child(5) { animation-delay: 240ms; }
.dp-visible .projection-card:nth-child(n+6) { animation-delay: 280ms; }

@keyframes projectionCardIn {
  from {
    opacity: 0;
    transform: translateY(8rpx);
    filter: blur(6rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }
}

@keyframes bgDataStream {
  from {
    background-position:
      center,
      0 0,
      0 0;
  }
  to {
    background-position:
      center,
      0 600rpx,
      600rpx 0;
  }
}

.directive-projection::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      rgba(18, 16, 16, 0) 0,
      rgba(18, 16, 16, 0) 2rpx,
      rgba(0, 0, 0, 0.15) 2rpx,
      rgba(0, 0, 0, 0.15) 4rpx
    ),
    linear-gradient(
      90deg,
      rgba(255, 0, 0, 0.04),
      rgba(0, 255, 0, 0.02),
      rgba(0, 0, 255, 0.04)
    );
  pointer-events: none;
  z-index: 100;
  opacity: 0.4;
}

.nav-telemetry-points {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.tele-point {
  position: absolute;
  font-family: "Courier New", Courier, monospace;
  font-size: 12rpx;
  color: rgba(0, 200, 255, 0.2);
  letter-spacing: 1rpx;
}
.tele-point.p1 {
  top: 20rpx;
  left: 20rpx;
}
.tele-point.p2 {
  top: 20rpx;
  right: 20rpx;
}
.tele-point.p3 {
  bottom: 180rpx;
  left: 20rpx;
}
.tele-point.p4 {
  bottom: 180rpx;
  right: 20rpx;
}

@keyframes navElementIn {
  0% {
    opacity: 0;
    transform: scaleY(0.1) translateY(80rpx);
    filter: brightness(4) blur(12px);
  }
  70% {
    opacity: 0.9;
    transform: scaleY(1.05) translateY(-5rpx);
    filter: brightness(1.8);
  }
  100% {
    opacity: 1;
    transform: scaleY(1) translateY(0);
    filter: brightness(1) blur(0);
  }
}

.dp-visible .projection-card {
  animation: navElementIn 0.8s cubic-bezier(0.19, 1, 0.22, 1) both;
}

.nav-hud-deco {
  width: 100%;
  max-width: 640rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
  position: relative;
  padding: 0 10rpx;
  height: 64rpx;
  z-index: 5;
}

.nav-deco-left,
.nav-deco-right {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* ##### 极简飞船导航 HUD (重构版) ##### */

/* 核心判决 */
.nav-main-verdict {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.nav-tag-minimal {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
  text-transform: uppercase;
}

.nav-verdict-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.5;
  letter-spacing: 2rpx;
  text-align: center;
}

.nav-reading-tags {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.nav-mini-tag {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(0, 200, 255, 0.6);
  letter-spacing: 1rpx;
}

/* 指令组 */
.nav-execution-params {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.nav-param-group {
  width: 100%;
}

.nav-group-title {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
  padding-left: 16rpx;
  border-left: 2rpx solid rgba(0, 200, 255, 0.4);
}

.nav-param-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.nav-param-item {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

/* 终端按钮 */
.nav-terminal-actions {
  display: flex;
  gap: 32rpx;
  width: 100%;
  margin-top: 80rpx;
}

.nav-btn {
  flex: 1;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
  color: rgba(255, 255, 255, 0.8);
}

.nav-btn--primary {
  border-color: rgba(0, 200, 255, 0.4);
  background: rgba(0, 200, 255, 0.1);
  color: #00c8ff;
}

.strategy-result-spacer {
  flex: 1;
  min-height: 40rpx;
}

/* ===== 15. reduce-motion 强制兜底 ===== */
.reduce-motion .directive-projection,
.reduce-motion .projection-card,
.reduce-motion .sync-bar,
.reduce-motion .generation-status,
.reduce-motion .wait-steps,
.reduce-motion .nav-core-stage,
.reduce-motion .ignition-console {
  animation: none !important;
  transition: none !important;
  filter: none !important;
}

.reduce-motion .directive-projection,
.reduce-motion .directive-projection.dp-visible,
.reduce-motion .projection-card {
  opacity: 1 !important;
  transform: none !important;
}

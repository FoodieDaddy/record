/* ===== 1. 全局容器 ===== */
.page-container {
  height: 100vh;
  min-height: 100vh;
  background:
    radial-gradient(circle at 20% 0%, rgba(0,175,255,0.08), transparent 32%),
    radial-gradient(circle at 90% 18%, rgba(94,92,230,0.05), transparent 30%),
    #05070A;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* ===== 2. reduce-motion 静默模式 ===== */
.reduce-motion .avionics-core,
.reduce-motion .scan-ring,
.reduce-motion .gen-core--breathing,
.reduce-motion .gen-log-line,
.reduce-motion .gen-log-typing,
.reduce-motion .gen-check-item,
.reduce-motion .result-card,
.reduce-motion .result-tags-inline,
.reduce-motion .result-section,
.reduce-motion .result-actions,
.reduce-motion .poster-gen-bar-fill,
.reduce-motion .poster-gen-text,
.reduce-motion .tap-hint {
  animation: none !important;
  transition-duration: 0ms !important;
}

/* ===== 3. 通用元素 ===== */
.page-kicker {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.6);
  letter-spacing: 6rpx;
}

.page-date {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255,255,255,0.12);
}

.page-lunar {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255,255,255,0.15);
  margin-top: 8rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 48rpx;
  opacity: 0;
  animation: fadeIn 0.6s ease 0.3s forwards;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.92);
  letter-spacing: 8rpx;
  white-space: nowrap;
}

.section-divider {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,175,255,0.15), transparent);
}

/* ===== 4. 飞控核心通用元素 ===== */
.core-inner {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.core-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255,255,255,0.04);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.core-ring--1 {
  width: 200rpx;
  height: 200rpx;
  border-color: rgba(255,255,255,0.06);
}

.core-ring--2 {
  width: 130rpx;
  height: 130rpx;
  border-color: rgba(255,255,255,0.05);
}

.core-ring--3 {
  width: 60rpx;
  height: 60rpx;
  border-color: rgba(255,255,255,0.04);
}

.core-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  position: relative;
  z-index: 1;
}

/* ===== 5. 扫描环 ===== */
.scan-ring {
  position: absolute;
  width: 340rpx;
  height: 340rpx;
  border-radius: 50%;
  border: 1px solid rgba(0,175,255,0.2);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
  box-shadow: 0 0 12rpx rgba(0,175,255,0.08);
}

.scan-ring--idle {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--gen {
  animation: scanRotate 8s linear infinite;
}

@keyframes scanRotate {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to   { transform: translate(-50%, -50%) rotate(360deg); }
}

/* ===== 6. idle 屏 ===== */
.idle-screen {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

.idle-header {
  text-align: center;
  margin-bottom: 48rpx;
  opacity: 0;
  animation: fadeInDown 0.8s ease forwards;
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.core-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 56rpx;
  opacity: 0;
  animation: coreEntrance 0.7s cubic-bezier(0.23, 1, 0.32, 1) 0.5s forwards;
}

@keyframes coreEntrance {
  from {
    opacity: 0;
    transform: translateY(60rpx) scale(0.85);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.avionics-core {
  width: 280rpx;
  height: 440rpx;
  position: relative;
  border-radius: 20rpx;
  background: linear-gradient(165deg, #12141A 0%, #0A0C12 100%);
  border: 1rpx solid rgba(0,175,255,0.12);
  box-shadow:
    0 12rpx 48rpx rgba(0,0,0,0.6),
    0 1rpx 0 rgba(0,175,255,0.08) inset;
  overflow: hidden;
  cursor: pointer;
  z-index: 2;
  transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1),
              box-shadow 0.4s ease;
}

.avionics-core:active {
  transform: scale(0.97);
}

.tap-hint {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
  letter-spacing: 6rpx;
  margin-top: 40rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; }
  50%      { opacity: 0.6; }
}

.idle-info {
  text-align: center;
  margin-bottom: 48rpx;
  opacity: 0;
  animation: fadeIn 0.6s ease 0.9s forwards;
}

.idle-info-label {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(255,255,255,0.25);
  letter-spacing: 4rpx;
}

.idle-info-tags {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.5);
  letter-spacing: 4rpx;
}

/* ===== 7. generating 屏 ===== */
.gen-screen {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: #05070A;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

.gen-fade-out {
  animation: fadeOut 0.4s ease forwards;
}

@keyframes fadeOut {
  to { opacity: 0; }
}

.gen-core-area {
  position: relative;
  width: 280rpx;
  height: 440rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.gen-core {
  width: 280rpx;
  height: 440rpx;
  border-radius: 20rpx;
  background: linear-gradient(165deg, #12141A 0%, #0A0C12 100%);
  border: 1rpx solid rgba(0,175,255,0.12);
  overflow: hidden;
  position: relative;
  z-index: 2;
}

.gen-core--breathing {
  animation: coreBreath 2.4s ease-in-out infinite;
}

@keyframes coreBreath {
  0%, 100% { transform: scale(0.96); opacity: 0.7; }
  50%      { transform: scale(1.02); opacity: 1; }
}

.gen-title-block {
  text-align: center;
  margin-bottom: 40rpx;
}

.gen-main-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.92);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.gen-sub-title {
  display: block;
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(255,255,255,0.3);
  letter-spacing: 2rpx;
  line-height: 1.6;
  max-width: 520rpx;
  margin: 0 auto;
}

/* 阶段清单 */
.gen-checklist {
  width: 400rpx;
  margin-bottom: 40rpx;
}

.gen-check-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  opacity: 0.3;
  transition: opacity 0.3s ease;
}

.gen-check-item--done {
  opacity: 0.8;
}

.gen-check-mark {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(0,175,255,0.32);
  background: rgba(0,175,255,0.08);
  flex-shrink: 0;
}

.gen-check-mark--active {
  border-color: rgba(0,200,255,0.72);
  background: rgba(0,200,255,0.18);
}

.gen-check-mark--done {
  border-color: rgba(48,209,88,0.72);
  background: #30D158;
  box-shadow: 0 0 10rpx rgba(48,209,88,0.38);
}

.gen-check-label {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 2rpx;
}

.gen-check-count {
  text-align: center;
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.4);
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

/* 终端日志流 */
.gen-terminal {
  width: 520rpx;
  margin-bottom: 32rpx;
  min-height: 200rpx;
}

.gen-log-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
  opacity: 0;
  transform: translateY(8rpx);
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.gen-log-line--visible {
  opacity: 1;
  transform: translateY(0);
}

.gen-log-prefix {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.6);
  flex-shrink: 0;
  width: 140rpx;
}

.gen-log-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(255,255,255,0.45);
  letter-spacing: 1rpx;
}

.gen-log-typing {
  border-right: 2rpx solid rgba(0,175,255,0.6);
  animation: blink 0.6s step-end infinite;
}

@keyframes blink {
  0%, 100% { border-color: rgba(0,175,255,0.6); }
  50%      { border-color: transparent; }
}

/* 超时提示 */
.gen-timeout {
  text-align: center;
  margin-top: 16rpx;
}

.gen-timeout-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(255,170,51,0.7);
  letter-spacing: 2rpx;
}

.gen-timeout--long {
  margin-top: 24rpx;
}

.gen-timeout-actions {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-top: 24rpx;
}

.gen-timeout-btn {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 3rpx;
  padding: 16rpx 40rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 4rpx;
}

.gen-timeout-btn--primary {
  color: #00AFFF;
  border-color: rgba(0,175,255,0.3);
}

/* ===== 8. success 屏 ===== */
.success-screen {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx 160rpx;
  box-sizing: border-box;
}

.success-header {
  text-align: center;
  margin-bottom: 32rpx;
  opacity: 0;
  animation: fadeInDown 0.6s ease forwards;
}

/* 结果卡片 */
.result-card {
  width: 100%;
  max-width: 640rpx;
  background: rgba(10,15,24,0.92);
  border: 1rpx solid rgba(0,175,255,0.18);
  border-radius: 20rpx;
  padding: 0;
  position: relative;
  overflow: hidden;
  margin-bottom: 40rpx;
  opacity: 0;
  transform: scale(0.9);
  animation: revealScale 0.5s cubic-bezier(0.23, 1, 0.32, 1) 0.2s forwards;
  box-shadow:
    0 0 40rpx rgba(0,175,255,0.06),
    0 24rpx 80rpx rgba(0,0,0,0.4);
}

/* 卡片顶部光晕 */
.result-card-glow {
  position: absolute;
  top: -60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 320rpx;
  height: 200rpx;
  border-radius: 50%;
  background: var(--accent, #00AFFF);
  opacity: 0.06;
  filter: blur(60px);
  pointer-events: none;
}

/* 卡片头部区域 */
.result-card-header {
  padding: 48rpx 44rpx 32rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.result-card-title {
  font-size: 48rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.95);
  letter-spacing: 6rpx;
  text-shadow: 0 0 32rpx rgba(0,175,255,0.15);
}

.result-card-subtitle {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255,255,255,0.22);
  text-transform: uppercase;
  letter-spacing: 6rpx;
  margin-top: 12rpx;
}

/* 核心建议区域 */
.result-card-body {
  padding: 0 44rpx 36rpx;
  position: relative;
  z-index: 1;
}

.result-card-verdict-label {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(0,175,255,0.45);
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.result-card-verdict {
  font-size: 30rpx;
  font-weight: 500;
  color: rgba(255,255,255,0.88);
  line-height: 1.65;
  letter-spacing: 1rpx;
  text-shadow: 0 0 24rpx rgba(0,175,255,0.08);
}

.result-card-divider {
  width: 80%;
  height: 1rpx;
  margin: 0 auto;
  background: linear-gradient(90deg, transparent, rgba(0,175,255,0.2), transparent);
}

/* 标签行（卡片内） */
.result-tags-inline {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 28rpx 44rpx 36rpx;
  position: relative;
  z-index: 1;
}

.result-tag {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.72);
  letter-spacing: 3rpx;
  padding: 10rpx 28rpx;
  background: rgba(0,175,255,0.06);
  border: 1rpx solid rgba(0,175,255,0.16);
  border-radius: 6rpx;
}

@keyframes revealScale {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* 区块 */
.result-section {
  width: 100%;
  max-width: 640rpx;
  margin-bottom: 32rpx;
  opacity: 0;
  animation: fadeIn 0.4s ease 0.7s forwards;
}

.result-section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.result-section-zh {
  color: #00C8FF;
  font-weight: 600;
}

.result-section-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  font-weight: 700;
  color: #30D158;
  border: 1rpx solid rgba(48,209,88,0.3);
  border-radius: 4rpx;
  flex-shrink: 0;
}

.result-section-icon--risk {
  color: #FF453A;
  border-color: rgba(255,69,58,0.3);
}

/* 列表卡片容器 */
.result-list-card {
  background: rgba(255,255,255,0.02);
  border: 1rpx solid rgba(255,255,255,0.05);
  border-radius: 14rpx;
  padding: 20rpx 28rpx;
}

.result-list-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 12rpx 0;
}

.result-list-item + .result-list-item {
  border-top: 1rpx solid rgba(255,255,255,0.04);
}

.result-list-dot {
  display: block;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 14rpx;
}

.result-list-dot--buff {
  background: #30D158;
  box-shadow: 0 0 8rpx rgba(48,209,88,0.4);
}

.result-list-dot--risk {
  background: #FF453A;
  box-shadow: 0 0 8rpx rgba(255,69,58,0.3);
}

.result-list-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.62);
  line-height: 1.55;
  letter-spacing: 1rpx;
}

/* 操作区 */
.result-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
  max-width: 640rpx;
  margin-top: 8rpx;
  opacity: 0;
  animation: fadeIn 0.4s ease 0.9s forwards;
}

.result-actions .flight-secondary,
.result-actions .flight-primary {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.result-btn-label {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
}

.result-btn--secondary {
  background: rgba(255,255,255,0.02);
  border: 1rpx solid rgba(255,255,255,0.1);
}

.result-btn--secondary .result-btn-label {
  color: rgba(255,255,255,0.38);
}

.result-btn--primary {
  background: rgba(0,175,255,0.06);
  border: 1rpx solid rgba(0,175,255,0.28);
  box-shadow: 0 0 20rpx rgba(0,175,255,0.08);
}

.result-btn--primary .result-btn-label {
  color: #00AFFF;
}

/* 按钮底部光效 */
.result-btn--primary::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0,175,255,0.5), transparent);
  border-radius: 1rpx;
}

/* 错误图标符号 */
.error-icon-symbol {
  font-family: 'Courier New', Courier, monospace;
}

/* ===== 9. error 屏 ===== */
.error-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.error-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,69,58,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Courier New', Courier, monospace;
  font-size: 36rpx;
  color: #FF453A;
  margin-bottom: 32rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.92);
  margin-bottom: 16rpx;
}

.error-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
  letter-spacing: 2rpx;
  margin-bottom: 48rpx;
  text-align: center;
}

.error-actions {
  display: flex;
  gap: 24rpx;
}

.error-btn {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: #00AFFF;
  letter-spacing: 4rpx;
  padding: 16rpx 48rpx;
  border: 1rpx solid rgba(0,175,255,0.3);
  border-radius: 4rpx;
}

.error-btn:active {
  opacity: 0.6;
}

/* ===== 10. 倒计时 ===== */
.countdown-bar {
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 14rpx 32rpx;
  background: rgba(0,175,255,0.03);
  border: 1rpx solid rgba(0,175,255,0.08);
  border-radius: 8rpx;
}

.countdown-label {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255,255,255,0.22);
  letter-spacing: 3rpx;
}

.countdown-value {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.6);
  letter-spacing: 2rpx;
}

/* ===== 11. 海报弹层 ===== */
.poster-mask {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0,0,0,0.92);
  backdrop-filter: blur(16px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.poster-container {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.poster-gen {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  padding: 80rpx 0;
}

.poster-gen-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  color: rgba(0,175,255,0.7);
  letter-spacing: 4rpx;
  animation: posterBreathe 1.5s ease-in-out infinite;
}

@keyframes posterBreathe {
  0%, 100% { opacity: 0.4; }
  50%      { opacity: 0.9; }
}

.poster-gen-bar {
  width: 300rpx;
  height: 4rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 2rpx;
  overflow: hidden;
}

.poster-gen-bar-fill {
  width: 40%;
  height: 100%;
  background: rgba(0,175,255,0.6);
  border-radius: 2rpx;
  animation: genBarSlide 1.2s ease-in-out infinite;
}

@keyframes genBarSlide {
  0%   { transform: translateX(-100%); }
  100% { transform: translateX(350%); }
}

.poster-preview {
  width: 100%;
  margin-bottom: 32rpx;
}

.poster-image {
  width: 100%;
  border-radius: 8rpx;
  border: 1rpx solid rgba(0,175,255,0.2);
}

.poster-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 60rpx 0;
}

.poster-error-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  color: rgba(255,69,58,0.8);
  letter-spacing: 2rpx;
}

.poster-error-actions {
  display: flex;
  gap: 24rpx;
}

.poster-error-btn {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 3rpx;
  padding: 16rpx 40rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 4rpx;
}

.poster-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.poster-btn {
  flex: 1;
  text-align: center;
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  padding: 20rpx 0;
  border-radius: 4rpx;
  transition: opacity 0.15s ease;
}

.poster-btn:active {
  opacity: 0.5;
}

.poster-btn--save {
  color: #F5F5F7;
  background: rgba(0,175,255,0.1);
  border: 1rpx solid rgba(0,175,255,0.3);
}

.poster-btn--share {
  color: #00AFFF;
  background: rgba(0,175,255,0.08);
  border: 1rpx solid rgba(0,175,255,0.4);
  box-shadow: 0 0 12rpx rgba(0,175,255,0.15);
}

.poster-btn--close {
  color: rgba(255,255,255,0.35);
  border: 1rpx solid rgba(255,255,255,0.08);
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}

/* ===== 12. 动画关键帧汇总 ===== */
@keyframes fadeIn {
  to { opacity: 1; }
}

/* ===== 13. 策略主题卡 ===== */
.strategy-hero-card {
  width: 100%;
  max-width: 640rpx;
  margin: 0 0 32rpx;
  padding: 30rpx 32rpx;
  opacity: 0;
  animation: fadeIn 0.4s ease 0.15s forwards;
}

.strategy-theme-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.strategy-theme-label {
  font-size: 22rpx;
  color: #00C8FF;
  letter-spacing: 3rpx;
}

.strategy-theme-code {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(255,255,255,0.34);
  letter-spacing: 4rpx;
}

.strategy-theme-text {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
  color: rgba(255,255,255,0.92);
  letter-spacing: 2rpx;
  margin-bottom: 18rpx;
}

.strategy-summary-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.75;
  color: rgba(255,255,255,0.56);
}

/* ===== 14. 编号列表 ===== */
.vector-index {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  flex-shrink: 0;
  border-radius: 6rpx;
  margin-right: 4rpx;
}

.vector-index--pos {
  color: #30D158;
  background: rgba(48,209,88,0.08);
  border: 1rpx solid rgba(48,209,88,0.18);
}

.vector-index--neg {
  color: #FF453A;
  background: rgba(255,69,58,0.08);
  border: 1rpx solid rgba(255,69,58,0.18);
}

/* ===== 15. 区块 kicker ===== */
.result-section-kicker {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(255,255,255,0.34);
  margin-left: 12rpx;
}

.result-section-kicker--risk {
  color: rgba(255,69,58,0.55);
}

.verdict-kicker {
  font-family: 'Courier New', Courier, monospace;
  font-size: 16rpx;
  letter-spacing: 3rpx;
  color: rgba(255,255,255,0.34);
  margin-left: 8rpx;
}

/* ===== 16. 按钮 code ===== */
.result-btn-code {
  display: block;
  font-family: 'Courier New', Courier, monospace;
  font-size: 16rpx;
  letter-spacing: 3rpx;
  color: rgba(255,255,255,0.22);
  margin-top: 4rpx;
}

.result-btn-code--primary {
  color: rgba(0,175,255,0.40);
}

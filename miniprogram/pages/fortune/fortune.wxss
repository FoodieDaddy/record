/* ===== 1. 全局容器 ===== */
.strategy-page {
  height: 100vh;
  min-height: 100vh;
  background:
    radial-gradient(circle at 20% 0%, rgba(0,175,255,0.08), transparent 32%),
    radial-gradient(circle at 90% 18%, rgba(94,92,230,0.05), transparent 30%),
    #05070A;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* ===== 2. reduce-motion 静默模式 ===== */
.reduce-motion .strategy-core-visual,
.reduce-motion .scan-ring,
.reduce-motion .strategy-reactor-core,
.reduce-motion .strategy-log-line,
.reduce-motion .strategy-log-typing,
.reduce-motion .strategy-step-item,
.reduce-motion .strategy-tag-pill,
.reduce-motion .strategy-insight,
.reduce-motion .strategy-section,
.reduce-motion .strategy-actions,
.reduce-motion .strategy-regen-modal--animate,
.reduce-motion .poster-gen-bar-fill,
.reduce-motion .poster-gen-text,
.reduce-motion .strategy-core-label,
.reduce-motion .strategy-reset-dot {
  animation: none !important;
  transition-duration: 0ms !important;
}

/* ===== 3. 飞控核心通用元素 ===== */
.core-inner {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.core-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255,255,255,0.04);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.core-ring--1 {
  width: 200rpx;
  height: 200rpx;
  border-color: rgba(255,255,255,0.06);
}

.core-ring--2 {
  width: 130rpx;
  height: 130rpx;
  border-color: rgba(255,255,255,0.05);
}

.core-ring--3 {
  width: 60rpx;
  height: 60rpx;
  border-color: rgba(255,255,255,0.04);
}

.core-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  position: relative;
  z-index: 1;
}

/* ===== 4. 扫描环 ===== */
.scan-ring {
  position: absolute;
  width: 340rpx;
  height: 340rpx;
  border-radius: 50%;
  border: 1px solid rgba(0,175,255,0.2);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
  box-shadow: 0 0 12rpx rgba(0,175,255,0.08);
}

.scan-ring--idle {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--gen {
  animation: scanRotate 8s linear infinite;
}

@keyframes scanRotate {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to   { transform: translate(-50%, -50%) rotate(360deg); }
}

/* ===== 5. 启动卡牌页 ===== */
.strategy-launch {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

.strategy-launch-header {
  text-align: center;
  margin-bottom: 48rpx;
  opacity: 0;
  animation: fadeInDown 0.8s ease forwards;
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.strategy-launch-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 6rpx;
}

.strategy-launch-kicker {
  display: block;
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(0,175,255,0.28);
  letter-spacing: 6rpx;
  margin-top: 8rpx;
}

.strategy-launch-date {
  display: block;
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(126, 156, 180, 0.12);
  margin-top: 4rpx;
}

/* 复位状态条 */
.strategy-reset-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  background: rgba(0,175,255,0.04);
  border: 1rpx solid rgba(0,175,255,0.12);
  border-radius: 8rpx;
  margin-bottom: 40rpx;
  opacity: 0;
  animation: fadeIn 0.4s ease 0.2s forwards;
}

.strategy-reset-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #00C8FF;
  box-shadow: 0 0 8rpx rgba(0,200,255,0.5);
  animation: resetPulse 2s ease-in-out infinite;
}

@keyframes resetPulse {
  0%, 100% { opacity: 0.5; }
  50%      { opacity: 1; }
}

.strategy-reset-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,200,255,0.6);
  letter-spacing: 2rpx;
}

/* 核心卡牌容器（scan-ring 定位参考） */
.strategy-core-wrap {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  opacity: 0;
  animation: coreEntrance 0.7s cubic-bezier(0.23, 1, 0.32, 1) 0.5s forwards;
}

/* 核心卡牌 */
.strategy-core-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 320rpx;
  height: 480rpx;
  position: relative;
  border-radius: 20rpx;
  background: linear-gradient(165deg, #12141A 0%, #0A0C12 100%);
  border: 1rpx solid rgba(0,175,255,0.12);
  box-shadow:
    0 12rpx 48rpx rgba(0,0,0,0.6),
    0 1rpx 0 rgba(0,175,255,0.08) inset;
  overflow: hidden;
  cursor: pointer;
  z-index: 2;
  transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1),
              box-shadow 0.4s ease,
              border-color 0.4s ease;
}

.strategy-core-card:active {
  transform: scale(0.97);
}

.strategy-core-card--armed {
  border-color: rgba(0,200,255,0.28);
  box-shadow:
    0 12rpx 48rpx rgba(0,0,0,0.6),
    0 0 24rpx rgba(0,200,255,0.06),
    0 1rpx 0 rgba(0,200,255,0.12) inset;
}

@keyframes coreEntrance {
  from {
    opacity: 0;
    transform: translateY(60rpx) scale(0.85);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.strategy-core-visual {
  width: 280rpx;
  height: 280rpx;
  position: relative;
  margin-bottom: 24rpx;
}

.strategy-core-label {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 6rpx;
  margin-bottom: 8rpx;
}

.strategy-core-sublabel {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.5);
  letter-spacing: 4rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; }
  50%      { opacity: 0.7; }
}

/* 底部说明 */
.strategy-launch-info {
  text-align: center;
  margin-bottom: 32rpx;
  opacity: 0;
  animation: fadeIn 0.6s ease 0.9s forwards;
}

.strategy-launch-info-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(126, 156, 180, 0.25);
  letter-spacing: 3rpx;
}

/* ===== 6. 计算页 ===== */
.strategy-generate {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: #05070A;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

/* 核心舱 HUD */
.strategy-reactor {
  position: relative;
  width: 280rpx;
  height: 440rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.strategy-reactor-core {
  width: 280rpx;
  height: 440rpx;
  border-radius: 20rpx;
  background: linear-gradient(165deg, #12141A 0%, #0A0C12 100%);
  border: 1rpx solid rgba(0,175,255,0.12);
  overflow: hidden;
  position: relative;
  z-index: 2;
  animation: coreBreath 2.4s ease-in-out infinite;
}

@keyframes coreBreath {
  0%, 100% { transform: scale(0.96); opacity: 0.7; }
  50%      { transform: scale(1.02); opacity: 1; }
}

/* 主文案 */
.strategy-gen-label {
  text-align: center;
  margin-bottom: 40rpx;
}

.strategy-gen-kicker {
  display: block;
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.28);
  letter-spacing: 6rpx;
  margin-bottom: 12rpx;
}

.strategy-gen-sub {
  display: block;
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(126, 156, 180, 0.30);
  letter-spacing: 2rpx;
  line-height: 1.6;
  max-width: 520rpx;
  margin: 0 auto;
}

/* 进度步骤 */
.strategy-progress-rail {
  width: 400rpx;
  margin-bottom: 40rpx;
}

.strategy-step-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  opacity: 0.3;
  transition: opacity 0.3s ease;
}

.strategy-step-item--active {
  opacity: 0.7;
}

.strategy-step-item--done {
  opacity: 0.85;
}

.strategy-step-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(0,175,255,0.32);
  background: rgba(0,175,255,0.08);
  flex-shrink: 0;
  transition: background 0.3s ease, border-color 0.3s ease;
}

.strategy-step-dot--active {
  border-color: rgba(0,200,255,0.72);
  background: rgba(0,200,255,0.18);
}

.strategy-step-dot--done {
  border-color: rgba(48,209,88,0.72);
  background: #30D158;
  box-shadow: 0 0 10rpx rgba(48,209,88,0.38);
}

.strategy-step-label {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

.strategy-step-count {
  text-align: center;
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.4);
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

/* 日志流 */
.strategy-terminal {
  width: 520rpx;
  margin-bottom: 32rpx;
  min-height: 200rpx;
}

.strategy-log-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
  opacity: 0;
  transform: translateY(8rpx);
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.strategy-log-line--visible {
  opacity: 1;
  transform: translateY(0);
}

.strategy-log-prefix {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.5);
  flex-shrink: 0;
  width: 80rpx;
}

.strategy-log-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(140, 176, 205, 0.45);
  letter-spacing: 1rpx;
}

.strategy-log-typing {
  border-right: 2rpx solid rgba(0,175,255,0.6);
  animation: blink 0.6s step-end infinite;
}

@keyframes blink {
  0%, 100% { border-color: rgba(0,175,255,0.6); }
  50%      { border-color: transparent; }
}

/* ===== 7. 结果页 ===== */
.strategy-result {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx 0;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.strategy-result-header {
  text-align: center;
  margin-bottom: 32rpx;
  opacity: 0;
  animation: fadeInDown 0.6s ease forwards;
}

.strategy-result-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 6rpx;
}

.strategy-result-kicker {
  display: block;
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(0,175,255,0.28);
  letter-spacing: 6rpx;
  margin-top: 8rpx;
}

.strategy-result-date {
  display: block;
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(126, 156, 180, 0.12);
  margin-top: 4rpx;
}

/* 状态胶囊 */
.strategy-tag-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 36rpx;
  border-radius: 999rpx;
  border: 1rpx solid;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  margin-bottom: 28rpx;
  opacity: 0;
  animation: fadeIn 0.4s ease 0.1s forwards;
}

/* HUD 芯片 */
.strategy-hud-chips {
  display: flex;
  gap: 12rpx;
  width: 100%;
  max-width: 640rpx;
  margin-bottom: 28rpx;
  opacity: 0;
  animation: fadeIn 0.4s ease 0.2s forwards;
}

.strategy-hud-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 8rpx;
  background: var(--bg-card);
  border: 1rpx solid rgba(255,255,255,0.05);
  border-radius: 10rpx;
}

.strategy-hud-chip-label {
  font-family: 'Courier New', Courier, monospace;
  font-size: 16rpx;
  color: rgba(126, 156, 180, 0.28);
  letter-spacing: 2rpx;
}

.strategy-hud-chip-value {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: rgba(0,175,255,0.72);
  letter-spacing: 1rpx;
  font-weight: 600;
}

/* 核心洞察 */
.strategy-insight {
  width: 100%;
  max-width: 640rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 28rpx;
  background: var(--bg-card);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  opacity: 0;
  animation: fadeIn 0.4s ease 0.25s forwards;
}

.strategy-insight-text {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.6;
  letter-spacing: 2rpx;
}

/* 区块标题 */
.strategy-section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.strategy-section-title {
  font-size: 22rpx;
  color: var(--accent, #0A84FF);
  letter-spacing: 3rpx;
  font-weight: 600;
}

.strategy-section-title--pos {
  color: #00C8FF;
}

.strategy-section-title--neg {
  color: #FF453A;
}

.strategy-section-kicker {
  font-family: 'Courier New', Courier, monospace;
  font-size: 16rpx;
  letter-spacing: 3rpx;
  color: rgba(126, 156, 180, 0.22);
}

.strategy-section-kicker--neg {
  color: rgba(255,69,58,0.45);
}

/* 策略读数 */
.strategy-reading {
  width: 100%;
  max-width: 640rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
  background: var(--bg-card);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 16rpx;
  opacity: 0;
  animation: fadeIn 0.4s ease 0.3s forwards;
}

.strategy-reading-head {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.strategy-reading-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 3rpx;
}

.strategy-reading-sub {
  font-family: 'Courier New', Courier, monospace;
  font-size: 16rpx;
  color: rgba(126, 156, 180, 0.22);
  letter-spacing: 3rpx;
}

.strategy-reading-tags {
  display: flex;
  gap: 12rpx;
}

.strategy-reading-tag {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.6);
  letter-spacing: 2rpx;
  padding: 6rpx 16rpx;
  background: rgba(0,175,255,0.05);
  border: 1rpx solid rgba(0,175,255,0.12);
  border-radius: 6rpx;
}

/* 结果区块 */
.strategy-section {
  width: 100%;
  max-width: 640rpx;
  margin-bottom: 28rpx;
  opacity: 0;
  animation: fadeIn 0.4s ease 0.4s forwards;
}

.strategy-section-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  font-weight: 700;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.strategy-section-icon--pos {
  color: #30D158;
  border: 1rpx solid rgba(48,209,88,0.3);
}

.strategy-section-icon--neg {
  color: #FF453A;
  border: 1rpx solid rgba(255,69,58,0.3);
}

/* 列表卡片 */
.strategy-list-card {
  background: var(--bg-card);
  border: 1rpx solid rgba(255,255,255,0.05);
  border-radius: 14rpx;
  padding: 16rpx 24rpx;
}

.strategy-list-card--risk {
  border-color: rgba(255,69,58,0.08);
}

.strategy-list-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 12rpx 0;
}

.strategy-list-item + .strategy-list-item {
  border-top: 1rpx solid rgba(255,255,255,0.04);
}

.strategy-list-index {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  flex-shrink: 0;
  border-radius: 6rpx;
  margin-right: 4rpx;
}

.strategy-list-index--pos {
  color: #30D158;
  background: rgba(48,209,88,0.08);
  border: 1rpx solid rgba(48,209,88,0.18);
}

.strategy-list-index--neg {
  color: #FF453A;
  background: rgba(255,69,58,0.08);
  border: 1rpx solid rgba(255,69,58,0.18);
}

.strategy-list-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.55;
  letter-spacing: 1rpx;
}

/* 底部操作区 */
.strategy-result-spacer {
  flex: 1;
  min-height: 40rpx;
}

.strategy-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
  max-width: 640rpx;
  padding-bottom: env(safe-area-inset-bottom);
  opacity: 0;
  animation: fadeIn 0.4s ease 0.6s forwards;
}

.strategy-action-btn {
  flex: 1;
  position: relative;
  height: 80rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.strategy-action-btn--secondary {
  border: 1rpx solid rgba(126, 156, 180, 0.10);
  background: var(--bg-card);
}

.strategy-action-btn--secondary:active {
  background: var(--glass-bg);
}

.strategy-action-btn--secondary .strategy-action-text {
  color: var(--text-secondary);
}

.strategy-action-btn--secondary .strategy-action-kicker {
  color: rgba(126, 156, 180, 0.18);
}

.strategy-action-btn--primary {
  border: 1rpx solid var(--accent, rgba(10,132,255,0.45));
  background: linear-gradient(135deg, rgba(10,132,255,0.15), rgba(0,200,255,0.06));
  box-shadow: 0 0 24rpx rgba(10,132,255,0.08);
}

.strategy-action-btn--primary:active {
  background: linear-gradient(135deg, rgba(10,132,255,0.25), rgba(0,200,255,0.12));
}

.strategy-action-btn--primary .strategy-action-text {
  color: var(--accent, #00C8FF);
}

.strategy-action-btn--primary .strategy-action-kicker {
  color: rgba(0,175,255,0.35);
}

.strategy-action-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.strategy-action-kicker {
  display: block;
  font-family: 'Courier New', Courier, monospace;
  font-size: 16rpx;
  letter-spacing: 3rpx;
  margin-top: 2rpx;
}

/* ===== 8. 倒计时 ===== */
.countdown-bar {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 14rpx 32rpx;
  background: rgba(0,175,255,0.03);
  border: 1rpx solid rgba(0,175,255,0.08);
  border-radius: 8rpx;
}

.countdown-label {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(126, 156, 180, 0.22);
  letter-spacing: 3rpx;
}

.countdown-value {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,175,255,0.6);
  letter-spacing: 2rpx;
}

/* ===== 9. 重新推演弹窗（推进舱风格） ===== */
.strategy-regen-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0,0,0,0.88);
  backdrop-filter: blur(12px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.strategy-regen-mask--show {
  opacity: 1;
}

.strategy-regen-modal {
  width: 100%;
  max-width: 640rpx;
  background: rgba(5,10,16,0.96);
  border: 1rpx solid rgba(10,132,255,0.32);
  border-radius: 16rpx;
  overflow: hidden;
  transform: translateY(24rpx);
  transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: 0 0 48rpx rgba(0,0,0,0.6), 0 0 24rpx rgba(10,132,255,0.06);
}

.strategy-regen-modal--animate {
  transform: translateY(0);
}

/* 顶部能量轨道 */
.strategy-modal-rail {
  height: 4rpx;
  background: var(--glass-bg);
  overflow: hidden;
}

.strategy-modal-rail-fill {
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(0,175,255,0.5), transparent);
  animation: railSweep 2s ease-in-out infinite;
}

@keyframes railSweep {
  0%   { transform: translateX(-100%); }
  100% { transform: translateX(200%); }
}

/* 小标签 */
.strategy-modal-tag {
  font-family: 'Courier New', Courier, monospace;
  font-size: 18rpx;
  color: rgba(0,175,255,0.55);
  letter-spacing: 4rpx;
  padding: 28rpx 32rpx 0;
}

/* 主标题 */
.strategy-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 3rpx;
  padding: 12rpx 32rpx 0;
}

/* 英文装饰 */
.strategy-modal-kicker {
  font-family: 'Courier New', Courier, monospace;
  font-size: 16rpx;
  color: rgba(126, 156, 180, 0.28);
  letter-spacing: 4rpx;
  padding: 8rpx 32rpx 0;
}

/* 推进核心图形 */
.strategy-modal-core {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 0;
}

.strategy-modal-core-bar {
  display: flex;
  gap: 8rpx;
  width: 320rpx;
  height: 12rpx;
}

.strategy-modal-core-seg {
  flex: 1;
  height: 100%;
  border-radius: 2rpx;
  background: rgba(0,175,255,0.08);
  border: 1rpx solid rgba(0,175,255,0.15);
}

.strategy-modal-core-seg--1 {
  animation: segPulse 1.5s ease-in-out 0s infinite;
}

.strategy-modal-core-seg--2 {
  animation: segPulse 1.5s ease-in-out 0.3s infinite;
}

.strategy-modal-core-seg--3 {
  animation: segPulse 1.5s ease-in-out 0.6s infinite;
}

@keyframes segPulse {
  0%, 100% { background: rgba(0,175,255,0.08); }
  50%      { background: rgba(0,175,255,0.2); }
}

.strategy-modal-core-block {
  width: 32rpx;
  height: 32rpx;
  border: 1rpx solid rgba(0,175,255,0.35);
  border-radius: 4rpx;
  background: rgba(0,175,255,0.06);
  box-shadow: 0 0 16rpx rgba(0,175,255,0.1);
}

/* 说明 */
.strategy-modal-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

/* 按钮 */
.strategy-modal-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}

.strategy-modal-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  border: 1rpx solid rgba(126, 156, 180, 0.10);
  background: var(--bg-card);
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 3rpx;
  transition: background 0.15s ease;
}

.strategy-modal-btn:active {
  background: var(--glass-bg);
}

.strategy-modal-btn--primary {
  border-color: rgba(10,132,255,0.45);
  background: linear-gradient(135deg, rgba(10,132,255,0.12), rgba(0,200,255,0.05));
  color: #00C8FF;
  box-shadow: 0 0 16rpx rgba(10,132,255,0.06);
}

.strategy-modal-btn--primary:active {
  background: linear-gradient(135deg, rgba(10,132,255,0.22), rgba(0,200,255,0.1));
}

/* ===== 10. 海报弹层（保留） ===== */
.poster-mask {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0,0,0,0.92);
  backdrop-filter: blur(16px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.poster-container {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.poster-gen {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  padding: 80rpx 0;
}

.poster-gen-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  color: rgba(0,175,255,0.7);
  letter-spacing: 4rpx;
  animation: posterBreathe 1.5s ease-in-out infinite;
}

@keyframes posterBreathe {
  0%, 100% { opacity: 0.4; }
  50%      { opacity: 0.9; }
}

.poster-gen-bar {
  width: 300rpx;
  height: 4rpx;
  background: var(--glass-bg-hover);
  border-radius: 2rpx;
  overflow: hidden;
}

.poster-gen-bar-fill {
  width: 40%;
  height: 100%;
  background: rgba(0,175,255,0.6);
  border-radius: 2rpx;
  animation: genBarSlide 1.2s ease-in-out infinite;
}

@keyframes genBarSlide {
  0%   { transform: translateX(-100%); }
  100% { transform: translateX(350%); }
}

.poster-preview {
  width: 100%;
  margin-bottom: 32rpx;
}

.poster-image {
  width: 100%;
  border-radius: 8rpx;
  border: 1rpx solid rgba(0,175,255,0.2);
}

.poster-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 60rpx 0;
}

.poster-error-text {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  color: rgba(255,69,58,0.8);
  letter-spacing: 2rpx;
}

.poster-error-actions {
  display: flex;
  gap: 24rpx;
}

.poster-error-btn {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  color: var(--text-secondary);
  letter-spacing: 3rpx;
  padding: 16rpx 40rpx;
  border: 1rpx solid rgba(126, 156, 180, 0.10);
  border-radius: 4rpx;
}

.poster-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.poster-btn {
  flex: 1;
  text-align: center;
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  padding: 20rpx 0;
  border-radius: 4rpx;
  transition: opacity 0.15s ease;
}

.poster-btn:active {
  opacity: 0.5;
}

.poster-btn--save {
  color: #F5F5F7;
  background: rgba(0,175,255,0.1);
  border: 1rpx solid rgba(0,175,255,0.3);
}

.poster-btn--share {
  color: var(--color-cyan);
  background: rgba(0,175,255,0.08);
  border: 1rpx solid rgba(0,175,255,0.4);
  box-shadow: 0 0 12rpx rgba(0,175,255,0.15);
}

.poster-btn--close {
  color: rgba(126, 156, 180, 0.35);
  border: 1rpx solid var(--glass-border-light);
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}

/* ===== 11. 动画关键帧汇总 ===== */
@keyframes fadeIn {
  to { opacity: 1; }
}

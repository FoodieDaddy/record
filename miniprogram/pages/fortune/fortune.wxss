/* ===== 1. 全局容器 ===== */
.strategy-page {
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.08), transparent 50%),
    radial-gradient(circle at 20% 80%, rgba(5, 11, 18, 0.8), transparent 60%),
    #02060A;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  position: relative;
  /* 自定义 tabbar 140rpx + Home Indicator + 操作栏预留 */
  padding: 24rpx;
}

.strategy-page--overlay-active {
  overflow: hidden;
  filter: brightness(0.85) blur(2px);
  transition: filter 300ms ease;
}

.strategy-page--completed .directive-projection {
  position: relative;
  z-index: 3;
}
.strategy-page--completed .directive-projection::before {
  content: '';
  position: absolute;
  inset: -20rpx -12rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(2, 8, 14, 0.06), rgba(2, 8, 14, 0.12));
  z-index: -1;
}

/* ===== 星图舷窗 — 三层结构 ===== */
.nav-map-window {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: 0;
  pointer-events: none;
  opacity: 0.45;
  filter: saturate(0.6) brightness(0.8);
  transition:
    opacity 600ms cubic-bezier(0.22, 1, 0.36, 1),
    filter 600ms cubic-bezier(0.22, 1, 0.36, 1);
}

/* === 第一层：宇宙背景 + 星尘 === */
.nav-map-cosmos {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 72% 28%, rgba(85, 255, 170, 0.08), transparent 22%),
    radial-gradient(circle at 28% 68%, rgba(0, 180, 255, 0.08), transparent 26%),
    radial-gradient(circle at 50% 50%, rgba(0, 60, 120, 0.06), transparent 40%),
    linear-gradient(180deg, rgba(4, 18, 30, 0.72), rgba(2, 8, 14, 0.88));
}

/* 星尘噪点纹理（伪元素） */
.nav-map-cosmos::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      0deg,
      transparent 0,
      transparent 2rpx,
      rgba(200, 230, 255, 0.012) 2rpx,
      rgba(200, 230, 255, 0.012) 3rpx
    ),
    repeating-linear-gradient(
      90deg,
      transparent 0,
      transparent 3rpx,
      rgba(200, 230, 255, 0.008) 3rpx,
      rgba(200, 230, 255, 0.008) 4rpx
    );
  opacity: 0.7;
}

/* 星尘粒子 */
.nav-dust {
  position: absolute;
  border-radius: 50%;
  background: rgba(200, 230, 255, 0.8);
  animation: dustDrift 80s linear infinite;
}

@keyframes dustDrift {
  0%   { transform: translate(0, 0); }
  25%  { transform: translate(3rpx, -5rpx); }
  50%  { transform: translate(-2rpx, -8rpx); }
  75%  { transform: translate(4rpx, -3rpx); }
  100% { transform: translate(0, 0); }
}

/* === 第二层：主星图元素 === */

/* 轨道弧线（动态数据驱动） */
.nav-map-orbit {
  position: absolute;
  border: 1rpx solid rgba(0, 190, 255, 0.12);
  border-radius: 50%;
  animation: orbitBreathe var(--orbit-dur, 10s) ease-in-out infinite alternate;
  animation-delay: var(--orbit-delay, 0s);
}

@keyframes orbitBreathe {
  0%   { opacity: var(--orbit-opacity, 0.08); transform: rotate(var(--orbit-rot, 0deg)) scale(1); }
  100% { opacity: calc(var(--orbit-opacity, 0.08) + 0.04); transform: rotate(var(--orbit-rot, 0deg)) scale(1.03); }
}

/* 连接线 */
.nav-conn-line {
  position: absolute;
  background: linear-gradient(90deg, rgba(0, 200, 255, 0.15), rgba(0, 200, 255, 0.04));
  transform-origin: left center;
}

/* 随机航线 */
.nav-route-line {
  position: absolute;
  height: 2rpx;
  background: linear-gradient(
    90deg,
    rgba(0, 210, 255, 0.10),
    rgba(0, 210, 255, 0.32),
    rgba(88, 255, 160, 0.40)
  );
  transform-origin: left center;
}

/* 主航线 */
.nav-map-route {
  position: absolute;
  left: 150rpx;
  bottom: 118rpx;
  width: 390rpx;
  height: 2rpx;
  transform: rotate(-32deg);
  transform-origin: left center;
  background: linear-gradient(
    90deg,
    rgba(0, 210, 255, 0.16),
    rgba(0, 210, 255, 0.42),
    rgba(88, 255, 160, 0.58)
  );
  opacity: 0.28;
}

/* 光晕 */
.nav-glow {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 200, 255, 0.30), transparent 70%);
  filter: blur(20rpx);
}

/* 星点 */
.nav-star {
  position: absolute;
  border-radius: 50%;
  background: rgba(200, 230, 255, 0.9);
  box-shadow: 0 0 4rpx rgba(200, 230, 255, 0.4);
  animation: starTwinkle 3s ease-in-out infinite alternate;
  animation-delay: var(--flicker-delay, 0s);
}

@keyframes starTwinkle {
  0%   { opacity: 0.4; transform: scale(0.9); }
  100% { opacity: 1; transform: scale(1.1); }
}

/* 能量节点 */
.nav-energy-node {
  position: absolute;
  border-radius: 50%;
  background: rgba(0, 210, 255, 0.6);
  box-shadow:
    0 0 8rpx rgba(0, 210, 255, 0.4),
    0 0 20rpx rgba(0, 210, 255, 0.15);
  animation: nodePulse var(--pulse-dur, 4s) ease-in-out infinite;
  animation-delay: var(--pulse-delay, 0s);
}

@keyframes nodePulse {
  0%, 100% { opacity: 0.5; transform: scale(1); box-shadow: 0 0 8rpx rgba(0, 210, 255, 0.3); }
  50%      { opacity: 0.9; transform: scale(1.3); box-shadow: 0 0 16rpx rgba(0, 210, 255, 0.6); }
}

/* 扫描波纹 */
.nav-scan-wave {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  margin-left: -30rpx;
  margin-top: -30rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.12);
  border-radius: 50%;
  animation: scanWavePulse 3s ease-out infinite;
}

.nav-scan-wave::after {
  content: '';
  position: absolute;
  inset: -20rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.06);
  border-radius: 50%;
}

@keyframes scanWavePulse {
  0%   { transform: scale(0.8); opacity: 0.6; }
  100% { transform: scale(2); opacity: 0; }
}

/* 星体 */
.nav-planet {
  position: absolute;
  width: 38rpx;
  height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-planet-core {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(0, 210, 255, 0.9);
  box-shadow:
    0 0 16rpx rgba(0, 210, 255, 0.55),
    0 0 34rpx rgba(0, 150, 255, 0.22);
}

.nav-planet--origin {
  left: 128rpx;
  bottom: 96rpx;
}

.nav-planet--target {
  right: 128rpx;
  top: 96rpx;
}

.nav-planet--target .nav-planet-core {
  width: 16rpx;
  height: 16rpx;
  background: var(--target-color, rgba(88, 255, 160, 0.96));
  box-shadow:
    0 0 20rpx var(--target-color, rgba(88, 255, 160, 0.70)),
    0 0 46rpx rgba(88, 255, 160, 0.24);
}

.nav-planet-lock {
  position: absolute;
  inset: -6rpx;
  border: 1rpx solid var(--target-color, rgba(88, 255, 160, 0.35));
  border-radius: 50%;
  opacity: 0;
}

/* 中央星点 */
.nav-center-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 6rpx;
  height: 6rpx;
  margin: -3rpx 0 0 -3rpx;
  border-radius: 50%;
  background: rgba(70, 255, 145, 0.7);
  box-shadow: 0 0 10rpx rgba(70, 255, 145, 0.3);
}

/* === 第三层：HUD 氛围 === */

/* 坐标网格（极淡，边缘渐隐） */
.nav-hud-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0, 200, 255, 0.025) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 200, 255, 0.025) 1rpx, transparent 1rpx);
  background-size: 80rpx 80rpx;
  mask-image: radial-gradient(circle at 50% 50%, transparent 30%, rgba(0,0,0,0.5) 70%, transparent 95%);
  -webkit-mask-image: radial-gradient(circle at 50% 50%, transparent 30%, rgba(0,0,0,0.5) 70%, transparent 95%);
}

/* 边缘刻度线 */
.nav-hud-ticks {
  position: absolute;
  inset: 0;
  border-top: 1rpx solid transparent;
  border-bottom: 1rpx solid transparent;
  background:
    repeating-linear-gradient(90deg, rgba(0, 200, 255, 0.06) 0, rgba(0, 200, 255, 0.06) 1rpx, transparent 1rpx, transparent 40rpx) top left / 100% 8rpx no-repeat,
    repeating-linear-gradient(90deg, rgba(0, 200, 255, 0.06) 0, rgba(0, 200, 255, 0.06) 1rpx, transparent 1rpx, transparent 40rpx) bottom left / 100% 8rpx no-repeat,
    repeating-linear-gradient(0deg, rgba(0, 200, 255, 0.06) 0, rgba(0, 200, 255, 0.06) 1rpx, transparent 1rpx, transparent 40rpx) top left / 8rpx 100% no-repeat,
    repeating-linear-gradient(0deg, rgba(0, 200, 255, 0.06) 0, rgba(0, 200, 255, 0.06) 1rpx, transparent 1rpx, transparent 40rpx) top right / 8rpx 100% no-repeat;
}

/* 雷达扫描光圈 */
.nav-hud-radar {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  margin-left: -100rpx;
  margin-top: -100rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(0, 200, 255, 0.06);
  overflow: hidden;
}

.nav-hud-radar::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    transparent 0deg,
    rgba(0, 200, 255, 0.08) 30deg,
    transparent 60deg
  );
  animation: radarSweep 6s linear infinite;
}

.nav-hud-radar::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 4rpx;
  height: 4rpx;
  margin: -2rpx;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.25);
}

@keyframes radarSweep {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* 四角辉光 */
.nav-hud-edge-glow {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 0% 0%, rgba(0, 200, 255, 0.04), transparent 20%),
    radial-gradient(circle at 100% 0%, rgba(0, 200, 255, 0.03), transparent 18%),
    radial-gradient(circle at 0% 100%, rgba(0, 200, 255, 0.03), transparent 18%),
    radial-gradient(circle at 100% 100%, rgba(0, 200, 255, 0.04), transparent 20%);
}

/* ===== 舷窗状态驱动 ===== */

/* idle: 中等亮度 */
.nav-map-window--idle {
  opacity: 0.45;
  filter: saturate(0.5) brightness(0.75);
}

.nav-map-window--idle .nav-map-route {
  opacity: 0.18;
}

/* starting: 启动中，亮度提升 */
.nav-map-window--starting {
  opacity: 0.55;
  filter: saturate(0.7) brightness(0.95);
}

/* calibrating: 校准中，最亮 + 扫描效果 */
.nav-map-window--calibrating {
  opacity: 0.55;
  filter: saturate(0.7) brightness(0.9);
}

.nav-map-window--calibrating .nav-map-route {
  opacity: 0.66;
  animation: routeEnergy 1200ms ease-in-out infinite;
}

.nav-map-window--calibrating .nav-planet-lock {
  opacity: 1;
  animation: targetLockPulse 1500ms ease-in-out infinite;
}

/* calibrating 态扫描横掠 */
.nav-map-window--calibrating::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  height: 40%;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(0, 200, 255, 0.06) 40%,
    rgba(0, 200, 255, 0.10) 50%,
    rgba(0, 200, 255, 0.06) 60%,
    transparent 100%
  );
  animation: mapScanSweep 2.2s ease-in-out infinite;
  pointer-events: none;
  z-index: 5;
}

/* calibrating 态星点逐个点亮 */
.nav-map-window--calibrating .nav-star {
  animation: starSearchLight 600ms ease-out forwards;
}

@keyframes starSearchLight {
  0%   { opacity: 0.08; transform: scale(0.5); }
  60%  { opacity: 1; transform: scale(1.3); }
  100% { opacity: var(--star-opacity, 0.6); transform: scale(1); }
}

/* calibrating 态轨道流动 */
.nav-map-window--calibrating .nav-map-orbit {
  animation: orbitFlow 8s linear infinite;
}

@keyframes orbitFlow {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

@keyframes mapScanSweep {
  0%   { top: -40%; }
  100% { top: 100%; }
}

@keyframes routeEnergy {
  0%, 100% { opacity: 0.50; }
  50%      { opacity: 0.78; }
}

/* completing + completed: 降低亮度保证文字清晰 */
.nav-map-window--completing,
.nav-map-window--completed {
  opacity: 0.32;
  filter: saturate(0.8) brightness(1);
}

.nav-map-window--completing .nav-map-route,
.nav-map-window--completed .nav-map-route {
  opacity: 0.78;
}

.nav-map-window--completing .nav-planet-lock,
.nav-map-window--completed .nav-planet-lock {
  opacity: 0.86;
}

/* completing 态：星图短暂提亮后回落 */
.nav-map-window--completing {
  animation: completingFlash 700ms ease-out forwards;
}

/* 完成态：TARGET 星体锁定脉冲 */
.nav-map-window--completed .nav-planet-lock {
  animation: resultLockPulse 2s ease-in-out infinite;
}

/* 完成态：中心光波扩散 */
.nav-map-window--completed::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 100rpx;
  height: 100rpx;
  margin: -50rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 200, 255, 0.20), transparent 70%);
  animation: resultRevealWave 1.2s ease-out forwards;
  pointer-events: none;
  z-index: 5;
}

@keyframes resultRevealWave {
  0%   { transform: scale(0); opacity: 0.6; }
  100% { transform: scale(12); opacity: 0; }
}

@keyframes resultLockPulse {
  0%, 100% { opacity: 0.60; transform: scale(1); }
  50%      { opacity: 1; transform: scale(1.18); }
}

@keyframes targetLockPulse {
  0%, 100% { opacity: 0.45; transform: scale(0.92); }
  50%      { opacity: 1; transform: scale(1.08); }
}

/* reduce-motion: 舷窗静态化 */
.reduce-motion .nav-planet-lock,
.reduce-motion .nav-map-route,
.reduce-motion .nav-star,
.reduce-motion .nav-energy-node,
.reduce-motion .nav-scan-wave,
.reduce-motion .nav-dust,
.reduce-motion .nav-map-orbit,
.reduce-motion .nav-hud-radar::before {
  animation: none !important;
}
.reduce-motion .nav-map-window--calibrating::after,
.reduce-motion .nav-map-window--completed::before {
  animation: none !important;
  display: none;
}

/* ===== 中央多行星系统 ===== */
.star-core {
  position: relative;
  width: 640rpx;
  height: 640rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  flex-shrink: 0;
  transition: opacity 850ms cubic-bezier(0.22, 1, 0.36, 1), transform 850ms cubic-bezier(0.22, 1, 0.36, 1), margin-bottom 850ms cubic-bezier(0.22, 1, 0.36, 1);
}

.star-core--completing {
  opacity: 0.55;
  transform: scale(0.95);
  pointer-events: none;
}

.star-core--completed {
  opacity: 0.22;
  transform: scale(0.92);
  pointer-events: none;
}

.core-system {
  position: relative;
  width: 100%;
  height: 100%;
}

.core-system--starting,
.core-system--calibrating {
  animation: csSystemSpin 80s linear infinite;
}

.core-system--completed {
  animation: csSystemSpin 180s linear infinite; /* 降速但保持非常平滑的运转 */
}

@keyframes csSystemSpin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ----- 主核心 ----- */
.cs-main {
  position: absolute;
  left: 50%;
  /* top 由 inline style 提供（main.y 偏移） */
  transform: translate(-50%, -50%);
  width: 0;
  height: 0;
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cs-main-halo,
.cs-main-glow,
.cs-main-dot,
.cs-main-scan {
  position: absolute;
  border-radius: 50%;
}

.cs-main-halo {
  background: radial-gradient(circle,
    rgba(0, 200, 255, 0.05) 0%,
    rgba(0, 200, 255, 0.02) 45%,
    transparent 75%);
  animation: csHaloBreathe var(--halo-dur, 6s) ease-in-out infinite;
}

.cs-main-glow {
  background: radial-gradient(circle,
    rgba(0, 215, 255, 0.18) 0%,
    rgba(0, 180, 255, 0.06) 50%,
    transparent 80%);
  animation: csGlowBreathe var(--glow-dur, 4s) ease-in-out infinite;
}

.cs-main-dot {
  background: rgba(0, 220, 255, 0.92);
  box-shadow:
    0 0 24rpx rgba(0, 220, 255, 0.6),
    0 0 60rpx rgba(0, 170, 255, 0.28);
  animation: csDotBreathe var(--dot-dur, 3.4s) ease-in-out infinite;
  z-index: 2;
}

.cs-main-scan {
  width: 80rpx;
  height: 80rpx;
  border: 2rpx solid rgba(0, 200, 255, 0.32);
  animation: csScanWave var(--scan-dur, 2.2s) ease-out infinite;
}

@keyframes csHaloBreathe {
  0%, 100% { transform: scale(1);    opacity: 0.55; }
  50%      { transform: scale(1.10); opacity: 0.85; }
}
@keyframes csGlowBreathe {
  0%, 100% { transform: scale(1);    opacity: 0.7; }
  50%      { transform: scale(1.12); opacity: 1; }
}
@keyframes csDotBreathe {
  0%, 100% { transform: scale(1);    box-shadow: 0 0 22rpx rgba(0, 220, 255, 0.5),  0 0 50rpx rgba(0, 170, 255, 0.20); }
  50%      { transform: scale(1.10); box-shadow: 0 0 32rpx rgba(0, 220, 255, 0.75), 0 0 72rpx rgba(0, 170, 255, 0.32); }
}
@keyframes csScanWave {
  0%   { transform: scale(0.5); opacity: 0.7; }
  100% { transform: scale(4.2); opacity: 0; }
}

/* 旧关键帧保留（被 .core-glow / .core-dot 等 nav-planet 节点复用） */
@keyframes coreGlowPulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1);    opacity: 0.6; }
  50%      { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
}

@keyframes coreDotPulse {
  0%, 100% { transform: scale(1);    box-shadow: 0 0 16rpx rgba(0, 210, 255, 0.4); }
  50%      { transform: scale(1.15); box-shadow: 0 0 28rpx rgba(0, 210, 255, 0.7); }
}

/* ----- 轨道 ----- */
.cs-orbit {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(140, 215, 255, 0.45);
  pointer-events: none;
  animation: csOrbitBreathe var(--orbit-dur, 10s) ease-in-out infinite;
  animation-delay: var(--orbit-delay, 0s);
  /* opacity 由 inline 控制 */
}

.cs-orbit--full {
  /* 默认完整环 */
}

.cs-orbit--half {
  /* 半弧：仅显示上半圆 */
  clip-path: polygon(0 0, 100% 0, 100% 50%, 0 50%);
}

.cs-orbit--dash {
  border-style: dashed;
  border-width: 1rpx;
  opacity: 0.85;  /* 与 inline 相乘体感不变 */
}

.cs-orbit--predict {
  border-style: dotted;
  border-color: rgba(0, 220, 255, 0.35) !important;
  opacity: 0.5 !important;
}

@keyframes csOrbitBreathe {
  0%, 100% { transform: translate(-50%, -50%) rotate(var(--orbit-rot, 0deg)) scale(1); }
  50%      { transform: translate(-50%, -50%) rotate(var(--orbit-rot, 0deg)) scale(1.015); }
}

/* 测量校准点阵环 (主核心附近极其精致的小点阵环) */
.cs-calibration-ring {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 1rpx dashed rgba(0, 200, 255, 0.12);
  background-image: radial-gradient(circle, rgba(0, 200, 255, 0.28) 1px, transparent 1px);
  background-size: 8rpx 8rpx;
  transform-origin: center center;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: calibrateRingRotate 24s linear infinite;
  z-index: 1;
}

@keyframes calibrateRingRotate {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to   { transform: translate(-50%, -50%) rotate(360deg); }
}

/* ----- 次级行星 ----- */
.cs-planet {
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 50%;
  opacity: var(--planet-opacity, 0.8);
  z-index: 3;
  pointer-events: none;
  transition: filter 300ms ease, opacity 300ms ease;
  /* 初始定位：绕中心旋转 */
  transform: rotate(var(--planet-angle, 0deg)) translateX(var(--planet-rx, 100rpx)) rotate(calc(-1 * var(--planet-angle, 0deg)));
}

/* 轨道公转动画：配合 baseState 不同阶段有明显的速度和旋转表现 */
.core-system--idle .cs-planet {
  animation: 
    csPlanetTwinkle var(--twinkle-dur, 3s) ease-in-out infinite alternate,
    csPlanetOrbitSpin calc(var(--orbit-spin-dur, 20s) * 3.5) linear infinite;
  animation-delay: var(--twinkle-delay, 0s), 0s;
}

.core-system--starting .cs-planet,
.core-system--calibrating .cs-planet {
  animation: 
    csPlanetTwinkle var(--twinkle-dur, 3s) ease-in-out infinite alternate,
    csPlanetOrbitSpin var(--orbit-spin-dur, 20s) linear infinite;
  animation-delay: var(--twinkle-delay, 0s), 0s;
}

.core-system--completed .cs-planet {
  animation: 
    csPlanetTwinkle var(--twinkle-dur, 3s) ease-in-out infinite alternate,
    csPlanetOrbitSpin calc(var(--orbit-spin-dur, 20s) * 8) linear infinite;
  animation-delay: var(--twinkle-delay, 0s), 0s;
}

.cs-planet--cyan {
  background: radial-gradient(circle at 35% 35%, #e0faff 0%, #5cdcff 40%, #007fa9 75%, #003a50 100%);
  box-shadow:
    inset 1rpx 1rpx 3rpx rgba(255, 255, 255, 0.65),
    0 0 var(--planet-glow, 16rpx) rgba(92, 220, 255, 0.45);
}
.cs-planet--blue {
  background: radial-gradient(circle at 35% 35%, #f0f5ff 0%, #6aa6ff 40%, #205ab8 75%, #0c2b60 100%);
  box-shadow:
    inset 1rpx 1rpx 3rpx rgba(255, 255, 255, 0.65),
    0 0 var(--planet-glow, 16rpx) rgba(106, 166, 255, 0.4);
}
.cs-planet--teal {
  background: radial-gradient(circle at 35% 35%, #ebfaf4 0%, #5fe8c0 40%, #17a07a 75%, #054835 100%);
  box-shadow:
    inset 1rpx 1rpx 3rpx rgba(255, 255, 255, 0.65),
    0 0 var(--planet-glow, 16rpx) rgba(95, 232, 192, 0.35);
}
.cs-planet--violet {
  background: radial-gradient(circle at 35% 35%, #f4f2fa 0%, #a29beb 40%, #584fb3 75%, #272163 100%);
  box-shadow:
    inset 1rpx 1rpx 3rpx rgba(255, 255, 255, 0.5),
    0 0 var(--planet-glow, 16rpx) rgba(162, 155, 235, 0.32);
}
.cs-planet--white {
  background: radial-gradient(circle at 35% 35%, #ffffff 0%, #e0e6ed 40%, #9cb2c9 75%, #4b5e70 100%);
  box-shadow:
    inset 1rpx 1rpx 3rpx rgba(255, 255, 255, 0.8),
    0 0 var(--planet-glow, 16rpx) rgba(255, 255, 255, 0.35);
}

@keyframes csPlanetTwinkle {
  0%   { opacity: var(--planet-opacity, 0.7); }
  100% { opacity: calc(var(--planet-opacity, 0.7) * 0.55); }
}

@keyframes csPlanetOrbitSpin {
  from { 
    transform: rotate(var(--planet-angle, 0deg)) translateX(var(--planet-rx, 100rpx)) rotate(calc(-1 * var(--planet-angle, 0deg))); 
  }
  to { 
    transform: rotate(calc(var(--planet-angle, 0deg) + 360deg)) translateX(var(--planet-rx, 100rpx)) rotate(calc(-1 * var(--planet-angle, 0deg) - 360deg)); 
  }
}

/* ----- 远轨小节点 ----- */
.cs-far-node {
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 50%;
  background: rgba(180, 220, 255, 0.9);
  box-shadow: 0 0 6rpx rgba(120, 200, 255, 0.4);
  z-index: 1;
  /* 初始定位：绕中心旋转 */
  transform: rotate(var(--node-angle, 0deg)) translateX(var(--node-rx, 240rpx)) rotate(calc(-1 * var(--node-angle, 0deg)));
}

.core-system--idle .cs-far-node {
  animation: 
    csFarTwinkle var(--twinkle-dur, 4.5s) ease-in-out infinite alternate,
    csFarNodeOrbitSpin calc(var(--orbit-spin-dur, 50s) * 4) linear infinite;
  animation-delay: var(--twinkle-delay, 0s), 0s;
}

.core-system--starting .cs-far-node,
.core-system--calibrating .cs-far-node {
  animation: 
    csFarTwinkle var(--twinkle-dur, 4.5s) ease-in-out infinite alternate,
    csFarNodeOrbitSpin var(--orbit-spin-dur, 50s) linear infinite;
  animation-delay: var(--twinkle-delay, 0s), 0s;
}

.core-system--completed .cs-far-node {
  animation: 
    csFarTwinkle var(--twinkle-dur, 4.5s) ease-in-out infinite alternate,
    csFarNodeOrbitSpin calc(var(--orbit-spin-dur, 50s) * 9) linear infinite;
  animation-delay: var(--twinkle-delay, 0s), 0s;
}

@keyframes csFarTwinkle {
  0%   { opacity: var(--node-opacity, 0.45); }
  100% { opacity: calc(var(--node-opacity, 0.45) * 0.35); }
}

@keyframes csFarNodeOrbitSpin {
  from { 
    transform: rotate(var(--node-angle, 0deg)) translateX(var(--node-rx, 240rpx)) rotate(calc(-1 * var(--node-angle, 0deg))); 
  }
  to { 
    transform: rotate(calc(var(--node-angle, 0deg) + 360deg)) translateX(var(--node-rx, 240rpx)) rotate(calc(-1 * var(--node-angle, 0deg) - 360deg)); 
  }
}

/* ----- 连接线 ----- */
.cs-link {
  position: absolute;
  height: 1rpx;
  background: linear-gradient(90deg,
    rgba(0, 220, 255, 0) 0%,
    rgba(0, 220, 255, 0.85) 50%,
    rgba(0, 220, 255, 0) 100%);
  transform-origin: 0 50%;
  animation: csLinkPulse var(--pulse-dur, 2.4s) ease-in-out infinite;
  animation-delay: var(--pulse-delay, 0s);
  z-index: 2;
  pointer-events: none;
}

.cs-link--predict {
  background: linear-gradient(90deg,
    rgba(0, 220, 255, 0) 0%,
    rgba(0, 220, 255, 0.28) 30%,
    rgba(0, 220, 255, 0.28) 70%,
    rgba(0, 220, 255, 0) 100%) !important;
  height: 2rpx !important;
}

/* 路径推演上的流动采样点 (由 CSS 模拟，避免增加 DOM 节点) */
.cs-link--predict::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #00c8ff;
  box-shadow: 
    0 0 8rpx #00c8ff,
    0 0 16rpx rgba(0, 200, 255, 0.5);
  transform: translate(-50%, -50%);
  animation: linkDotMove var(--pulse-dur, 3s) linear infinite;
  animation-delay: var(--pulse-delay, 0s);
}

@keyframes linkDotMove {
  0% {
    left: 0%;
    opacity: 0;
  }
  15% {
    opacity: 0.85;
  }
  85% {
    opacity: 0.85;
  }
  100% {
    left: 100%;
    opacity: 0;
  }
}

/* ===== 状态：starting（点火） ===== */
.core-system--starting .cs-main-dot {
  animation: csDotIgnite 700ms ease-out forwards;
}
.core-system--starting .cs-main-glow {
  animation: csGlowIgnite 1.6s ease-in-out forwards;
}
.core-system--starting .cs-orbit {
  animation: csOrbitFlash 1s ease-out forwards;
}
.core-system--starting .cs-planet {
  animation: csPlanetLightUp 1.2s ease-out forwards;
  animation-delay: var(--light-up-delay, 0s);
}

@keyframes csDotIgnite {
  0%   { transform: scale(1);   box-shadow: 0 0 24rpx rgba(0, 220, 255, 0.6); }
  100% { transform: scale(1.4); box-shadow: 0 0 60rpx rgba(0, 220, 255, 0.9); }
}
@keyframes csGlowIgnite {
  0%   { opacity: 0.7;  transform: scale(1); }
  60%  { opacity: 1;    transform: scale(1.4); }
  100% { opacity: 0.85; transform: scale(1.25); }
}
@keyframes csOrbitFlash {
  0%   { filter: brightness(1); }
  50%  { filter: brightness(2.4); }
  100% { filter: brightness(1.2); }
}
@keyframes csPlanetLightUp {
  0%   { opacity: var(--planet-opacity, 0.5); transform: translate(-50%, -50%) scale(1); }
  60%  { opacity: 1; transform: translate(-50%, -50%) scale(1.45); }
  100% { opacity: 1; transform: translate(-50%, -50%) scale(1.1); }
}

/* ===== 状态：calibrating（校准同步） ===== */
.core-system--calibrating .cs-main-dot {
  box-shadow:
    0 0 36rpx rgba(0, 220, 255, 0.75),
    0 0 80rpx rgba(0, 170, 255, 0.4);
}
.core-system--calibrating .cs-orbit {
  border-color: rgba(140, 215, 255, 0.85);
  animation: csOrbitBreathe var(--orbit-dur, 10s) ease-in-out infinite, csOrbitHighlight var(--scan-dur, 2.4s) ease-out infinite;
  animation-delay: var(--orbit-delay, 0s), calc(var(--orbit-delay, 0s) * 0.5);
}
.core-system--calibrating .cs-planet {
  /* 行星持续微亮 */
  filter: brightness(1.18);
}
.core-system--calibrating .cs-link {
  animation: csLinkPulse var(--pulse-dur, 2.4s) ease-in-out infinite;
}
.core-system--calibrating .cs-far-node {
  animation: csFarTwinkle var(--twinkle-dur, 4.5s) ease-in-out infinite alternate, csFarPulse 3.5s ease-out infinite;
  animation-delay: var(--twinkle-delay, 0s), calc(var(--twinkle-delay, 0s) * 0.7);
}

@keyframes csOrbitHighlight {
  0%, 100% { border-color: rgba(140, 215, 255, 0.45); filter: brightness(1); }
  15%      { border-color: rgba(0, 220, 255, 0.85); filter: brightness(1.8); }
  35%      { border-color: rgba(140, 215, 255, 0.45); filter: brightness(1); }
}

@keyframes csFarPulse {
  0%, 100% { box-shadow: 0 0 6rpx rgba(120, 200, 255, 0.4); filter: brightness(1); }
  50%      { box-shadow: 0 0 24rpx rgba(0, 200, 255, 0.85); filter: brightness(1.6); transform: translate(-50%, -50%) scale(1.35); }
}

@keyframes csLinkPulse {
  0%, 100% { opacity: var(--link-base, 0.10); filter: brightness(1); }
  50%      { opacity: 0.35; filter: brightness(1.6); }
}

/* ===== 状态：regenerating（重生成） ===== */
.core-system--regenerating .cs-main-dot {
  animation: csDotRegen 800ms ease-out forwards;
}

@keyframes csDotRegen {
  0%   { transform: scale(0.4); opacity: 0.3; box-shadow: 0 0 4rpx rgba(0, 220, 255, 0.2); }
  50%  { transform: scale(1.6); opacity: 1;   box-shadow: 0 0 60rpx rgba(0, 220, 255, 0.9); }
  100% { transform: scale(1);   opacity: 1;   box-shadow: 0 0 16rpx rgba(0, 220, 255, 0.5); }
}

/* ===== reduce-motion：所有中央系统动画静音 ===== */
.reduce-motion .cs-main-halo,
.reduce-motion .cs-main-glow,
.reduce-motion .cs-main-dot,
.reduce-motion .cs-main-scan,
.reduce-motion .cs-orbit,
.reduce-motion .cs-planet,
.reduce-motion .cs-far-node,
.reduce-motion .cs-link {
  animation: none !important;
}

/* ===== 启动按钮 ===== */
.nav-launch-btn-area {
  display: flex;
  justify-content: center;
  margin-top: 36rpx;
  transition: opacity 500ms ease;
}

.btn-visible {
  opacity: 1;
  pointer-events: auto;
}

.btn-fade-out {
  opacity: 0;
  pointer-events: none;
}

.btn-hidden {
  display: none !important;
}

.nav-launch-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, rgba(4, 28, 48, 0.72) 0%, rgba(2, 12, 22, 0.95) 100%);
  border: 1.5rpx solid rgba(0, 200, 255, 0.32);
  box-shadow: 
    inset 0 0 20rpx rgba(0, 200, 255, 0.22),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.1),
    0 10rpx 32rpx rgba(0, 0, 0, 0.65);
  transition: background 250ms ease, border-color 250ms ease, box-shadow 250ms ease, transform 250ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  animation: btnMainBreathe 4s ease-in-out infinite alternate;
}

/* 按钮外侧控制环 (极细青蓝描边) */
.btn-outer-control-ring {
  position: absolute;
  inset: -16rpx;
  border: 1.5rpx solid rgba(0, 200, 255, 0.15);
  border-radius: 50%;
  pointer-events: none;
  transition: all 400ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  animation: btnOuterRingRotate 28s linear infinite;
}

/* 外环对称的四个刻度 */
.btn-ring-tick {
  position: absolute;
  background: rgba(0, 200, 255, 0.45);
  transition: all 300ms ease;
}
.btn-ring-tick--1 { top: -6rpx; left: 50%; width: 2rpx; height: 10rpx; transform: translateX(-50%); }
.btn-ring-tick--2 { right: -6rpx; top: 50%; width: 10rpx; height: 2rpx; transform: translateY(-50%); }
.btn-ring-tick--3 { bottom: -6rpx; left: 50%; width: 2rpx; height: 10rpx; transform: translateX(-50%); }
.btn-ring-tick--4 { left: -6rpx; top: 50%; width: 10rpx; height: 2rpx; transform: translateY(-50%); }

/* 内部微弱呼吸能量光 */
.btn-internal-energy {
  position: absolute;
  inset: 6rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, rgba(0, 200, 255, 0.08) 0%, transparent 75%);
  pointer-events: none;
  animation: btnEnergyBreathe 3.5s ease-in-out infinite alternate;
}

.nav-launch-btn:active {
  transform: scale(0.96);
  background: radial-gradient(circle at 50% 50%, rgba(6, 40, 68, 0.82) 0%, rgba(1, 8, 16, 0.96) 100%) !important;
  border-color: rgba(0, 200, 255, 0.65) !important;
  box-shadow: 
    inset 0 0 32rpx rgba(0, 200, 255, 0.45),
    0 4rpx 16rpx rgba(0, 200, 255, 0.15) !important;
}

.nav-launch-btn:active .btn-outer-control-ring {
  inset: -12rpx;
  border-color: rgba(0, 200, 255, 0.45);
}

.nav-launch-btn:active .btn-ring-tick {
  background: rgba(0, 200, 255, 0.8);
}

@keyframes btnMainBreathe {
  0% {
    border-color: rgba(0, 200, 255, 0.28);
    box-shadow: inset 0 0 16rpx rgba(0, 200, 255, 0.16), 0 10rpx 32rpx rgba(0, 0, 0, 0.65);
  }
  100% {
    border-color: rgba(0, 200, 255, 0.45);
    box-shadow: inset 0 0 28rpx rgba(0, 200, 255, 0.28), 0 10rpx 36rpx rgba(0, 170, 255, 0.1);
  }
}

/* Starting状态：按钮快速向内坍缩淡出，视觉交给星图 */
.nav-launch-btn--starting {
  transform: scale(0.01) !important;
  opacity: 0 !important;
  pointer-events: none !important;
  box-shadow: 0 0 32rpx rgba(0, 200, 255, 0.6) !important;
  transition: transform 650ms cubic-bezier(0.6, -0.28, 0.735, 0.045), opacity 550ms ease !important;
  animation: none !important;
}

.nav-launch-btn--starting .btn-outer-control-ring {
  inset: 0rpx !important;
  opacity: 0 !important;
  border-color: rgba(0, 200, 255, 0.8) !important;
  transition: inset 550ms cubic-bezier(0.22, 1, 0.36, 1), opacity 500ms ease !important;
  animation: btnOuterRingRotate 3s linear infinite !important;
}

@keyframes btnOuterRingRotate {
  from { transform: rotate(0deg); }
  to   { transform: rotate(-360deg); }
}

@keyframes btnEnergyBreathe {
  0% { opacity: 0.35; transform: scale(0.92); }
  100% { opacity: 0.9; transform: scale(1.05); }
}

/* ===== 状态指示线 ===== */
.nav-status-line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.nav-status-indicator {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;

/* ===== 4. 飞控核心通用元素 ===== */
.core-inner {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.core-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.core-ring--1 {
  width: 200rpx;
  height: 200rpx;
  border-color: rgba(10, 132, 255, 0.12);
}

.core-ring--2 {
  width: 130rpx;
  height: 130rpx;
  border-color: rgba(10, 132, 255, 0.08);
}

.core-ring--3 {
  width: 60rpx;
  height: 60rpx;
  border-color: rgba(10, 132, 255, 0.06);
}

/* 能量辉光 */
.core-glow {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle,
    rgba(10, 132, 255, 0.25),
    transparent 70%
  );
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: coreGlowPulse 3s ease-in-out infinite;
  z-index: 1;
}

/* (coreGlowPulse defined above in star-core section) */

/* 能量点 */
.core-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(10, 132, 255, 0.6);
  box-shadow: 0 0 12rpx rgba(10, 132, 255, 0.4);
  position: relative;
  z-index: 2;
  animation: coreDotPulse 2s ease-in-out infinite;
}

/* (coreDotPulse defined above in star-core section) */

/* ===== 5. 扫描环 ===== */
.scan-ring {
  position: absolute;
  width: 340rpx;
  height: 340rpx;
  border-radius: 50%;
  border: 1px solid rgba(0, 175, 255, 0.18);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
  box-shadow: 0 0 12rpx rgba(0, 175, 255, 0.06);
}

.scan-ring::after {
  content: "";
  position: absolute;
  inset: -2rpx;
  border-radius: 50%;
  background: conic-gradient(
    from 0deg,
    transparent 0deg,
    transparent 300deg,
    rgba(10, 132, 255, 0.3) 340deg,
    transparent 360deg
  );
  mask: radial-gradient(transparent 48%, black 49%, black 51%, transparent 52%);
  -webkit-mask: radial-gradient(
    transparent 48%,
    black 49%,
    black 51%,
    transparent 52%
  );
}

.scan-ring--idle {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--idle::after {
  animation: scanRotate 12s linear infinite;
}

.scan-ring--gen {
  animation: scanRotate 6s linear infinite;
}

.scan-ring--gen::after {
  animation: scanRotate 6s linear infinite;
}

@keyframes scanRotate {
  from {
    transform: translate(-50%, -50%) rotate(0deg);
  }
  to {
    transform: translate(-50%, -50%) rotate(360deg);
  }
}

/* ===== 6. 甲板透视线 ===== */
.deck-perspective {
  position: absolute;
  bottom: 130rpx;
  left: 0;
  right: 0;
  height: 300rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.deck-line {
  position: absolute;
  bottom: 0;
  height: 200rpx;
  width: 1rpx;
  background: linear-gradient(to top, rgba(10, 132, 255, 0.08), transparent);
  transform-origin: bottom center;
  transition: opacity 0.8s ease;
}

.deck-line--1 {
  left: 8%;
  transform: perspective(300rpx) rotateX(50deg) rotate(-16deg);
}
.deck-line--2 {
  left: 25%;
  transform: perspective(300rpx) rotateX(50deg) rotate(-8deg);
}
.deck-line--3 {
  left: 50%;
  transform: perspective(300rpx) rotateX(50deg) rotate(0deg);
  background: linear-gradient(to top, rgba(10, 132, 255, 0.14), transparent);
}
.deck-line--4 {
  left: 75%;
  transform: perspective(300rpx) rotateX(50deg) rotate(8deg);
}
.deck-line--5 {
  left: 92%;
  transform: perspective(300rpx) rotateX(50deg) rotate(16deg);
}


/* ===== 7. 暗色渐变遮罩层 ===== */
.page-dark-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background:
    radial-gradient(circle at 50% 20%, rgba(0, 190, 255, 0.10), transparent 42%),
    linear-gradient(to bottom,
      rgba(0, 8, 12, 0.15) 0%,
      rgba(0, 4, 8, 0.40) 40%,
      rgba(0, 4, 8, 0.75) 100%
    );
  z-index: 0;
  pointer-events: none;
}

/* ===== 8. 飞行甲板统一舞台 ===== */
.flight-deck {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 320rpx 40rpx 80rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  transition: padding-top 500ms cubic-bezier(0.22, 1, 0.36, 1);
}

.flight-deck--idle,
.flight-deck--starting,
.flight-deck--calibrating,
.flight-deck--completing,
.flight-deck--completed,
.flight-deck--regenerating {
  padding-top: 320rpx;
}

.flight-deck > .bay-status-tab {
  position: absolute;
  top: 24rpx;
  left: 28rpx;
  margin-bottom: 0;
}

/* --- 顶部标题 --- */
.flight-deck-header {
  text-align: center;
  margin-bottom: 48rpx;
  transition:
    opacity 0.4s ease,
    height 0.4s ease,
    margin 0.4s ease;
}

.fdh-visible {
  opacity: 1;
  animation: fadeInDown 0.8s ease forwards;
}

.flight-deck-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 6rpx;
}

.flight-deck-date {
  display: block;
  font-family: "Courier New", Courier, monospace;
  font-size: 18rpx;
  color: rgba(126, 156, 180, 0.12);
  margin-top: 4rpx;
}



/* ===== 10. 底部说明 ===== */
.flight-deck-info {
  text-align: center;
  margin-bottom: 24rpx;
  transition:
    opacity 0.4s ease,
    height 0.4s ease;
}

.fdi-visible {
  opacity: 0;
  animation: fadeIn 0.6s ease 0.9s forwards;
}

/* entered 态：跳过入场动画延迟（重新点火用） */
.fdi-entered {
  animation: none !important;
  opacity: 1 !important;
}

.flight-deck-info-text {
  display: block;
  font-family: "Courier New", Courier, monospace;
  font-size: 22rpx;
  color: rgba(126, 156, 180, 0.38);
  letter-spacing: 3rpx;
  line-height: 1.8;
}

/* ===== 待机页下方舱体刻度（pseudo 增强） ===== */
.flight-deck-info::after {
  content: '';
  display: flex;
  gap: 6rpx;
  margin-top: 28rpx;
  justify-content: center;
  height: 2rpx;
  width: 280rpx;
  margin-left: auto;
  margin-right: auto;
  background:
    repeating-linear-gradient(
      90deg,
      rgba(0, 180, 255, 0.14) 0,
      rgba(0, 180, 255, 0.14) 8rpx,
      transparent 8rpx,
      transparent 20rpx
    );
  opacity: 0.65;
}

.fdi-hidden::after {
  display: none;
}


/* ===== 12. 飞行阶段联动动画 ===== */

/* completed: 核心淡出退到背景 */
.strategy-page--completed .nav-core-stage,
.flight-deck--completed .nav-core-stage {
  opacity: 0.02 !important;
  animation: none !important;
  transform: translateY(-72rpx) scale(0.56) !important;
  pointer-events: none !important;
  min-height: 0 !important;
  max-height: 40rpx !important;
  margin-bottom: -20rpx !important;
  transition:
    opacity 720ms ease,
    transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
    margin-bottom 720ms ease;
  z-index: 0 !important;
}


/* entered 态：跳过入场动画，立即可见（重新点火用） */
.nav-core-stage--entered {
  animation: none !important;
  opacity: 1 !important;
  transform: none !important;
}

/* compact 态：done 阶段核心进一步收缩（优先级高于 entered） */
.nav-core-stage--compact {
  opacity: 0.02 !important;
  animation: none !important;
  transform: translateY(-72rpx) scale(0.56) !important;
  pointer-events: none !important;
  min-height: 0 !important;
  max-height: 40rpx !important;
  margin-bottom: -20rpx !important;
  transition:
    opacity 720ms ease,
    transform 720ms cubic-bezier(0.22, 1, 0.36, 1),
    margin-bottom 720ms ease;
}

.flight-deck--completed .nav-core-rings {
  opacity: 0;
}

.flight-deck--completed .deck-perspective {
  opacity: 0;
  transition: opacity 0.4s ease;
}


/* ===== 14. heartbeat ===== */
.flight-heartbeat {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.heartbeat-visible {
  opacity: 1;
}

.flight-heartbeat-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(0, 175, 255, 0.5);
  animation: heartbeatDot 1.2s ease-in-out infinite;
}

@keyframes heartbeatDot {
  0%,
  100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.flight-heartbeat-text {
  font-family: "Courier New", Courier, monospace;
  font-size: 20rpx;
  color: rgba(0, 175, 255, 0.5);
  letter-spacing: 2rpx;
}

/* ##### 飞船导航系统 HUD 重构 - 终极版 (修复版) ##### */

.directive-projection {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: calc(var(--custom-nav-height, 176rpx) + 30rpx) 40rpx calc(env(safe-area-inset-bottom) + 30rpx);
  box-sizing: border-box;
  opacity: 0;
  transform: scale(0.97) translateY(20rpx);
  transition:
    opacity 550ms ease,
    transform 550ms cubic-bezier(0.22, 1, 0.36, 1),
    backdrop-filter 550ms ease,
    background 550ms ease;
  pointer-events: none;
  background: rgba(2, 10, 18, 0);
  /* 增加背景动态数据流 */
  background-image:
    radial-gradient(
      circle at 50% 50%,
      rgba(0, 200, 255, 0.03) 0%,
      transparent 80%
    ),
    linear-gradient(rgba(0, 200, 255, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 200, 255, 0.04) 1px, transparent 1px);
  background-size:
    100% 100%,
    60rpx 60rpx,
    60rpx 60rpx;
  animation: bgDataStream 40s linear infinite;
  z-index: 100;
}

.strategy-page--completed .directive-projection {
  margin-top: 0;
}

.dp-visible {
  opacity: 1;
  transform: scale(1) translateY(0);
  pointer-events: auto;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  background: rgba(2, 10, 18, 0.76);
}

.projection-card {
  opacity: 0;
  transform: translateY(6rpx);
}

.dp-visible .projection-card {
  animation: 
    projectionCardIn 260ms cubic-bezier(0.22, 1, 0.36, 1) both,
    cardBorderFlash 1.4s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.dp-visible .projection-card:nth-child(1) { animation-delay: 20ms; }
.dp-visible .projection-card:nth-child(2) { animation-delay: 45ms; }
.dp-visible .projection-card:nth-child(3) { animation-delay: 70ms; }
.dp-visible .projection-card:nth-child(n+4) { animation-delay: 90ms; }

@keyframes projectionCardIn {
  from {
    opacity: 0;
    transform: translateY(6rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes cardBorderFlash {
  0% {
    border-color: rgba(0, 190, 255, 0.15);
    box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
  }
  25% {
    border-color: rgba(0, 200, 255, 0.85) !important;
    box-shadow: 
      0 0 32rpx rgba(0, 200, 255, 0.3),
      0 10rpx 40rpx rgba(0, 0, 0, 0.45) !important;
  }
  100% {
    border-color: rgba(0, 190, 255, 0.15);
    box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
  }
}

@keyframes bgDataStream {
  from {
    background-position:
      center,
      0 0,
      0 0;
  }
  to {
    background-position:
      center,
      0 600rpx,
      600rpx 0;
  }
}

.directive-projection::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      rgba(18, 16, 16, 0) 0,
      rgba(18, 16, 16, 0) 2rpx,
      rgba(0, 0, 0, 0.15) 2rpx,
      rgba(0, 0, 0, 0.15) 4rpx
    ),
    linear-gradient(
      90deg,
      rgba(255, 0, 0, 0.04),
      rgba(0, 255, 0, 0.02),
      rgba(0, 0, 255, 0.04)
    );
  pointer-events: none;
  z-index: 100;
  opacity: 0.18;
}

.nav-telemetry-points {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.tele-point {
  position: absolute;
  font-family: "Courier New", Courier, monospace;
  font-size: 12rpx;
  color: rgba(0, 200, 255, 0.2);
  letter-spacing: 1rpx;
}
.tele-point.p1 {
  top: 20rpx;
  left: 20rpx;
}
.tele-point.p2 {
  top: 20rpx;
  right: 20rpx;
}
.tele-point.p3 {
  bottom: 180rpx;
  left: 20rpx;
}
.tele-point.p4 {
  bottom: 180rpx;
  right: 20rpx;
}

.nav-hud-deco {
  width: 100%;
  max-width: 640rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 24rpx;
  position: relative;
  padding: 0 10rpx;
  height: 64rpx;
  z-index: 5;
}

.nav-deco-left,
.nav-deco-right {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* ##### HUD 数据面板 ##### */

/* 玻璃 HUD 面板 */
.result-panel {
  width: 640rpx;
  border-radius: 20rpx;
  background: rgba(3, 20, 28, 0.52);
  border: 1rpx solid rgba(0, 190, 255, 0.12);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  padding: 28rpx 32rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 角标装饰 */
.result-panel::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 28rpx;
  height: 28rpx;
  border-top: 2rpx solid rgba(0, 200, 255, 0.25);
  border-left: 2rpx solid rgba(0, 200, 255, 0.25);
  border-top-left-radius: 20rpx;
}

.result-panel::after {
  content: '';
  position: absolute;
  bottom: 0;
  right: 0;
  width: 28rpx;
  height: 28rpx;
  border-bottom: 2rpx solid rgba(0, 200, 255, 0.18);
  border-right: 2rpx solid rgba(0, 200, 255, 0.18);
  border-bottom-right-radius: 20rpx;
}

/* 状态胶囊 */
.rp-status-capsule {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(10, 80, 50, 0.35);
  border: 1rpx solid rgba(80, 255, 170, 0.18);
  margin-bottom: 20rpx;
}

.rp-status-capsule text {
  font-size: 20rpx;
  color: rgba(80, 255, 170, 0.80);
  letter-spacing: 2rpx;
}

.rp-capsule-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(80, 255, 170, 0.80);
  box-shadow: 0 0 6rpx rgba(80, 255, 170, 0.4);
}

/* 主标题 */
.rp-verdict {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(230, 246, 255, 0.92);
  line-height: 1.5;
  text-align: center;
  margin-bottom: 16rpx;
}

/* 副标签 */
.rp-tags {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.rp-tag-pill {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(0, 190, 255, 0.08);
  border: 1rpx solid rgba(0, 190, 255, 0.15);
  font-size: 20rpx;
  color: rgba(0, 200, 255, 0.58);
  letter-spacing: 2rpx;
}

/* 细分割线 */
.rp-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 190, 255, 0.14), transparent);
  margin: 20rpx 0;
}

/* 参数区 */
.rp-params {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rp-param-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rp-param-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: rgba(160, 210, 235, 0.48);
  letter-spacing: 3rpx;
}

.rp-param-dot {
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
}

.rp-param-dot--buff {
  background: rgba(80, 255, 170, 0.6);
  box-shadow: 0 0 4rpx rgba(80, 255, 170, 0.3);
}

.rp-param-dot--debuff {
  background: rgba(255, 160, 60, 0.6);
  box-shadow: 0 0 4rpx rgba(255, 160, 60, 0.3);
}

.rp-param-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.rp-param-card {
  flex: 1 1 calc(50% - 6rpx);
  min-width: 0;
  background: rgba(0, 20, 30, 0.35);
  border: 1rpx solid rgba(0, 190, 255, 0.06);
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.rp-param-card text {
  font-size: 24rpx;
  color: rgba(220, 240, 255, 0.78);
  line-height: 1.4;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rp-param-indicator {
  width: 4rpx;
  height: 20rpx;
  border-radius: 2rpx;
  background: rgba(80, 255, 170, 0.5);
  flex-shrink: 0;
}

.rp-param-indicator--warn {
  background: rgba(255, 160, 60, 0.5);
}

/* 底部稳定度进度线 */
.rp-stability-bar {
  height: 3rpx;
  background: rgba(0, 190, 255, 0.08);
  border-radius: 1.5rpx;
  margin-top: 24rpx;
  overflow: visible;
  position: relative;
}

.rp-stability-fill {
  height: 100%;
  background: linear-gradient(90deg, rgba(0, 200, 255, 0.40), rgba(80, 255, 170, 0.50));
  border-radius: 1.5rpx;
  transition: width 800ms cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
}

.rp-stability-fill::after {
  content: '';
  position: absolute;
  right: -3rpx;
  top: -2rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: rgba(80, 255, 170, 0.9);
  box-shadow: 0 0 10rpx rgba(80, 255, 170, 0.5);
}

.rp-stability-label {
  text-align: right;
  margin-top: 8rpx;
}

.rp-stability-label text {
  font-size: 18rpx;
  color: rgba(160, 210, 235, 0.35);
  letter-spacing: 2rpx;
  font-family: 'Courier New', monospace;
}

/* 操作按钮区 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
  width: 100%;
  margin-top: 24rpx;
}

.result-primary-btn {
  width: 520rpx;
  height: 100rpx;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.10), transparent 60%),
    rgba(4, 18, 30, 0.50);
  border: 1rpx solid rgba(0, 190, 255, 0.28);
  box-shadow:
    0 0 20rpx rgba(0, 170, 255, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(230, 246, 255, 0.92);
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  transition: transform 180ms ease, box-shadow 300ms ease;
  animation: btnGlowPulse 3s ease-in-out infinite;
}

.result-primary-btn:active {
  transform: translateY(2rpx) scale(0.99);
  box-shadow: 0 0 10rpx rgba(0, 170, 255, 0.15);
}

@keyframes btnGlowPulse {
  0%, 100% { box-shadow: 0 0 20rpx rgba(0, 170, 255, 0.08); }
  50%      { box-shadow: 0 0 30rpx rgba(0, 170, 255, 0.16); }
}

.result-secondary-link {
  width: 380rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(4, 18, 30, 0.30);
  border: 1rpx solid rgba(0, 190, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: rgba(160, 210, 235, 0.48);
  letter-spacing: 2rpx;
  transition: transform 180ms ease, color 200ms ease;
}

.result-secondary-link:active {
  transform: translateY(2rpx) scale(0.99);
  color: rgba(160, 210, 235, 0.72);
}

.result-secondary-link--loading {
  opacity: 0.6;
  pointer-events: none;
}

.result-secondary-link--loading::after {
  content: '';
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.5);
  margin-left: 8rpx;
  animation: btnPulse 1s ease-in-out infinite;
}

@keyframes btnPulse {
  0%, 100% { opacity: 0.3; }
  50%      { opacity: 1; }
}

.strategy-result-spacer {
  flex: 1;
  min-height: 40rpx;
}

/* ===== 全局禁止圆形 spinner ===== */
.strategy-page .loading-spinner,
.strategy-page .spinner,
.strategy-page .circle-loading {
  display: none !important;
}

/* ===== 15. reduce-motion 强制兜底 ===== */
.reduce-motion .directive-projection,
.reduce-motion .projection-card {
  animation: none !important;
  transition: none !important;
  filter: none !important;
}

.reduce-motion .directive-projection,
.reduce-motion .directive-projection.dp-visible,
.reduce-motion .projection-card {
  opacity: 1 !important;
  transform: none !important;
}

/* ===== 海报弹层（CSS 控制显隐，始终挂载） ===== */
.poster-mask {
  position: fixed;
  inset: 0;
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  background: rgba(0, 0, 0, 0);
  backdrop-filter: blur(0px);
  -webkit-backdrop-filter: blur(0px);
  transition: background 350ms ease,
              backdrop-filter 350ms ease,
              -webkit-backdrop-filter 350ms ease;
}

.poster-mask--visible {
  pointer-events: auto;
  background: rgba(0, 0, 0, 0.50);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.poster-mask--hidden {
  pointer-events: none;
  background: rgba(0, 0, 0, 0);
  backdrop-filter: blur(0px);
  -webkit-backdrop-filter: blur(0px);
}

.poster-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  width: 600rpx;
  max-height: 85vh;
  opacity: 0;
  transform: scale(0.96) translateY(16rpx);
  transition: opacity 350ms cubic-bezier(0.22, 1, 0.36, 1),
              transform 400ms cubic-bezier(0.22, 1, 0.36, 1);
}

.poster-mask--visible .poster-container {
  opacity: 1;
  transform: scale(1) translateY(0);
}

/* 生成中 */
.poster-gen {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.poster-gen-dots {
  display: flex;
  gap: 16rpx;
}

.poster-gen-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.6);
  animation: posterDotPulse 1.2s ease-in-out infinite;
}
.poster-gen-dot:nth-child(2) { animation-delay: 0.2s; }
.poster-gen-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes posterDotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

.poster-gen-text {
  font-size: 24rpx;
  color: rgba(180, 215, 235, 0.52);
  letter-spacing: 2rpx;
  animation: posterTextBreath 2s ease-in-out infinite;
}

@keyframes posterTextBreath {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 0.9; }
}

/* 预览 */
.poster-preview {
  width: 600rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.poster-image {
  width: 100%;
  display: block;
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 190, 255, 0.18);
}

/* 错误 */
.poster-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.poster-error-text {
  font-size: 26rpx;
  color: rgba(255, 160, 60, 0.82);
}

.poster-error-actions {
  display: flex;
  gap: 24rpx;
}

.poster-error-btn {
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  color: rgba(180, 215, 235, 0.68);
  border: 1rpx solid rgba(0, 190, 255, 0.18);
  border-radius: 8rpx;
}

/* 操作按钮 */
.poster-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.poster-actions--three {
  justify-content: center;
}

.poster-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(220, 240, 255, 0.88);
  background: rgba(8, 24, 38, 0.82);
  border: 1rpx solid rgba(0, 190, 255, 0.18);
  border-radius: 12rpx;
  letter-spacing: 2rpx;
}

.poster-btn--save {
  background: rgba(0, 175, 255, 0.12);
  border-color: rgba(0, 190, 255, 0.28);
}

.poster-btn--share {
  margin: 0;
  padding: 0;
  line-height: normal;
}
.poster-btn--share::after { border: none; }

.poster-btn--close {
  color: rgba(160, 210, 235, 0.52);
  border-color: rgba(160, 210, 235, 0.14);
}

/* Canvas 离屏 */
.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}

.reduce-motion .poster-gen-dot {
  animation: none !important;
  opacity: 0.6;
}

.reduce-motion .poster-gen-text {
  animation: none !important;
  opacity: 0.7;
}

/* ===== 通用 fadeIn / fadeInDown ===== */
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-16rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ===== 星图色相偏移 ===== */
.nav-map-window--tint-cyan .nav-star       { /* 默认青蓝，无需偏移 */ }
.nav-map-window--tint-blue-green .nav-star  { filter: hue-rotate(15deg); }
.nav-map-window--tint-blue .nav-star        { filter: hue-rotate(-15deg); }
.nav-map-window--tint-teal .nav-star        { filter: hue-rotate(30deg); }

/* ===== 底部导航渐变遮罩 ===== */
.flight-deck {
  position: relative;
}

.flight-deck::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(to bottom, transparent, rgba(2, 8, 14, 0.6));
  pointer-events: none;
  z-index: 0;
}

/* ===== 新增动画 reduce-motion 覆盖 ===== */
.reduce-motion .calibration-phase-text {
  animation: none !important;
}

/* ===== 星图 crossfade ===== */
.nav-map-window--crossfade-out {
  animation: crossfadeOut 800ms ease-out forwards;
}

.nav-map-window--crossfade-in {
  /* crossfade-in 只在 seed 变化时触发，默认状态保持正常 */
}

@keyframes crossfadeOut {
  0%   { opacity: 0.45; }
  100% { opacity: 0; }
}

@keyframes crossfadeIn {
  0%   { opacity: 0; }
  100% { opacity: 0.45; }
}

/* ===== completing 转场动画 ===== */
@keyframes completingFlash {
  0%   { opacity: 0.55; filter: saturate(0.7) brightness(0.9); }
  30%  { opacity: 0.65; filter: saturate(0.8) brightness(1.1); }
  100% { opacity: 0.32; filter: saturate(0.8) brightness(1); }
}

/* completing 星核聚光脉冲 */
.star-core--completing .cs-main-dot {
  animation: completingCorePulse 700ms ease-out forwards;
}

@keyframes completingCorePulse {
  0%   { transform: scale(1);   box-shadow: 0 0 30rpx rgba(0, 210, 255, 0.6); }
  40%  { transform: scale(1.6); box-shadow: 0 0 80rpx rgba(0, 210, 255, 1); }
  100% { transform: scale(0.8); box-shadow: 0 0 12rpx rgba(0, 210, 255, 0.3); }
}

/* completing 光波扩散（从星核） */
.nav-map-window--completing::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 40%;
  width: 40rpx;
  height: 40rpx;
  margin: -20rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0, 210, 255, 0.5), transparent 70%);
  animation: completionWave 700ms ease-out forwards;
  pointer-events: none;
  z-index: 5;
}

@keyframes completionWave {
  0%   { transform: scale(0); opacity: 0.7; }
  100% { transform: scale(18); opacity: 0; }
}

/* completing 连接线闪烁 */
.nav-map-window--completing .nav-conn-line {
  animation: connFlash 300ms ease-out;
}

@keyframes connFlash {
  0%   { opacity: 0.5; }
  100% { opacity: var(--conn-opacity, 0.08); }
}

/* ===== regenerating 星核重构脉冲 =====
 * 由 .core-system--regenerating .cs-main-dot 的 csDotRegen 处理（见上）；
 * 这里保留 .star-core--regenerating 钩子用于父层联动（如有），不再附加额外动画。
 */

/* ===== starting 按钮淡出 ===== */
.flight-deck--starting .nav-launch-btn-area {
  animation: btnFadeOut 400ms ease-out forwards;
}

@keyframes btnFadeOut {
  to { opacity: 0; transform: translateY(12rpx); }
}

/* ===== reduce-motion: 转场动画禁用 ===== */
.reduce-motion .nav-map-window--completing,
.reduce-motion .nav-map-window--completing::before,
.reduce-motion .nav-map-window--crossfade-out,
.reduce-motion .star-core--completing .cs-main-dot,
.reduce-motion .core-system--regenerating .cs-main-dot,
.reduce-motion .flight-deck--starting .nav-launch-btn-area {
  animation: none !important;
}

/* ===== 精致按钮内部元素 ===== */
.btn-cockpit-icon {
  width: 44rpx;
  height: 44rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.btn-icon-pulse {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 1.5rpx solid rgba(0, 200, 255, 0.45);
  border-radius: 50%;
  animation: btnIconPulse 2.5s ease-out infinite;
}

.btn-icon-core {
  width: 10rpx;
  height: 10rpx;
  background: #00c8ff;
  border-radius: 50%;
  box-shadow: 0 0 10rpx #00c8ff;
  z-index: 3;
}

.btn-icon-reticle {
  position: absolute;
  width: 130%;
  height: 130%;
  border: 1rpx dashed rgba(0, 200, 255, 0.25);
  border-radius: 50%;
  animation: btnIconRotate 14s linear infinite;
  z-index: 1;
}

.btn-icon-cross-h {
  position: absolute;
  left: -20%;
  right: -20%;
  height: 1.5rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.4), transparent);
  z-index: 2;
}

.btn-icon-cross-v {
  position: absolute;
  top: -20%;
  bottom: -20%;
  width: 1.5rpx;
  background: linear-gradient(180deg, transparent, rgba(0, 200, 255, 0.4), transparent);
  z-index: 2;
}

.btn-caption-text {
  font-size: 20rpx;
  color: rgba(230, 246, 255, 0.85);
  letter-spacing: 6rpx;
  font-family: "Courier New", Courier, monospace;
  font-weight: 600;
  text-shadow: 0 0 10rpx rgba(0, 200, 255, 0.3);
}

@keyframes btnIconPulse {
  0% { transform: scale(0.7); opacity: 0.8; }
  100% { transform: scale(2.2); opacity: 0; }
}

@keyframes btnIconRotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ===== 左上角 HUD 状态控制器 ===== */
.hud-status-module {
  position: absolute;
  top: calc(180rpx + env(safe-area-inset-top));
  left: 40rpx;
  z-index: 90;
  padding: 16rpx 20rpx;
  background: rgba(3, 16, 28, 0.35);
  border: 1rpx solid rgba(0, 190, 255, 0.12);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  font-family: "Courier New", Courier, monospace;
  min-width: 240rpx;
  pointer-events: auto;
  transition: opacity 0.5s ease, transform 0.5s ease;
}

.hud-row {
  display: flex;
  align-items: center;
}

.hud-row--connection {
  gap: 8rpx;
  margin-bottom: 2rpx;
}

.hud-connection-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  transition: background-color 0.3s ease, box-shadow 0.3s ease;
}

.css-connection-dot--idle {
  background: rgba(160, 210, 235, 0.4);
  box-shadow: 0 0 4rpx rgba(160, 210, 235, 0.2);
}

.css-connection-dot--starting {
  background: rgba(0, 200, 255, 0.75);
  box-shadow: 0 0 8rpx rgba(0, 200, 255, 0.4);
  animation: hudDotPulse 1.5s infinite;
}

.css-connection-dot--online {
  background: rgba(50, 215, 75, 0.75);
  box-shadow: 0 0 8rpx rgba(50, 215, 75, 0.4);
}

@keyframes hudDotPulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 1; }
}

.hud-connection-text {
  font-size: 16rpx;
  color: rgba(160, 210, 235, 0.5);
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.hud-state-label {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(230, 246, 255, 0.9);
  letter-spacing: 2rpx;
}

.hud-step-text {
  font-size: 18rpx;
  color: rgba(0, 200, 255, 0.7);
  letter-spacing: 1.5rpx;
}

.hud-micro-text {
  font-size: 14rpx;
  color: rgba(126, 156, 180, 0.35);
  letter-spacing: 1rpx;
  margin-top: 2rpx;
}

/* ===== 诊断信息结果卡片 ===== */
.result-card-container {
  width: 640rpx;
  background: rgba(3, 16, 28, 0.45);
  border: 1.5rpx solid rgba(0, 190, 255, 0.2);
  border-radius: 20rpx;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.5);
  /* 严格防拉长页面：卡片最大高度自适应 */
  max-height: calc(100vh - var(--custom-nav-height, 176rpx) - env(safe-area-inset-bottom) - 340rpx);
}

/* 结果面板高光流线装饰 */
.rc-header-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  width: 100%;
}

.rc-serial {
  font-family: "Courier New", Courier, monospace;
  font-size: 16rpx;
  color: rgba(126, 156, 180, 0.45);
  letter-spacing: 2rpx;
}

.rc-line-deco {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(0, 190, 255, 0.04), rgba(0, 190, 255, 0.15), rgba(0, 190, 255, 0.04));
  margin: 0 16rpx;
}

.rc-type {
  font-size: 18rpx;
  color: rgba(0, 200, 255, 0.65);
  letter-spacing: 2rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.25);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.rc-verdict {
  font-size: 34rpx;
  font-weight: 700;
  color: rgba(230, 246, 255, 0.95);
  line-height: 1.5;
  text-align: center;
  margin-bottom: 28rpx;
  letter-spacing: 3rpx;
}

.rc-badges {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 24rpx;
  width: 100%;
}

.rc-badge-pill {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 8rpx;
  border-radius: 8rpx;
  background: rgba(0, 190, 255, 0.05);
  border: 1rpx solid rgba(0, 190, 255, 0.1);
}

.rc-badge-label {
  font-size: 14rpx;
  color: rgba(126, 156, 180, 0.5);
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.rc-badge-value {
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(230, 246, 255, 0.9);
}

.rc-divider-dash {
  height: 1rpx;
  border-top: 1rpx dashed rgba(0, 190, 255, 0.18);
  width: 100%;
  margin: 20rpx 0;
}

.rc-details {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
  width: 100%;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.rc-detail-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.rc-detail-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.rc-detail-dot--buff {
  background: #32d74b;
  box-shadow: 0 0 6rpx rgba(50, 215, 75, 0.5);
}

.rc-detail-dot--debuff {
  background: #ff9f0a;
  box-shadow: 0 0 6rpx rgba(255, 159, 10, 0.5);
}

.rc-detail-text {
  font-size: 22rpx;
  color: rgba(230, 246, 255, 0.85);
  line-height: 1.5;
}

.rc-summary {
  font-size: 22rpx;
  color: rgba(230, 246, 255, 0.8);
  line-height: 1.6;
  margin-bottom: 20rpx;
  text-align: center;
}

.rc-footer-tip {
  margin-top: 16rpx;
  text-align: center;
  width: 100%;
}

.rc-footer-tip text {
  font-family: "Courier New", Courier, monospace;
  font-size: 12rpx;
  color: rgba(126, 156, 180, 0.3);
  letter-spacing: 2rpx;
}

/* ===== 自定义导航栏左上角极简 HUD 视觉痕迹 (无字) ===== */
.cockpit-hud-indicator {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 40rpx;
  pointer-events: none;
}

/* 状态信号线：一个极小状态点 */
.css-status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  transition: all 0.4s ease;
}
.css-status-dot--idle {
  background: rgba(0, 200, 255, 0.45);
  box-shadow: 0 0 8rpx rgba(0, 200, 255, 0.35);
}
.css-status-dot--starting {
  background: rgba(0, 200, 255, 0.95);
  box-shadow: 0 0 12rpx rgba(0, 200, 255, 0.7);
  animation: cssStatusDotPulse 1.2s ease-in-out infinite alternate;
}
.css-status-dot--online {
  background: rgba(50, 215, 75, 0.85);
  box-shadow: 0 0 10rpx rgba(50, 215, 75, 0.5);
}

@keyframes cssStatusDotPulse {
  0% { transform: scale(0.85); opacity: 0.6; }
  100% { transform: scale(1.15); opacity: 1; }
}

/* 一条极淡弱光状态线 */
.css-status-line {
  width: 32rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(0, 200, 255, 0.45) 0%, rgba(0, 200, 255, 0.05) 100%);
  box-shadow: 0 0 4rpx rgba(0, 200, 255, 0.25);
  border-radius: 1rpx;
}

/* 一个极淡图形信号标记：三根递增高度的细信号竖杠 */
.css-hud-signal {
  display: flex;
  align-items: flex-end;
  gap: 3rpx;
  height: 14rpx;
  width: 16rpx;
}
.css-hud-signal::before {
  content: '';
  width: 2rpx;
  height: 6rpx;
  background: rgba(0, 200, 255, 0.22);
}
.css-hud-signal::after {
  content: '';
  width: 2rpx;
  height: 12rpx;
  background: rgba(0, 200, 255, 0.22);
  box-shadow: -5rpx 0 0 rgba(0, 200, 255, 0.22);
}

<scroll-view class="strategy-page {{!animationEnabled ? 'reduce-motion' : ''}}" scroll-y="{{pageMode !== 'generating'}}" enable-flex="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">

  <!-- ═══ launch / relaunchReady 启动卡牌页 ═══ -->
  <view class="strategy-launch" wx:if="{{pageMode === 'launch' || pageMode === 'relaunchReady'}}">

    <!-- 顶部标题 -->
    <view class="strategy-launch-header">
      <text class="strategy-launch-title">今日航行指令</text>
      <text class="strategy-launch-kicker">CORE STATUS</text>
      <text class="strategy-launch-date">{{currentDate}}</text>
    </view>

    <!-- 复位状态条（仅 relaunchReady） -->
    <view class="strategy-reset-bar" wx:if="{{pageMode === 'relaunchReady'}}">
      <view class="strategy-reset-dot"></view>
      <text class="strategy-reset-text">策略核心待机 · 点击启动</text>
    </view>

    <!-- 核心卡牌 -->
    <view class="strategy-core-wrap">
      <view class="scan-ring scan-ring--idle"></view>
      <view class="strategy-core-card {{pageMode === 'relaunchReady' ? 'strategy-core-card--armed' : ''}}" bindtap="onTapLaunchCore">
        <view class="strategy-core-visual">
          <view class="core-inner">
            <view class="core-ring core-ring--1"></view>
            <view class="core-ring core-ring--2"></view>
            <view class="core-ring core-ring--3"></view>
            <view class="core-dot"></view>
          </view>
        </view>
        <view class="strategy-core-label">策略核心</view>
        <view class="strategy-core-sublabel">点击启动</view>
      </view>
    </view>

    <!-- 底部说明 -->
    <view class="strategy-launch-info">
      <text class="strategy-launch-info-text">同步身份协议与黑匣子样本，生成今日航行指令</text>
    </view>

    <view class="countdown-bar" wx:if="{{countdownText}}">
      <text class="countdown-label">下次策略刷新：</text>
      <text class="countdown-value">{{countdownText}}</text>
    </view>
  </view>

  <!-- ═══ generating 计算页 ═══ -->
  <view class="strategy-generate" wx:if="{{pageMode === 'generating'}}">

    <!-- 核心舱 HUD -->
    <view class="strategy-reactor">
      <view class="strategy-reactor-core">
        <view class="core-inner">
          <view class="core-ring core-ring--1"></view>
          <view class="core-ring core-ring--2"></view>
          <view class="core-ring core-ring--3"></view>
          <view class="core-dot"></view>
        </view>
      </view>
      <view class="scan-ring scan-ring--gen"></view>
    </view>

    <!-- 主文案 -->
    <view class="strategy-gen-label">
      <text class="strategy-gen-kicker">STRATEGY CORE</text>
      <text class="strategy-gen-sub">系统正在同步身份协议、历史样本与今日状态</text>
    </view>

    <!-- 进度步骤 -->
    <view class="strategy-progress-rail">
      <view class="strategy-step-item {{item.done ? 'strategy-step-item--done' : index === step ? 'strategy-step-item--active' : ''}}"
            wx:for="{{stages}}" wx:key="index">
        <view class="strategy-step-dot {{item.done ? 'strategy-step-dot--done' : index === step ? 'strategy-step-dot--active' : ''}}"></view>
        <text class="strategy-step-label">{{item.label}}</text>
      </view>
      <view class="strategy-step-count">{{stagesDoneCount}} / 4</view>
    </view>

    <!-- 日志流 -->
    <view class="strategy-terminal">
      <view class="strategy-log-line {{item.visible ? 'strategy-log-line--visible' : ''}}"
            wx:for="{{logs}}" wx:key="index">
        <text class="strategy-log-prefix">{{item.prefix}}</text>
        <text class="strategy-log-text {{item.typing ? 'strategy-log-typing' : ''}}">{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- ═══ result 结果页 ═══ -->
  <view class="strategy-result" wx:if="{{pageMode === 'result'}}" style="--accent: {{themeColor}};">

    <!-- 顶部标题区 -->
    <view class="strategy-result-header">
      <text class="strategy-result-title">今日航行指令</text>
      <text class="strategy-result-kicker">CORE STATUS</text>
      <text class="strategy-result-date">{{currentDate}}</text>
    </view>

    <!-- 状态胶囊 -->
    <view class="strategy-tag-pill" wx:if="{{strategy.tag}}" style="border-color: {{themeColor}}40; background: {{themeColor}}12; color: {{themeColor}};">
      <text>{{strategy.tag}}</text>
    </view>

    <!-- HUD 芯片 -->
    <view class="strategy-hud-chips">
      <view class="strategy-hud-chip">
        <text class="strategy-hud-chip-label">数据源</text>
        <text class="strategy-hud-chip-value">{{sourceLabel}}</text>
      </view>
      <view class="strategy-hud-chip">
        <text class="strategy-hud-chip-label">观测窗口</text>
        <text class="strategy-hud-chip-value">{{solarTermLabel}}</text>
      </view>
      <view class="strategy-hud-chip">
        <text class="strategy-hud-chip-label">状态噪声</text>
        <text class="strategy-hud-chip-value">{{userTagLabel}}</text>
      </view>
    </view>

    <!-- 核心洞察 -->
    <view class="strategy-insight" wx:if="{{strategy.verdict}}">
      <view class="strategy-section-head">
        <text class="strategy-section-title">当前状态</text>
        <text class="strategy-section-kicker">INSIGHT</text>
      </view>
      <text class="strategy-insight-text">{{strategy.verdict}}</text>
    </view>

    <!-- 策略读数 -->
    <view class="strategy-reading" wx:if="{{strategy.title}}">
      <view class="strategy-reading-head">
        <text class="strategy-reading-name">{{strategy.title}}</text>
        <text class="strategy-reading-sub" wx:if="{{strategy.subtitle}}">{{strategy.subtitle}}</text>
      </view>
      <view class="strategy-reading-tags" wx:if="{{strategy.tags && strategy.tags.length}}">
        <text class="strategy-reading-tag" wx:for="{{strategy.tags}}" wx:key="index">{{item}}</text>
      </view>
    </view>

    <!-- 行动优势 -->
    <view class="strategy-section" wx:if="{{strategy.buffs && strategy.buffs.length}}">
      <view class="strategy-section-head">
        <text class="strategy-section-icon strategy-section-icon--pos">+</text>
        <text class="strategy-section-title strategy-section-title--pos">执行节奏</text>
        <text class="strategy-section-kicker">ADVANTAGE</text>
      </view>
      <view class="strategy-list-card">
        <view class="strategy-list-item" wx:for="{{strategy.buffs}}" wx:key="index">
          <text class="strategy-list-index strategy-list-index--pos">{{index + 1 < 10 ? '0' + (index + 1) : index + 1}}</text>
          <text class="strategy-list-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 风险提示 -->
    <view class="strategy-section" wx:if="{{strategy.debuffs && strategy.debuffs.length}}">
      <view class="strategy-section-head">
        <text class="strategy-section-icon strategy-section-icon--neg">!</text>
        <text class="strategy-section-title strategy-section-title--neg">风险提示</text>
        <text class="strategy-section-kicker strategy-section-kicker--neg">RISK</text>
      </view>
      <view class="strategy-list-card strategy-list-card--risk">
        <view class="strategy-list-item" wx:for="{{strategy.debuffs}}" wx:key="index">
          <text class="strategy-list-index strategy-list-index--neg">{{index + 1 < 10 ? '0' + (index + 1) : index + 1}}</text>
          <text class="strategy-list-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 刷新倒计时 -->
    <view class="countdown-bar" wx:if="{{countdownText}}">
      <text class="countdown-label">刷新倒计时 </text>
      <text class="countdown-value">{{countdownText}}</text>
    </view>

    <!-- 底部操作区 -->
    <view class="strategy-result-spacer"></view>
    <view class="strategy-actions">
      <view class="strategy-action-btn strategy-action-btn--secondary" bindtap="onTapRegenerate">
        <text class="strategy-action-text">重新推演</text>
        <text class="strategy-action-kicker">REGEN</text>
      </view>
      <view class="strategy-action-btn strategy-action-btn--primary" bindtap="onTapShare">
        <text class="strategy-action-text">分享策略卡</text>
        <text class="strategy-action-kicker">SHARE</text>
      </view>
    </view>
  </view>

  <!-- ═══ 海报弹层（保留原逻辑） ═══ -->
  <view wx:if="{{phase === 'poster_generating' || phase === 'poster_preview'}}" class="poster-mask" catchtap="noop">
    <view class="poster-container">

      <view class="poster-gen" wx:if="{{phase === 'poster_generating'}}">
        <text class="poster-gen-text">正在生成策略投影...</text>
        <view class="poster-gen-bar">
          <view class="poster-gen-bar-fill"></view>
        </view>
      </view>

      <view class="poster-preview" wx:if="{{phase === 'poster_preview' && posterPath}}">
        <image class="poster-image" src="{{posterPath}}" mode="widthFix" show-menu-by-longpress />
      </view>

      <view class="poster-error" wx:if="{{posterError}}">
        <text class="poster-error-text">{{posterError}}</text>
        <view class="poster-error-actions">
          <view class="poster-error-btn" bindtap="onPosterRetry">重试</view>
          <view class="poster-error-btn" bindtap="onPosterCancel">取消</view>
        </view>
      </view>

      <view class="poster-actions" wx:if="{{phase === 'poster_preview' && posterPath}}">
        <view class="poster-btn poster-btn--save" bindtap="onSavePoster">保存图片</view>
        <view class="poster-btn poster-btn--share" bindtap="onSharePoster">分享微信</view>
        <view class="poster-btn poster-btn--close" bindtap="onClosePoster">关闭</view>
      </view>

    </view>
  </view>

  <canvas type="2d" id="posterCanvas" class="poster-canvas"></canvas>

  <!-- ═══ 重新推演弹窗（完全自定义 · 推进舱风格） ═══ -->
  <view class="strategy-regen-mask {{showRegenerateModal ? 'strategy-regen-mask--show' : ''}}" wx:if="{{showRegenerateModal}}" catchtap="noop">
    <view class="strategy-regen-modal {{reduceMotion ? '' : 'strategy-regen-modal--animate'}}">

      <!-- 顶部能量轨道 -->
      <view class="strategy-modal-rail">
        <view class="strategy-modal-rail-fill"></view>
      </view>

      <!-- 小标签 -->
      <view class="strategy-modal-tag">核心复位</view>

      <!-- 主标题 -->
      <view class="strategy-modal-title">重新启动策略核心</view>

      <!-- 英文装饰 -->
      <view class="strategy-modal-kicker">RE-IGNITION</view>

      <!-- 推进核心图形 -->
      <view class="strategy-modal-core">
        <view class="strategy-modal-core-bar">
          <view class="strategy-modal-core-seg strategy-modal-core-seg--1"></view>
          <view class="strategy-modal-core-seg strategy-modal-core-seg--2"></view>
          <view class="strategy-modal-core-seg strategy-modal-core-seg--3"></view>
        </view>
        <view class="strategy-modal-core-block"></view>
      </view>

      <!-- 说明 -->
      <view class="strategy-modal-desc">
        当前策略将收起，核心回到待启动状态。再次点击核心卡牌后，系统会重新推演今日策略。
      </view>

      <!-- 按钮 -->
      <view class="strategy-modal-actions">
        <view class="strategy-modal-btn" bindtap="onCancelRegenerate">
          <text>保持当前</text>
        </view>
        <view class="strategy-modal-btn strategy-modal-btn--primary" bindtap="onConfirmRegenerate">
          <text>复位核心</text>
        </view>
      </view>
    </view>
  </view>

</scroll-view>

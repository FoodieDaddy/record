<scroll-view class="page-container {{!animationEnabled ? 'reduce-motion' : ''}}" scroll-y="{{phase !== 'generating'}}" enable-flex="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">

  <!-- ═══ idle 屏 ═══ -->
  <view class="idle-screen" wx:if="{{phase === 'idle'}}">
    <view class="idle-header">
      <view class="page-kicker">STRATEGY</view>
      <view class="page-date">[ {{currentDate}} ]</view>
      <view class="page-lunar" wx:if="{{lunarInfo}}">{{lunarInfo}}</view>
    </view>

    <view class="sr-section-head" style="margin: 0 48rpx 48rpx;">
      <view>
        <text class="sr-title">今日策略</text>
        <text class="sr-kicker">STRATEGY · DAILY</text>
      </view>
    </view>

    <view class="card-stage" bindtap="onTapDraw">
      <view class="oracle-card">
        <view class="card-inner">
          <view class="card-ring card-ring--1"></view>
          <view class="card-ring card-ring--2"></view>
          <view class="card-ring card-ring--3"></view>
          <view class="card-dot"></view>
        </view>
      </view>
      <view class="scan-ring scan-ring--idle"></view>
      <view class="tap-hint">点击生成</view>
    </view>

    <view class="idle-info">
      <view class="idle-info-label">系统将结合：</view>
      <view class="idle-info-tags">人格协议 · 战绩镜像 · 历史行为</view>
    </view>

    <view class="countdown-bar" wx:if="{{countdownText}}">
      <text class="countdown-label">下一次策略更新：</text>
      <text class="countdown-value">{{countdownText}}</text>
    </view>
  </view>

  <!-- ═══ generating 屏 ═══ -->
  <view class="gen-screen {{genFadeOut ? 'gen-fade-out' : ''}}" wx:if="{{phase === 'generating'}}">
    <view class="gen-card-area">
      <view class="gen-card gen-card--breathing">
        <view class="card-inner">
          <view class="card-ring card-ring--1"></view>
          <view class="card-ring card-ring--2"></view>
          <view class="card-ring card-ring--3"></view>
          <view class="card-dot"></view>
        </view>
      </view>
      <view class="scan-ring scan-ring--gen"></view>
    </view>

    <view class="gen-title-block">
      <text class="gen-main-title">正在推演今日策略</text>
      <text class="gen-sub-title">系统正在结合人格协议与历史行为模型，生成最优行动建议</text>
    </view>

    <view class="gen-checklist">
      <view class="gen-check-item {{item.done ? 'gen-check-item--done' : ''}}"
            wx:for="{{stages}}" wx:key="index">
        <text class="gen-check-mark">{{item.done ? '✓' : (index === step ? '...' : '·')}}</text>
        <text class="gen-check-label">{{item.label}}</text>
      </view>
      <view class="gen-check-count">{{stagesDoneCount}} / 4</view>
    </view>

    <view class="gen-terminal">
      <view class="gen-log-line {{item.visible ? 'gen-log-line--visible' : ''}}"
            wx:for="{{logs}}" wx:key="index">
        <text class="gen-log-prefix">{{item.prefix}}</text>
        <text class="gen-log-text {{item.typing ? 'gen-log-typing' : ''}}">{{item.text}}</text>
      </view>
    </view>

    <view class="gen-timeout" wx:if="{{timeoutLevel === 'warning'}}">
      <text class="gen-timeout-text">推演仍在进行，请稍候</text>
    </view>
    <view class="gen-timeout gen-timeout--long" wx:if="{{timeoutLevel === 'critical'}}">
      <text class="gen-timeout-text">推演耗时较长，可继续等待或重新发起</text>
      <view class="gen-timeout-actions">
        <view class="gen-timeout-btn" bindtap="onTapWait">继续等待</view>
        <view class="gen-timeout-btn gen-timeout-btn--primary" bindtap="onTapRetry">重新推演</view>
      </view>
    </view>
  </view>

  <!-- ═══ success 屏 ═══ -->
  <view class="success-screen" wx:if="{{phase === 'success'}}">
    <view class="success-header">
      <view class="page-kicker">STRATEGY</view>
      <view class="page-date">[ {{currentDate}} ]</view>
      <view class="page-lunar" wx:if="{{lunarInfo}}">{{lunarInfo}}</view>
    </view>

    <view class="sr-section-head" style="margin: 0 16rpx 32rpx;">
      <view>
        <text class="sr-title">今日策略</text>
        <text class="sr-kicker">STRATEGY · DAILY</text>
      </view>
      <text class="sr-status-code" wx:if="{{strategy.tag}}">{{strategy.tag}}</text>
    </view>

    <!-- 策略主题卡 -->
    <view class="strategy-hero-card sr-card">
      <view class="strategy-theme-head">
        <text class="strategy-theme-label">策略主题</text>
        <text class="strategy-theme-code">THEME</text>
      </view>
      <text class="strategy-theme-text">{{strategyTheme || '节奏校准'}}</text>
      <text class="strategy-summary-text">{{strategySummary || '当前策略已生成。建议先观察场上节奏，再根据反馈调整行动。'}}</text>
    </view>

    <view class="result-card" style="--accent: {{strategy.glowColor || '#00AFFF'}};" wx:if="{{strategy.verdict || strategy.title}}">
      <view class="result-card-glow"></view>
      <view class="result-card-header" wx:if="{{strategy.title}}">
        <view class="result-card-title">{{strategy.title}}</view>
        <view class="result-card-subtitle" wx:if="{{strategy.subtitle}}">{{strategy.subtitle}}</view>
      </view>
      <view class="result-card-body" wx:if="{{strategy.verdict}}">
        <view class="result-card-verdict-label">核心洞察 <text class="verdict-kicker">INSIGHT</text></view>
        <view class="result-card-verdict">{{strategy.verdict}}</view>
      </view>
      <view class="result-card-divider" wx:if="{{strategy.title && strategy.verdict}}"></view>
      <view class="result-tags-inline" wx:if="{{strategy.tags && strategy.tags.length}}">
        <view class="result-tag" wx:for="{{strategy.tags}}" wx:key="index">{{item}}</view>
      </view>
    </view>

    <view class="result-section" wx:if="{{strategy.buffs && strategy.buffs.length}}">
      <view class="result-section-title">
        <text class="result-section-icon">+</text>
        <text class="result-section-zh">行动优势</text>
        <text class="result-section-kicker">ADVANTAGE</text>
      </view>
      <view class="result-list-card">
        <view class="result-list-item result-list-item--buff" wx:for="{{strategy.buffs}}" wx:key="index">
          <text class="vector-index vector-index--pos">{{index + 1 < 10 ? '0' + (index + 1) : index + 1}}</text>
          <text class="result-list-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="result-section" wx:if="{{strategy.debuffs && strategy.debuffs.length}}">
      <view class="result-section-title">
        <text class="result-section-icon result-section-icon--risk">!</text>
        <text class="result-section-zh">风险提示</text>
        <text class="result-section-kicker result-section-kicker--risk">RISK</text>
      </view>
      <view class="result-list-card">
        <view class="result-list-item result-list-item--risk" wx:for="{{strategy.debuffs}}" wx:key="index">
          <text class="vector-index vector-index--neg">{{index + 1 < 10 ? '0' + (index + 1) : index + 1}}</text>
          <text class="result-list-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="result-actions">
      <view class="result-btn result-btn--secondary" bindtap="onTapRefresh">
        <text class="result-btn-label">重新生成</text>
        <text class="result-btn-code">REGEN</text>
      </view>
      <view class="result-btn result-btn--primary" bindtap="onTapShare">
        <text class="result-btn-label">分享策略卡</text>
        <text class="result-btn-code result-btn-code--primary">SHARE</text>
      </view>
    </view>

    <view class="countdown-bar" wx:if="{{countdownText}}">
      <text class="countdown-label">刷新倒计时 </text>
      <text class="countdown-value">{{countdownText}}</text>
    </view>
  </view>

  <!-- ═══ error 屏 ═══ -->
  <view class="error-screen" wx:if="{{phase === 'error'}}">
    <view class="error-icon">!</view>
    <view class="error-title">策略推演失败</view>
    <view class="error-text">系统暂时无法生成今日策略</view>
    <view class="error-actions">
      <view class="error-btn" bindtap="onTapRetryError">重试</view>
    </view>
  </view>

  <!-- ═══ 海报弹层 ═══ -->
  <view wx:if="{{phase === 'poster_generating' || phase === 'poster_preview'}}" class="poster-mask" catchtap="noop">
    <view class="poster-container">

      <view class="poster-gen" wx:if="{{phase === 'poster_generating'}}">
        <text class="poster-gen-text">正在生成档案...</text>
        <view class="poster-gen-bar">
          <view class="poster-gen-bar-fill"></view>
        </view>
      </view>

      <view class="poster-preview" wx:if="{{phase === 'poster_preview' && posterPath}}">
        <image class="poster-image" src="{{posterPath}}" mode="widthFix" show-menu-by-longpress />
      </view>

      <view class="poster-error" wx:if="{{posterError}}">
        <text class="poster-error-text">{{posterError}}</text>
        <view class="poster-error-actions">
          <view class="poster-error-btn" bindtap="onPosterRetry">重试</view>
          <view class="poster-error-btn" bindtap="onPosterCancel">取消</view>
        </view>
      </view>

      <view class="poster-actions" wx:if="{{phase === 'poster_preview' && posterPath}}">
        <view class="poster-btn poster-btn--save" bindtap="onSavePoster">保存图片</view>
        <view class="poster-btn poster-btn--share" bindtap="onSharePoster">分享微信</view>
        <view class="poster-btn poster-btn--close" bindtap="onClosePoster">关闭</view>
      </view>

    </view>
  </view>

  <canvas type="2d" id="posterCanvas" class="poster-canvas"></canvas>

  <!-- 重新生成确认弹窗 -->
  <terminal-popup
    wx:if="{{showRefreshConfirm}}"
    visible="{{showRefreshConfirm}}"
    title="重新生成"
    subtitle="REGENERATE"
    content="确定要重新生成今日策略？"
    cancelText="取消"
    confirmText="确认"
    confirmType="primary"
    reduceMotion="{{reduceMotion}}"
    bind:cancel="onRefreshCancel"
    bind:confirm="onRefreshConfirm"
  />

</scroll-view>

<scroll-view class="page-container {{!animationEnabled ? 'reduce-motion' : ''}}" scroll-y="{{phase !== 'reveal'}}" enhanced show-scrollbar="{{false}}">

  <!-- Phase 1: 盲抽仪式 — 战术盲盒 -->
  <view class="draw-screen" wx:if="{{phase === 'draw'}}">
    <view class="draw-header">
      <view class="draw-subtitle">SMART RECORD · STRATEGY</view>
      <view class="draw-date">[ {{currentDate}} ]</view>
    </view>

    <view class="cards-stage">
      <view
        wx:for="{{cards}}"
        wx:key="id"
        class="tactical-card {{selectedCardIdx === index ? 'tactical-card--selected' : ''}} {{cardFadeOut && selectedCardIdx !== index ? 'tactical-card--fade' : ''}}"
        style="--delay: {{index * 0.12}}s;"
        bindtap="onCardTap"
        data-idx="{{index}}"
      >
        <view class="card-inner">
          <view class="card-back-ring card-back-ring--1"></view>
          <view class="card-back-ring card-back-ring--2"></view>
          <view class="card-back-ring card-back-ring--3"></view>
          <view class="card-back-dot"></view>
        </view>
      </view>
    </view>

    <view class="draw-prompt" wx:if="{{selectedCardIdx === -1}}">
      <view class="prompt-line">默念今日对局</view>
      <view class="prompt-line prompt-line--dim">抽取你的战术盲盒</view>
    </view>
  </view>

  <!-- Phase 2: 数据推演（卡片旋转 + 日志滚动） -->
  <view class="calc-screen {{calcFadeOut ? 'calc-fade-out' : ''}}" wx:if="{{phase === 'calc'}}">
    <!-- 中央旋转卡片 -->
    <view class="calc-card-area">
      <view class="calc-card calc-card--spinning">
        <view class="card-inner">
          <view class="card-back-ring card-back-ring--1"></view>
          <view class="card-back-ring card-back-ring--2"></view>
          <view class="card-back-ring card-back-ring--3"></view>
          <view class="card-back-dot"></view>
        </view>
      </view>
      <view class="calc-glow-ring"></view>
      <view class="calc-pulse-ring"></view>
    </view>

    <!-- 赛博终端消散日志 -->
    <view class="terminal-bar">
      <view class="terminal-bar__inner" style="{{logSliding ? 'transform: translateY(-36rpx)' : ''}}">
        <view
          wx:for="{{logs}}"
          wx:key="index"
          class="log-line"
          style="opacity: {{item.opacity}}; filter: blur({{item.blur}}rpx);"
        >
          <text class="log-time">{{item.time}}</text>
          <text class="log-msg {{item.type === 'warn' ? 'log-msg--warn' : item.type === 'success' ? 'log-msg--success' : ''}}">{{item.msg}}</text>
        </view>
      </view>
      <view class="cursor-line">
        <text class="blinking-cursor">█</text>
      </view>
    </view>
  </view>

  <!-- Phase 3: 策略揭晓弹窗 -->
  <view class="reveal-modal" wx:if="{{phase === 'reveal'}}">
    <view class="reveal-overlay" catchtouchmove="preventTouchMove"></view>
    <view class="reveal-content" catchtouchmove="preventTouchMove">
      <!-- 战术原型卡面 -->
      <view class="reveal-card-face" style="--accent: {{strategy.glowColor || '#00BFFF'}};">
        <view class="card-face-top-line"></view>
        <view class="card-face-number">No.{{strategyCard.id}}</view>
        <view class="card-face-name">{{strategyCard.name}}</view>
        <view class="card-face-archetype">{{strategyCard.archetype}}</view>
        <view class="card-face-symbol">
          <text class="card-face-icon">{{strategyCard.icon}}</text>
        </view>
        <view class="card-face-verdict">{{strategy.verdict}}</view>
        <view class="card-face-top-line card-face-bottom-line"></view>
      </view>

      <!-- 策略数据面板（打字机逐行出现） -->
      <view class="reveal-strategy-panel">
        <view class="strategy-tag-row typewriter-line" style="--tw-delay: 0.2s;">
          <view class="strategy-tag" style="color: {{strategy.glowColor || '#00BFFF'}}; border-color: {{strategy.glowColor || '#00BFFF'}};">
            {{strategy.tag || strategy.userTag}}
          </view>
          <view class="strategy-source">{{strategy.source === 'llm' ? 'AI 推演' : '离线演算'}}</view>
        </view>

        <block wx:if="{{strategy.buffs && strategy.buffs.length}}">
          <view class="strategy-section-title strategy-section-title--buff typewriter-line" style="--tw-delay: 0.4s;">系统增益</view>
          <view class="strategy-item typewriter-line" wx:for="{{strategy.buffs}}" wx:key="index" style="--tw-delay: {{0.5 + index * 0.15}}s;">
            <text class="strategy-item-prefix strategy-item-prefix--buff">+</text>
            <text class="strategy-item-text">{{item}}</text>
          </view>
        </block>

        <block wx:if="{{strategy.debuffs && strategy.debuffs.length}}">
          <view class="strategy-section-title strategy-section-title--debuff typewriter-line" style="--tw-delay: {{0.5 + (strategy.buffs.length || 0) * 0.15 + 0.2}}s;">风险预警</view>
          <view class="strategy-item typewriter-line" wx:for="{{strategy.debuffs}}" wx:key="index" style="--tw-delay: {{0.5 + (strategy.buffs.length || 0) * 0.15 + 0.3 + index * 0.15}}s;">
            <text class="strategy-item-prefix strategy-item-prefix--debuff">-</text>
            <text class="strategy-item-text">{{item}}</text>
          </view>
        </block>

        <view class="strategy-meta typewriter-line" wx:if="{{strategy.lunarDate}}" style="--tw-delay: {{0.5 + ((strategy.buffs.length || 0) + (strategy.debuffs.length || 0)) * 0.15 + 0.4}}s;">
          <text class="strategy-meta-text">{{strategy.lunarDate}}</text>
          <text class="strategy-meta-text" wx:if="{{strategy.solarTerm}}"> · {{strategy.solarTerm}}</text>
        </view>
      </view>

      <!-- 操作区 -->
      <view class="reveal-actions">
        <view class="reveal-action-btn" bindtap="closeReveal">关闭</view>
        <view class="reveal-action-btn reveal-action-btn--primary" bindtap="refreshStrategy">重新校准</view>
      </view>

      <view class="reveal-cta-btn {{typewriterDone ? 'reveal-cta-btn--visible' : ''}}" bindtap="onShareStrategy">
        <text class="cta-btn-text">分享战术海报</text>
      </view>
    </view>
  </view>

  <!-- 错误态 -->
  <view class="error-screen" wx:if="{{phase === 'error'}}">
    <view class="error-icon">!</view>
    <view class="error-text">{{error}}</view>
    <view class="error-btn" bindtap="startDraw">重新连接</view>
  </view>

  <!-- 状态刷新倒计时 -->
  <view class="countdown-bar" wx:if="{{phase !== 'calc'}}">
    <text class="countdown-text">状态刷新于 {{countdownStr}} 后</text>
  </view>

</scroll-view>

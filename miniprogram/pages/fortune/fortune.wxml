<scroll-view class="strategy-page strategy-page--{{baseState}} {{reduceMotion ? 'reduce-motion' : ''}} {{overlayState !== 'none' ? 'strategy-page--overlay-active' : ''}}" scroll-y="{{baseState === 'completed' && overlayState === 'none'}}" enable-flex="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}" style="height: {{pageHeight}}px; padding-top: {{customNavHeight}}px;">

  <!-- 统一沉浸式导航条 -->
  <view
    class="sr-custom-nav"
    style="height: {{customNavHeight}}px; padding-top: {{customNavTop}}px;"
  >
    <view class="sr-custom-nav__stars"></view>
    <view class="sr-custom-nav__bar" style="height: {{customNavBarHeight}}px;">
      <view class="cockpit-nav-hud">
        <view class="cockpit-nav-hud__link">
          <view class="css-status-dot css-status-dot--{{cockpitView.statusDot || 'idle'}}"></view>
          <text>{{cockpitView.statusDot === 'online' ? '已连接' : cockpitView.statusDot === 'starting' ? '计算中' : '待机'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 跨 Tab 骨架屏 -->
  <view wx:if="{{!pageReady}}" class="page-skeleton">
    <view class="page-skeleton-dot"></view>
    <text class="page-skeleton-text">接入导航舱</text>
  </view>

  <!-- 旧星图层（crossfade 重新生成时短暂保留） -->
  <view class="nav-map-window nav-map-window--crossfade-out nav-map-window--tint-{{oldStarMap.colorTint}}"
        wx:if="{{oldStarMap}}">
    <view wx:for="{{oldStarMap.stars}}" wx:key="index" class="nav-star"
          style="left:{{item.x}}%;top:{{item.y}}%;width:{{item.size}}rpx;height:{{item.size}}rpx;opacity:{{item.opacity}}"></view>
    <view wx:for="{{oldStarMap.orbitArcs}}" wx:key="index" class="nav-map-orbit"
          style="left:{{item.cx - item.rx}}%;top:{{item.cy - item.ry}}%;width:{{item.rx * 2}}%;height:{{item.ry * 2}}%;transform:rotate({{item.rotation}}deg);opacity:{{item.opacity}}"></view>
    <view wx:for="{{oldStarMap.connectionLines}}" wx:key="index" class="nav-conn-line"
          style="left:{{item.x1}}%;top:{{item.y1}}%;width:{{item.length}}vw;height:1rpx;transform:rotate({{item.angle}}deg);opacity:{{item.opacity}}"></view>
  </view>

  <!-- 星图舷窗 — 全屏背景视觉层（三层结构） -->
  <view class="nav-map-window nav-map-window--{{baseState}} nav-map-window--tint-{{starMap.colorTint || 'cyan'}} nav-map-window--crossfade-in" wx:if="{{pageReady}}" wx:key="starMapSeed">

    <!-- 第一层：宇宙背景 + 星尘 -->
    <view class="nav-map-cosmos"></view>
    <view wx:for="{{starMap.dustParticles}}" wx:key="index" class="nav-dust"
          style="left:{{item.x}}%;top:{{item.y}}%;width:{{item.size}}rpx;height:{{item.size}}rpx;opacity:{{item.opacity}};animation-duration:{{item.driftDuration}}s;animation-delay:{{item.driftDelay}}s"></view>

    <!-- 第二层：主星图 -->
    <!-- 轨道弧线（动态数据驱动） -->
    <view wx:for="{{starMap.orbitArcs}}" wx:key="index" class="nav-map-orbit"
          style="left:{{item.cx - item.rx}}%;top:{{item.cy - item.ry}}%;width:{{item.rx * 2}}%;height:{{item.ry * 2}}%;transform:rotate({{item.rotation}}deg);opacity:{{item.opacity}};--orbit-dur:{{item.breatheDuration}}s;--orbit-delay:{{item.breatheDelay}}s"></view>

    <!-- 连接线 -->
    <view wx:for="{{starMap.connectionLines}}" wx:key="index" class="nav-conn-line"
          style="left:{{item.x1}}%;top:{{item.y1}}%;width:{{item.length}}vw;height:1rpx;transform:rotate({{item.angle}}deg);opacity:{{item.opacity}}"></view>

    <!-- 随机航线 -->
    <view wx:for="{{starMap.routes}}" wx:key="index" class="nav-route-line"
          style="left:{{item.x1}}%;top:{{item.y1}}%;width:{{item.length}}rpx;transform:rotate({{item.angle}}deg);opacity:{{item.opacity}}"></view>

    <!-- 主航线 -->
    <view class="nav-map-route"></view>

    <!-- 随机光晕 -->
    <view wx:for="{{starMap.highlights}}" wx:key="index" class="nav-glow"
          style="left:{{item.x}}%;top:{{item.y}}%;width:{{item.size}}rpx;height:{{item.size}}rpx;opacity:{{item.opacity}}"></view>

    <!-- 随机星点 -->
    <view wx:for="{{starMap.stars}}" wx:key="index" class="nav-star"
          style="left:{{item.x}}%;top:{{item.y}}%;width:{{item.size}}rpx;height:{{item.size}}rpx;opacity:{{item.opacity}};--flicker-delay:{{item.flickerDelay}}s"></view>

    <!-- 能量节点 -->
    <view wx:for="{{starMap.energyNodes}}" wx:key="index" class="nav-energy-node"
          style="left:{{item.x}}%;top:{{item.y}}%;width:{{item.size}}rpx;height:{{item.size}}rpx;--pulse-dur:{{item.pulseDuration}}s;--pulse-delay:{{item.pulseDelay}}s"></view>

    <!-- 扫描波纹 -->
    <view class="nav-scan-wave"
          style="left:{{starMap.scanCenter.x}}%;top:{{starMap.scanCenter.y}}%"></view>

    <!-- 当前坐标 ORIGIN -->
    <view class="nav-planet nav-planet--origin">
      <view class="nav-planet-core"></view>
    </view>

    <!-- 目标星体 TARGET -->
    <view class="nav-planet nav-planet--target"
          style="--target-color: {{themeColor || '#32D74B'}}">
      <view class="nav-planet-lock"></view>
      <view class="nav-planet-core"></view>
    </view>

    <!-- 中央常驻星点 -->
    <view class="nav-center-dot"></view>

    <!-- 第三层：HUD 氛围 -->
    <view class="nav-hud-grid"></view>
    <view class="nav-hud-ticks"></view>
    <view class="nav-hud-radar"
          style="left:{{starMap.radarCenter.x}}%;top:{{starMap.radarCenter.y}}%"></view>
    <view class="nav-hud-edge-glow"></view>
  </view>

  <!-- 暗色渐变遮罩层：星图与内容融合 -->
  <view class="page-dark-overlay" wx:if="{{pageReady}}"></view>

  <!-- 飞行甲板统一舞台（贯穿 idle -> completed） -->
  <view class="flight-deck flight-deck--{{baseState}}" wx:if="{{pageReady}}">

    <!-- 状态指示线 -->
    <view class="nav-status-line">
      <view class="nav-status-indicator nav-status-indicator--{{cockpitView.statusDot || 'idle'}}"></view>
      <text class="nav-status-text">{{statusLineText}}</text>
    </view>

    <!-- 甲板透视线 -->
    <view class="deck-perspective">
      <view class="deck-line deck-line--1"></view>
      <view class="deck-line deck-line--2"></view>
      <view class="deck-line deck-line--3"></view>
      <view class="deck-line deck-line--4"></view>
      <view class="deck-line deck-line--5"></view>
    </view>

    <!-- 中央多行星系统（idle/calibrating/regenerating 态可见） -->
    <view class="star-core star-core--{{baseState}}" wx:if="{{baseState !== 'completed' && baseState !== 'completing'}}">
      <view class="core-system core-system--{{baseState}}" wx:if="{{starMap.coreSystem}}">

        <!-- 远轨小节点（最远，最淡，最先入场） -->
        <view wx:for="{{starMap.coreSystem.farNodes}}" wx:key="index" wx:for-item="node"
              class="cs-far-node"
              style="left:calc(50% + {{node.x}}rpx);top:calc(50% + {{node.y}}rpx);width:{{node.size}}rpx;height:{{node.size}}rpx;opacity:{{node.opacity}};--twinkle-dur:{{node.twinkleDuration}}s;--twinkle-delay:{{node.twinkleDelay}}s"></view>

        <!-- 轨道弧线（多层） -->
        <view wx:for="{{starMap.coreSystem.orbits}}" wx:key="index" wx:for-item="orbit"
              class="cs-orbit cs-orbit--{{orbit.arc}}"
              style="width:{{orbit.rx * 2}}rpx;height:{{orbit.ry * 2}}rpx;left:50%;top:calc(50% + {{starMap.coreSystem.main.y * 0.3}}rpx);transform:translate(-50%,-50%) rotate({{orbit.rotation}}deg);opacity:{{orbit.opacity}};--orbit-dur:{{orbit.breatheDuration}}s;--orbit-delay:{{orbit.breatheDelay}}s"></view>

        <!-- 行星↔主核 / 行星间连接线 -->
        <view wx:for="{{starMap.coreSystem.links}}" wx:key="index" wx:for-item="link"
              class="cs-link"
              style="left:calc(50% + {{link.x1}}rpx);top:calc(50% + {{link.y1}}rpx);width:{{link.length}}rpx;transform:rotate({{link.angle}}deg);opacity:{{link.opacity}};--pulse-dur:{{link.pulseDuration}}s;--pulse-delay:{{link.pulseDelay}}s"></view>

        <!-- 次级行星 -->
        <view wx:for="{{starMap.coreSystem.planets}}" wx:key="index" wx:for-item="planet"
              class="cs-planet cs-planet--{{planet.color}}"
              style="left:calc(50% + {{planet.x}}rpx);top:calc(50% + {{planet.y}}rpx);width:{{planet.size}}rpx;height:{{planet.size}}rpx;--planet-opacity:{{planet.opacity}};--planet-glow:{{planet.glow}}rpx;--twinkle-dur:{{planet.twinkleDuration}}s;--twinkle-delay:{{planet.twinkleDelay}}s;--light-up-delay:{{planet.lightUpOrder * 0.18}}s"></view>

        <!-- 主核心（最大、最亮，位于中央偏上） -->
        <view class="cs-main" style="left:calc(50% + {{starMap.coreSystem.main.x}}rpx);top:calc(50% + {{starMap.coreSystem.main.y}}rpx)">
          <view class="cs-main-halo" style="width:{{starMap.coreSystem.main.haloSize}}rpx;height:{{starMap.coreSystem.main.haloSize}}rpx;--halo-dur:{{starMap.coreSystem.main.haloDur}}s"></view>
          <view class="cs-main-glow" style="width:{{starMap.coreSystem.main.glowSize}}rpx;height:{{starMap.coreSystem.main.glowSize}}rpx;--glow-dur:{{starMap.coreSystem.main.glowDur}}s"></view>
          <view class="cs-main-dot" style="width:{{starMap.coreSystem.main.dotSize}}rpx;height:{{starMap.coreSystem.main.dotSize}}rpx;--dot-dur:{{starMap.coreSystem.main.dotDur}}s"></view>
          <view class="cs-main-scan" wx:if="{{baseState === 'calibrating'}}" style="--scan-dur:{{starMap.coreSystem.main.scanDur}}s"></view>
        </view>

      </view>
    </view>

    <!-- idle 态状态文案 -->
    <view class="idle-status-hint" wx:if="{{baseState === 'idle'}}">
      <text class="idle-hint-main">导航待机中</text>
      <text class="idle-hint-sub">等待星图校准指令</text>
    </view>

    <!-- starting/calibrating 态文案 -->
    <view class="calibrating-status-hint" wx:if="{{baseState === 'starting' || baseState === 'calibrating'}}">
      <text class="calibrating-hint-main">{{baseState === 'starting' ? '星图启动中' : '星图校准中'}}</text>
      <text class="calibrating-hint-sub">{{calibrationText || '同步坐标...'}}</text>
    </view>

    <!-- 主操作按钮 -->
    <view class="nav-launch-btn-area {{baseState === 'idle' ? 'btn-visible' : (baseState === 'starting' ? 'btn-fade-out' : 'btn-hidden')}}">
      <view class="nav-launch-btn {{baseState === 'starting' ? 'nav-launch-btn--starting' : ''}}" bindtap="onTapLaunchCore">
        <text>{{baseState === 'starting' ? '启动中' : '开始校准'}}</text>
      </view>
    </view>

    <!-- done 态：结果投影内容 -->
    <view class="directive-projection {{baseState === 'completed' ? 'dp-visible' : ''}}" wx:if="{{baseState === 'completing' || baseState === 'completed'}}">

      <!-- 极简 HUD 结果面板 -->
      <view class="result-panel-simple projection-card">
        <!-- 主标题 -->
        <view class="rp-verdict-simple">{{strategy.verdict}}</view>
        <!-- 描述 -->
        <view class="rp-desc-simple" wx:if="{{directiveText}}">{{directiveText}}</view>
        <!-- 稳定度简单显示 -->
        <view class="rp-stability-simple">系统稳定度 {{stabilityPercent || 72}}%</view>
      </view>

      <!-- 操作按钮 -->
      <view class="result-actions projection-card">
        <view class="result-primary-btn" bindtap="onTapGeneratePoster">分享指令</view>
        <view class="result-secondary-link {{baseState === 'regenerating' ? 'result-secondary-link--loading' : ''}}" bindtap="onTapRegenerate">
          {{baseState === 'regenerating' ? '生成中...' : '重新生成星图'}}
        </view>
      </view>

      <!-- 底部安全间距 -->
      <view class="strategy-result-spacer"></view>

    </view>

    <!-- 底部安全区占位，确保滚动到底部时不被 Tab Bar 遮挡 -->
    <view style="width: 100%; height: var(--sr-page-bottom-safe, calc(240rpx + env(safe-area-inset-bottom))); flex-shrink: 0;"></view>

  </view>

  <!-- 重新生成弹窗 -->
  <terminal-popup
    visible="{{overlayState === 'confirmRegenerate'}}"
    title="确认重新生成星图？"
    content="当前指令将被清除，系统将重新生成星图 seed 与校准结果。"
    cancelText="维持现状"
    confirmText="确认生成"
    confirmType="primary"
    reduce-motion="{{reduceMotion}}"
    bind:cancel="onCancelRegenerate"
    bind:confirm="onConfirmRegenerate"
  />

  <!-- 海报弹层 -->
  <view class="poster-mask poster-mask--{{overlayState === 'share' ? 'visible' : 'hidden'}}" catchtouchmove="noop">
    <view class="poster-container">

      <!-- 生成中 -->
      <view class="poster-gen" wx:if="{{phase === 'poster_generating'}}">
        <view class="poster-gen-dots">
          <view class="poster-gen-dot"></view>
          <view class="poster-gen-dot"></view>
          <view class="poster-gen-dot"></view>
        </view>
        <text class="poster-gen-text">分享卡生成中...</text>
      </view>

      <!-- 预览 -->
      <view class="poster-preview" wx:if="{{phase === 'poster_preview'}}">
        <image class="poster-image" src="{{posterPath}}" mode="widthFix" show-menu-by-longpress="{{true}}"></image>
      </view>

      <!-- 错误 -->
      <view class="poster-error" wx:if="{{phase === 'poster_error'}}">
        <text class="poster-error-text">{{posterError || '分享卡生成失败'}}</text>
        <view class="poster-error-actions">
          <view class="poster-error-btn" bindtap="onPosterRetry">重试</view>
          <view class="poster-error-btn" bindtap="onClosePoster">取消</view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="poster-actions {{canUseWxShare ? 'poster-actions--three' : 'poster-actions--two'}}" wx:if="{{phase === 'poster_preview'}}">
        <view class="poster-btn poster-btn--save" bindtap="onSavePoster">下载图片</view>
        <button class="poster-btn poster-btn--share" open-type="share" wx:if="{{canUseWxShare}}">分享朋友</button>
        <view class="poster-btn poster-btn--close" bindtap="onClosePoster">关闭</view>
      </view>

    </view>
  </view>

  <canvas type="2d" id="posterCanvas" class="poster-canvas" style="width: 750px; height: 1050px;"></canvas>

  <!-- 系统全局左上角提示 -->
  <sr-toast id="srToast" reduceMotion="{{!animationEnabled}}" />

</scroll-view>

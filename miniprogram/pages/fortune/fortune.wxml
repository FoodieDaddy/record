<scroll-view class="strategy-page strategy-page--phase-{{visualPhase}} {{reduceMotion ? 'reduce-motion' : ''}} {{showRegenerateModal || posterModalVisible ? 'strategy-page--modal-open' : ''}}" scroll-y="{{pageMode === 'result' && !posterModalVisible && !showRegenerateModal}}" enable-flex="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}" style="height: {{pageHeight}}px; padding-top: {{customNavHeight}}px;">

  <!-- 统一沉浸式导航条 -->
  <view
    class="sr-custom-nav"
    style="height: {{customNavHeight}}px; padding-top: {{customNavTop}}px;"
  >
    <view class="sr-custom-nav__stars"></view>
    <view class="sr-custom-nav__bar" style="height: {{customNavBarHeight}}px;">
      <view class="cockpit-nav-hud">
        <view class="cockpit-nav-hud__link">
          <view class="css-status-dot css-status-dot--{{cockpitView.statusDot || 'idle'}}"></view>
          <text>{{cockpitView.statusLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 跨 Tab 骨架屏 -->
  <view wx:if="{{!pageReady}}" class="page-skeleton">
    <view class="page-skeleton-dot"></view>
    <text class="page-skeleton-text">接入导航舱</text>
  </view>

  <!-- 飞行甲板统一舞台（贯穿 idle -> result） -->
  <view class="flight-deck flight-deck--{{flightStage}}" wx:if="{{pageReady}}">

    <!-- 左上角舱位状态 Tab (已迁移至导航栏，此页面内隐藏) -->
    <view class="bay-status-tab bay-status-tab--{{pageMode === 'generating' ? 'starting' : pageMode === 'result' || pageMode === 'relaunchReady' ? 'online' : 'standby'}}" style="display: none;">
      <view class="bay-status-tab__dot"></view>
      <text class="bay-status-tab__label">{{pageMode === 'generating' ? '导航舱启动中' : pageMode === 'result' || pageMode === 'relaunchReady' ? '导航舱已接入' : '导航舱待机中'}}</text>
    </view>

    <!-- 甲板透视线（永远存在） -->
    <view class="deck-perspective">
      <view class="deck-line deck-line--1"></view>
      <view class="deck-line deck-line--2"></view>
      <view class="deck-line deck-line--3"></view>
      <view class="deck-line deck-line--4"></view>
      <view class="deck-line deck-line--5"></view>
    </view>

    <!-- 顶部标题（沉浸式方案中完全移除） -->
    <view class="flight-deck-header hide-page-title" style="display: none;">
      <text class="flight-deck-title">导航舱</text>
      <text class="flight-deck-date">{{currentDate}}</text>
    </view>

    <!-- 共享导航核心（唯一 DOM，贯穿 idle -> done） -->
    <view class="nav-core-stage {{firstEnter === false ? 'nav-core-stage--entered' : ''}} {{coreCompact ? 'nav-core-stage--compact' : ''}}">
      <view class="scan-ring scan-ring--{{flightStage === 'syncing' || flightStage === 'projecting' || flightStage === 'done' ? 'gen' : 'idle'}}"></view>
      <view class="nav-core-rings">
        <view class="core-inner">
          <view class="core-ring core-ring--1"></view>
          <view class="core-ring core-ring--2"></view>
          <view class="core-ring core-ring--3"></view>
          <view class="core-glow"></view>
          <view class="core-dot"></view>
        </view>
      </view>
      <view class="nav-core-beam"></view>
    </view>

    <!-- 投影线（projecting/done 态出现） -->
    <view class="projection-line"></view>

    <!-- 日志接入条（syncing/projecting 态，紧贴核心下方） -->
    <view class="sync-bar {{showSyncLogs && (flightStage === 'syncing' || flightStage === 'projecting') ? 'sync-bar--visible' : ''}} {{compactSyncLogs ? 'sync-bar--compact' : ''}}">
      <view class="sync-bar-line"></view>
      <view class="sync-bar-chips">
        <view class="sync-chip {{item.visible ? 'sync-chip--on' : ''}}" wx:for="{{logs}}" wx:key="index">
          <view class="sync-chip-dot"></view>
          <text class="sync-chip-text {{item.typing ? 'sync-chip-typing' : ''}}">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- 统一等待主文案（唯一用户可见等待出口，替换 heartbeat + engineWaitText） -->
    <view class="generation-status generation-status--{{generationStatusLevel}} {{generationStatusText && flightStage === 'syncing' ? 'generation-status--visible' : ''}}">
      <view class="generation-status-dot"></view>
      <text>{{generationStatusText}}</text>
    </view>

    <!-- 四段式进度条（仅 generating 态显示） -->
    <view class="wait-steps wait-steps--{{waitStep}} {{pageMode === 'generating' && waitStep > 0 ? 'wait-steps--visible' : ''}}">
      <view class="wait-step {{waitStep >= 1 ? 'wait-step--active' : ''}}"></view>
      <view class="wait-step {{waitStep >= 2 ? 'wait-step--active' : ''}}"></view>
      <view class="wait-step {{waitStep >= 3 ? 'wait-step--active' : ''}}"></view>
      <view class="wait-step {{waitStep >= 3 ? 'wait-step--active' : ''}}"></view>
    </view>

    <!-- HUD 刻度线 -->
    <view class="hud-marks hud-marks--left">
      <view class="hud-mark"></view>
      <view class="hud-mark"></view>
      <view class="hud-mark"></view>
      <view class="hud-mark"></view>
    </view>
    <view class="hud-marks hud-marks--right">
      <view class="hud-mark"></view>
      <view class="hud-mark"></view>
      <view class="hud-mark"></view>
      <view class="hud-mark"></view>
    </view>

    <!-- idle 态：点火控制器 -->
    <view class="ignition-console {{flightStage === 'idle' ? '' : flightStage === 'syncing' || flightStage === 'projecting' || flightStage === 'done' ? 'ignition-console--hidden' : 'ignition-console--fading'}} {{firstEnter === false ? 'ignition-console--entered' : ''}} {{flightStage === 'arming' || flightStage === 'pressed' || flightStage === 'plasma' || flightStage === 'lifting' ? 'ignition-console--active' : ''}}" wx:if="{{pageMode === 'launch' || pageMode === 'generating' || visualPhase === 'bridge' || visualPhase === 'reveal'}}">
      <!-- 四角铆点 -->
      <view class="ignition-bolt ignition-bolt--tl"></view>
      <view class="ignition-bolt ignition-bolt--tr"></view>
      <view class="ignition-bolt ignition-bolt--bl"></view>
      <view class="ignition-bolt ignition-bolt--br"></view>

      <!-- 状态灯 -->
      <view class="ignition-led ignition-led--left">
        <view class="ignition-led-dot"></view>
        <view class="ignition-led-dot"></view>
      </view>
      <view class="ignition-led ignition-led--right">
        <view class="ignition-led-dot"></view>
        <view class="ignition-led-dot"></view>
      </view>

      <view class="ignition-arm-header">
        <text class="ignition-arm-label">ARMING</text>
        <view class="ignition-arm-dots">
          <view class="ignition-arm-dot"></view>
          <view class="ignition-arm-dot"></view>
        </view>
      </view>

      <view class="ignition-safety-rail {{flightStage !== 'idle' ? 'rail-open' : ''}}">
        <view class="rail-half rail-half--left"></view>
        <view class="rail-gap"></view>
        <view class="rail-half rail-half--right"></view>
      </view>

      <view class="ignition-guard">
        <view class="ignition-button" bindtap="onTapLaunchCore">
          <view class="plasma-flame {{flightStage === 'pressed' || flightStage === 'plasma' ? 'plasma-flame--active' : ''}}">
            <view class="plasma-flame-core"></view>
          </view>
          <text class="ignition-button-text">IGNITE</text>
        </view>
      </view>

      <view class="ignition-energy-slot">
        <view class="ignition-energy-fill {{flightStage !== 'idle' ? 'ignition-energy-fill--active' : ''}}"></view>
      </view>

      <view class="ignition-status">
        <view class="ignition-status-item">
          <view class="ignition-status-dot"></view>
          <text class="ignition-status-text">PWR_ON</text>
        </view>
        <view class="ignition-status-item">
          <view class="ignition-status-dot"></view>
          <text class="ignition-status-text">SYS_OK</text>
        </view>
      </view>
    </view>

    <!-- done 态：结果投影内容 (极简飞船导航重构) -->
    <view class="directive-projection {{projectionVisible ? 'dp-visible' : ''}}" wx:if="{{pageMode === 'result'}}">

      <!-- 核心判决区 (简约主视觉) -->
      <view class="nav-main-verdict projection-card">
        <view class="nav-tag-minimal">{{strategy.tag || '状态同步'}}</view>
        <text class="nav-verdict-text">{{strategy.verdict}}</text>
        <view class="nav-reading-tags" wx:if="{{strategy.tags && strategy.tags.length > 0}}">
          <view class="nav-mini-tag" wx:for="{{strategy.tags}}" wx:key="*this"># {{item}}</view>
        </view>
      </view>

      <!-- 执行指令模块 (简约列表) -->
      <view class="nav-execution-params projection-card">

        <!-- 推进参数 -->
        <view class="nav-param-group" wx:if="{{strategy.buffs && strategy.buffs.length > 0}}">
          <view class="nav-group-title">推进参数</view>
          <view class="nav-param-list">
            <view class="nav-param-item" wx:for="{{strategy.buffs}}" wx:key="*this">
              <text class="nav-param-text">{{item}}</text>
            </view>
          </view>
        </view>

        <!-- 警戒边界 -->
        <view class="nav-param-group" wx:if="{{strategy.debuffs && strategy.debuffs.length > 0}}">
          <view class="nav-group-title">警戒边界</view>
          <view class="nav-param-list">
            <view class="nav-param-item" wx:for="{{strategy.debuffs}}" wx:key="*this">
              <text class="nav-param-text">{{item}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 底部安全间距 -->
      <view class="strategy-result-spacer"></view>

      <!-- 导航终端指令 -->
      <view class="nav-terminal-actions projection-card">
        <view class="nav-btn nav-btn--secondary" bindtap="onTapRegenerate">
          <text class="nav-btn-text">重新点火</text>
        </view>
        <view class="nav-btn nav-btn--primary" bindtap="onTapGeneratePoster">
          <text class="nav-btn-text">投影档案</text>
        </view>
      </view>

    </view>

    <!-- 底部说明（idle 态显示） -->
    <view class="flight-deck-info {{flightStage === 'idle' ? 'fdi-visible' : 'fdi-hidden'}} {{firstEnter === false ? 'fdi-entered' : ''}}">
      <text class="flight-deck-info-text">NAV_UNIT: MK-IV STATUS: STANDBY</text>
      <text class="flight-deck-info-text">LAST_SYNC: {{currentDate}}</text>
    </view>

    <!-- 底部安全区占位，确保滚动到底部时不被 Tab Bar 遮挡 -->
    <view style="width: 100%; height: var(--sr-page-bottom-safe, calc(240rpx + env(safe-area-inset-bottom))); flex-shrink: 0;"></view>

  </view>

  <!-- 重新点火弹窗 -->
  <terminal-popup
    visible="{{showRegenerateModal}}"
    title="确认重新点火？"
    content="每日指令校准仅限一次，强制重新点火可能导致导航轨迹偏移。确认执行？"
    cancelText="维持现状"
    confirmText="强制点火"
    confirmType="primary"
    reduce-motion="{{reduceMotion}}"
    bind:cancel="onCancelRegenerate"
    bind:confirm="onConfirmRegenerate"
  />

  <!-- 海报弹层 -->
  <view class="poster-mask" wx:if="{{posterModalVisible}}" catchtouchmove="noop">
    <view class="poster-container">

      <!-- 生成中 -->
      <view class="poster-gen" wx:if="{{phase === 'poster_generating'}}">
        <view class="poster-gen-dots">
          <view class="poster-gen-dot"></view>
          <view class="poster-gen-dot"></view>
          <view class="poster-gen-dot"></view>
        </view>
        <text class="poster-gen-text">档案卡封存中...</text>
      </view>

      <!-- 预览 -->
      <view class="poster-preview" wx:if="{{phase === 'poster_preview'}}">
        <image class="poster-image" src="{{posterPath}}" mode="widthFix" show-menu-by-longpress="{{true}}"></image>
      </view>

      <!-- 错误 -->
      <view class="poster-error" wx:if="{{phase === 'poster_error'}}">
        <text class="poster-error-text">{{posterError || '档案卡封存失败'}}</text>
        <view class="poster-error-actions">
          <view class="poster-error-btn" bindtap="onPosterRetry">重试</view>
          <view class="poster-error-btn" bindtap="onClosePoster">取消</view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="poster-actions {{canUseWxShare ? 'poster-actions--three' : 'poster-actions--two'}}" wx:if="{{phase === 'poster_preview'}}">
        <view class="poster-btn poster-btn--save" bindtap="onSavePoster">保存图片</view>
        <button class="poster-btn poster-btn--share" open-type="share" wx:if="{{canUseWxShare}}">分享朋友</button>
        <view class="poster-btn poster-btn--close" bindtap="onClosePoster">关闭</view>
      </view>

    </view>
  </view>

  <canvas type="2d" id="posterCanvas" class="poster-canvas" style="width: 750px; height: 1300px;"></canvas>

  <!-- 系统全局左上角提示 -->
  <sr-toast id="srToast" reduceMotion="{{!animationEnabled}}" />

</scroll-view>

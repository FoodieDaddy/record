<scroll-view class="strategy-page strategy-page--{{uiPhase}} {{reduceMotion ? 'reduce-motion' : ''}} {{showRegenerateModal || posterModalVisible ? 'strategy-page--modal-open' : ''}}" scroll-y="{{pageMode === 'result' && !posterModalVisible && !showRegenerateModal}}" enable-flex="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}" style="height: {{pageHeight}}px; padding-top: {{customNavHeight}}px;">

  <!-- 统一沉浸式导航条 -->
  <view
    class="sr-custom-nav"
    style="height: {{customNavHeight}}px; padding-top: {{customNavTop}}px;"
  >
    <view class="sr-custom-nav__stars"></view>
    <view class="sr-custom-nav__bar" style="height: {{customNavBarHeight}}px;">
      <view class="cockpit-nav-hud">
        <view class="cockpit-nav-hud__link">
          <view class="css-status-dot css-status-dot--{{cockpitView.statusDot || 'idle'}}"></view>
          <text>{{cockpitView.statusLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 跨 Tab 骨架屏 -->
  <view wx:if="{{!pageReady}}" class="page-skeleton">
    <view class="page-skeleton-dot"></view>
    <text class="page-skeleton-text">接入导航舱</text>
  </view>

  <!-- 飞行甲板统一舞台（贯穿 idle -> result） -->
  <view class="flight-deck flight-deck--{{flightStage}}" wx:if="{{pageReady}}">

    <!-- 左上角舱位状态 Tab (已迁移至导航栏，此页面内隐藏) -->
    <view class="bay-status-tab bay-status-tab--{{pageMode === 'generating' ? 'starting' : pageMode === 'result' || pageMode === 'relaunchReady' ? 'online' : 'standby'}}" style="display: none;">
      <view class="bay-status-tab__dot"></view>
      <text class="bay-status-tab__label">{{pageMode === 'generating' ? '导航舱启动中' : pageMode === 'result' || pageMode === 'relaunchReady' ? '导航舱已接入' : '导航舱待机中'}}</text>
    </view>

    <!-- 星图舷窗（页面主视觉） -->
    <view class="nav-map-window nav-map-window--{{uiPhase}}">
      <view class="nav-map-grid"></view>

      <!-- 轨道弧线 -->
      <view class="nav-map-orbit nav-map-orbit--1"></view>
      <view class="nav-map-orbit nav-map-orbit--2"></view>

      <!-- 航线 -->
      <view class="nav-map-route"></view>

      <!-- 当前坐标 ORIGIN -->
      <view class="nav-planet nav-planet--origin">
        <view class="nav-planet-core"></view>
      </view>

      <!-- 目标星体 TARGET -->
      <view class="nav-planet nav-planet--target"
            style="--target-color: {{themeColor || '#32D74B'}}">
        <view class="nav-planet-lock"></view>
        <view class="nav-planet-core"></view>
      </view>

      <!-- 信标状态灯 -->
      <view class="nav-map-status nav-map-status--beacon">
        <view class="nav-map-status-dot"></view>
        <text>信标</text>
      </view>

      <!-- 航迹状态灯 -->
      <view class="nav-map-status nav-map-status--trace">
        <view class="nav-map-status-dot nav-map-status-dot--green"></view>
        <text>航迹</text>
      </view>

      <!-- 中央读数 -->
      <view class="nav-center-readout">
        <view class="nav-center-dot"></view>
        <text class="nav-center-value {{dashboardValueIsZh ? 'nav-center-value--zh' : ''}}">{{dashboardValue}}</text>
      </view>

      <!-- SYNC 状态条 -->
      <view class="nav-sync-strip" wx:if="{{pageMode === 'generating'}}">
        <text class="{{syncStep >= 1 ? 'on' : ''}}">LINK</text>
        <text class="{{syncStep >= 2 ? 'on' : ''}}">TRACE</text>
        <text class="{{syncStep >= 3 ? 'on' : ''}}">LOCK</text>
      </view>
    </view>

    <!-- 甲板透视线 -->
    <view class="deck-perspective">
      <view class="deck-line deck-line--1"></view>
      <view class="deck-line deck-line--2"></view>
      <view class="deck-line deck-line--3"></view>
      <view class="deck-line deck-line--4"></view>
      <view class="deck-line deck-line--5"></view>
    </view>

    <!-- 主操作按钮 -->
    <view class="nav-launch-btn-area" wx:if="{{pageMode !== 'result'}}">
      <view
        class="nav-launch-btn {{pageMode === 'generating' ? 'nav-launch-btn--loading' : ''}}"
        bindtap="onTapLaunchCore"
      >
        <text>{{pageMode === 'generating' ? '校准中' : '开始校准'}}</text>
      </view>
    </view>

    <!-- done 态：结果投影内容 (极简飞船导航重构) -->
    <view class="directive-projection {{projectionVisible ? 'dp-visible' : ''}}" wx:if="{{pageMode === 'result'}}">

      <!-- 核心判决区 (简约主视觉) -->
      <view class="nav-main-verdict projection-card">
        <view class="nav-tag-minimal">{{strategy.tag || '状态同步'}}</view>
        <text class="nav-verdict-text">{{strategy.verdict}}</text>
        <view class="nav-reading-tags" wx:if="{{strategy.tags && strategy.tags.length > 0}}">
          <view class="nav-mini-tag" wx:for="{{strategy.tags}}" wx:key="*this"># {{item}}</view>
        </view>
      </view>

      <!-- 执行指令模块 (简约列表) -->
      <view class="nav-execution-params projection-card">

        <!-- 推进参数 -->
        <view class="nav-param-group" wx:if="{{strategy.buffs && strategy.buffs.length > 0}}">
          <view class="nav-group-title">推进参数</view>
          <view class="nav-param-list">
            <view class="nav-param-item" wx:for="{{strategy.buffs}}" wx:key="*this">
              <text class="nav-param-text">{{item}}</text>
            </view>
          </view>
        </view>

        <!-- 警戒边界 -->
        <view class="nav-param-group" wx:if="{{strategy.debuffs && strategy.debuffs.length > 0}}">
          <view class="nav-group-title">警戒边界</view>
          <view class="nav-param-list">
            <view class="nav-param-item" wx:for="{{strategy.debuffs}}" wx:key="*this">
              <text class="nav-param-text">{{item}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 底部安全间距 -->
      <view class="strategy-result-spacer"></view>

      <!-- 导航终端指令 -->
      <view class="nav-terminal-actions projection-card">
        <view class="result-secondary-link" bindtap="onTapRegenerate">重新点火</view>
        <view class="result-primary-btn" bindtap="onTapGeneratePoster">投影档案</view>
      </view>

    </view>

    <!-- 底部说明（idle 态显示） -->
    <view class="flight-deck-info {{flightStage === 'idle' ? 'fdi-visible' : 'fdi-hidden'}} {{firstEnter === false ? 'fdi-entered' : ''}}">
      <text class="flight-deck-info-text">NAV_UNIT: MK-IV STATUS: STANDBY</text>
      <text class="flight-deck-info-text">LAST_SYNC: {{currentDate}}</text>
    </view>

    <!-- 底部安全区占位，确保滚动到底部时不被 Tab Bar 遮挡 -->
    <view style="width: 100%; height: var(--sr-page-bottom-safe, calc(240rpx + env(safe-area-inset-bottom))); flex-shrink: 0;"></view>

  </view>

  <!-- 重新点火弹窗 -->
  <terminal-popup
    visible="{{showRegenerateModal}}"
    title="确认重新点火？"
    content="每日指令校准仅限一次，强制重新点火可能导致导航轨迹偏移。确认执行？"
    cancelText="维持现状"
    confirmText="强制点火"
    confirmType="primary"
    reduce-motion="{{reduceMotion}}"
    bind:cancel="onCancelRegenerate"
    bind:confirm="onConfirmRegenerate"
  />

  <!-- 海报弹层 -->
  <view class="poster-mask" wx:if="{{posterModalVisible}}" catchtouchmove="noop">
    <view class="poster-container">

      <!-- 生成中 -->
      <view class="poster-gen" wx:if="{{phase === 'poster_generating'}}">
        <view class="poster-gen-dots">
          <view class="poster-gen-dot"></view>
          <view class="poster-gen-dot"></view>
          <view class="poster-gen-dot"></view>
        </view>
        <text class="poster-gen-text">档案卡封存中...</text>
      </view>

      <!-- 预览 -->
      <view class="poster-preview" wx:if="{{phase === 'poster_preview'}}">
        <image class="poster-image" src="{{posterPath}}" mode="widthFix" show-menu-by-longpress="{{true}}"></image>
      </view>

      <!-- 错误 -->
      <view class="poster-error" wx:if="{{phase === 'poster_error'}}">
        <text class="poster-error-text">{{posterError || '档案卡封存失败'}}</text>
        <view class="poster-error-actions">
          <view class="poster-error-btn" bindtap="onPosterRetry">重试</view>
          <view class="poster-error-btn" bindtap="onClosePoster">取消</view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="poster-actions {{canUseWxShare ? 'poster-actions--three' : 'poster-actions--two'}}" wx:if="{{phase === 'poster_preview'}}">
        <view class="poster-btn poster-btn--save" bindtap="onSavePoster">保存图片</view>
        <button class="poster-btn poster-btn--share" open-type="share" wx:if="{{canUseWxShare}}">分享朋友</button>
        <view class="poster-btn poster-btn--close" bindtap="onClosePoster">关闭</view>
      </view>

    </view>
  </view>

  <canvas type="2d" id="posterCanvas" class="poster-canvas" style="width: 750px; height: 1300px;"></canvas>

  <!-- 系统全局左上角提示 -->
  <sr-toast id="srToast" reduceMotion="{{!animationEnabled}}" />

</scroll-view>

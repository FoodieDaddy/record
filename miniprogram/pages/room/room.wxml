<wxs src="./room.wxs" module="fmt" />
<wxs src="../../utils/truncate.wxs" module="t" />
<!-- 全局切页扫描遮罩 -->
<view class="route-transition-mask {{routeAnimating ? 'is-animating' : ''}}"></view>

<view class="room-page cockpit-page {{!animationEnabled ? 'reduce-motion' : ''}} {{cockpitState === 'active' ? 'room-page--active' : ''}} {{isInputOpen ? 'room-page--input-open' : ''}} route-transition-enter {{routeAnimating ? 'is-animating' : ''}}">
  <view
    class="room-custom-nav {{cockpitState === 'active' ? 'room-custom-nav--active' : ''}}"
    style="height: {{customNavHeight}}px; padding-top: {{customNavTop}}px;"
  >
    <view class="room-custom-nav__stars"></view>
    <view class="room-custom-nav__bar" style="height: {{customNavBarHeight}}px;">
      <view class="cockpit-nav-hud">
        <view class="cockpit-nav-hud__link">
          <view class="css-status-dot css-status-dot--{{cockpitView.statusDot || 'idle'}}"></view>
          <text>{{cockpitView.statusLabel}}</text>
        </view>
        <view class="cockpit-nav-hud__formation" wx:if="{{cockpitView.roomNo && cockpitView.roomNo !== '--'}}">
          <text class="cockpit-nav-hud__code">编队 {{cockpitView.roomNo}}</text>
          <view class="cockpit-nav-hud__divider"></view>
          <text class="cockpit-nav-hud__crew">{{cockpitView.memberCountText}}</text>
        </view>
      </view>
    </view>
    <view class="room-custom-nav__hud-line"></view>
  </view>


  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="empty-auth">
    <view class="empty-auth-icon icon-lock-wrap"><view class="icon-lock"></view></view>
    <text class="text-lg text-bold" style="margin-bottom:12rpx;">终端未接入</text>
    <text class="text-secondary" style="margin-bottom:40rpx;">接入终端后可创建或加入任务编队</text>
    <view class="flight-primary" style="width:320rpx;" bindtap="goLogin">
      <text>接入终端</text>
    </view>
  </view>

  <!-- idle 状态：基地编队终端 · 待命中 -->
  <view wx:if="{{isLoggedIn && cockpitState === 'idle'}}" class="cockpit-viewport cockpit-viewport--idle idle-base {{cockpitView.hasRoom ? 'idle-base--formed' : ''}}">

    <!-- 基地环境层 -->
    <view class="base-ambient">
      <view class="base-glow"></view>
      <view class="base-grid"></view>
      <view class="base-vignette"></view>
      <view class="base-breathe"></view>
    </view>

    <!-- 基地空间线索 -->
    <view class="base-platform"></view>
    <view class="base-bay-shadow"></view>
    <view class="base-hangar"></view>
    <view class="base-strip-light"></view>
    <view class="base-projection"></view>

    <!-- 终端面板轮廓 -->
    <view class="base-terminal-frame"></view>

    <!-- 中央信息区 -->
    <view class="base-center-info">
      <!-- 状态A：未创建编队 -->
      <block wx:if="{{!cockpitView.hasRoom}}">
        <view class="base-main-title">基地待命中</view>
        <view class="base-sub-title">当前位于基地编队终端，可创建或加入编队后申请出航</view>
      </block>
      <!-- 状态B：已创建编队 -->
      <block wx:else>
        <view class="base-main-title">等待编队集结</view>
        <view class="base-sub-title">当前位于基地编队终端，队员集结完成后可申请出航</view>
      </block>
      <view class="base-channel-status">
        <view class="base-channel-dot"></view>
        <text>{{cockpitView.hasRoom ? '基地信道广播中' : '基地信道开启中'}}</text>
      </view>
    </view>

    <!-- 编队信标 -->
    <view class="base-beacon">
      <view class="base-beacon-ring base-beacon-ring--outer"></view>
      <view class="base-beacon-ring base-beacon-ring--mid"></view>
      <view class="base-beacon-ring base-beacon-ring--inner"></view>
      <view class="base-beacon-core"></view>
      <view class="base-beacon-line"></view>
      <view class="base-beacon-nodes">
        <view class="base-beacon-node base-beacon-node--l"></view>
        <view class="base-beacon-node base-beacon-node--c"></view>
        <view class="base-beacon-node base-beacon-node--r"></view>
      </view>
    </view>

    <!-- 状态面板：未创建编队 -->
    <view wx:if="{{!cockpitView.hasRoom}}" class="base-status-row">
      <view class="base-status-chips">
        <view class="base-chip">
          <text class="base-chip-label">当前状态</text>
          <text class="base-chip-value">基地待命</text>
        </view>
        <view class="base-chip">
          <text class="base-chip-label">编队人数</text>
          <text class="base-chip-value">0/16</text>
        </view>
        <view class="base-chip">
          <text class="base-chip-label">出航许可</text>
          <text class="base-chip-value">未激活</text>
        </view>
        <view class="base-chip">
          <text class="base-chip-label">编队状态</text>
          <text class="base-chip-value">未建立</text>
        </view>
      </view>
    </view>

    <!-- 状态面板：已创建编队 -->
    <view wx:if="{{cockpitView.hasRoom}}" class="base-status-row">
      <view class="base-status-chips">
        <view class="base-chip">
          <text class="base-chip-label">当前状态</text>
          <text class="base-chip-value">基地待命</text>
        </view>
        <view class="base-chip">
          <text class="base-chip-label">编队人数</text>
          <text class="base-chip-value">{{cockpitView.formationCount}}/16</text>
        </view>
        <view class="base-chip">
          <text class="base-chip-label">出航许可</text>
          <text class="base-chip-value">未激活</text>
        </view>
        <view class="base-chip">
          <text class="base-chip-label">编队状态</text>
          <text class="base-chip-value">等待集结</text>
        </view>
      </view>
    </view>

    <!-- 组队方式：仅未创建时显示 -->
    <view wx:if="{{!cockpitView.hasRoom}}" class="base-protocol">
      <view class="base-protocol-label">组队方式</view>
      <view class="base-protocol-capsule">
        <view class="base-protocol-opt {{scoreMode === 1 ? 'base-protocol-opt--on' : ''}}" bindtap="selectScoreMode" data-mode="1">
          <view class="base-protocol-dot {{scoreMode === 1 ? 'base-protocol-dot--on' : ''}}"></view>
          <text>公开编队</text>
        </view>
        <view class="base-protocol-opt {{scoreMode === 2 ? 'base-protocol-opt--on' : ''}}" bindtap="selectScoreMode" data-mode="2">
          <view class="base-protocol-dot {{scoreMode === 2 ? 'base-protocol-dot--on' : ''}}"></view>
          <text>编队码加入</text>
        </view>
      </view>
    </view>

    <!-- 操作区：未创建编队 -->
    <view wx:if="{{!cockpitView.hasRoom}}" class="base-actions">
      <button class="base-btn-primary {{launching ? 'base-btn-primary--loading' : ''}}" bindtap="handleStartSpace">
        <view class="base-btn-glow"></view>
        <text class="base-btn-text">创建编队</text>
        <text class="base-btn-hint">建立小队后可发起出航</text>
      </button>
      <button class="base-btn-secondary" bindtap="openJoinPanel">
        <text class="base-btn-text">加入编队</text>
        <text class="base-btn-hint">输入编号进入待命</text>
      </button>
    </view>

    <!-- 操作区：已创建编队 -->
    <view wx:if="{{cockpitView.hasRoom}}" class="base-actions">
      <button class="base-btn-primary" bindtap="openBeacon">
        <view class="base-btn-glow"></view>
        <text class="base-btn-text">复制编队码</text>
        <text class="base-btn-hint">发送给队员后等待集结</text>
      </button>
      <button class="base-btn-secondary" bindtap="confirmLeaveOrDisband">
        <text class="base-btn-text">{{isOwner ? '解散编队' : '退出编队'}}</text>
        <text class="base-btn-hint">{{isOwner ? '退出当前出航准备' : '返回基地待命状态'}}</text>
      </button>
    </view>

  </view>

  <!-- 启动过渡层 -->
  <view wx:if="{{isLaunching}}" class="launch-transition">
    <view class="launch-transition-bg"></view>
    <view class="launch-ring">
      <view class="launch-ring-outer"></view>
      <view class="launch-ring-inner"></view>
    </view>
    <view class="launch-phase-text">
      <text wx:if="{{launchPhase === 'linking'}}">编队信道建立中</text>
      <text wx:elif="{{launchPhase === 'window'}}">信道校准中</text>
      <text wx:elif="{{launchPhase === 'hud'}}">系统接入完成</text>
      <text wx:elif="{{launchPhase === 'slow'}}">编队链路校准中</text>
    </view>
    <view class="launch-slow-actions" wx:if="{{launchPhase === 'slow'}}">
      <view class="launch-slow-btn" bindtap="cancelLaunchWait">返回待机</view>
      <view class="launch-slow-btn launch-slow-btn--primary" bindtap="retryLaunchWait">重新尝试</view>
    </view>
    <view class="launch-phase-bar">
      <view class="launch-phase-dot {{launchPhase === 'linking' ? 'launch-phase-dot--active' : ''}}"></view>
      <view class="launch-phase-dot {{launchPhase === 'window' ? 'launch-phase-dot--active' : ''}}"></view>
      <view class="launch-phase-dot {{launchPhase === 'hud' ? 'launch-phase-dot--active' : ''}}"></view>
    </view>
  </view>

  <!-- connecting 状态：编队链路建立中 -->
  <view wx:if="{{isLoggedIn && cockpitState === 'connecting'}}" class="cockpit-viewport cockpit-viewport--connecting idle-base idle-base--connecting">

    <!-- 基地环境层 -->
    <view class="base-ambient">
      <view class="base-glow"></view>
      <view class="base-grid"></view>
      <view class="base-vignette"></view>
      <view class="base-breathe"></view>
    </view>

    <!-- 基地空间线索 -->
    <view class="base-platform"></view>
    <view class="base-bay-shadow"></view>
    <view class="base-strip-light"></view>

    <!-- 终端面板轮廓 -->
    <view class="base-terminal-frame"></view>

    <!-- 中央信息 -->
    <view class="base-center-info">
      <view class="base-main-title">编队系统接入中</view>
      <view class="base-sub-title">正在校准编队信道，完成后进入基地待命</view>
      <view class="base-channel-status">
        <view class="base-channel-dot"></view>
        <text>信道校准中</text>
      </view>
    </view>

  </view>

  <!-- 加入编队弹窗 -->
  <view wx:if="{{joinPanelVisible}}" class="cockpit-mask" bindtap="closeJoinPanel">
    <view class="join-panel sr-hud-panel" catchtap="preventClose">
      <view class="panel-head">
        <view>
          <view class="panel-title">加入编队</view>
        </view>
        <view class="panel-close" bindtap="closeJoinPanel">
          <view class="icon-close"></view>
        </view>
      </view>

      <view class="code-input-wrap">
        <input
          class="code-input"
          value="{{joinCode}}"
          type="text"
          adjust-position="{{false}}"
          maxlength="6"
          placeholder="输入 6 位编队码"
          placeholder-class="input-placeholder"
          bindinput="onJoinCodeInput"
        />
      </view>

      <button class="sr-btn sr-btn-primary {{joining ? 'sr-btn--loading' : ''}}" bindtap="handleJoinSpace">
        <text class="btn-text">确认加入</text>
      </button>
    </view>
  </view>

  <!-- idle 状态：已有编队快捷入口 -->
  <view wx:if="{{isLoggedIn && cockpitState === 'idle' && cockpitView.hasRoom && !viewingRoom}}" class="reentry-card sr-card">
    <view class="reentry-head">
      <view class="reentry-title">基地编队待命中</view>
    </view>
    <view class="reentry-info">
      <view class="reentry-code">{{cockpitView.roomNo}}</view>
      <view class="reentry-meta">
        <text>编队成员 {{cockpitView.formationCount}}</text>
        <text>{{currentRoom.scoreMode === 1 ? '公开编队' : '编队码加入'}}</text>
      </view>
    </view>
    <view class="reentry-actions">
      <button class="sr-btn sr-btn-primary" bindtap="enterRoom">
        <text class="btn-text">进入编队</text>
      </button>
    </view>
  </view>

  <!-- active 状态：驾驶舱主界面 -->
  <view wx:if="{{isLoggedIn && cockpitState === 'active' && currentRoom}}" class="cockpit-active">
  
    <!-- 单屏驾驶舱 -->
    <view class="cockpit-active-screen">

      <!-- ===== 抬头：HUD 舷窗主面板 ===== -->
      <view class="cockpit-hud-zone">
        <!-- 座舱包围 -->
        <view class="cockpit-frame-left"></view>
        <view class="cockpit-frame-right"></view>
        <view class="cockpit-canopy-arc"></view>

        <!-- 深空背景层 -->
        <view class="deep-space-bg">
          <view class="deep-space-stars"></view>
          <view class="deep-space-nebula"></view>
          <view class="deep-space-grid"></view>
          <view class="deep-space-vignette"></view>
        </view>

        <!-- 成员观测层 -->
        <view class="observation-zone" id="formation-window">
          <view
            wx:for="{{cockpitView.externalShips}}"
            wx:key="userId"
            id="seat-{{item.userId}}"
            class="hud-member {{item.online ? 'hud-member--online' : ''}} {{item.isNew ? 'hud-member--new' : ''}} {{impactCrewId == item.userId ? 'hud-member--impact' : ''}} {{contactFxUserId == item.userId ? (contactFxRole === 'sending' ? 'hud-member--sending' : 'hud-member--receiving') : ''}}"
            style="left: {{item.x}}%; top: {{item.y}}%;"
            bindtap="handleTapShip"
            catchtouchstart="handleShipTouchStart"
            catchtouchmove="handleShipTouchMove"
            catchtouchend="handleShipTouchEnd"
            catchtouchcancel="handleShipTouchEnd"
            hover-class="hud-member--tap"
            hover-stay-time="120"
            data-user-id="{{item.userId}}"
            data-active="{{item.online}}"
          >
            <view class="contact-marker {{item.sizeClass}} {{item.online ? 'contact-marker--online' : 'contact-marker--offline'}}">
              <view class="contact-marker__tick contact-marker__tick--left"></view>
              <view class="contact-marker__tick contact-marker__tick--right"></view>
              <view class="contact-marker__orbit"></view>
              <view class="contact-marker__pulse-fx"></view>
              <view class="contact-marker__core">
                <image wx:if="{{item.avatarUrl}}" class="hud-member__avatar" src="{{item.avatarUrl}}" mode="aspectFill" binderror="onHudAvatarError" data-user-id="{{item.userId}}" />
                <view wx:else class="hud-member__avatar hud-member__avatar--char">
                  <text class="hud-member__avatar-char-text">{{item.avatarChar || '?'}}</text>
                </view>
              </view>
              <view class="contact-marker__status {{item.online ? 'is-on' : ''}}"></view>
            </view>
            <view class="hud-member__info">
              <text class="hud-member__name">{{item.nickname}}</text>
              <text class="hud-member__score {{item.pulseClass}}">{{item.pulseDisplay}}</text>
            </view>
          </view>

          <!-- 空态：远距离信标扫描 -->
          <view class="observation-empty" wx:if="{{cockpitView.externalShips.length === 0}}">
            <view class="scan-beacon-visual">
              <view class="scan-pulse-ring"></view>
              <view class="scan-pulse-ring scan-pulse-ring--mid"></view>
              <view class="scan-pulse-ring scan-pulse-ring--outer"></view>
              <view class="scan-placeholder-dots">
                <view class="scan-placeholder-dot scan-placeholder-dot--1"></view>
                <view class="scan-placeholder-dot scan-placeholder-dot--2"></view>
                <view class="scan-placeholder-dot scan-placeholder-dot--3"></view>
              </view>
            </view>
            <text class="observation-empty__title">等待编队接入</text>
            <text class="observation-empty__desc">展开信标邀请外部航船</text>
            <text class="observation-empty__hint">扫描频段开启中</text>
          </view>

          <view class="observation-grid-marks">
            <text class="coord-mark coord-mark--tl">N 0°</text>
            <text class="coord-mark coord-mark--tr">E 90°</text>
          </view>
        </view>

        <!-- HUD 下沿唇缘 -->
        <view class="cockpit-dashboard-lip"></view>
      </view>

      <!-- ===== 飞船控制台（与HUD融合） ===== -->
      <view class="cockpit-console-v2">
        <view class="ccv2-rail ccv2-rail--left"></view>
        <view class="ccv2-rail ccv2-rail--right"></view>

        <view class="ccv2-panel">
          <view class="ccv2-btn ccv2-btn--beacon" bindtap="openBeacon" hover-class="ccv2-btn--press">
            <view class="ccv2-btn__glow"></view>
            <view class="ccv2-btn__body">
              <view class="ccv2-btn__indicator ccv2-btn__indicator--cyan"></view>
              <text class="ccv2-btn__label">信标</text>
            </view>
          </view>

          <view class="console-pulse-log" bindtap="openPulseLogPanel">
            <view class="console-pulse-readout {{cockpitView.selfPulseClass}} {{cockpitView.selfPulseSizeClass}} {{pulseReadoutRolling ? (pulseReadoutDirection === 'loss' ? 'is-roll-down' : 'is-roll-up') : ''}}">
              <view class="console-pulse-readout__ticks console-pulse-readout__ticks--left"></view>
              <view class="console-pulse-readout__digits">
                <view class="pulse-odometer" wx:if="{{pulseReadoutColumns.length > 0}}">
                  <view
                    class="pulse-odometer__column {{item.numeric ? 'is-numeric' : 'is-symbol'}}"
                    wx:for="{{pulseReadoutColumns}}"
                    wx:key="id"
                  >
                    <view
                      class="pulse-odometer__track {{item.animated ? 'is-animated' : ''}}"
                      style="transform: translateY(-{{item.offset}}rpx);"
                    >
                      <text wx:for="{{item.values}}" wx:for-item="digit" wx:key="index">{{digit}}</text>
                    </view>
                  </view>
                </view>
                <text class="pulse-odometer__stable" wx:else>{{pulseReadoutDisplay || cockpitView.selfPulseDisplay}}</text>
              </view>
              <view class="console-pulse-readout__ticks console-pulse-readout__ticks--right"></view>
              <view class="console-pulse-readout__dot"></view>
            </view>
            <view class="console-pulse-log__list" wx:if="{{cockpitView.terminalLogEntries.length > 0}}">
              <view
                class="console-pulse-log__item {{item.myRole === 'to' ? 'console-pulse-log__item--gain' : item.myRole === 'from' ? 'console-pulse-log__item--loss' : 'console-pulse-log__item--other'}} {{item.isNew ? 'console-pulse-log__item--new' : ''}}"
                wx:for="{{cockpitView.terminalLogEntries}}"
                wx:key="id"
              >
                <text class="console-pulse-log__route">{{item.fromName}} → {{item.toName}}</text>
                <text class="console-pulse-log__value">{{item.value}}</text>
              </view>
            </view>
            <view class="console-pulse-log__empty" wx:else>
              <view class="console-pulse-log__idle-line"></view>
            </view>
          </view>

          <view class="ccv2-btn ccv2-btn--trace" bindtap="goTrace" hover-class="ccv2-btn--press">
            <view class="ccv2-btn__glow"></view>
            <view class="ccv2-btn__body">
              <view class="ccv2-btn__indicator ccv2-btn__indicator--green"></view>
              <text class="ccv2-btn__label">航迹</text>
            </view>
          </view>
        </view>
      </view>

    </view>



    <!-- 脉冲飞行动画层 -->
    <view wx:if="{{pulseFlight.visible}}" class="pulse-flight-layer">
      <view
        class="pulse-flight-dot"
        style="left: {{pulseFlight.fromX}}px; top: {{pulseFlight.fromY}}px; --dx: {{pulseFlight.dx}}px; --dy: {{pulseFlight.dy}}px;"
      >
        <view class="pulse-tail"></view>
        <text class="pulse-flight-value">{{pulseFlight.value}}</text>
      </view>
    </view>

    <!-- 解散 / 撤离确认弹窗 -->
    <view wx:if="{{leaveConfirmVisible}}" class="cockpit-mask" bindtap="closeLeaveConfirm">
      <view class="seal-panel sr-hud-panel" catchtap="preventClose">
        <view class="seal-core">
          <view class="seal-ring"></view>
          <view class="seal-title">{{isOwner ? '解散' : '撤离'}}</view>
          <view class="seal-desc">
            {{isOwner ? '确认结束编队？' : '确认离开？'}}
          </view>
        </view>

        <view class="seal-actions">
          <button class="sr-btn sr-btn-secondary" bindtap="closeLeaveConfirm">
            <text class="btn-text">取消</text>
          </button>
          <button class="sr-btn sr-btn-danger-outline" bindtap="executeLeaveOrDisband">
            <text class="btn-text">{{isOwner ? '解散' : '撤离'}}</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 脉冲记录详情：本人收发记录使用独立色彩 -->
    <view wx:if="{{showPulseLogPanel}}" class="cockpit-mask pulse-log-mask" bindtap="closePulseLogPanel">
      <view class="pulse-log-sheet" catchtap="preventClose">
        <pulse-stream
          records="{{scoreRecords}}"
          live="{{wsConnected}}"
          loading="{{pulseRecordsLoading}}"
          title="实时脉冲记录"
          max-rows="{{12}}"
          show-close
          bind:close="closePulseLogPanel"
        />
      </view>
    </view>

    <!-- VR 悬浮触控阵列（驾驶舱输入层） -->
    <view class="pulse-vr-overlay {{showNumpad ? 'pulse-vr-overlay--show' : ''}}" catchtap="cancelTransfer">
      <view class="pulse-vr-cluster {{numpadLaunching ? 'is-launching' : ''}}" catchtap="preventClose">
        <!-- AR 面板扫描线 -->
        <view class="pulse-vr-scanline"></view>
        <!-- AR 面板边角装饰 -->
        <view class="pulse-vr-corner pulse-vr-corner--tl"></view>
        <view class="pulse-vr-corner pulse-vr-corner--tr"></view>
        <view class="pulse-vr-corner pulse-vr-corner--bl"></view>
        <view class="pulse-vr-corner pulse-vr-corner--br"></view>

        <!-- 目标锁定条：很薄的 HUD 锁定条 -->
        <view class="pulse-lock-strip">
          <view class="pulse-lock-target" wx:if="{{transferToInfo}}">
            <helmet-avatar
              src="{{transferToInfo.avatarUrl || ''}}"
              nickname="{{transferToInfo.nickname}}"
              size="56"
              active="{{false}}"
              showStatus="{{false}}"
              reduceMotion="{{!animationEnabled}}"
            />
            <view class="pulse-lock-text">
              <text class="pulse-lock-name">{{t.truncateName(transferToInfo.nickname)}}</text>
              <text class="pulse-lock-sub">目标锁定</text>
            </view>
          </view>
          <view class="pulse-lock-value {{numpadLaunching ? 'is-launching' : ''}}">
            <text>{{numpadValue || '0'}}</text>
          </view>
        </view>

        <!-- 悬浮按键阵列：独立 VR 触控块（稳定三列布局） -->
        <view class="pulse-vr-grid">
          <view class="transfer-key-row" wx:for="{{transferKeyRows}}" wx:for-item="row" wx:key="index">
            <button 
              class="transfer-key {{item.type === 'close' ? 'transfer-key--close' : ''}} {{item.type === 'submit' ? 'transfer-key--launch' : ''}} {{item.type === 'submit' && (numpadValue <= 0 || submitting) ? 'transfer-key--disabled' : ''}}"
              wx:for="{{row}}"
              wx:for-item="item"
              wx:key="index"
              disabled="{{submitting}}"
              bindtap="onTransferKeyTap"
              data-type="{{item.type}}"
              data-value="{{item.value}}"
            >
              <block wx:if="{{item.type === 'submit'}}">
                <view class="pulse-launch-glyph">
                  <view class="pulse-launch-core"></view>
                  <view class="pulse-launch-triangle"></view>
                  <view class="pulse-launch-ray pulse-launch-ray--one"></view>
                  <view class="pulse-launch-ray pulse-launch-ray--two"></view>
                </view>
              </block>
              <text>{{item.text}}</text>
            </button>
          </view>
        </view>

      </view>
    </view>

    <!-- 数值总览（全局组件） -->
    <matrix-overview
      id="matrix-overview"
      visible="{{showMatrixPanel}}"
      room-id="{{currentRoom.roomId}}"
      member-grid="{{memberGrid}}"
      score-records="{{scoreRecords}}"
      relation-map="{{relationMap}}"
      chart-data="{{matrixChartData}}"
      my-user-id="{{myUserId}}"
      bind:close="onMatrixClose"
    />

    <!-- 记录动画层（CSS 驱动） -->
    <view class="transfer-anim-overlay" wx:if="{{animActive}}">
      <!-- 屏幕瞬时闪烁（全息光晕 Flare） -->
      <view class="transfer-anim-flash {{animFlying ? 'is-active' : ''}}"></view>

      <!-- 发射起点波纹（Launch Ripple） -->
      <view class="launch-ripple-container {{animFlying ? 'is-active' : ''}}"
            style="left:{{animStartX}}px;top:{{animStartY}}px;">
        <view class="launch-ripple-wave"></view>
      </view>

      <!-- 终点命中反馈（冲击波 Ripple） -->
      <view class="impact-ripple-container {{impactCrewId ? 'is-impacting' : ''}}"
            style="left:{{animStartX + animDx}}px;top:{{animStartY + animDy}}px;">
        <view class="impact-ripple-wave"></view>
        <view class="impact-ripple-hex"></view>
      </view>

      <!-- 终点命中飘字（Decryption Float Text） -->
      <view class="impact-float-text {{impactCrewId ? 'is-floating' : ''}}"
            style="left:{{animStartX + animDx}}px;top:{{animStartY + animDy - 30}}px;">
        +{{animAmount}}
      </view>

      <!-- 主干光束跃迁（Warp Beam Flight） -->
      <view class="transfer-anim-beam-wrapper {{animFlying ? 'is-flying' : ''}}"
            style="left:{{animStartX}}px;top:{{animStartY}}px;--dx:{{animDx}}px;--dy:{{animDy}}px;--arc:{{animArc}}px;--angle:{{animAngle}}deg;"
            bindanimationend="onParticleAnimEnd">
        <!-- 拖尾与残影 -->
        <view class="beam-trail"></view>
        <!-- 高能光束核心 -->
        <view class="beam-core"></view>
        <!-- 环绕光环（Warp Rings） -->
        <view class="beam-rings"></view>
      </view>
    </view>

    <!-- 本局录入弹窗 -->
    <host-fill-modal
      wx:if="{{showHostFill && roundRecord}}"
      members="{{currentRoom.members}}"
      zero-sum="{{currentRoom.zeroSumRequired}}"
      bind:submit="submitHostFill"
      bind:close="onHostFillClose"
    />
    <member-fill-modal
      wx:if="{{showMemberFill && roundRecord}}"
      submitted="{{roundRecord.mySubmitted}}"
      my-score="{{roundRecord.myScore}}"
      bind:submit="submitMemberFill"
      bind:close="onMemberFillClose"
    />
    <round-confirm-modal
      wx:if="{{showRoundConfirm && roundRecord}}"
      round="{{roundRecord}}"
      my-user-id="{{myUserId}}"
      bind:confirm="confirmRound"
      bind:reject="onRoundReject"
      bind:close="onRoundConfirmClose"
    />
  </view>

  <!-- sealing 状态：航迹档案写入中 -->
  <view wx:if="{{cockpitState === 'sealing'}}" class="sealing-overlay">
    <view class="blackbox-write sr-hud-panel">
      <view class="write-beam"></view>
      <view class="write-title">航迹档案写入中</view>
      <view class="write-desc">{{sealHeartbeatText}}</view>
    </view>
  </view>

  <!-- 信标面板 (AR 浮空终端风格) -->
  <view class="beacon-overlay {{showShareSheet ? 'beacon-overlay--show' : ''}}" catchtap="closeShareSheet" catchtouchmove="preventClose">
    <view class="beacon-panel" catchtap="preventClose">
      <view class="beacon-panel__scanline"></view>
      <view class="beacon-panel__corner beacon-panel__corner--tl"></view>
      <view class="beacon-panel__corner beacon-panel__corner--tr"></view>
      <view class="beacon-panel__corner beacon-panel__corner--bl"></view>
      <view class="beacon-panel__corner beacon-panel__corner--br"></view>
      <view class="beacon-panel__close" bindtap="closeShareSheet">
        <view class="beacon-close-x"></view>
      </view>

      <view class="beacon-code-row" bindtap="copyRoomNo">
        <text class="beacon-code-value">{{currentRoom.roomNo}}</text>
      </view>

      <!-- 二维码：加载中 -->
      <view class="beacon-qr-section" wx:if="{{qrLoading}}">
        <view class="beacon-qr-frame beacon-qr-frame--loading">
          <view class="beacon-qr-spinner"></view>
          <text class="beacon-qr-loading-text">生成中...</text>
        </view>
      </view>

      <!-- 二维码：失败 -->
      <view class="beacon-qr-section" wx:elif="{{qrFailed}}">
        <view class="beacon-qr-frame beacon-qr-frame--fail">
          <text class="beacon-qr-fail-text">生成失败</text>
          <view class="beacon-qr-retry" bindtap="retryLoadQrCode">
            <text>重试</text>
          </view>
        </view>
      </view>

      <!-- 二维码：正常 -->
      <view class="beacon-qr-section" wx:elif="{{currentRoom.qrCodeUrl}}">
        <view class="beacon-qr-frame">
          <image class="beacon-qr-image" src="{{currentRoom.qrCodeUrl}}" mode="aspectFit" show-menu-by-longpress></image>
        </view>
      </view>

      <view class="beacon-manage-entry" bindtap="openFormationManageFromBeacon">
        <view class="beacon-manage-entry__dot"></view>
        <text>{{isOwner ? '解散编队' : '撤离编队'}}</text>
      </view>
    </view>
  </view>

  <!-- 驳回确认弹窗 -->
  <terminal-popup
    visible="{{showRejectConfirm}}"
    title="操作确认"
    content="确认驳回本轮录入？驳回后本轮数据将被清除。"
    cancel-text="返回"
    confirm-text="确认驳回"
    confirm-type="danger"
    reduce-motion="{{!animationEnabled}}"
    bind:cancel="closeRejectConfirm"
    bind:confirm="confirmRoundReject"
  />

  <!-- 航程报告弹层 -->
  <view class="settle-overlay {{showSettleOverlay ? 'settle-overlay--show' : ''}}" catchtouchmove="preventClose">
    <scroll-view class="settle-overlay__inner" scroll-y enhanced show-scrollbar="{{false}}">

      <!-- 顶部关闭按钮 -->
      <view class="settle-top-bar">
        <view class="settle-close-cyber" bindtap="closeSettleOverlay">
          <view class="settle-close-ring">
            <view class="fi fi--close"></view>
          </view>
        </view>
      </view>

      <!-- 1. 航程总结 -->
      <battle-summary
        winner="{{settleWinner}}"
        loser="{{settleLoser}}"
        maxSingle="{{settleMaxSingle}}"
        totalTransfer="{{settleTotalTransfer}}"
        transferCount="{{settleTransferCount}}"
        memberCount="{{settleMemberCount}}"
        roomNo="{{settleRoomNo}}"
        settleTime="{{settleTime}}" />

      <view class="settle-card-tabs">
        <view class="settle-card-tab {{settleActiveCard === 'overview' ? 'settle-card-tab--active' : ''}}"
          data-card="overview" bindtap="switchSettleCard">总览</view>
        <view class="settle-card-tab {{settleActiveCard === 'trend' ? 'settle-card-tab--active' : ''}}"
          data-card="trend" bindtap="switchSettleCard">趋势</view>
        <view class="settle-card-tab {{settleActiveCard === 'network' ? 'settle-card-tab--active' : ''}}"
          data-card="network" bindtap="switchSettleCard">关系</view>
        <view class="settle-card-tab {{settleActiveCard === 'signal' ? 'settle-card-tab--active' : ''}}"
          data-card="signal" bindtap="switchSettleCard">信号</view>
      </view>

      <!-- 2. 总览卡片 -->
      <block wx:if="{{settleActiveCard === 'overview'}}">
        <battle-insight
          wx:if="{{settleInsight}}"
          mostActiveUser="{{settleInsight.mostActiveUser}}"
          mostFocusedUser="{{settleLoser}}"
          networkDensity="{{settleInsight.networkDensity}}"
          transferCount="{{settleInsight.transferCount}}"
          memberCount="{{settleMemberCount}}" />

        <view class="settle-card" wx:if="{{settleRankedMembers.length > 0}}">
          <view class="settle-card-header">
            <view class="settle-card-title">实时序列</view>
            <view class="settle-card-line"></view>
          </view>
          <view class="settle-rank-list">
            <view class="settle-rank-item {{index === 0 ? 'settle-rank-champion' : ''}}"
              wx:for="{{settleRankedMembers}}" wx:key="userId">
              <view class="settle-rank-badge {{index < 3 ? 'settle-rank-top3' : ''}} {{index === 0 ? 'settle-badge-champion' : ''}}">
                <text class="settle-rank-num">{{index + 1}}</text>
              </view>
              <view class="settle-rank-avatar" style="background: {{item.avatarColor}}">
                <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="settle-rank-avatar-img" mode="aspectFill" />
                <text wx:else class="settle-rank-avatar-char">{{item.avatarChar}}</text>
              </view>
              <text class="settle-rank-name" style="color: {{item.userId == myUserId ? '#00AFFF' : 'rgba(255,255,255,0.85)'}}">
                {{item.nickname}}
                <text wx:if="{{item.userId == myUserId}}" class="settle-me-tag">我</text>
              </text>
              <text class="settle-rank-score"
                style="color: {{item.finalScore > 0 ? '#32D74B' : item.finalScore < 0 ? '#FF453A' : 'rgba(255,255,255,0.35)'}}">
                {{item.finalScore > 0 ? '+' : ''}}{{item.finalScore}}
              </text>
            </view>
          </view>
        </view>
      </block>

      <!-- 3. 数值趋势卡片，切换后才挂载 Canvas -->
      <view class="settle-card" wx:if="{{settleActiveCard === 'trend' && settleSeries.length > 0}}">
        <view class="settle-card-header">
          <view class="settle-card-title">数值演化轨迹</view>
          <view class="settle-card-line"></view>
        </view>
        <view class="settle-chart-wrap">
          <score-chart
            timestamps="{{settleTimestamps}}"
            series="{{settleSeries}}"
            visibleUsers="{{settleVisibleUsers}}"
            eventMarkers="{{settleEventMarkers}}"
            highlightUser="{{myUserId}}" />
        </view>
      </view>

      <!-- 4. 关系卡片，切换后才请求并挂载 Canvas -->
      <block wx:if="{{settleActiveCard === 'network'}}">
        <view class="settle-card settle-network-loading" wx:if="{{settleNetworkLoading}}">
          <view class="settle-loading-dot"></view>
          <text>正在构建成员关系...</text>
        </view>
        <score-network
          wx:elif="{{settleNetworkNodes.length > 0}}"
          nodes="{{settleNetworkNodes}}"
          links="{{settleNetworkLinks}}"
          my-user-id="{{myUserId}}" />
        <view class="settle-card settle-network-empty" wx:else>
          <text>暂无可展示的成员关系</text>
        </view>

      </block>

      <!-- 5. 行为信号卡片 -->
      <block wx:if="{{settleActiveCard === 'signal'}}">
        <view class="settle-card settle-network-loading" wx:if="{{settleNetworkLoading}}">
          <view class="settle-loading-dot"></view>
          <text>正在分析行为信号...</text>
        </view>
        <persona-signal
          wx:elif="{{settlePersonaSignals}}"
          activity="{{settlePersonaSignals.socialActivity}}"
          volatility="{{settlePersonaSignals.riskPreference}}"
          concentration="{{settlePersonaSignals.resourceControl}}"
          density="{{settlePersonaSignals.allianceTendency}}"
          low-sample="{{settleTransferCount < 5}}" />
        <view class="settle-card settle-network-empty" wx:else>
          <text>暂无足够数据生成行为信号</text>
        </view>
      </block>

      <view class="settle-report-actions">
        <button class="settle-confirm-exit" bindtap="closeSettleOverlay">确认并退出</button>
      </view>
    </scroll-view>
  </view>

  <!-- 身份重叠弹窗 -->
  <view class="name-collision-mask {{showNameCollisionModal ? 'nc-show' : ''}}" catchtap="closeNameCollisionModal">
    <view class="name-collision-card" catchtap="">
      <view class="nc-icon-wrap">
        <view class="nc-icon">!</view>
      </view>
      <text class="nc-title">身份重叠</text>
      <text class="nc-desc">检测到场域内存在同名实体，请前往[身份]终端重新校准呼号。</text>
      <view class="nc-btn" bindtap="goToProfile">
        <text class="nc-btn-text">前往身份</text>
      </view>
    </view>
  </view>
  <!-- 系统全局左上角提示 -->
  <sr-toast id="srToast" reduceMotion="{{!animationEnabled}}" />
</view>

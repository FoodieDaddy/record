<wxs src="./room.wxs" module="fmt" />
<wxs src="../../utils/truncate.wxs" module="t" />
<view class="room-page">
  <!-- WS 断线遮罩 -->
  <view class="ws-mask {{wsReconnecting ? 'ws-mask--show' : ''}}" catchtap catchtouchmove="preventClose">
    <view class="ws-mask__card glass-card">
      <view class="ws-mask__dot"></view>
      <text class="ws-mask__text">网络不太稳定，正在重试...</text>
    </view>
  </view>
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="empty-auth">
    <view class="empty-auth-icon icon-lock-wrap"><view class="icon-lock"></view></view>
    <text class="text-lg text-bold" style="margin-bottom:12rpx;">尚未登录</text>
    <text class="text-secondary" style="margin-bottom:40rpx;">登录后即可创建或加入房间</text>
    <button class="btn-primary" style="width:320rpx;" bindtap="goLogin">去登录</button>
  </view>

  <!-- 已登录：无房间 -->
  <view wx:elif="{{!currentRoom}}" class="empty-room">
    <!-- 创建房间 -->
    <view class="cyber-card create-card">
      <!-- 系统状态 -->
      <view class="cyber-system-bar">
        <text class="cyber-system-name">SMART RECORD</text>
        <view class="cyber-system-status">
          <view class="cyber-status-dot"></view>
          <text class="cyber-status-text">在线</text>
        </view>
      </view>
      <view class="cyber-divider"></view>

      <!-- 房间模式 -->
      <view class="cyber-section-title">
        <text class="cyber-cn">房间模式</text>
        <text class="cyber-en">ROOM MODE</text>
      </view>
      <view class="cyber-mode-cards">
        <view class="cyber-mode-card {{scoreMode === 1 ? 'cyber-mode-active' : ''}}" bindtap="selectScoreMode" data-mode="1">
          <view class="cyber-mode-head">
            <text class="cyber-mode-dot {{scoreMode === 1 ? 'mode-dot-on' : ''}}"></text>
            <text class="cyber-mode-name">自由流转</text>
            <text class="cyber-mode-badge {{scoreMode === 1 ? 'badge-on' : ''}}">开放</text>
          </view>
          <text class="cyber-mode-desc">实时转移积分</text>
        </view>
        <view class="cyber-mode-card {{scoreMode === 2 ? 'cyber-mode-active' : ''}}" bindtap="selectScoreMode" data-mode="2">
          <view class="cyber-mode-head">
            <text class="cyber-mode-dot {{scoreMode === 2 ? 'mode-dot-on' : ''}}"></text>
            <text class="cyber-mode-name">本局录入</text>
            <text class="cyber-mode-badge {{scoreMode === 2 ? 'badge-on' : ''}}">推荐</text>
          </view>
          <text class="cyber-mode-desc">每局结束统一录入积分</text>
        </view>
      </view>

      <!-- 本局录入配置 -->
      <block wx:if="{{scoreMode === 2}}">
        <view class="cyber-divider"></view>

        <!-- 录入方式 -->
        <view class="cyber-section-title">
          <text class="cyber-cn">录入方式</text>
          <text class="cyber-en">RECORD MODE</text>
        </view>
        <view class="cyber-cards">
          <view class="cyber-opt-card {{roundInputMethod === 1 ? 'cyber-opt-active' : ''}}" bindtap="selectRoundInputMethod" data-value="1">
            <view class="cyber-opt-status" wx:if="{{roundInputMethod === 1}}">
              <text class="cyber-opt-check">✓</text>
              <text class="cyber-opt-status-text">已启用</text>
            </view>
            <text class="cyber-opt-title">房主填写</text>
            <text class="cyber-opt-desc">由房主统一录入</text>
            <text class="cyber-opt-hint">适合麻将扑克</text>
          </view>
          <view class="cyber-opt-card {{roundInputMethod === 2 ? 'cyber-opt-active' : ''}}" bindtap="selectRoundInputMethod" data-value="2">
            <view class="cyber-opt-status" wx:if="{{roundInputMethod === 2}}">
              <text class="cyber-opt-check">✓</text>
              <text class="cyber-opt-status-text">已启用</text>
            </view>
            <text class="cyber-opt-title">成员自填</text>
            <text class="cyber-opt-desc">每人提交自己结果</text>
            <text class="cyber-opt-hint">待选择</text>
          </view>
        </view>
        <view class="cyber-divider"></view>

        <!-- 确认协议 -->
        <view class="cyber-section-title">
          <text class="cyber-cn">确认协议</text>
          <text class="cyber-en">CONFIRM PROTOCOL</text>
        </view>
        <view class="cyber-chips">
          <view class="cyber-chip {{trustMode === 0 ? 'cyber-chip-active' : ''}}" bindtap="selectTrustMode" data-value="0">
            <text class="cyber-chip-dot {{trustMode === 0 ? 'dot-on' : ''}}"></text>
            <view class="cyber-chip-text">
              <text class="cyber-chip-main">标准协议</text>
              <text class="cyber-chip-sub">需要全员确认</text>
            </view>
          </view>
          <view class="cyber-chip {{trustMode === 1 ? 'cyber-chip-active' : ''}}" bindtap="selectTrustMode" data-value="1">
            <text class="cyber-chip-dot {{trustMode === 1 ? 'dot-on' : ''}}"></text>
            <view class="cyber-chip-text">
              <text class="cyber-chip-main">快速协议</text>
              <text class="cyber-chip-sub">直接生效</text>
            </view>
          </view>
        </view>
        <view class="cyber-divider"></view>

        <!-- 积分模型 -->
        <view class="cyber-section-title">
          <text class="cyber-cn">积分模型</text>
          <text class="cyber-en">SCORE MODEL</text>
        </view>
        <view class="cyber-chips">
          <view class="cyber-chip {{zeroSumRequired === 1 ? 'cyber-chip-active' : ''}}" bindtap="selectZeroSum" data-value="1">
            <text class="cyber-chip-dot {{zeroSumRequired === 1 ? 'dot-on' : ''}}"></text>
            <view class="cyber-chip-text">
              <text class="cyber-chip-main">零和结算</text>
              <text class="cyber-chip-sub">积分守恒</text>
            </view>
          </view>
          <view class="cyber-chip {{zeroSumRequired === 0 ? 'cyber-chip-active' : ''}}" bindtap="selectZeroSum" data-value="0">
            <text class="cyber-chip-dot {{zeroSumRequired === 0 ? 'dot-on' : ''}}"></text>
            <view class="cyber-chip-text">
              <text class="cyber-chip-main">自由结算</text>
              <text class="cyber-chip-sub">允许积分增减</text>
            </view>
          </view>
        </view>

        <!-- 确认时限（仅标准协议时显示） -->
        <block wx:if="{{trustMode === 0}}">
          <view class="cyber-divider"></view>
          <view class="cyber-section-title">
            <text class="cyber-cn">确认时限</text>
            <text class="cyber-en">TIMEOUT</text>
          </view>
          <view class="cyber-chips cyber-timeout-chips">
            <view class="cyber-chip {{autoTimeoutSeconds === 15 ? 'cyber-chip-active' : ''}}" bindtap="selectTimeout" data-value="15">
              <text class="cyber-chip-dot {{autoTimeoutSeconds === 15 ? 'dot-on' : ''}}"></text>
              <text class="cyber-chip-main">15秒</text>
            </view>
            <view class="cyber-chip {{autoTimeoutSeconds === 30 ? 'cyber-chip-active' : ''}}" bindtap="selectTimeout" data-value="30">
              <text class="cyber-chip-dot {{autoTimeoutSeconds === 30 ? 'dot-on' : ''}}"></text>
              <text class="cyber-chip-main">30秒</text>
            </view>
            <view class="cyber-chip {{autoTimeoutSeconds === 60 ? 'cyber-chip-active' : ''}}" bindtap="selectTimeout" data-value="60">
              <text class="cyber-chip-dot {{autoTimeoutSeconds === 60 ? 'dot-on' : ''}}"></text>
              <text class="cyber-chip-main">60秒</text>
            </view>
          </view>
          <view class="cyber-timeout-action">
            <text class="cyber-timeout-label">超时行为</text>
            <view class="cyber-chips" style="flex:1">
              <view class="cyber-chip {{autoTimeoutAction === 1 ? 'cyber-chip-active' : ''}}" bindtap="selectAutoTimeoutAction" data-value="1">
                <text class="cyber-chip-dot {{autoTimeoutAction === 1 ? 'dot-on' : ''}}"></text>
                <text class="cyber-chip-main">自动同意</text>
              </view>
              <view class="cyber-chip {{autoTimeoutAction === 2 ? 'cyber-chip-active' : ''}}" bindtap="selectAutoTimeoutAction" data-value="2">
                <text class="cyber-chip-dot {{autoTimeoutAction === 2 ? 'dot-on' : ''}}"></text>
                <text class="cyber-chip-main">自动取消</text>
              </view>
            </view>
          </view>
        </block>
      </block>

      <!-- 配置预览 -->
      <view class="cyber-divider"></view>
      <view class="cyber-preview">
        <text class="cyber-preview-title">当前配置</text>
        <view class="cyber-preview-row">
          <text class="cyber-preview-key">房间模式</text>
          <text class="cyber-preview-val">{{scoreMode === 1 ? '自由流转' : '本局录入'}}</text>
        </view>
        <block wx:if="{{scoreMode === 2}}">
          <view class="cyber-preview-row">
            <text class="cyber-preview-key">录入方式</text>
            <text class="cyber-preview-val">{{roundInputMethod === 1 ? '房主填写' : '成员自填'}}</text>
          </view>
          <view class="cyber-preview-row">
            <text class="cyber-preview-key">确认协议</text>
            <text class="cyber-preview-val">{{trustMode === 0 ? '标准协议' : '快速协议'}}</text>
          </view>
          <view class="cyber-preview-row">
            <text class="cyber-preview-key">积分模型</text>
            <text class="cyber-preview-val">{{zeroSumRequired === 1 ? '零和结算' : '自由结算'}}</text>
          </view>
          <view class="cyber-preview-row" wx:if="{{trustMode === 0}}">
            <text class="cyber-preview-key">确认时限</text>
            <text class="cyber-preview-val">{{autoTimeoutSeconds}}秒</text>
          </view>
        </block>
      </view>

      <!-- 启动房间 -->
      <view class="cyber-divider"></view>
      <view class="cyber-create-btn" bindtap="createRoom">
        <view class="cyber-create-inner {{creating ? 'btn-loading' : ''}}">
          <text class="cyber-create-text">启动房间</text>
          <text class="cyber-create-sub">ROOM INITIALIZATION</text>
        </view>
      </view>
    </view>

    <view class="divider-glow"><text class="divider-text">或者</text></view>

    <!-- 接入房间 -->
    <view class="cyber-card join-card">
      <!-- 双层标题 -->
      <view class="cyber-section-title">
        <text class="cyber-cn">接入房间</text>
        <text class="cyber-en">ROOM ACCESS</text>
      </view>
      <view class="cyber-divider"></view>

      <!-- 扫描接入（主入口） -->
      <view class="cyber-scan-card" bindtap="scanJoin">
        <view class="cyber-scan-icon">
          <view class="cyber-scan-corner cyber-scan-tl"></view>
          <view class="cyber-scan-corner cyber-scan-tr"></view>
          <view class="cyber-scan-corner cyber-scan-bl"></view>
          <view class="cyber-scan-corner cyber-scan-br"></view>
          <view class="cyber-scan-line"></view>
        </view>
        <view class="cyber-scan-text">
          <text class="cyber-scan-title">扫描房间</text>
          <text class="cyber-scan-sub">ROOM SCAN</text>
        </view>
        <text class="cyber-scan-hint">推荐方式 · 扫描房主二维码快速接入</text>
      </view>
      <view class="cyber-divider"></view>

      <!-- 房间识别码输入 -->
      <view class="cyber-section-title">
        <text class="cyber-cn">房间识别码</text>
        <text class="cyber-en">ROOM CODE</text>
      </view>
      <view class="cyber-terminal-input" bindtap="onTerminalTap">
        <text class="cyber-terminal-prefix">SR-</text>
        <input class="cyber-terminal-field" type="text" maxlength="6"
               value="{{roomCodeRaw}}" placeholder="XXXXXX"
               bindinput="onRoomCodeInput" bindblur="onRoomCodeBlur"
               focus="{{terminalFocused}}" adjust-position="{{false}}" />
        <view class="cyber-terminal-cursor" wx:if="{{terminalFocused && roomCodeRaw.length < 6}}"></view>
      </view>

      <!-- 房间状态反馈 -->
      <view class="cyber-room-status" wx:if="{{roomCodeRaw.length >= 6}}">
        <view class="cyber-status-row">
          <view class="cyber-status-dot {{roomLookupValid ? 'dot-green' : 'dot-red'}}"></view>
          <text class="cyber-status-msg {{roomLookupValid ? 'msg-green' : 'msg-red'}}">
            {{roomLookupValid ? '房间存在' : (roomLookupMsg || '未发现房间')}}
          </text>
        </view>
        <view class="cyber-room-preview" wx:if="{{roomLookupValid && roomPreview}}">
          <view class="cyber-preview-row">
            <text class="cyber-preview-key">房间模式</text>
            <text class="cyber-preview-val">{{roomPreview.scoreMode === 1 ? '自由流转' : '本局录入'}}</text>
          </view>
          <view class="cyber-preview-row">
            <text class="cyber-preview-key">在线人数</text>
            <text class="cyber-preview-val">{{roomPreview.memberCount || '?'}} / 16</text>
          </view>
        </view>
      </view>

      <!-- 接入按钮 -->
      <view class="cyber-divider"></view>
      <view class="cyber-create-btn" bindtap="joinByNo">
        <view class="cyber-create-inner {{joining ? 'btn-loading' : ''}} {{roomCodeRaw.length >= 6 ? '' : 'btn-dim'}}">
          <text class="cyber-create-text">接入空间</text>
          <text class="cyber-create-sub">CONNECT</text>
        </view>
      </view>

      <!-- 最近加入 -->
      <block wx:if="{{recentRooms.length > 0}}">
        <view class="cyber-divider"></view>
        <view class="cyber-section-title">
          <text class="cyber-cn">最近加入</text>
          <text class="cyber-en">RECENT ACCESS</text>
        </view>
        <view class="cyber-recent-list">
          <view class="cyber-recent-item" wx:for="{{recentRooms}}" wx:key="roomNo"
                bindtap="onRecentTap" data-room-no="{{item.roomNo}}">
            <text class="cyber-recent-code">SR-{{item.roomNo}}</text>
            <text class="cyber-recent-time">{{item.timeLabel}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 已登录：已有房间（首页快捷入口） -->
  <view wx:elif="{{!viewingRoom}}" class="has-room">
    <view class="glass-card-glow room-quick-card">
      <view class="rq-header">
        <view class="rq-info">
          <text class="section-title">我的房间</text>
          <text class="rq-room-no">{{currentRoom.roomNo}}</text>
        </view>
        <view class="rq-badge {{currentRoom.status === 1 ? 'badge-success' : 'badge-accent'}}">
          {{currentRoom.status === 1 ? '已结束' : '进行中'}}
        </view>
      </view>
      <view class="rq-meta">
        <text class="text-tertiary text-xs">{{currentRoom.members ? currentRoom.members.length : 0}}人</text>
      </view>
      <view class="rq-actions">
        <view class="rq-action-btn" bindtap="copyRoomNo">
          <view class="icon-clip"></view>
          <text class="rq-action-text">复制房间号</text>
        </view>
        <view class="rq-action-btn" bindtap="openShareSheet">
          <view class="icon-link"></view>
          <text class="rq-action-text">二维码</text>
        </view>
        <button class="rq-action-btn" open-type="share">
          <view class="icon-share"></view>
          <text class="rq-action-text">分享</text>
        </button>
      </view>
      <button class="btn-primary" style="margin-top:20rpx;" bindtap="enterRoom">进入房间</button>
    </view>
  </view>

  <!-- 已登录：在房间中 -->
  <view wx:else class="room-content">
    <!-- 顶部提示 -->
    <view class="top-toast {{toastMsg ? 'top-toast-show' : ''}} {{toastType === 'error' ? 'top-toast-error' : ''}}" wx:if="{{toastMsg}}">
      <text>{{toastMsg}}</text>
    </view>

    <!-- 可滚动区域（积分总览打开时禁止滚动） -->
    <scroll-view scroll-y="{{!showMatrixPanel && !showNumpad}}" class="{{showMatrixPanel || showNumpad ? 'scroll-locked' : ''}}" style="height:100vh;" bindscrolltolower="onScoreScrollToLower" lower-threshold="200">
      <!-- ROOM TERMINAL 顶部终端栏 -->
      <view class="room-terminal">
        <view class="rt-top-row">
          <text class="rt-kicker">ROOM TERMINAL</text>
          <view class="rt-status">
            <view class="rt-status-dot"></view>
            <text class="rt-status-text">ONLINE</text>
          </view>
        </view>
        <view class="rt-bottom-row">
          <view class="rt-info">
            <text class="rt-room-no">{{currentRoom.roomNo}}</text>
            <text class="rt-meta-sep">·</text>
            <text class="rt-meta">{{memberGrid.length}}/{{currentRoom.maxMembers || 16}}</text>
            <text class="rt-meta-sep">·</text>
            <text class="rt-mode-tag">{{currentRoom.scoreMode === 1 ? '自由流转' : '本局录入'}}</text>
          </view>
          <view class="rt-actions">
            <view class="rt-action" bindtap="copyRoomNo">
              <view class="icon-clip"></view>
            </view>
            <view class="rt-action" bindtap="openShareSheet">
              <view class="icon-share"></view>
            </view>
          </view>
        </view>
      </view>

      <!-- 本局录入状态条 -->
      <round-status-bar
        wx:if="{{currentRoom.scoreMode === 2}}"
        round="{{roundRecord}}"
        is-owner="{{isOwner}}"
        bind:tap="onRoundStatusTap"
        bind:cancel="onRoundCancel"
      />

      <!-- 录入本局按钮（ROUND_RECORD 模式，无待处理录时显示） -->
      <view class="round-start-wrap" wx:if="{{currentRoom.scoreMode === 2 && !roundRecord && isOwner}}">
        <view class="round-start-btn" bindtap="startRound">
          <text class="round-start-text">录入本局</text>
        </view>
      </view>

      <!-- 成员区域 -->
      <view class="glass-card member-section">
        <view class="flex-between" style="margin-bottom:16rpx;">
          <text class="section-title" style="margin-bottom:0;">成员</text>
          <text class="text-tertiary text-sm">{{memberGrid.length}}人</text>
        </view>
        <scroll-view class="member-grid-scroll" scroll-y="{{memberGrid.length > 8}}" style="max-height:{{memberGrid.length > 8 ? '600rpx' : 'none'}};">
          <view class="member-grid">
            <view class="mg-cell {{item.userId === transferTo ? 'mg-cell-on' : ''}}"
                  wx:for="{{memberGrid}}" wx:key="userId"
                  bindtap="onTapMember" data-user-id="{{item.userId}}">
              <view class="mg-avatar-wrap">
                <view class="auto-avatar" style="background:{{item.avatarColor}};" wx:if="{{!item.avatarUrl}}">
                  <text class="auto-avatar-char">{{item.avatarChar}}</text>
                </view>
                <image class="mg-avatar" src="{{item.avatarUrl}}" mode="aspectFill" wx:else binderror="onAvatarError" data-user-id="{{item.userId}}"></image>
                <view class="mg-glow" wx:if="{{item.userId === transferTo}}"></view>
              </view>
              <text class="mg-name">{{t.truncateName(item.nickname)}}</text>
              <text class="mg-score score-number" style="color:{{item.scoreColor}};">
                {{fmt.formatScore(item.displayScore)}}
              </text>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- 积分记录 -->
      <view class="glass-card score-record-card">
        <view class="flex-between" style="margin-bottom:12rpx;">
          <text class="section-title" style="margin-bottom:0;">积分记录</text>
          <view style="display:flex;gap:12rpx;">
            <view class="matrix-btn filter-btn {{filterMine ? 'filter-btn-on' : ''}}" bindtap="toggleFilterMine">
              <view class="icon-person matrix-btn-icon-svg"></view>
              <text class="matrix-btn-text">我</text>
            </view>
            <view class="matrix-btn" bindtap="openMatrixPanel" wx:if="{{memberGrid.length >= 2}}">
              <view class="icon-chart matrix-btn-icon-svg"></view>
              <text class="matrix-btn-text">积分总览</text>
            </view>
          </view>
        </view>
        <view wx:if="{{groupedRecords.length === 0}}" class="empty-batches">
          <view class="icon-empty-doc"></view>
          <text class="empty-hint-text">{{filterMine ? '暂无与你相关的记录' : '暂无记录'}}</text>
        </view>
        <view wx:else class="score-records">
          <block wx:for="{{groupedRecords}}" wx:key="timeKey">
            <view class="sr-time-header">{{item.timeDisplay}}</view>
            <view class="sr-item" wx:for="{{item.records}}" wx:for-item="rec" wx:key="id">
              <view class="sr-col sr-from">
                <view class="sr-avatar-wrap">
                  <view class="auto-avatar-xs" style="background:{{rec.fromColor}};" wx:if="{{!rec.fromAvatarUrl}}">
                    <text class="auto-avatar-char-xs">{{rec.fromChar}}</text>
                  </view>
                  <image class="sr-avatar" src="{{rec.fromAvatarUrl}}" wx:else></image>
                </view>
                <text class="sr-name">{{rec.fromName}}</text>
              </view>
              <view class="sr-col sr-amount">
                <text class="sr-amount-text {{rec.myRole === 'from' ? 'sr-amt-red' : rec.myRole === 'to' ? 'sr-amt-green' : 'sr-amt-gray'}}">{{fmt.formatAmount(rec.amount)}}</text>
                <text class="sr-arrow-icon">→</text>
              </view>
              <view class="sr-col sr-to">
                <view class="sr-avatar-wrap">
                  <view class="auto-avatar-xs" style="background:{{rec.toColor}};" wx:if="{{!rec.toAvatarUrl}}">
                    <text class="auto-avatar-char-xs">{{rec.toChar}}</text>
                  </view>
                  <image class="sr-avatar" src="{{rec.toAvatarUrl}}" wx:else></image>
                </view>
                <text class="sr-name">{{rec.toName}}</text>
              </view>
            </view>
          </block>
          <view wx:if="{{loadingMore}}" class="sr-loading">
            <text class="text-tertiary text-xs">加载中...</text>
          </view>
          <view wx:if="{{noMore && groupedRecords.length > 0}}" class="sr-loading">
            <text class="text-tertiary text-xs">— 没有更多了 —</text>
          </view>
        </view>
      </view>

    </scroll-view>

    <!-- 数字键盘弹窗 -->
    <view class="numpad-overlay {{showNumpad ? 'numpad-show' : ''}}" catchtap="closeNumpad">
      <view class="numpad-sheet" catchtap="preventClose">
        <view class="numpad-header">
          <text class="numpad-player-name">{{t.truncateName(transferToInfo.nickname) || '输入积分'}}</text>
          <view class="numpad-display">
            <text class="numpad-display-value">{{numpadValue || '0'}}</text>
            <text class="numpad-unit">积分</text>
          </view>
        </view>
        <view class="numpad-grid">
          <view class="numpad-key" bindtap="onNumpadKey" data-key="1">1</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="2">2</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="3">3</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="4">4</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="5">5</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="6">6</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="7">7</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="8">8</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="9">9</view>
          <view class="numpad-key numpad-key-func" bindtap="onNumpadKey" data-key="clear">C</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="0">0</view>
          <view class="numpad-key numpad-key-func" bindtap="onNumpadKey" data-key="del">⌫</view>
        </view>
        <view class="numpad-actions">
          <button class="numpad-confirm" bindtap="confirmNumpad">确认计分</button>
        </view>
      </view>
    </view>

    <!-- 积分总览（全局组件） -->
    <matrix-overview
      id="matrix-overview"
      visible="{{showMatrixPanel}}"
      room-id="{{currentRoom.roomId}}"
      member-grid="{{memberGrid}}"
      score-records="{{scoreRecords}}"
      my-user-id="{{myUserId}}"
      bind:close="onMatrixClose"
    />

    <!-- 计分动画层 -->
    <view class="transfer-anim-overlay" wx:if="{{animActive}}">
      <!-- 屏幕闪烁 -->
      <view class="transfer-anim-flash" style="opacity:{{animFlashOpacity}};"></view>
      <!-- 拖尾粒子 -->
      <view class="transfer-anim-trail"
            style="left:{{animTrail1X}}px;top:{{animTrail1Y}}px;opacity:{{animTrail1Opacity}};transform:scale({{animTrail1Scale}});">
        <view class="transfer-anim-dot-trail"></view>
      </view>
      <view class="transfer-anim-trail"
            style="left:{{animTrail2X}}px;top:{{animTrail2Y}}px;opacity:{{animTrail2Opacity}};transform:scale({{animTrail2Scale}});">
        <view class="transfer-anim-dot-trail dot-trail-2"></view>
      </view>
      <!-- 主粒子 -->
      <view class="transfer-anim-particle"
            style="left:{{animCurX}}px;top:{{animCurY}}px;opacity:{{animCurOpacity}};transform:scale({{animCurScale}});">
        <view class="transfer-anim-dot"></view>
        <text class="transfer-anim-amount">{{animAmount}}</text>
      </view>
    </view>

    <!-- 本局录入弹窗 -->
    <host-fill-modal
      wx:if="{{showHostFill && roundRecord}}"
      members="{{currentRoom.members}}"
      zero-sum="{{currentRoom.zeroSumRequired}}"
      bind:submit="submitHostFill"
      bind:close="onHostFillClose"
    />
    <member-fill-modal
      wx:if="{{showMemberFill && roundRecord}}"
      submitted="{{roundRecord.mySubmitted}}"
      my-score="{{roundRecord.myScore}}"
      bind:submit="submitMemberFill"
      bind:close="onMemberFillClose"
    />
    <round-confirm-modal
      wx:if="{{showRoundConfirm && roundRecord}}"
      round="{{roundRecord}}"
      my-user-id="{{myUserId}}"
      bind:confirm="confirmRound"
      bind:close="onRoundConfirmClose"
    />
  </view>

  <!-- 分享面板（全局，可从首页或房间内打开） -->
  <view class="share-overlay {{showShareSheet ? 'share-show' : ''}}" catchtap="closeShareSheet" catchtouchmove="preventClose">
    <view class="share-sheet" catchtap="preventClose">
      <view class="detail-header">
        <text class="section-title" style="margin-bottom:0;">邀请牌友</text>
        <view class="detail-close" bindtap="closeShareSheet">×</view>
      </view>
      <!-- 二维码 -->
      <view class="share-qr-section" wx:if="{{currentRoom.qrCodeUrl}}">
        <view class="share-qr-frame">
          <image class="share-qr-image" src="{{currentRoom.qrCodeUrl}}" mode="aspectFit" show-menu-by-longpress></image>
        </view>
        <text class="text-tertiary text-xs">长按识别二维码加入房间</text>
      </view>
      <view class="share-qr-section" wx:else>
        <view class="share-qr-frame share-qr-placeholder">
          <text class="share-qr-room-no">{{currentRoom.roomNo}}</text>
        </view>
        <text class="text-tertiary text-xs">房间号 {{currentRoom.roomNo}}</text>
      </view>
      <!-- 操作按钮 -->
      <view class="share-actions">
        <button class="share-action-btn" open-type="share">
          <view class="icon-chat share-action-svg"></view>
          <text class="share-action-text">分享给好友</text>
        </button>
        <view class="share-action-btn" bindtap="sharePoster">
          <view class="icon-image share-action-svg"></view>
          <text class="share-action-text">保存图片</text>
        </view>
        <view class="share-action-btn" bindtap="copyRoomLink">
          <view class="icon-link share-action-svg"></view>
          <text class="share-action-text">复制链接</text>
        </view>
        <view class="share-action-btn" bindtap="scanJoin">
          <view class="icon-cam share-action-svg"></view>
          <text class="share-action-text">扫码加入</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 结算总览弹层 -->
  <view class="settle-overlay {{showSettleOverlay ? 'settle-overlay--show' : ''}}" catchtouchmove="preventClose">
    <view class="settle-overlay__inner">
      <!-- 顶部栏 -->
      <view class="settle-header">
        <view class="settle-header-info">
          <text class="settle-header-title">结算详情</text>
          <text class="settle-header-room" wx:if="{{settleRoomNo}}">房间 {{settleRoomNo}}</text>
        </view>
        <view class="settle-close-btn" bindtap="closeSettleOverlay">
          <view class="settle-close-icon">✕</view>
        </view>
      </view>

      <!-- 折线图卡片 -->
      <view class="settle-section settle-chart-card" wx:if="{{settleSeries.length > 0}}">
        <score-chart
          timestamps="{{settleTimestamps}}"
          series="{{settleSeries}}"
          visibleUsers="{{settleVisibleUsers}}"
          highlightUser="{{myUserId}}" />
      </view>

      <!-- 玩家总分卡牌 -->
      <view class="settle-section" wx:if="{{settleRankedMembers.length > 0}}">
        <text class="settle-section-title">总分一览</text>
        <settle-table
          memberScores="{{settleRankedMembers}}"
          myUserId="{{myUserId}}" />
      </view>

      <!-- 排名列表 -->
      <view class="settle-section" wx:if="{{settleRankedMembers.length > 0}}">
        <text class="settle-section-title">排名</text>
        <view class="settle-rank-list">
          <view class="settle-rank-item {{index === 0 ? 'settle-rank-first' : ''}}"
            wx:for="{{settleRankedMembers}}"
            wx:key="userId">
            <view class="settle-rank-badge {{index < 3 ? 'settle-rank-top3' : ''}}">
              <text class="settle-rank-num">{{index + 1}}</text>
            </view>
            <view class="settle-rank-avatar" style="background: {{item.avatarColor}}">
              <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="settle-rank-avatar-img" mode="aspectFill" />
              <text wx:else class="settle-rank-avatar-char">{{item.avatarChar}}</text>
            </view>
            <text class="settle-rank-name" style="color: {{item.userId == myUserId ? '#0A84FF' : 'rgba(255,255,255,0.85)'}}">
              {{item.nickname}}
              <text wx:if="{{item.userId == myUserId}}" class="settle-me-tag">我</text>
            </text>
            <text class="settle-rank-score"
              style="color: {{item.finalScore > 0 ? '#32D74B' : item.finalScore < 0 ? '#FF453A' : 'rgba(255,255,255,0.5)'}}">
              {{item.finalScore > 0 ? '+' : ''}}{{item.finalScore}}
            </text>
          </view>
        </view>
      </view>

      <!-- 底部关闭按钮 -->
      <view class="settle-bottom-btn" bindtap="closeSettleOverlay">
        <text class="settle-bottom-btn-text">完成</text>
      </view>
    </view>
  </view>

  <!-- 身份重叠弹窗 -->
  <view class="name-collision-mask {{showNameCollisionModal ? 'nc-show' : ''}}" catchtap="closeNameCollisionModal">
    <view class="name-collision-card" catchtap="">
      <view class="nc-icon-wrap">
        <view class="nc-icon">!</view>
      </view>
      <text class="nc-title">身份重叠 | IDENTITY OVERLAP</text>
      <text class="nc-desc">检测到场域内存在同名实体，请前往[我的]终端重新校准代号。</text>
      <view class="nc-btn" bindtap="goToProfile">
        <text class="nc-btn-text">[ GO TO PROFILE ]</text>
      </view>
    </view>
  </view>
</view>

<wxs src="./room.wxs" module="fmt" />
<wxs src="../../utils/truncate.wxs" module="t" />
<view class="room-page cockpit-page {{!animationEnabled ? 'reduce-motion' : ''}}">
  <!-- WS 断线遮罩 -->
  <view class="ws-mask {{wsReconnecting ? 'ws-mask--show' : ''}}" catchtap catchtouchmove="preventClose">
    <view class="ws-mask__card glass-card">
      <view class="ws-mask__dot"></view>
      <text class="ws-mask__text">通讯链路波动，正在重试...</text>
    </view>
  </view>
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="empty-auth">
    <view class="empty-auth-icon icon-lock-wrap"><view class="icon-lock"></view></view>
    <text class="text-lg text-bold" style="margin-bottom:12rpx;">终端未接入</text>
    <text class="text-secondary" style="margin-bottom:40rpx;">接入终端后可创建或加入任务编队</text>
    <view class="flight-primary" style="width:320rpx;" bindtap="goLogin">
      <text>接入终端</text>
    </view>
  </view>

  <!-- 驾驶舱 Header -->
  <view wx:if="{{isLoggedIn}}" class="cockpit-header">
    <view class="bay-status-tab bay-status-tab--{{cockpitView.statusDot === 'online' ? 'online' : cockpitView.statusDot === 'connecting' ? 'starting' : 'standby'}}">
      <view class="bay-status-tab__dot"></view>
      <text class="bay-status-tab__label">{{cockpitView.statusLabel}}</text>
    </view>
  </view>

  <!-- idle 状态：驾驶舱舷窗待机 -->
  <view wx:if="{{isLoggedIn && cockpitState === 'idle'}}" class="cockpit-viewport cockpit-viewport--idle sr-hud-panel">
    <view class="starfield"></view>
    <view class="windshield-grid"></view>
    <view class="windshield-frame"></view>
    <view class="windshield-horizon"></view>

    <view class="standby-window-copy">
      <view class="standby-title">任务编队待机</view>
      <view class="standby-desc">创建编队，开始记录本次航程脉冲</view>
    </view>

    <view class="cockpit-id-panel cockpit-id-panel--idle">
      <text class="hud-label">状态</text>
      <text class="hud-code">待机</text>
    </view>

    <view class="cockpit-stats cockpit-stats--idle">
      <view class="hud-stat">
        <text class="hud-stat-label">编队成员</text>
        <text class="hud-stat-value">0/16</text>
      </view>
      <view class="hud-stat">
        <text class="hud-stat-label">航程阶段</text>
        <text class="hud-stat-value">待机</text>
      </view>
      <view class="hud-stat">
        <text class="hud-stat-label">链路状态</text>
        <text class="hud-stat-value">待接入</text>
      </view>
    </view>

    <view class="launch-config cockpit-mode-console">
      <view class="config-chips">
        <view class="config-chip {{scoreMode === 1 ? 'config-chip--on' : ''}}" bindtap="selectScoreMode" data-mode="1">
          <view class="chip-dot {{scoreMode === 1 ? 'chip-dot--on' : ''}}"></view>
          <text>自由流转</text>
        </view>
        <view class="config-chip {{scoreMode === 2 ? 'config-chip--on' : ''}}" bindtap="selectScoreMode" data-mode="2">
          <view class="chip-dot {{scoreMode === 2 ? 'chip-dot--on' : ''}}"></view>
          <text>本局录入</text>
        </view>
      </view>
    </view>

    <view class="launch-actions cockpit-launch-actions">
      <button class="sr-btn sr-btn-primary launch-btn {{launching ? 'sr-btn--loading' : ''}}" bindtap="handleStartSpace">
        <text class="btn-text">创建编队</text>
        <view class="btn-energy"></view>
      </button>
      <button class="sr-btn sr-btn-secondary" bindtap="openJoinPanel">
        <text class="btn-text">加入编队</text>
      </button>
    </view>
  </view>

  <!-- 启动过渡层 -->
  <view wx:if="{{isLaunching}}" class="launch-transition">
    <view class="launch-transition-bg"></view>
    <view class="launch-ring">
      <view class="launch-ring-outer"></view>
      <view class="launch-ring-inner"></view>
    </view>
    <view class="launch-phase-text">
      <text wx:if="{{launchPhase === 'linking'}}">编队链路建立中</text>
      <text wx:elif="{{launchPhase === 'window'}}">舷窗正在开启</text>
      <text wx:elif="{{launchPhase === 'hud'}}">HUD 接入完成</text>
    </view>
    <view class="launch-phase-bar">
      <view class="launch-phase-dot {{launchPhase === 'linking' ? 'launch-phase-dot--active' : ''}}"></view>
      <view class="launch-phase-dot {{launchPhase === 'window' ? 'launch-phase-dot--active' : ''}}"></view>
      <view class="launch-phase-dot {{launchPhase === 'hud' ? 'launch-phase-dot--active' : ''}}"></view>
    </view>
  </view>

  <!-- connecting 状态：链路接入中 -->
  <view wx:if="{{isLoggedIn && cockpitState === 'connecting'}}" class="cockpit-viewport cockpit-viewport--connecting sr-hud-panel">
    <view class="starfield"></view>
    <view class="windshield-grid"></view>
    <view class="windshield-frame"></view>
    <view class="windshield-horizon"></view>

    <view class="standby-window-copy">
      <view class="standby-title">链路接入中</view>
      <view class="standby-desc">正在建立编队链路...</view>
    </view>

    <view class="cockpit-id-panel cockpit-id-panel--idle">
      <text class="hud-label">状态</text>
      <text class="hud-code">接入中</text>
    </view>
  </view>

  <!-- 加入编队弹窗 -->
  <view wx:if="{{joinPanelVisible}}" class="cockpit-mask" bindtap="closeJoinPanel">
    <view class="join-panel sr-hud-panel" catchtap="preventClose">
      <view class="panel-head">
        <view>
          <view class="panel-title">加入编队</view>
        </view>
        <view class="panel-close" bindtap="closeJoinPanel">
          <view class="icon-close"></view>
        </view>
      </view>

      <view class="code-input-wrap">
        <input
          class="code-input"
          value="{{joinCode}}"
          maxlength="6"
          placeholder="输入 6 位编队码"
          placeholder-class="input-placeholder"
          bindinput="onJoinCodeInput"
        />
      </view>

      <button class="sr-btn sr-btn-primary {{joining ? 'sr-btn--loading' : ''}}" bindtap="handleJoinSpace">
        <text class="btn-text">确认加入</text>
      </button>
    </view>
  </view>

  <!-- idle 状态：已有编队快捷入口 -->
  <view wx:if="{{isLoggedIn && cockpitState === 'idle' && currentRoom && !viewingRoom}}" class="reentry-card sr-card">
    <view class="reentry-head">
      <view class="reentry-title">进行中的任务编队</view>
    </view>
    <view class="reentry-info">
      <view class="reentry-code">SR-{{currentRoom.roomNo}}</view>
      <view class="reentry-meta">
        <text>编队成员 {{currentRoom.members ? currentRoom.members.length : 0}}</text>
        <text>{{currentRoom.scoreMode === 1 ? '自由流转' : '本局录入'}}</text>
      </view>
    </view>
    <view class="reentry-actions">
      <button class="sr-btn sr-btn-primary" bindtap="enterRoom">
        <text class="btn-text">进入编队</text>
      </button>
    </view>
  </view>

  <!-- active 状态：驾驶舱主界面 -->
  <view wx:if="{{isLoggedIn && cockpitState === 'active' && currentRoom}}" class="cockpit-active">
    <!-- 顶部提示 -->
    <view class="top-toast {{toastMsg ? 'top-toast-show' : ''}} {{toastType === 'error' ? 'top-toast-error' : ''}}" wx:if="{{toastMsg}}">
      <text>{{toastMsg}}</text>
    </view>

    <scroll-view
      scroll-y
      class="cockpit-scroll"
      style="height:100vh;"
      scroll-into-view="{{cockpitScrollTarget}}"
      scroll-with-animation="{{animationEnabled}}"
    >

      <view class="cockpit-main">
        <view id="formation-window" class="cockpit-starry-shell">
          <view class="cockpit-starry-bg">
            <view class="cockpit-starry-nebula"></view>
            <view class="cockpit-starry-grid"></view>
            <view class="cockpit-starry-vignette"></view>
          </view>

          <view class="overlay-readout overlay-readout--code">
            <text>{{cockpitView.roomNo}}</text>
          </view>
          <view class="overlay-readout overlay-readout--members">
            <text>{{cockpitView.memberCountText}}</text>
          </view>

          <view class="overlay-ships">
            <view
              wx:for="{{cockpitView.externalShips}}"
              wx:key="userId"
              id="seat-{{item.userId}}"
              class="ship-craft {{item.sizeClass}} {{item.online ? 'is-online' : 'is-offline'}} {{item.isNew ? 'is-new' : ''}}"
              style="left: {{item.x}}%; top: {{item.y}}%;"
              bindtap="handleTapShip"
              data-user-id="{{item.userId}}"
              data-active="{{item.online}}"
            >
              <view class="ship-craft-body">
                <view class="ship-craft-nose"></view>
                <view class="ship-craft-wing ship-craft-wing--left"></view>
                <view class="ship-craft-wing ship-craft-wing--right"></view>
                <view class="ship-craft-core">
                  <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" class="ship-craft-avatar" />
                  <text wx:else class="ship-craft-char">{{item.avatarChar}}</text>
                </view>
                <view class="ship-craft-ring"></view>
                <view class="ship-craft-dot"></view>
              </view>

              <view class="ship-craft-label">
                <text class="ship-craft-name">{{item.callsign}}</text>
                <text class="ship-craft-pulse {{item.pulseClass}}">{{item.pulseDisplay}}</text>
              </view>
            </view>

            <view class="external-ship-empty" wx:if="{{cockpitView.externalShips.length === 0}}">
              <text>外部航船</text>
              <text>编队记录中</text>
            </view>
          </view>

          <view class="overlay-gauge {{cockpitView.selfPulseClass}}">
            <text class="overlay-gauge-title">本舰脉冲</text>
            <text class="overlay-gauge-value">{{cockpitView.selfPulseDisplay}}</text>
            <view class="overlay-gauge-status">
              <view class="overlay-gauge-dot"></view>
              <text>{{cockpitView.linkText}}</text>
            </view>
          </view>

          <view class="overlay-terminal">
            <view class="terminal-meta">
              <view class="terminal-code">
                <text class="terminal-meta-label">编队码</text>
                <text class="terminal-meta-code">{{cockpitView.roomNo}}</text>
                <button class="terminal-copy" bindtap="copyRoomNo" hover-class="none">复制</button>
              </view>
              <view class="terminal-chips">
                <text>{{cockpitView.memberCountText}}</text>
                <text>{{cockpitView.modeText}}</text>
                <text>{{cockpitView.stageText}}</text>
              </view>
            </view>

            <view class="terminal-pulse-head">
              <text class="terminal-section-title">实时脉冲</text>
              <view class="terminal-badges">
                <text>流转 {{cockpitView.transferCount}}</text>
                <text>总额 {{cockpitView.totalPulse}}</text>
              </view>
            </view>

            <view class="terminal-last-event">
              <text>{{cockpitView.lastPulseText}}</text>
              <text>{{cockpitView.lastPulseAmount}}</text>
            </view>

            <view class="terminal-trajectory">
              <text class="trajectory-label">脉冲轨迹</text>
              <view class="trajectory-mini {{cockpitView.hasTrajectory ? '' : 'is-empty'}}">
                <view class="trajectory-base"></view>
                <view
                  wx:for="{{cockpitView.sparklinePoints}}"
                  wx:key="index"
                  class="trajectory-dot"
                  style="left: {{item.x}}%; bottom: {{item.y}}%;"
                ></view>
                <text wx:if="{{!cockpitView.hasTrajectory}}" class="trajectory-empty-text">等待更多脉冲写入</text>
              </view>
              <button class="trajectory-link" bindtap="goPulseTrajectory" hover-class="none">查看轨迹</button>
            </view>
          </view>

          <view class="overlay-control">
            <view class="control-title-row">
              <text>航程控制</text>
              <text>{{cockpitView.stageText}}</text>
            </view>
            <view class="control-actions">
              <button bindtap="openPulseRecorder" hover-class="none">记录脉冲</button>
              <button bindtap="openBeacon" hover-class="none">展开信标</button>
              <button class="control-danger" bindtap="handleSettle" hover-class="none">封存航程</button>
            </view>
          </view>
        </view>
      </view>

      <!-- 本局录入状态条 -->
      <round-status-bar
        wx:if="{{currentRoom.scoreMode === 2 && roundRecord}}"
        round="{{roundRecord}}"
        is-owner="{{isOwner}}"
        bind:tap="onRoundStatusTap"
        bind:cancel="onRoundCancel"
      />

    </scroll-view>

    <!-- 脉冲飞行动画层 -->
    <view wx:if="{{pulseFlight.visible}}" class="pulse-flight-layer">
      <view
        class="pulse-flight-dot"
        style="left: {{pulseFlight.fromX}}px; top: {{pulseFlight.fromY}}px; --dx: {{pulseFlight.dx}}px; --dy: {{pulseFlight.dy}}px;"
      >
        <view class="pulse-tail"></view>
        <text class="pulse-flight-value">{{pulseFlight.value}}</text>
      </view>
    </view>

    <!-- 封存/解散确认弹窗 -->
    <view wx:if="{{sealConfirmVisible}}" class="cockpit-mask" bindtap="closeSealConfirm">
      <view class="seal-panel sr-hud-panel" catchtap="preventClose">
        <view class="seal-core">
          <view class="seal-ring"></view>
          <view class="seal-title">{{canSealRoom ? '确认封存航程' : '解散编队'}}</view>
          <view class="seal-desc">
            {{canSealRoom ? '当前脉冲轨迹将写入航迹档案，封存后不可继续记录。' : '当前编队暂无轨迹记录，解散后不会生成航程档案。'}}
          </view>
        </view>

        <view class="seal-meta">
          <view class="meta-item">
            <text class="meta-label">成员</text>
            <text class="meta-value">{{memberGrid.length}}</text>
          </view>
          <view class="meta-item">
            <text class="meta-label">轨迹</text>
            <text class="meta-value">{{pulseTraces.length}}</text>
          </view>
        </view>

        <view class="seal-actions">
          <button class="sr-btn sr-btn-secondary" bindtap="closeSealConfirm">
            <text class="btn-text">{{canSealRoom ? '继续航程' : '返回'}}</text>
          </button>
          <button class="sr-btn sr-btn-danger-outline" bindtap="handleSealRoom">
            <text class="btn-text">{{canSealRoom ? '确认封存' : '确认解散'}}</text>
          </button>
        </view>
      </view>
    </view>

    <!-- 记录脉冲面板 -->
    <view class="transfer-overlay {{showNumpad ? 'transfer-show' : ''}}" catchtap="closeNumpad">
      <view class="transfer-sheet" catchtap="preventClose">
        <!-- 顶部：标题 + 目标 + 数值 -->
        <view class="transfer-header transfer-header--compact">
          <view class="transfer-title-row">
            <text class="transfer-title">记录脉冲</text>
            <view class="transfer-sender-info" wx:if="{{transferToInfo}}">
              <helmet-avatar
                src="{{transferToInfo.avatarUrl || ''}}"
                size="xs"
                active="{{false}}"
                showStatus="{{false}}"
                reduceMotion="{{!animationEnabled}}"
              />
              <text class="transfer-sender-name">{{t.truncateName(transferToInfo.nickname)}}</text>
            </view>
          </view>
          <view class="transfer-display-compact">{{numpadValue || '0'}}</view>
        </view>

        <!-- 常用脉冲 -->
        <view class="transfer-suggestions" wx:if="{{transferAmountSuggestions.length}}">
          <view class="suggestion-grid">
            <view
              wx:for="{{transferAmountSuggestions}}"
              wx:key="amount"
              class="suggestion-chip {{numpadValue === item.amount ? 'is-active' : ''}}"
              bindtap="tapTransferSuggestion"
              data-amount="{{item.amount}}"
            >
              <text class="suggestion-amount">{{item.amount}}</text>
              <text class="suggestion-label">{{item.label}}</text>
            </view>
          </view>
        </view>

        <!-- 数字键盘 + 确认 -->
        <view class="transfer-bottom-row">
          <view class="transfer-numpad transfer-numpad--compact">
            <view class="transfer-key" bindtap="onNumpadKey" data-key="1">1</view>
            <view class="transfer-key" bindtap="onNumpadKey" data-key="2">2</view>
            <view class="transfer-key" bindtap="onNumpadKey" data-key="3">3</view>
            <view class="transfer-key" bindtap="onNumpadKey" data-key="4">4</view>
            <view class="transfer-key" bindtap="onNumpadKey" data-key="5">5</view>
            <view class="transfer-key" bindtap="onNumpadKey" data-key="6">6</view>
            <view class="transfer-key" bindtap="onNumpadKey" data-key="7">7</view>
            <view class="transfer-key" bindtap="onNumpadKey" data-key="8">8</view>
            <view class="transfer-key" bindtap="onNumpadKey" data-key="9">9</view>
            <view class="transfer-key transfer-key-func" bindtap="onNumpadKey" data-key="clear">
              <text class="numpad-func-icon">清空</text>
            </view>
            <view class="transfer-key" bindtap="onNumpadKey" data-key="0">0</view>
            <view class="transfer-key transfer-key-func" bindtap="onNumpadKey" data-key="del">
              <text class="numpad-func-icon numpad-func-icon--del"></text>
            </view>
          </view>
          <view class="transfer-confirm-wrap">
            <view class="transfer-confirm {{numpadValue > 0 ? '' : 'transfer-confirm-disabled'}}" bindtap="confirmNumpad">
              <text class="transfer-confirm-text">确认记录</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 数值总览（全局组件） -->
    <matrix-overview
      id="matrix-overview"
      visible="{{showMatrixPanel}}"
      room-id="{{currentRoom.roomId}}"
      member-grid="{{memberGrid}}"
      score-records="{{scoreRecords}}"
      my-user-id="{{myUserId}}"
      bind:close="onMatrixClose"
    />

    <!-- 记录动画层 -->
    <view class="transfer-anim-overlay" wx:if="{{animActive}}">
      <!-- 屏幕闪烁 -->
      <view class="transfer-anim-flash" style="opacity:{{animFlashOpacity}};"></view>
      <!-- 拖尾粒子 -->
      <view class="transfer-anim-trail"
            style="left:{{animTrail1X}}px;top:{{animTrail1Y}}px;opacity:{{animTrail1Opacity}};transform:scale({{animTrail1Scale}});">
        <view class="transfer-anim-dot-trail"></view>
      </view>
      <view class="transfer-anim-trail"
            style="left:{{animTrail2X}}px;top:{{animTrail2Y}}px;opacity:{{animTrail2Opacity}};transform:scale({{animTrail2Scale}});">
        <view class="transfer-anim-dot-trail dot-trail-2"></view>
      </view>
      <!-- 主粒子 -->
      <view class="transfer-anim-particle"
            style="left:{{animCurX}}px;top:{{animCurY}}px;opacity:{{animCurOpacity}};transform:scale({{animCurScale}});">
        <view class="transfer-anim-dot"></view>
        <text class="transfer-anim-amount">{{animAmount}}</text>
      </view>
    </view>

    <!-- 本局录入弹窗 -->
    <host-fill-modal
      wx:if="{{showHostFill && roundRecord}}"
      members="{{currentRoom.members}}"
      zero-sum="{{currentRoom.zeroSumRequired}}"
      bind:submit="submitHostFill"
      bind:close="onHostFillClose"
    />
    <member-fill-modal
      wx:if="{{showMemberFill && roundRecord}}"
      submitted="{{roundRecord.mySubmitted}}"
      my-score="{{roundRecord.myScore}}"
      bind:submit="submitMemberFill"
      bind:close="onMemberFillClose"
    />
    <round-confirm-modal
      wx:if="{{showRoundConfirm && roundRecord}}"
      round="{{roundRecord}}"
      my-user-id="{{myUserId}}"
      bind:confirm="confirmRound"
      bind:reject="onRoundReject"
      bind:close="onRoundConfirmClose"
    />
  </view>

  <!-- sealing 状态：航迹档案写入中 -->
  <view wx:if="{{cockpitState === 'sealing'}}" class="sealing-overlay">
    <view class="blackbox-write sr-hud-panel">
      <view class="write-beam"></view>
      <view class="write-title">航迹档案写入中</view>
      <view class="write-desc">{{sealHeartbeatText}}</view>
    </view>
  </view>

  <!-- 编队加入面板 -->
  <view class="share-overlay {{showShareSheet ? 'share-show' : ''}}" catchtap="closeShareSheet" catchtouchmove="preventClose">
    <view class="share-sheet" catchtap="preventClose">
      <view class="share-header">
        <view class="share-title-area">
          <text class="share-title">编队加入</text>
        </view>
        <view class="fi fi--close" bindtap="closeShareSheet"></view>
      </view>

      <!-- 二维码区域：加载中 -->
      <view class="share-qr-section" wx:if="{{qrLoading}}">
        <view class="share-qr-frame share-qr-loading">
          <view class="share-qr-spinner"></view>
          <text class="share-qr-loading-text">生成信标中...</text>
        </view>
      </view>

      <!-- 二维码区域：生成失败 -->
      <view class="share-qr-section" wx:elif="{{qrFailed}}">
        <view class="share-qr-frame share-qr-fail">
          <text class="share-qr-fail-text">信标生成失败</text>
          <text class="share-qr-fail-hint">可使用编队码加入</text>
          <view class="share-qr-retry" bindtap="retryLoadQrCode">
            <text class="share-qr-retry-text">重新生成</text>
          </view>
        </view>
      </view>

      <!-- 二维码区域：有二维码 -->
      <view class="share-qr-section" wx:elif="{{currentRoom.qrCodeUrl}}">
        <view class="share-qr-frame">
          <image class="share-qr-image" src="{{currentRoom.qrCodeUrl}}" mode="aspectFit" show-menu-by-longpress></image>
        </view>
        <text class="share-qr-hint">长按识别信标加入编队</text>
      </view>

      <!-- 二维码区域：无二维码，显示编队码 -->
      <view class="share-qr-section" wx:else>
        <view class="share-qr-frame share-qr-placeholder">
          <text class="share-qr-room-no">{{currentRoom.roomNo}}</text>
        </view>
        <text class="share-qr-hint">编队码 {{currentRoom.roomNo}}</text>
      </view>

      <!-- 操作按钮 -->
      <view class="share-actions">
        <button class="share-action-btn" open-type="share">
          <view class="icon-chat share-action-svg"></view>
          <text class="share-action-text">发送信标</text>
        </button>
        <view class="share-action-btn" bindtap="sharePoster">
          <view class="icon-image share-action-svg"></view>
          <text class="share-action-text">保存信标</text>
        </view>
        <view class="share-action-btn" bindtap="copyRoomLink">
          <view class="icon-link share-action-svg"></view>
          <text class="share-action-text">复制编队码</text>
        </view>
        <view class="share-action-btn" bindtap="scanJoin">
          <view class="icon-cam share-action-svg"></view>
          <text class="share-action-text">扫描信标</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 驳回确认弹窗 -->
  <terminal-popup
    visible="{{showRejectConfirm}}"
    title="操作确认"
    content="确认驳回本轮录入？驳回后本轮数据将被清除。"
    cancel-text="返回"
    confirm-text="确认驳回"
    confirm-type="danger"
    reduce-motion="{{!animationEnabled}}"
    bind:cancel="closeRejectConfirm"
    bind:confirm="confirmRoundReject"
  />

  <!-- 战局报告弹层 -->
  <view class="settle-overlay {{showSettleOverlay ? 'settle-overlay--show' : ''}}" catchtouchmove="preventClose">
    <scroll-view class="settle-overlay__inner" scroll-y enhanced show-scrollbar="{{false}}">

      <!-- 顶部关闭按钮 -->
      <view class="settle-top-bar">
        <view class="settle-close-cyber" bindtap="closeSettleOverlay">
          <view class="settle-close-ring">
            <view class="fi fi--close"></view>
          </view>
        </view>
      </view>

      <!-- 1. 战局总结 -->
      <battle-summary
        winner="{{settleWinner}}"
        loser="{{settleLoser}}"
        maxSingle="{{settleMaxSingle}}"
        totalTransfer="{{settleTotalTransfer}}"
        transferCount="{{settleTransferCount}}"
        memberCount="{{settleMemberCount}}"
        roomNo="{{settleRoomNo}}"
        settleTime="{{settleTime}}" />

      <!-- 2. 数值趋势图 -->
      <view class="settle-card" wx:if="{{settleSeries.length > 0}}">
        <view class="settle-card-header">
          <view class="settle-card-title">数值演化轨迹</view>

          <view class="settle-card-line"></view>
        </view>
        <view class="settle-chart-wrap">
          <score-chart
            timestamps="{{settleTimestamps}}"
            series="{{settleSeries}}"
            visibleUsers="{{settleVisibleUsers}}"
            eventMarkers="{{settleEventMarkers}}"
            highlightUser="{{myUserId}}" />
        </view>
      </view>

      <!-- 3. 数值关系网络 -->
      <score-network
        wx:if="{{settleNetworkNodes.length > 0}}"
        nodes="{{settleNetworkNodes}}"
        links="{{settleNetworkLinks}}"
        my-user-id="{{myUserId}}" />

      <!-- 4. 编队洞察 -->
      <battle-insight
        wx:if="{{settleInsight}}"
        mostActiveUser="{{settleInsight.mostActiveUser}}"
        mostFocusedUser="{{settleLoser}}"
        networkDensity="{{settleInsight.networkDensity}}"
        transferCount="{{settleInsight.transferCount}}"
        memberCount="{{settleMemberCount}}" />

      <!-- 5. 实时序列 -->
      <view class="settle-card" wx:if="{{settleRankedMembers.length > 0}}">
        <view class="settle-card-header">
          <view class="settle-card-title">实时序列</view>
          <view class="settle-card-line"></view>
        </view>
        <view class="settle-rank-list">
          <view class="settle-rank-item {{index === 0 ? 'settle-rank-champion' : ''}}"
            wx:for="{{settleRankedMembers}}" wx:key="userId">
            <view class="settle-rank-badge {{index < 3 ? 'settle-rank-top3' : ''}} {{index === 0 ? 'settle-badge-champion' : ''}}">
              <text class="settle-rank-num">{{index + 1}}</text>
            </view>
            <view class="settle-rank-avatar" style="background: {{item.avatarColor}}">
              <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="settle-rank-avatar-img" mode="aspectFill" />
              <text wx:else class="settle-rank-avatar-char">{{item.avatarChar}}</text>
            </view>
            <text class="settle-rank-name" style="color: {{item.userId == myUserId ? '#00AFFF' : 'rgba(255,255,255,0.85)'}}">
              {{item.nickname}}
              <text wx:if="{{item.userId == myUserId}}" class="settle-me-tag">我</text>
            </text>
            <text class="settle-rank-score"
              style="color: {{item.finalScore > 0 ? '#32D74B' : item.finalScore < 0 ? '#FF453A' : 'rgba(255,255,255,0.35)'}}">
              {{item.finalScore > 0 ? '+' : ''}}{{item.finalScore}}
            </text>
          </view>
        </view>
      </view>

      <!-- 6. 人格信号 -->
      <persona-signal
        wx:if="{{settlePersonaSignals}}"
        socialActivity="{{settlePersonaSignals.socialActivity}}"
        riskPreference="{{settlePersonaSignals.riskPreference}}"
        resourceControl="{{settlePersonaSignals.resourceControl}}"
        allianceTendency="{{settlePersonaSignals.allianceTendency}}" />

      <view style="height: 60rpx;"></view>
    </scroll-view>
  </view>

  <!-- 身份重叠弹窗 -->
  <view class="name-collision-mask {{showNameCollisionModal ? 'nc-show' : ''}}" catchtap="closeNameCollisionModal">
    <view class="name-collision-card" catchtap="">
      <view class="nc-icon-wrap">
        <view class="nc-icon">!</view>
      </view>
      <text class="nc-title">身份重叠</text>
      <text class="nc-desc">检测到场域内存在同名实体，请前往[身份]终端重新校准呼号。</text>
      <view class="nc-btn" bindtap="goToProfile">
        <text class="nc-btn-text">前往身份</text>
      </view>
    </view>
  </view>
</view>

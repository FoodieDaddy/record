<wxs src="./room.wxs" module="fmt" />
<wxs src="../../utils/truncate.wxs" module="t" />
<view class="room-page {{!animationEnabled ? 'reduce-motion' : ''}}">
  <!-- WS 断线遮罩 -->
  <view class="ws-mask {{wsReconnecting ? 'ws-mask--show' : ''}}" catchtap catchtouchmove="preventClose">
    <view class="ws-mask__card glass-card">
      <view class="ws-mask__dot"></view>
      <text class="ws-mask__text">网络不太稳定，正在重试...</text>
    </view>
  </view>
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="empty-auth">
    <view class="empty-auth-icon icon-lock-wrap"><view class="icon-lock"></view></view>
    <text class="text-lg text-bold" style="margin-bottom:12rpx;">尚未登录</text>
    <text class="text-secondary" style="margin-bottom:40rpx;">登录后即可启动或接入空间</text>
    <view class="flight-primary" style="width:320rpx;" bindtap="goLogin">
      <text>去登录</text>
    </view>
  </view>

  <!-- 已登录：无房间 -->
  <view wx:elif="{{!currentRoom}}" class="empty-room">
    <!-- 创建房间 -->
    <view class="cyber-card create-card">
      <!-- 系统状态 -->
      <view class="cyber-system-bar">
        <text class="cyber-system-name">脉冲终端</text>
        <view class="cyber-system-status">
          <view class="cyber-status-dot"></view>
          <text class="cyber-status-text">在线</text>
        </view>
      </view>
      <view class="cyber-divider"></view>

      <!-- 房间模式 -->
      <view class="cyber-section-title">
        <text class="cyber-cn">空间模式</text>
        <text class="cyber-en">SPACE MODE</text>
      </view>
      <view class="cyber-mode-cards">
        <view class="sr-t-base cyber-mode-card {{scoreMode === 1 ? 'cyber-mode-active' : ''}}" bindtap="selectScoreMode" data-mode="1">
          <view class="cyber-mode-head">
            <text class="sr-t-base cyber-mode-dot {{scoreMode === 1 ? 'mode-dot-on' : ''}}"></text>
            <text class="cyber-mode-name">自由流转</text>
            <text class="sr-t-base cyber-mode-badge {{scoreMode === 1 ? 'badge-on' : ''}}">开放</text>
          </view>
          <text class="cyber-mode-desc">实时记录数值变化</text>
        </view>
        <view class="sr-t-base cyber-mode-card {{scoreMode === 2 ? 'cyber-mode-active' : ''}}" bindtap="selectScoreMode" data-mode="2">
          <view class="cyber-mode-head">
            <text class="sr-t-base cyber-mode-dot {{scoreMode === 2 ? 'mode-dot-on' : ''}}"></text>
            <text class="cyber-mode-name">本局录入</text>
            <text class="sr-t-base cyber-mode-badge {{scoreMode === 2 ? 'badge-on' : ''}}">推荐</text>
          </view>
          <text class="cyber-mode-desc">每轮结束统一录入数值</text>
        </view>
      </view>

      <!-- 本局录入配置 -->
      <block wx:if="{{scoreMode === 2}}">
        <view class="cyber-divider"></view>

        <!-- 录入方式 -->
        <view class="cyber-section-title">
          <text class="cyber-cn">录入方式</text>
          <text class="cyber-en">RECORD MODE</text>
        </view>
        <view class="cyber-cards">
          <view class="sr-t-base cyber-opt-card {{roundInputMethod === 1 ? 'cyber-opt-active' : ''}}" bindtap="selectRoundInputMethod" data-value="1">
            <view class="cyber-opt-status" wx:if="{{roundInputMethod === 1}}">
              <view class="cyber-opt-check"></view>
              <text class="cyber-opt-status-text">已启用</text>
            </view>
            <text class="cyber-opt-title">主控填写</text>
            <text class="cyber-opt-desc">由主控统一录入</text>
            <text class="cyber-opt-hint">适合统一复盘</text>
          </view>
          <view class="sr-t-base cyber-opt-card {{roundInputMethod === 2 ? 'cyber-opt-active' : ''}}" bindtap="selectRoundInputMethod" data-value="2">
            <view class="cyber-opt-status" wx:if="{{roundInputMethod === 2}}">
              <view class="cyber-opt-check"></view>
              <text class="cyber-opt-status-text">已启用</text>
            </view>
            <text class="cyber-opt-title">成员自填</text>
            <text class="cyber-opt-desc">每人提交自己结果</text>
            <text class="cyber-opt-hint">待选择</text>
          </view>
        </view>
        <view class="cyber-divider"></view>

        <!-- 确认协议 -->
        <view class="cyber-section-title">
          <text class="cyber-cn">确认协议</text>
          <text class="cyber-en">CONFIRM PROTOCOL</text>
        </view>
        <view class="cyber-chips">
          <view class="sr-t-base cyber-chip {{trustMode === 0 ? 'cyber-chip-active' : ''}}" bindtap="selectTrustMode" data-value="0">
            <text class="sr-t-base cyber-chip-dot {{trustMode === 0 ? 'dot-on' : ''}}"></text>
            <view class="cyber-chip-text">
              <text class="cyber-chip-main">标准协议</text>
              <text class="cyber-chip-sub">需要全员确认</text>
            </view>
          </view>
          <view class="sr-t-base cyber-chip {{trustMode === 1 ? 'cyber-chip-active' : ''}}" bindtap="selectTrustMode" data-value="1">
            <text class="sr-t-base cyber-chip-dot {{trustMode === 1 ? 'dot-on' : ''}}"></text>
            <view class="cyber-chip-text">
              <text class="cyber-chip-main">快速协议</text>
              <text class="cyber-chip-sub">直接生效</text>
            </view>
          </view>
        </view>
        <view class="cyber-divider"></view>

        <!-- 积分模型 -->
        <view class="cyber-section-title">
          <text class="cyber-cn">数值模型</text>
          <text class="cyber-en">VALUE MODEL</text>
        </view>
        <view class="cyber-chips">
          <view class="sr-t-base cyber-chip {{zeroSumRequired === 1 ? 'cyber-chip-active' : ''}}" bindtap="selectZeroSum" data-value="1">
            <text class="sr-t-base cyber-chip-dot {{zeroSumRequired === 1 ? 'dot-on' : ''}}"></text>
            <view class="cyber-chip-text">
              <text class="cyber-chip-main">零和封存</text>
              <text class="cyber-chip-sub">数值守恒</text>
            </view>
          </view>
          <view class="sr-t-base cyber-chip {{zeroSumRequired === 0 ? 'cyber-chip-active' : ''}}" bindtap="selectZeroSum" data-value="0">
            <text class="sr-t-base cyber-chip-dot {{zeroSumRequired === 0 ? 'dot-on' : ''}}"></text>
            <view class="cyber-chip-text">
              <text class="cyber-chip-main">自由封存</text>
              <text class="cyber-chip-sub">允许数值增减</text>
            </view>
          </view>
        </view>

        <!-- 确认时限（仅标准协议时显示） -->
        <block wx:if="{{trustMode === 0}}">
          <view class="cyber-divider"></view>
          <view class="cyber-section-title">
            <text class="cyber-cn">确认时限</text>
            <text class="cyber-en">TIMEOUT</text>
          </view>
          <view class="cyber-chips cyber-timeout-chips">
            <view class="sr-t-base cyber-chip {{autoTimeoutSeconds === 15 ? 'cyber-chip-active' : ''}}" bindtap="selectTimeout" data-value="15">
              <text class="sr-t-base cyber-chip-dot {{autoTimeoutSeconds === 15 ? 'dot-on' : ''}}"></text>
              <text class="cyber-chip-main">15秒</text>
            </view>
            <view class="sr-t-base cyber-chip {{autoTimeoutSeconds === 30 ? 'cyber-chip-active' : ''}}" bindtap="selectTimeout" data-value="30">
              <text class="sr-t-base cyber-chip-dot {{autoTimeoutSeconds === 30 ? 'dot-on' : ''}}"></text>
              <text class="cyber-chip-main">30秒</text>
            </view>
            <view class="sr-t-base cyber-chip {{autoTimeoutSeconds === 60 ? 'cyber-chip-active' : ''}}" bindtap="selectTimeout" data-value="60">
              <text class="sr-t-base cyber-chip-dot {{autoTimeoutSeconds === 60 ? 'dot-on' : ''}}"></text>
              <text class="cyber-chip-main">60秒</text>
            </view>
          </view>
          <view class="cyber-timeout-action">
            <text class="cyber-timeout-label">超时行为</text>
            <view class="cyber-chips" style="flex:1">
              <view class="sr-t-base cyber-chip {{autoTimeoutAction === 1 ? 'cyber-chip-active' : ''}}" bindtap="selectAutoTimeoutAction" data-value="1">
                <text class="sr-t-base cyber-chip-dot {{autoTimeoutAction === 1 ? 'dot-on' : ''}}"></text>
                <text class="cyber-chip-main">自动同意</text>
              </view>
              <view class="sr-t-base cyber-chip {{autoTimeoutAction === 2 ? 'cyber-chip-active' : ''}}" bindtap="selectAutoTimeoutAction" data-value="2">
                <text class="sr-t-base cyber-chip-dot {{autoTimeoutAction === 2 ? 'dot-on' : ''}}"></text>
                <text class="cyber-chip-main">自动取消</text>
              </view>
            </view>
          </view>
        </block>
      </block>

      <!-- 配置预览 -->
      <view class="cyber-divider"></view>
      <view class="cyber-preview">
        <text class="cyber-preview-title">当前配置</text>
        <view class="cyber-preview-row">
          <text class="cyber-preview-key">空间模式</text>
          <text class="cyber-preview-val">{{scoreMode === 1 ? '自由流转' : '本局录入'}}</text>
        </view>
        <block wx:if="{{scoreMode === 2}}">
          <view class="cyber-preview-row">
            <text class="cyber-preview-key">录入方式</text>
            <text class="cyber-preview-val">{{roundInputMethod === 1 ? '主控填写' : '成员自填'}}</text>
          </view>
          <view class="cyber-preview-row">
            <text class="cyber-preview-key">确认协议</text>
            <text class="cyber-preview-val">{{trustMode === 0 ? '标准协议' : '快速协议'}}</text>
          </view>
          <view class="cyber-preview-row">
            <text class="cyber-preview-key">数值模型</text>
            <text class="cyber-preview-val">{{zeroSumRequired === 1 ? '零和封存' : '自由封存'}}</text>
          </view>
          <view class="cyber-preview-row" wx:if="{{trustMode === 0}}">
            <text class="cyber-preview-key">确认时限</text>
            <text class="cyber-preview-val">{{autoTimeoutSeconds}}秒</text>
          </view>
        </block>
      </view>

      <!-- 启动空间 -->
      <view class="cyber-divider"></view>
      <view class="cyber-create-btn" bindtap="createRoom">
        <view class="sr-t-base cyber-create-inner {{creating ? 'btn-loading' : ''}}">
          <text class="cyber-create-text">启动空间</text>
          <text class="cyber-create-sub">INIT</text>
        </view>
      </view>
    </view>

    <view class="divider-glow"><text class="divider-text">或者</text></view>

    <!-- 接入空间 -->
    <view class="cyber-card join-card">
      <!-- 双层标题 -->
      <view class="cyber-section-title">
        <text class="cyber-cn">接入空间</text>
        <text class="cyber-en">SPACE ACCESS</text>
      </view>
      <view class="cyber-divider"></view>

      <!-- 扫描接入（主入口） -->
      <view class="sr-t-base cyber-scan-card" bindtap="scanJoin">
        <view class="cyber-scan-icon">
          <view class="cyber-scan-corner cyber-scan-tl"></view>
          <view class="cyber-scan-corner cyber-scan-tr"></view>
          <view class="cyber-scan-corner cyber-scan-bl"></view>
          <view class="cyber-scan-corner cyber-scan-br"></view>
          <view class="cyber-scan-line"></view>
        </view>
        <view class="cyber-scan-text">
          <text class="cyber-scan-title">扫描接入</text>
          <text class="cyber-scan-sub">SPACE SCAN</text>
        </view>
        <text class="cyber-scan-hint">推荐方式 · 扫描主控二维码快速接入</text>
      </view>
      <view class="cyber-divider"></view>

      <!-- 空间识别码输入 -->
      <view class="cyber-section-title">
        <text class="cyber-cn">空间识别码</text>
        <text class="cyber-en">SPACE CODE</text>
      </view>
      <view class="sr-t-base cyber-terminal-input" bindtap="onTerminalTap">
        <text class="cyber-terminal-prefix">SR-</text>
        <input class="cyber-terminal-field" type="text" maxlength="6"
               value="{{roomCodeRaw}}" placeholder="XXXXXX"
               bindinput="onRoomCodeInput" bindblur="onRoomCodeBlur"
               focus="{{terminalFocused}}" adjust-position="{{false}}" />
        <view class="cyber-terminal-cursor" wx:if="{{terminalFocused && roomCodeRaw.length < 6}}"></view>
      </view>

      <!-- 房间状态反馈 -->
      <view class="cyber-room-status" wx:if="{{roomCodeRaw.length >= 6}}">
        <view class="cyber-status-row">
          <view class="cyber-status-dot {{roomLookupValid ? 'dot-green' : 'dot-red'}}"></view>
          <text class="cyber-status-msg {{roomLookupValid ? 'msg-green' : 'msg-red'}}">
            {{roomLookupValid ? '空间存在' : (roomLookupMsg || '未发现空间')}}
          </text>
        </view>
        <view class="cyber-room-preview" wx:if="{{roomLookupValid && roomPreview}}">
          <view class="cyber-preview-row">
            <text class="cyber-preview-key">空间模式</text>
            <text class="cyber-preview-val">{{roomPreview.scoreMode === 1 ? '自由流转' : '本局录入'}}</text>
          </view>
          <view class="cyber-preview-row">
            <text class="cyber-preview-key">在线成员</text>
            <text class="cyber-preview-val">{{roomPreview.memberCount || '?'}} / 16</text>
          </view>
        </view>
      </view>

      <!-- 接入按钮 -->
      <view class="cyber-divider"></view>
      <view class="cyber-create-btn" bindtap="joinByNo">
        <view class="sr-t-base cyber-create-inner {{joining ? 'btn-loading' : ''}} {{roomCodeRaw.length >= 6 ? '' : 'btn-dim'}}">
          <text class="cyber-create-text">接入空间</text>
          <text class="cyber-create-sub">CONNECT</text>
        </view>
      </view>

      <!-- 最近加入 -->
      <block wx:if="{{recentRooms.length > 0}}">
        <view class="cyber-divider"></view>
        <view class="cyber-section-title">
          <text class="cyber-cn">最近加入</text>
          <text class="cyber-en">RECENT ACCESS</text>
        </view>
        <view class="cyber-recent-list">
          <view class="sr-t-fast cyber-recent-item" wx:for="{{recentRooms}}" wx:key="roomNo"
                bindtap="onRecentTap" data-room-no="{{item.roomNo}}">
            <text class="cyber-recent-code">SR-{{item.roomNo}}</text>
            <text class="cyber-recent-time">{{item.timeLabel}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 已登录：已有房间（首页快捷入口） -->
  <view wx:elif="{{!viewingRoom}}" class="has-room">
    <view class="glass-card-glow room-quick-card">
      <view class="rq-header">
        <view class="rq-info">
          <text class="section-title">我的空间</text>
          <text class="rq-room-no">{{currentRoom.roomNo}}</text>
        </view>
        <view class="rq-badge {{currentRoom.status === 1 ? 'badge-success' : 'badge-accent'}}">
          {{currentRoom.status === 1 ? '已结束' : '进行中'}}
        </view>
      </view>
      <view class="rq-meta">
        <text class="text-tertiary text-xs">{{currentRoom.members ? currentRoom.members.length : 0}}人</text>
      </view>
      <view class="rq-actions">
        <view class="sr-t-fast rq-action-btn" bindtap="copyRoomNo">
          <view class="icon-clip"></view>
          <text class="rq-action-text">复制接入码</text>
        </view>
        <view class="sr-t-fast rq-action-btn" bindtap="openShareSheet">
          <view class="icon-link"></view>
          <text class="rq-action-text">二维码</text>
        </view>
        <button class="sr-t-fast rq-action-btn" open-type="share">
          <view class="icon-share"></view>
          <text class="rq-action-text">分享</text>
        </button>
      </view>
      <view class="flight-primary" style="margin-top:20rpx;" bindtap="enterRoom">
        <text>进入空间</text>
      </view>
    </view>
  </view>

  <!-- 已登录：在房间中 -->
  <view wx:else class="room-content">
    <!-- 顶部提示 -->
    <view class="top-toast {{toastMsg ? 'top-toast-show' : ''}} {{toastType === 'error' ? 'top-toast-error' : ''}}" wx:if="{{toastMsg}}">
      <text>{{toastMsg}}</text>
    </view>

    <!-- 可滚动区域（积分总览打开时禁止滚动） -->
    <scroll-view scroll-y="{{!showMatrixPanel && !showNumpad}}" class="{{showMatrixPanel || showNumpad ? 'scroll-locked' : ''}}" style="height:100vh;" bindscrolltolower="onScoreScrollToLower" lower-threshold="200">
      <!-- ROOM TERMINAL 顶部终端栏 -->
      <view class="room-terminal">
        <view class="rt-top-row">
          <text class="rt-kicker">空间终端 · SPACE</text>
          <view class="rt-status">
            <view class="rt-status-dot"></view>
            <text class="rt-status-text">在线</text>
          </view>
        </view>
        <view class="rt-main-row">
          <view class="rt-info-grid">
            <view class="rt-info-seg">
              <text class="rt-info-label">空间</text>
              <text class="rt-info-value">{{currentRoom.roomNo}}</text>
            </view>
            <view class="rt-info-seg">
              <text class="rt-info-label">模式</text>
              <text class="rt-info-value">{{currentRoom.scoreMode === 1 ? '自由流转' : '本局录入'}}</text>
            </view>
            <view class="rt-info-seg">
              <text class="rt-info-label">成员</text>
              <text class="rt-info-value">{{memberGrid.length}} / {{currentRoom.maxMembers || 16}}</text>
            </view>
          </view>
          <view class="rt-actions">
            <view class="rt-action" bindtap="copyRoomNo">
              <view class="icon-clip"></view>
            </view>
            <view class="rt-action" bindtap="openShareSheet">
              <view class="icon-share"></view>
            </view>
          </view>
        </view>
      </view>

      <!-- 本局录入状态条 -->
      <round-status-bar
        wx:if="{{currentRoom.scoreMode === 2}}"
        round="{{roundRecord}}"
        is-owner="{{isOwner}}"
        bind:tap="onRoundStatusTap"
        bind:cancel="onRoundCancel"
      />

      <!-- 录入本局按钮（ROUND_RECORD 模式，无待处理录时显示） -->
      <view class="round-start-wrap" wx:if="{{currentRoom.scoreMode === 2 && !roundRecord && isOwner}}">
        <view class="round-start-btn" bindtap="startRound">
          <text class="round-start-text">录入本局</text>
        </view>
      </view>

      <!-- PLAYER NETWORK 成员网络 -->
      <view class="player-network">
        <view class="pn-header">
          <view class="pn-title-group">
            <text class="pn-cn">成员网络</text>
            <text class="pn-en">NETWORK</text>
          </view>
          <text class="pn-count">{{memberGrid.length}} / {{currentRoom.maxMembers || 16}}</text>
        </view>
        <view class="pn-divider"></view>
        <scroll-view class="member-grid-scroll" scroll-y="{{memberGrid.length > 8}}" enhanced show-scrollbar="{{false}}">
          <view class="member-matrix">
            <view class="mg-cell {{item.userId === transferTo ? 'mg-cell-selected' : ''}}"
                  wx:for="{{memberGrid}}" wx:key="userId"
                  bindtap="onTapMember" data-user-id="{{item.userId}}">
              <view class="mg-avatar-wrap">
                <helmet-avatar
                  src="{{item.avatarUrl || ''}}"
                  size="sm"
                  active="{{item.userId === transferTo}}"
                  controller="{{item.isHost}}"
                  dimmed="{{item.score < 0}}"
                  showStatus="{{false}}"
                  reduceMotion="{{!animationEnabled}}"
                />
                <view class="mg-host-badge" wx:if="{{item.isHost}}">主控</view>
              </view>
              <text class="mg-name">{{t.truncateName(item.nickname)}}</text>
              <text class="mg-score score-number" style="color:{{item.scoreColor}};">
                {{fmt.formatScore(item.displayScore)}}
              </text>
              <!-- TARGET LOCKED -->
              <text class="mg-target-lock" wx:if="{{item.userId === transferTo}}">目标锁定</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- FLOW LOG 流向日志终端 -->
      <flow-log-panel
        grouped-records="{{groupedRecords}}"
        filter-mine="{{filterMine}}"
        loading-more="{{loadingMore}}"
        no-more="{{noMore}}"
        show-matrix="{{memberGrid.length >= 2}}"
        bind:toggleFilter="onToggleFilter"
        bind:openMatrix="openMatrixPanel"
      />

      <!-- SPACE SCAN 空间扫描面板 -->
      <space-scan-panel
        insight="{{roomInsight}}"
      />

      <!-- 底部操作区 -->
      <view class="room-bottom-bar">
        <view class="rb-settle-btn" bindtap="onSettleTap" wx:if="{{isOwner}}">
          <text class="rb-settle-text">封存任务</text>
          <text class="rb-settle-sub">SEAL</text>
        </view>
        <view class="rb-quit-btn" bindtap="quitRoom" wx:else>
          <text class="rb-quit-text">断开空间</text>
        </view>
      </view>

      <!-- 结算确认弹窗 -->
      <view class="settle-confirm-mask {{showSettleConfirm ? 'sc-show' : ''}}" catchtap="closeSettleConfirm">
        <view class="settle-confirm-card" catchtap="preventClose">
          <text class="sc-kicker">WARNING</text>
          <text class="sc-title">确认封存当前任务？</text>
          <text class="sc-desc">封存后，本次任务的数值流向将进入档案库</text>
          <view class="sc-actions">
            <view class="sc-btn sc-btn-cancel" bindtap="closeSettleConfirm">
              <text class="sc-btn-text">取消</text>
            </view>
            <view class="sc-btn sc-btn-confirm" bindtap="confirmSettle">
              <text class="sc-btn-text">确认封存</text>
            </view>
          </view>
        </view>
      </view>

    </scroll-view>

    <!-- TRANSFER TERMINAL 流转终端 -->
    <view class="transfer-overlay {{showNumpad ? 'transfer-show' : ''}}" catchtap="closeNumpad">
      <view class="transfer-sheet" catchtap="preventClose">
        <view class="transfer-header">
          <text class="transfer-kicker">FLOW SHIFT</text>
          <text class="transfer-subtitle">流向调整</text>
        </view>

        <!-- FROM → TO -->
        <view class="transfer-direction">
          <view class="transfer-player">
            <text class="transfer-role-label">源成员</text>
            <helmet-avatar
              src="{{transferFromInfo.avatarUrl || ''}}"
              size="sm"
              active
              showStatus="{{false}}"
              reduceMotion="{{!animationEnabled}}"
            />
            <text class="transfer-player-name">{{t.truncateName(transferFromInfo.nickname)}}</text>
          </view>
          <view class="transfer-arrow-wrap">
            <view class="transfer-arrow-line"></view>
            <view class="transfer-arrow-beam"></view>
            <text class="transfer-arrow-head">→</text>
          </view>
          <view class="transfer-player">
            <text class="transfer-role-label">目标成员</text>
            <helmet-avatar
              src="{{transferToInfo.avatarUrl || ''}}"
              size="sm"
              active
              showStatus="{{false}}"
              reduceMotion="{{!animationEnabled}}"
            />
            <text class="transfer-player-name">{{t.truncateName(transferToInfo.nickname)}}</text>
          </view>
        </view>

        <!-- AMOUNT -->
        <view class="transfer-amount-section">
          <text class="transfer-amount-label">流向数值</text>
          <text class="transfer-display-value">{{numpadValue || '0'}}</text>
        </view>

        <!-- 实时预览 -->
        <view class="transfer-preview" wx:if="{{numpadValue > 0 && transferPreview}}">
          <view class="tp-row">
            <text class="tp-name">{{transferPreview.fromName}}</text>
            <view class="tp-arrow">
              <text class="tp-score-old">{{transferPreview.fromOldScore}}</text>
              <text class="tp-arrow-icon">→</text>
              <text class="tp-score tp-score-neg">-{{numpadValue}}</text>
            </view>
          </view>
          <view class="tp-divider"></view>
          <view class="tp-row">
            <text class="tp-name">{{transferPreview.toName}}</text>
            <view class="tp-arrow">
              <text class="tp-score-old">{{transferPreview.toOldScore}}</text>
              <text class="tp-arrow-icon">→</text>
              <text class="tp-score tp-score-pos">+{{numpadValue}}</text>
            </view>
          </view>
        </view>

        <!-- 数字键盘 -->
        <view class="transfer-numpad">
          <view class="transfer-key" bindtap="onNumpadKey" data-key="1">1</view>
          <view class="transfer-key" bindtap="onNumpadKey" data-key="2">2</view>
          <view class="transfer-key" bindtap="onNumpadKey" data-key="3">3</view>
          <view class="transfer-key" bindtap="onNumpadKey" data-key="4">4</view>
          <view class="transfer-key" bindtap="onNumpadKey" data-key="5">5</view>
          <view class="transfer-key" bindtap="onNumpadKey" data-key="6">6</view>
          <view class="transfer-key" bindtap="onNumpadKey" data-key="7">7</view>
          <view class="transfer-key" bindtap="onNumpadKey" data-key="8">8</view>
          <view class="transfer-key" bindtap="onNumpadKey" data-key="9">9</view>
          <view class="transfer-key transfer-key-func" bindtap="onNumpadKey" data-key="clear">
            <text class="numpad-func-icon">C</text>
          </view>
          <view class="transfer-key" bindtap="onNumpadKey" data-key="0">0</view>
          <view class="transfer-key transfer-key-func" bindtap="onNumpadKey" data-key="del">
            <text class="numpad-func-icon numpad-func-icon--del"></text>
          </view>
        </view>
        <view class="transfer-actions">
          <view class="transfer-confirm {{numpadValue > 0 ? '' : 'transfer-confirm-disabled'}}" bindtap="confirmNumpad">
            <text class="transfer-confirm-text">确认调整</text>
            <text class="transfer-confirm-sub">CONFIRM</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 数值总览（全局组件） -->
    <matrix-overview
      id="matrix-overview"
      visible="{{showMatrixPanel}}"
      room-id="{{currentRoom.roomId}}"
      member-grid="{{memberGrid}}"
      score-records="{{scoreRecords}}"
      my-user-id="{{myUserId}}"
      bind:close="onMatrixClose"
    />

    <!-- 记录动画层 -->
    <view class="transfer-anim-overlay" wx:if="{{animActive}}">
      <!-- 屏幕闪烁 -->
      <view class="transfer-anim-flash" style="opacity:{{animFlashOpacity}};"></view>
      <!-- 拖尾粒子 -->
      <view class="transfer-anim-trail"
            style="left:{{animTrail1X}}px;top:{{animTrail1Y}}px;opacity:{{animTrail1Opacity}};transform:scale({{animTrail1Scale}});">
        <view class="transfer-anim-dot-trail"></view>
      </view>
      <view class="transfer-anim-trail"
            style="left:{{animTrail2X}}px;top:{{animTrail2Y}}px;opacity:{{animTrail2Opacity}};transform:scale({{animTrail2Scale}});">
        <view class="transfer-anim-dot-trail dot-trail-2"></view>
      </view>
      <!-- 主粒子 -->
      <view class="transfer-anim-particle"
            style="left:{{animCurX}}px;top:{{animCurY}}px;opacity:{{animCurOpacity}};transform:scale({{animCurScale}});">
        <view class="transfer-anim-dot"></view>
        <text class="transfer-anim-amount">{{animAmount}}</text>
      </view>
    </view>

    <!-- 本局录入弹窗 -->
    <host-fill-modal
      wx:if="{{showHostFill && roundRecord}}"
      members="{{currentRoom.members}}"
      zero-sum="{{currentRoom.zeroSumRequired}}"
      bind:submit="submitHostFill"
      bind:close="onHostFillClose"
    />
    <member-fill-modal
      wx:if="{{showMemberFill && roundRecord}}"
      submitted="{{roundRecord.mySubmitted}}"
      my-score="{{roundRecord.myScore}}"
      bind:submit="submitMemberFill"
      bind:close="onMemberFillClose"
    />
    <round-confirm-modal
      wx:if="{{showRoundConfirm && roundRecord}}"
      round="{{roundRecord}}"
      my-user-id="{{myUserId}}"
      bind:confirm="confirmRound"
      bind:reject="onRoundReject"
      bind:close="onRoundConfirmClose"
    />
  </view>

  <!-- 空间接入面板 -->
  <view class="share-overlay {{showShareSheet ? 'share-show' : ''}}" catchtap="closeShareSheet" catchtouchmove="preventClose">
    <view class="share-sheet" catchtap="preventClose">
      <view class="share-header">
        <view class="share-title-area">
          <text class="share-kicker">ACCESS PORTAL</text>
          <text class="share-title">空间接入</text>
        </view>
        <view class="fi fi--close" bindtap="closeShareSheet"></view>
      </view>

      <!-- 二维码区域：加载中 -->
      <view class="share-qr-section" wx:if="{{qrLoading}}">
        <view class="share-qr-frame share-qr-loading">
          <view class="share-qr-spinner"></view>
          <text class="share-qr-loading-text">生成识别图中...</text>
        </view>
      </view>

      <!-- 二维码区域：生成失败 -->
      <view class="share-qr-section" wx:elif="{{qrFailed}}">
        <view class="share-qr-frame share-qr-fail">
          <text class="share-qr-fail-text">识别图生成失败</text>
          <text class="share-qr-fail-hint">可使用识别码接入</text>
          <view class="share-qr-retry" bindtap="retryLoadQrCode">
            <text class="share-qr-retry-text">重新生成</text>
          </view>
        </view>
      </view>

      <!-- 二维码区域：有二维码 -->
      <view class="share-qr-section" wx:elif="{{currentRoom.qrCodeUrl}}">
        <view class="share-qr-frame">
          <image class="share-qr-image" src="{{currentRoom.qrCodeUrl}}" mode="aspectFit" show-menu-by-longpress></image>
        </view>
        <text class="share-qr-hint">长按识别二维码接入空间</text>
      </view>

      <!-- 二维码区域：无二维码，显示识别码 -->
      <view class="share-qr-section" wx:else>
        <view class="share-qr-frame share-qr-placeholder">
          <text class="share-qr-room-no">{{currentRoom.roomNo}}</text>
        </view>
        <text class="share-qr-hint">识别码 {{currentRoom.roomNo}}</text>
      </view>

      <!-- 操作按钮 -->
      <view class="share-actions">
        <button class="share-action-btn" open-type="share">
          <view class="icon-chat share-action-svg"></view>
          <text class="share-action-text">分享空间</text>
        </button>
        <view class="share-action-btn" bindtap="sharePoster">
          <view class="icon-image share-action-svg"></view>
          <text class="share-action-text">保存识别图</text>
        </view>
        <view class="share-action-btn" bindtap="copyRoomLink">
          <view class="icon-link share-action-svg"></view>
          <text class="share-action-text">复制识别码</text>
        </view>
        <view class="share-action-btn" bindtap="scanJoin">
          <view class="icon-cam share-action-svg"></view>
          <text class="share-action-text">扫码接入</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 驳回确认弹窗 -->
  <terminal-popup
    visible="{{showRejectConfirm}}"
    title="操作确认"
    subtitle="ROUND REJECT"
    content="确认驳回本轮录入？驳回后本轮数据将被清除。"
    cancel-text="返回"
    confirm-text="确认驳回"
    confirm-type="danger"
    reduce-motion="{{!animationEnabled}}"
    bind:cancel="closeRejectConfirm"
    bind:confirm="confirmRoundReject"
  />

  <!-- 战局报告弹层 -->
  <view class="settle-overlay {{showSettleOverlay ? 'settle-overlay--show' : ''}}" catchtouchmove="preventClose">
    <scroll-view class="settle-overlay__inner" scroll-y enhanced show-scrollbar="{{false}}">

      <!-- 顶部关闭按钮 -->
      <view class="settle-top-bar">
        <view class="settle-close-cyber" bindtap="closeSettleOverlay">
          <view class="settle-close-ring">
            <view class="fi fi--close"></view>
          </view>
        </view>
      </view>

      <!-- 1. 战局总结 -->
      <battle-summary
        winner="{{settleWinner}}"
        loser="{{settleLoser}}"
        maxSingle="{{settleMaxSingle}}"
        totalTransfer="{{settleTotalTransfer}}"
        transferCount="{{settleTransferCount}}"
        memberCount="{{settleMemberCount}}"
        roomNo="{{settleRoomNo}}"
        settleTime="{{settleTime}}" />

      <!-- 2. 数值趋势图 -->
      <view class="settle-card" wx:if="{{settleSeries.length > 0}}">
        <view class="settle-card-header">
          <view class="settle-card-title">数值演化轨迹</view>
          <view class="settle-kicker">TIMELINE</view>
          <view class="settle-card-line"></view>
        </view>
        <view class="settle-chart-wrap">
          <score-chart
            timestamps="{{settleTimestamps}}"
            series="{{settleSeries}}"
            visibleUsers="{{settleVisibleUsers}}"
            eventMarkers="{{settleEventMarkers}}"
            highlightUser="{{myUserId}}" />
        </view>
      </view>

      <!-- 3. 数值关系网络 -->
      <score-network
        wx:if="{{settleNetworkNodes.length > 0}}"
        nodes="{{settleNetworkNodes}}"
        links="{{settleNetworkLinks}}"
        my-user-id="{{myUserId}}" />

      <!-- 4. 空间洞察 -->
      <battle-insight
        wx:if="{{settleInsight}}"
        mostActiveUser="{{settleInsight.mostActiveUser}}"
        mostFocusedUser="{{settleLoser}}"
        networkDensity="{{settleInsight.networkDensity}}"
        transferCount="{{settleInsight.transferCount}}"
        memberCount="{{settleMemberCount}}" />

      <!-- 5. 实时序列 -->
      <view class="settle-card" wx:if="{{settleRankedMembers.length > 0}}">
        <view class="settle-card-header">
          <view class="settle-card-title">实时序列</view>
          <view class="settle-kicker">SEQUENCE</view>
          <view class="settle-card-line"></view>
        </view>
        <view class="settle-rank-list">
          <view class="settle-rank-item {{index === 0 ? 'settle-rank-champion' : ''}}"
            wx:for="{{settleRankedMembers}}" wx:key="userId">
            <view class="settle-rank-badge {{index < 3 ? 'settle-rank-top3' : ''}} {{index === 0 ? 'settle-badge-champion' : ''}}">
              <text class="settle-rank-num">{{index + 1}}</text>
            </view>
            <view class="settle-rank-avatar" style="background: {{item.avatarColor}}">
              <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="settle-rank-avatar-img" mode="aspectFill" />
              <text wx:else class="settle-rank-avatar-char">{{item.avatarChar}}</text>
            </view>
            <text class="settle-rank-name" style="color: {{item.userId == myUserId ? '#00AFFF' : 'rgba(255,255,255,0.85)'}}">
              {{item.nickname}}
              <text wx:if="{{item.userId == myUserId}}" class="settle-me-tag">我</text>
            </text>
            <text class="settle-rank-score"
              style="color: {{item.finalScore > 0 ? '#32D74B' : item.finalScore < 0 ? '#FF453A' : 'rgba(255,255,255,0.35)'}}">
              {{item.finalScore > 0 ? '+' : ''}}{{item.finalScore}}
            </text>
          </view>
        </view>
      </view>

      <!-- 6. 人格信号 -->
      <persona-signal
        wx:if="{{settlePersonaSignals}}"
        socialActivity="{{settlePersonaSignals.socialActivity}}"
        riskPreference="{{settlePersonaSignals.riskPreference}}"
        resourceControl="{{settlePersonaSignals.resourceControl}}"
        allianceTendency="{{settlePersonaSignals.allianceTendency}}" />

      <view style="height: 60rpx;"></view>
    </scroll-view>
  </view>

  <!-- 身份重叠弹窗 -->
  <view class="name-collision-mask {{showNameCollisionModal ? 'nc-show' : ''}}" catchtap="closeNameCollisionModal">
    <view class="name-collision-card" catchtap="">
      <view class="nc-icon-wrap">
        <view class="nc-icon">!</view>
      </view>
      <text class="nc-title">身份重叠</text>
      <text class="nc-desc">检测到场域内存在同名实体，请前往[我的]终端重新校准代号。</text>
      <view class="nc-btn" bindtap="goToProfile">
        <text class="nc-btn-text">前往档案</text>
      </view>
    </view>
  </view>
</view>

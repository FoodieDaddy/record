<wxs src="./room.wxs" module="fmt" />
<view class="room-page">
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="empty-auth">
    <view class="empty-auth-icon">🔐</view>
    <text class="text-lg text-bold" style="margin-bottom:12rpx;">尚未登录</text>
    <text class="text-secondary" style="margin-bottom:40rpx;">登录后即可创建或加入房间</text>
    <button class="btn-primary" style="width:320rpx;" bindtap="goLogin">去登录</button>
  </view>

  <!-- 已登录：无房间 -->
  <view wx:elif="{{!currentRoom}}" class="empty-room">
    <view class="glass-card-glow create-card">
      <view class="card-header">
        <text class="section-title">创建房间</text>
        <text class="text-tertiary text-xs">开局成为房主</text>
      </view>
      <view class="form-row">
        <text class="form-label">底分</text>
        <input class="input-glass flex-1" type="number" value="{{baseScore}}" bindinput="onBaseScoreInput" placeholder="1" />
      </view>
      <button class="btn-primary" style="margin-top:24rpx;" bindtap="createRoom" loading="{{creating}}">创建房间</button>
    </view>

    <view class="divider-glow"><text class="divider-text">或者</text></view>

    <view class="glass-card-glow join-card">
      <view class="card-header">
        <text class="section-title">加入房间</text>
        <text class="text-tertiary text-xs">输入牌友的房间号</text>
      </view>
      <view class="form-row">
        <input class="input-glass flex-1" value="{{joinRoomNo}}" bindinput="onJoinInput" placeholder="输入 6 位房间号" maxlength="6" />
      </view>
      <view class="join-actions">
        <button class="btn-primary flex-1" bindtap="joinByNo">加入房间</button>
        <button class="btn-secondary-scan" bindtap="scanJoin"><text class="scan-icon">📷</text></button>
      </view>
    </view>
  </view>

  <!-- 已登录：在房间中 -->
  <view wx:else class="room-content">
    <!-- 顶部提示 -->
    <view class="top-toast {{toastMsg ? 'top-toast-show' : ''}} {{toastType === 'error' ? 'top-toast-error' : ''}}" wx:if="{{toastMsg}}">
      <text>{{toastMsg}}</text>
    </view>
    <!-- 顶部信息卡片 -->
    <view class="glass-card-glow room-top-card">
      <view class="hero-glow"></view>
      <view class="top-card-row">
        <view class="top-card-info">
          <text class="top-card-label text-tertiary">房间号</text>
          <text class="top-card-value">{{currentRoom.roomNo}}</text>
        </view>
        <view class="top-card-actions">
          <view class="tc-action" bindtap="copyRoomNo">
            <text class="tc-icon">📋</text>
          </view>
          <view class="tc-action" open-type="share">
            <text class="tc-icon">📤</text>
          </view>
          <view class="tc-action" bindtap="scanJoin">
            <text class="tc-icon">📷</text>
          </view>
          <view class="tc-action {{audioEnabled ? 'tc-audio-on' : ''}}" bindtap="toggleAudioSwitch">
            <text class="tc-icon">{{audioEnabled ? '🔊' : '🔇'}}</text>
          </view>
          <view class="tc-action tc-danger" wx:if="{{!isOwner}}" bindtap="quitRoom">
            <text class="tc-icon">🚪</text>
          </view>
          <view class="tc-action tc-danger" wx:if="{{isOwner}}" bindtap="dissolveRoom">
            <text class="tc-icon">🗑️</text>
          </view>
        </view>
      </view>
      <!-- 小程序码 -->
      <view class="qr-section" wx:if="{{currentRoom.qrCodeUrl}}">
        <view class="qr-frame">
          <image class="qr-image" src="{{currentRoom.qrCodeUrl}}" mode="aspectFit" show-menu-by-longpress></image>
        </view>
        <text class="text-tertiary text-xs">长按识别或截图分享给牌友</text>
      </view>
    </view>

    <!-- 成员网格（4 列：头像 + 昵称 + 分数，点击计分） -->
    <view class="glass-card member-section">
      <view class="flex-between" style="margin-bottom:16rpx;">
        <text class="section-title" style="margin-bottom:0;">成员</text>
        <text class="text-tertiary text-sm">{{memberGrid.length}}人</text>
      </view>
      <view class="member-grid">
        <view class="mg-cell {{item.userId === transferTo ? 'mg-cell-on' : ''}}"
              wx:for="{{memberGrid}}" wx:key="userId"
              bindtap="onTapMember" data-user-id="{{item.userId}}">
          <view class="mg-avatar-wrap">
            <view class="auto-avatar" style="background:{{item.avatarColor}};" wx:if="{{!item.avatarUrl}}">
              <text class="auto-avatar-char">{{item.avatarChar}}</text>
            </view>
            <image class="mg-avatar" src="{{item.avatarUrl}}" mode="aspectFill" wx:else binderror="onAvatarError" data-user-id="{{item.userId}}"></image>
            <view class="mg-glow" wx:if="{{item.userId === transferTo}}"></view>
          </view>
          <text class="mg-name">{{item.nickname}}</text>
          <text class="mg-score score-number" style="color:{{item.scoreColor}};">
            {{fmt.formatScore(item.displayScore)}}
          </text>
        </view>
      </view>
    </view>

    <!-- 数字键盘 -->
    <view class="numpad-overlay {{showNumpad ? 'numpad-show' : ''}}" catchtap="closeNumpad">
      <view class="numpad-sheet" catchtap="preventClose">
        <view class="numpad-header">
          <text class="numpad-player-name">{{transferToInfo.nickname || '输入积分'}}</text>
          <view class="numpad-display">
            <text class="numpad-display-value">{{numpadValue || '0'}}</text>
            <text class="numpad-unit">积分</text>
          </view>
        </view>
        <!-- 留证区 -->
        <view class="evidence-area">
          <view class="evidence-dashed" bindtap="chooseImage">
            <view wx:if="{{selectedImages.length === 0}}" class="evidence-empty">
              <text class="evidence-icon">📸</text>
              <text class="evidence-label">添加留证 (选填)</text>
            </view>
            <view wx:else class="evidence-thumbs">
              <view class="evidence-thumb" wx:for="{{selectedImages}}" wx:key="*this">
                <image src="{{item}}" mode="aspectFill" class="thumb-img" catchtap="previewImage" data-src="{{item}}"></image>
                <view class="thumb-remove" catchtap="removeImage" data-index="{{index}}">✕</view>
              </view>
              <view class="evidence-add" wx:if="{{selectedImages.length < 9}}" catchtap="chooseImage">
                <text class="evidence-add-icon">+</text>
              </view>
            </view>
          </view>
        </view>
        <view class="numpad-grid">
          <view class="numpad-key" bindtap="onNumpadKey" data-key="1">1</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="2">2</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="3">3</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="4">4</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="5">5</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="6">6</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="7">7</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="8">8</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="9">9</view>
          <view class="numpad-key numpad-key-func" bindtap="onNumpadKey" data-key="clear">C</view>
          <view class="numpad-key" bindtap="onNumpadKey" data-key="0">0</view>
          <view class="numpad-key numpad-key-func" bindtap="onNumpadKey" data-key="del">⌫</view>
        </view>
        <view class="numpad-actions">
          <button class="numpad-confirm" bindtap="confirmNumpad">确认计分</button>
        </view>
      </view>
    </view>

    <!-- 积分记录 -->
    <view class="glass-card">
      <view class="flex-between" style="margin-bottom:12rpx;">
        <text class="section-title" style="margin-bottom:0;">积分记录</text>
        <view class="matrix-btn" bindtap="openMatrixPanel" wx:if="{{memberGrid.length >= 2}}">
          <text class="matrix-btn-icon">📊</text>
          <text class="matrix-btn-text">积分总览</text>
        </view>
      </view>
      <view wx:if="{{scoreRecords.length === 0}}" class="empty-batches">
        <text class="empty-icon-sm">📝</text>
        <text class="text-tertiary">暂无记录</text>
      </view>
      <scroll-view wx:else class="score-records-scroll" scroll-y style="height:{{scoreRecordHeight}}rpx;">
        <view class="score-records">
          <view class="sr-item" wx:for="{{scoreRecords}}" wx:key="id">
            <view class="sr-col sr-from">
              <view class="sr-avatar-wrap">
                <view class="auto-avatar-xs" style="background:{{item.fromColor}};" wx:if="{{!item.fromAvatarUrl}}">
                  <text class="auto-avatar-char-xs">{{item.fromChar}}</text>
                </view>
                <image class="sr-avatar" src="{{item.fromAvatarUrl}}" wx:else></image>
              </view>
              <text class="sr-name">{{item.fromName}}</text>
            </view>
            <view class="sr-col sr-amount">
              <text class="sr-amount-text {{item.myRole === 'from' ? 'sr-amt-red' : item.myRole === 'to' ? 'sr-amt-green' : 'sr-amt-gray'}}">{{fmt.formatAmount(item.amount)}}</text>
              <text class="sr-arrow-icon">→</text>
            </view>
            <view class="sr-col sr-to">
              <view class="sr-avatar-wrap">
                <view class="auto-avatar-xs" style="background:{{item.toColor}};" wx:if="{{!item.toAvatarUrl}}">
                  <text class="auto-avatar-char-xs">{{item.toChar}}</text>
                </view>
                <image class="sr-avatar" src="{{item.toAvatarUrl}}" wx:else></image>
              </view>
              <text class="sr-name">{{item.toName}}</text>
            </view>
            <text class="sr-time">{{item.timeFormatted}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 积分总览弹窗 -->
    <view class="matrix-panel-overlay {{showMatrixPanel ? 'mp-show' : ''}}" catchtap="closeMatrixPanel">
      <view class="matrix-panel-sheet" catchtap="preventClose">
        <view class="detail-header">
          <text class="section-title" style="margin-bottom:0;">积分总览</text>
          <view class="detail-close" bindtap="closeMatrixPanel">✕</view>
        </view>
        <view wx:if="{{memberGrid.length < 2}}" class="empty-batches">
          <text class="text-tertiary">至少需要 2 名成员</text>
        </view>
        <view wx:else class="matrix-wrap">
          <!-- 表头 -->
          <view class="matrix-row matrix-header">
            <view class="matrix-corner"></view>
            <view class="matrix-th" wx:for="{{matrixMembers}}" wx:key="userId">
              <view class="matrix-th-avatar">
                <view class="auto-avatar-xxs" style="background:{{item.avatarColor}};" wx:if="{{!item.avatarUrl}}">
                  <text class="auto-avatar-char-xxs">{{item.avatarChar}}</text>
                </view>
                <image class="matrix-th-img" src="{{item.avatarUrl}}" wx:else></image>
              </view>
              <text class="matrix-th-name">{{item.nickname}}</text>
            </view>
          </view>
          <!-- 数据行 -->
          <view class="matrix-row" wx:for="{{matrixData}}" wx:for-item="row" wx:key="fromUserId">
            <view class="matrix-row-header">
              <view class="auto-avatar-xxs" style="background:{{row.fromColor}};" wx:if="{{!row.fromAvatarUrl}}">
                <text class="auto-avatar-char-xxs">{{row.fromChar}}</text>
              </view>
              <image class="matrix-rh-img" src="{{row.fromAvatarUrl}}" wx:else></image>
            </view>
            <view class="matrix-cell {{cell.value > 0 ? 'mc-pos' : cell.value < 0 ? 'mc-neg' : ''}}"
                  wx:for="{{row.cells}}" wx:for-item="cell" wx:key="toUserId"
                  bindtap="onMatrixCell" data-from="{{row.fromUserId}}" data-to="{{cell.toUserId}}">
              <text class="matrix-cell-val">{{cell.display}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 积分明细弹窗 -->
    <view class="matrix-detail-overlay {{showMatrixDetail ? 'detail-show' : ''}}" catchtap="closeMatrixDetail">
      <view class="matrix-detail-sheet" catchtap="preventClose">
        <view class="detail-header">
          <text class="section-title" style="margin-bottom:0;">积分明细</text>
          <view class="detail-close" bindtap="closeMatrixDetail">✕</view>
        </view>
        <view class="detail-parties">
          <view class="detail-party">
            <view class="auto-avatar-sm" style="background:{{detailFrom.avatarColor}};" wx:if="{{!detailFrom.avatarUrl}}">
              <text class="auto-avatar-char-sm">{{detailFrom.avatarChar}}</text>
            </view>
            <image class="detail-avatar" src="{{detailFrom.avatarUrl}}" wx:else></image>
            <text class="detail-name">{{detailFrom.nickname}}</text>
          </view>
          <text class="detail-arrow">⇄</text>
          <view class="detail-party">
            <view class="auto-avatar-sm" style="background:{{detailTo.avatarColor}};" wx:if="{{!detailTo.avatarUrl}}">
              <text class="auto-avatar-char-sm">{{detailTo.avatarChar}}</text>
            </view>
            <image class="detail-avatar" src="{{detailTo.avatarUrl}}" wx:else></image>
            <text class="detail-name">{{detailTo.nickname}}</text>
          </view>
        </view>
        <view class="detail-total">
          <text class="text-tertiary text-xs">净积分</text>
          <text class="detail-total-val {{detailNet > 0 ? 'mg-pos' : detailNet < 0 ? 'mg-neg' : ''}}">{{fmt.formatScore(detailNet)}}</text>
        </view>
        <view class="detail-list">
          <view class="detail-item" wx:for="{{detailRecords}}" wx:key="id">
            <text class="detail-item-dir">{{item.direction}}</text>
            <text class="detail-item-amount">{{fmt.formatScore(item.amount)}}</text>
            <text class="detail-item-time text-tertiary text-xs">{{item.timeFormatted}}</text>
          </view>
          <view wx:if="{{detailRecords.length === 0}}" class="empty-batches" style="padding:24rpx 0;">
            <text class="text-tertiary">暂无记录</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 计分动画层 -->
    <view class="transfer-anim-overlay" wx:if="{{animActive}}">
      <!-- 屏幕闪烁 -->
      <view class="transfer-anim-flash" style="opacity:{{animFlashOpacity}};"></view>
      <!-- 拖尾粒子 -->
      <view class="transfer-anim-trail"
            style="left:{{animTrail1X}}px;top:{{animTrail1Y}}px;opacity:{{animTrail1Opacity}};transform:scale({{animTrail1Scale}});">
        <view class="transfer-anim-dot-trail"></view>
      </view>
      <view class="transfer-anim-trail"
            style="left:{{animTrail2X}}px;top:{{animTrail2Y}}px;opacity:{{animTrail2Opacity}};transform:scale({{animTrail2Scale}});">
        <view class="transfer-anim-dot-trail dot-trail-2"></view>
      </view>
      <!-- 主粒子 -->
      <view class="transfer-anim-particle"
            style="left:{{animCurX}}px;top:{{animCurY}}px;opacity:{{animCurOpacity}};transform:scale({{animCurScale}});">
        <view class="transfer-anim-dot"></view>
        <text class="transfer-anim-amount">{{animAmount}}</text>
      </view>
    </view>

    <!-- 结束本轮按钮（房主） -->
    <view class="settle-bar" wx:if="{{isOwner && ranking.length > 0}}">
      <button class="btn-settle" bindtap="settleRoom">结束本轮</button>
    </view>
  </view>
</view>

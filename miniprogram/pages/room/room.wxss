}

.deck-meta-chips text {
  max-width: 112rpx;
  padding: 3rpx 8rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(0,200,255,0.13);
  font-size: 17rpx;
  line-height: 20rpx;
  color: rgba(0,200,255,0.58);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

.deck-pulse-line {
  height: 36rpx;
  margin-top: 7rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.deck-section-title {
  font-size: 22rpx;

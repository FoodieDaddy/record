  background: linear-gradient(to bottom, rgba(48,209,88,0.0), rgba(48,209,88,0.72), rgba(0,200,255,0.42));
}

.trace-item.is-mine .trace-title {
  color: rgba(226,242,255,0.96);
}

.trace-value.is-related {
  color: rgba(48,209,88,0.92);
}

.trace-line {
  width: 2rpx;
  align-self: stretch;
  background: linear-gradient(to bottom, rgba(0,200,255,0.0), rgba(0,200,255,0.6), rgba(0,200,255,0.0));
}

.trace-main {
  flex: 1;
  min-width: 0;
}

.trace-title {
  font-size: 25rpx;
  color: rgba(226,242,255,0.88);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.trace-desc {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: rgba(226,242,255,0.46);
}

.trace-value {
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 26rpx;
  color: rgba(0,200,255,0.92);
  flex-shrink: 0;
}

.trace-value.is-negative {
  color: rgba(255,159,10,0.92);
}

.overview-rank {
  margin-top: 18rpx;
  border: 1rpx solid rgba(255,255,255,0.07);
  background: rgba(255,255,255,0.018);
}

.overview-rank-title {
  padding: 16rpx 18rpx 10rpx;
  font-size: 22rpx;
  color: rgba(226,242,255,0.64);
}

.overview-rank-row {
  min-height: 68rpx;
  padding: 10rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid rgba(255,255,255,0.055);
}

.overview-rank-left {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: rgba(226,242,255,0.76);
  font-size: 23rpx;
}

.overview-rank-left text {
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.overview-rank-score {
  font-family: 'DIN Alternate', Menlo, monospace;
  color: rgba(0,200,255,0.88);
  font-size: 26rpx;
}

.trace-empty {
  text-align: center;
  padding: 48rpx 0;
}

.trace-empty .empty-title {
  font-size: 26rpx;
  color: rgba(226,242,255,0.46);
  margin-bottom: 8rpx;
}

.trace-empty .empty-desc {
  font-size: 22rpx;
  color: rgba(226,242,255,0.24);
}

/* 航程封存区 */
.voyage-seal-zone {
  padding: 24rpx 0 0;
  padding-bottom: calc(360rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255,255,255,0.06);
  margin-top: 24rpx;
}

.seal-zone-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.28);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

/* === 封存确认弹窗 === */
.seal-panel {
  width: 100%;
  max-width: 600rpx;
  text-align: center;
}

.seal-core {
  margin-bottom: 24rpx;
}

.seal-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255,69,58,0.34);
  margin: 0 auto 20rpx;
  position: relative;
}

.seal-ring::before {
  content: '';
  position: absolute;
  inset: 16rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255,69,58,0.18);
}

.seal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255,126,118,0.96);
  margin-bottom: 12rpx;
}

.seal-desc {
  font-size: 24rpx;
  color: rgba(226,242,255,0.56);
  line-height: 1.6;
}

.seal-meta {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 24rpx;
}

.seal-meta .meta-label {
  text-align: center;
}

.seal-meta .meta-value {
  text-align: center;
  font-size: 28rpx;
}

.seal-actions {
  display: flex;
  gap: 16rpx;
}

.seal-actions .sr-btn {
  flex: 1;
}

/* === 航迹档案写入中 === */
.sealing-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.88);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.blackbox-write {
  text-align: center;
  width: 400rpx;
}

.write-beam {
  width: 4rpx;
  height: 80rpx;
  background: linear-gradient(to bottom, rgba(0,200,255,0.0), rgba(0,200,255,0.8), rgba(0,200,255,0.0));
  margin: 0 auto 24rpx;
  animation: beamPulse 1.5s ease-in-out infinite;
}

@keyframes beamPulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 1; }
}

.write-title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(0,200,255,0.92);
  margin-bottom: 12rpx;
}

.write-desc {
  font-size: 24rpx;
  color: rgba(226,242,255,0.56);
  animation: textFade 3s ease-in-out infinite;
}

@keyframes textFade {
  0%, 100% { opacity: 0.56; }
  50% { opacity: 0.92; }
}

/* === 本局录入（保留） === */
.round-start-wrap {
  display: flex;
  justify-content: center;
  padding: 16rpx 0;
}

.round-start-btn {
  padding: 14rpx 32rpx;
  border: 1rpx solid rgba(0,200,255,0.34);
  border-radius: 12rpx;
  background: rgba(0,200,255,0.06);
  transition: opacity .18s;
}

.round-start-text {
  font-size: 26rpx;
  color: rgba(0,200,255,0.92);
}

/* === reduce-motion === */
.reduce-motion .core-ring-outer,
.reduce-motion .core-ring-inner,
.reduce-motion .core-orbit-a,
.reduce-motion .core-orbit-b,
.reduce-motion .core-pulse,
.reduce-motion .idle-scanline,
.reduce-motion .btn-energy,
.reduce-motion .sr-btn-secondary,
.reduce-motion .write-beam,
.reduce-motion .write-desc,
.reduce-motion .deck-grid {
  animation: none !important;
}

/* === active v2：一屏驾驶舱 === */
.cockpit-scroll {
  box-sizing: border-box;
  padding-bottom: calc(380rpx + env(safe-area-inset-bottom));
}

.cockpit-main {
  margin: 24rpx 28rpx 0;
}

.cockpit-shell-v2 {
  position: relative;
  height: 800rpx;
  max-height: 820rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0,200,255,0.26);
  background:
    radial-gradient(circle at 24% 4%, rgba(10,132,255,0.12), transparent 34%),
    radial-gradient(circle at 80% 18%, rgba(0,200,255,0.08), transparent 30%),
    linear-gradient(180deg, rgba(1,8,18,0.98), rgba(2,10,18,0.96) 46%, rgba(3,12,22,0.98));
  clip-path: polygon(24rpx 0, calc(100% - 24rpx) 0, 100% 24rpx, 100% calc(100% - 24rpx), calc(100% - 24rpx) 100%, 24rpx 100%, 0 calc(100% - 24rpx), 0 24rpx);
}

.cockpit-window-v2 {
  position: relative;
  height: 430rpx;
  overflow: hidden;
  background:
    radial-gradient(ellipse at 50% 18%, rgba(0,200,255,0.10), transparent 42%),
    linear-gradient(180deg, rgba(1,7,16,0.98), rgba(0,0,0,0.98));
}

.space-field {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 18% 28%, rgba(255,255,255,0.22) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 34% 16%, rgba(0,200,255,0.18) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 66% 28%, rgba(255,255,255,0.18) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 84% 12%, rgba(0,200,255,0.14) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 72% 58%, rgba(255,255,255,0.13) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 26% 62%, rgba(255,255,255,0.12) 0 1rpx, transparent 2rpx);
  opacity: 0.86;
}

.window-grid {
  position: absolute;
  inset: 24rpx 22rpx 18rpx;
  opacity: 0.22;
  background-image:
    linear-gradient(rgba(0,200,255,0.11) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0,200,255,0.08) 1rpx, transparent 1rpx),
    linear-gradient(120deg, transparent 0 48%, rgba(0,200,255,0.10) 49%, transparent 50%),
    linear-gradient(60deg, transparent 0 48%, rgba(0,200,255,0.08) 49%, transparent 50%);
  background-size: 54rpx 54rpx, 54rpx 54rpx, 210rpx 210rpx, 210rpx 210rpx;
  mask-image: radial-gradient(ellipse at center, black 0 56%, transparent 78%);
  -webkit-mask-image: radial-gradient(ellipse at center, black 0 56%, transparent 78%);
  pointer-events: none;
}

.window-readout {
  position: absolute;
  z-index: 4;
  top: 26rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 20rpx;
  line-height: 1;
  color: rgba(0,200,255,0.62);
  letter-spacing: 2rpx;
  font-variant-numeric: tabular-nums;
  pointer-events: none;
}

.window-readout--code {
  left: 28rpx;
}

.window-readout--members {
  right: 28rpx;
}

.external-ship-field-v2 {
  position: absolute;
  inset: 0;
  z-index: 3;
}

.external-ship-empty {
  position: absolute;
  left: 50%;
  top: 30%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: rgba(226,242,255,0.34);
  font-size: 20rpx;
  letter-spacing: 2rpx;
  pointer-events: none;
}

.ship-craft {
  position: absolute;
  width: 112rpx;
  min-height: 104rpx;
  padding: 10rpx 8rpx 8rpx;
  box-sizing: border-box;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  color: rgba(226,242,255,0.74);
  transition: opacity .18s, transform .18s;
}

.ship-craft:active {
  transform: translate(-50%, -50%) scale(0.94);
}

.ship-craft.motion-score-impact {
  animation: shipCraftImpact 220ms var(--sr-spring, cubic-bezier(0.34, 1.56, 0.64, 1)) both;
}

@keyframes shipCraftImpact {
  0% { transform: translate(-50%, -50%) scale(1); }
  45% { transform: translate(-50%, -50%) scale(1.12); }
  100% { transform: translate(-50%, -50%) scale(1); }
}

.ship-craft.is-offline {
  opacity: 0.42;
}

.ship-craft-body {
  position: relative;
  width: 72rpx;
  height: 54rpx;
}

.ship-craft--solo .ship-craft-body,
.ship-craft--duo .ship-craft-body {
  transform: scale(1.04);
}

.ship-craft--compact {
  width: 102rpx;
}

.ship-craft-nose {
  position: absolute;
  top: 0;
  left: 50%;
  width: 0;
  height: 0;
  transform: translateX(-50%);
  border-left: 9rpx solid transparent;
  border-right: 9rpx solid transparent;
  border-bottom: 16rpx solid rgba(0,200,255,0.54);
}

.ship-craft-wing {
  position: absolute;
  top: 28rpx;
  width: 22rpx;
  height: 7rpx;
  background: linear-gradient(90deg, rgba(0,200,255,0.10), rgba(0,200,255,0.44));
}

.ship-craft-wing--left {
  left: 2rpx;
  transform: rotate(-18deg);
}

.ship-craft-wing--right {
  right: 2rpx;
  transform: rotate(18deg) scaleX(-1);
}

.ship-craft-core {
  position: absolute;
  left: 50%;
  top: 17rpx;
  width: 38rpx;
  height: 38rpx;
  transform: translateX(-50%);
  border: 1rpx solid rgba(0,200,255,0.26);
  border-radius: 50%;
  background: rgba(2,12,22,0.92);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.ship-craft-avatar {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
}

.ship-craft-char {
  font-size: 17rpx;
  font-weight: 700;
  color: rgba(0,200,255,0.86);
}

.ship-craft-ring {
  position: absolute;
  left: 50%;
  top: 12rpx;
  width: 54rpx;
  height: 44rpx;
  transform: translateX(-50%);
  border: 1rpx solid rgba(0,200,255,0.26);
  border-radius: 50%;
  box-shadow: 0 0 12rpx rgba(0,200,255,0.08);
}

.ship-craft-dot {
  position: absolute;
  right: 15rpx;
  top: 16rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: rgba(226,242,255,0.28);
  z-index: 3;
}

.ship-craft.is-online .ship-craft-dot {
  background: rgba(48,209,88,0.9);
  box-shadow: 0 0 7rpx rgba(48,209,88,0.45);
}

.ship-craft-label {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rpx;
  width: 100%;
}

.ship-craft-name,
.ship-craft-pulse {
  max-width: 94rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.ship-craft-name {
  font-size: 15rpx;
  line-height: 18rpx;
  color: rgba(226,242,255,0.58);
}

.ship-craft-pulse {
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 18rpx;
  line-height: 20rpx;
  color: rgba(0,200,255,0.72);
  font-variant-numeric: tabular-nums;
}

.ship-craft-pulse.is-positive {
  color: rgba(48,209,88,0.86);
}

.ship-craft-pulse.is-negative {
  color: rgba(255,159,10,0.9);
}

.ship-craft.is-new {
  animation: shipCraftJoin .45s ease-out;
}

@keyframes shipCraftJoin {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.72);
  }
  100% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

.cockpit-deck-v2 {
  position: relative;
  height: 370rpx;
  overflow: hidden;
  border-top: 1rpx solid rgba(0,200,255,0.18);
  background:
    linear-gradient(180deg, rgba(0,200,255,0.02), rgba(2,12,22,0.92) 22%, rgba(0,4,10,0.98)),
    linear-gradient(90deg, rgba(0,200,255,0.05), transparent 18%, transparent 82%, rgba(0,200,255,0.05));
}

.deck-lip-v2 {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent 8%, rgba(0,200,255,0.28), rgba(0,200,255,0.44), rgba(0,200,255,0.28), transparent 92%);

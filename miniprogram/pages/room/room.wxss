  overflow: hidden;
  border-top: 1rpx solid rgba(0,200,255,0.18);
  border-left: 1rpx solid rgba(0,200,255,0.08);
  border-right: 1rpx solid rgba(0,200,255,0.08);
  background:
    linear-gradient(180deg, rgba(0,200,255,0.035), transparent 40%),

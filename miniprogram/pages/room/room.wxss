}

.deck-meta-line,
.deck-pulse-line,
.deck-last-event,
.deck-trajectory-line {
  min-width: 0;
}

.deck-meta-line {
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.deck-room-code {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  flex-shrink: 0;
}

.meta-label {
  font-size: 18rpx;
  line-height: 22rpx;
  color: rgba(226,242,255,0.38);
  white-space: nowrap;
}

.meta-code {
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 25rpx;
  line-height: 30rpx;
  font-weight: 700;
  color: rgba(0,200,255,0.9);
  letter-spacing: 2rpx;
  font-variant-numeric: tabular-nums;
}

.meta-copy,
.trajectory-link,
.vcp-actions button,

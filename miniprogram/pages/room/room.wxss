/* 数字键盘 */
.transfer-numpad {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.transfer-key {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border: 1rpx solid rgba(10,132,255,0.16);
  border-radius: 14rpx;
  font-size: 40rpx;
  font-weight: 500;
  color: var(--text-primary);
  transition: background 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
}
.transfer-key:active {
  background: rgba(10,132,255,0.10);
  border-color: rgba(10,132,255,0.35);
  box-shadow: inset 0 0 20rpx rgba(10,132,255,0.12);
}
.transfer-key-func {
  background: transparent;
  border-color: rgba(255,255,255,0.06);
  color: var(--text-tertiary);
  font-size: 32rpx;
}
.transfer-key-func:active {
  background: var(--glass-bg);
  box-shadow: inset 0 0 16rpx rgba(255,255,255,0.04);
}

/* 数字键盘功能图标 */
.numpad-func-icon {
  font-family: 'Courier New', Courier, monospace;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--text-tertiary);
}
.numpad-func-icon--del {
  display: inline-block;
  width: 32rpx;
  height: 20rpx;
  position: relative;
}
.numpad-func-icon--del::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  width: 32rpx;
  height: 2rpx;
  background: var(--text-tertiary);
  transform: translateY(-50%) rotate(-30deg);
}
.numpad-func-icon--del::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: 50%;
  width: 32rpx;
  height: 2rpx;
  background: var(--text-tertiary);
  transform: translateY(50%) rotate(30deg);
}

/* 确认按钮：能量风格 */
.transfer-actions {
  margin-top: 4rpx;
}
.transfer-confirm {
  height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  background: linear-gradient(135deg, rgba(0, 200, 255,0.15), rgba(10, 132, 255,0.08));
  border: 1rpx solid rgba(0, 200, 255,0.35);
  border-radius: 14rpx;
  position: relative;
  overflow: hidden;
  clip-path: polygon(12rpx 0, calc(100% - 12rpx) 0, 100% 12rpx, 100% calc(100% - 12rpx), calc(100% - 12rpx) 100%, 12rpx 100%, 0 calc(100% - 12rpx), 0 12rpx);
}
.transfer-confirm:active {
  background: linear-gradient(135deg, rgba(0, 200, 255,0.25), rgba(10, 132, 255,0.15));
  transform: scale(0.98);
}
.transfer-confirm-disabled {
  opacity: 0.35;
  pointer-events: none;
}
.transfer-confirm::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255,0.08), transparent);
  animation: cyberSweep 4s ease-in-out infinite;
}
.transfer-confirm-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-cyan);
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
}
.transfer-confirm-sub {
  font-size: 14rpx;
  color: rgba(0, 200, 255,0.4);
  letter-spacing: 3rpx;
  font-family: monospace;
  position: relative;
  z-index: 1;
}

/* reduce-motion 降级 */
.reduce-motion .transfer-confirm::before {
  animation: none;
}
.reduce-motion .transfer-key,
.reduce-motion .transfer-confirm {
  transition: none;
}


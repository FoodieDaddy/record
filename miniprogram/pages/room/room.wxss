.trajectory-link::after,
.vcp-actions button::after,
.vcp-danger::after {
  border: none;
}

.meta-copy {
  width: 58rpx;
  height: 30rpx;
  border: 1rpx solid rgba(0,200,255,0.24);
  font-size: 18rpx;
  color: rgba(0,200,255,0.72);
}

.deck-meta-chips {

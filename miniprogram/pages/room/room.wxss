.room-page {
  padding: var(--spacing-md);
  padding-bottom: 160rpx;
  min-height: 100vh;
}

/* 隐藏所有滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}

/* ===== 纯色线框图标系统 ===== */
/* 锁 */
.icon-lock-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-lock {
  width: 28rpx;
  height: 22rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
  border-radius: 6rpx;
  position: relative;
}
.icon-lock::before {
  content: '';
  position: absolute;
  top: -14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 14rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
  border-bottom: none;
  border-radius: 10rpx 10rpx 0 0;
}
/* 分享/导出 */
.icon-share {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-share::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: 10rpx;
  background: currentColor;
}
.icon-share::after {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%) rotate(45deg);
  width: 8rpx;
  height: 8rpx;
  border-top: 2rpx solid currentColor;
  border-right: 2rpx solid currentColor;
}
/* 链接 */
.icon-link {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 10rpx;
  position: relative;
  opacity: 0.8;
}
.icon-link::before {
  content: '';
  position: absolute;
  top: 50%;
  left: -6rpx;
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
.icon-link::after {
  content: '';
  position: absolute;
  top: 50%;
  right: -6rpx;
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
/* 剪贴板 */
.icon-clip {
  width: 22rpx;
  height: 26rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-clip::before {
  content: '';
  position: absolute;
  top: -4rpx;
  left: 4rpx;
  right: 4rpx;
  height: 6rpx;
  border: 2rpx solid currentColor;
  border-radius: 3rpx 3rpx 0 0;
}
/* 人物 */
.icon-person {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  position: relative;
  opacity: 0.8;
}
.icon-person::before {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 10rpx;
  border: 2rpx solid currentColor;
  border-bottom: none;
  border-radius: 12rpx 12rpx 0 0;
}
/* 图表 */
.icon-chart {
  width: 22rpx;
  height: 22rpx;
  position: relative;
  opacity: 0.8;
}
.icon-chart::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 6rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
.icon-chart::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10rpx;
  width: 6rpx;
  height: 14rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
/* 聊天 */
.icon-chat {
  width: 24rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 6rpx 6rpx 6rpx 0;
  position: relative;
  opacity: 0.8;
}
.icon-chat::before {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: -2rpx;
  width: 8rpx;
  height: 6rpx;
  border-left: 2rpx solid currentColor;
  transform: skewX(-20deg);
}
/* 图片 */
.icon-image {
  width: 22rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-image::before {
  content: '';
  position: absolute;
  bottom: 3rpx;
  left: 2rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 6rpx solid currentColor;
}
/* 相机 */
.icon-cam {
  width: 24rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-cam::before {
  content: '';
  position: absolute;
  top: -5rpx;
  left: 6rpx;
  width: 10rpx;
  height: 5rpx;
  border: 2rpx solid currentColor;
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
}
.icon-cam::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 8rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}
/* 音频开 */
.icon-audio-on {
  width: 20rpx;
  height: 20rpx;
  position: relative;
  opacity: 0.8;
}
.icon-audio-on::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 8rpx 8rpx 0;
}
.icon-audio-on::after {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 18rpx;
  border-right: 2rpx solid currentColor;
  border-radius: 0 12rpx 12rpx 0;
}
/* 音频关 */
.icon-audio-off {
  width: 20rpx;
  height: 20rpx;
  position: relative;
  opacity: 0.8;
}
.icon-audio-off::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 8rpx 8rpx 0;
}
.icon-audio-off::after {
  content: '';
  position: absolute;
  right: 0;
  top: 2rpx;
  width: 2rpx;
  height: 18rpx;
  background: currentColor;
  transform: rotate(45deg);
  transform-origin: center;
}
/* 门 */
.icon-door {
  width: 18rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 3rpx 6rpx 6rpx 3rpx;
  position: relative;
  opacity: 0.8;
}
.icon-door::before {
  content: '';
  position: absolute;
  top: 50%;
  right: 4rpx;
  transform: translateY(-50%);
  width: 4rpx;
  height: 4rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}
/* 垃圾桶 */
.icon-trash {
  width: 18rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 0 4rpx 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-trash::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 2rpx;
  right: 2rpx;
  height: 4rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
.icon-trash::after {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
/* 网格视图 */
.icon-grid {
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
  position: relative;
  opacity: 0.8;
}
.icon-grid::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
  transform: translateY(-50%);
}
.icon-grid::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: currentColor;
  transform: translateX(-50%);
}
/* 列表视图 */
.icon-list {
  width: 18rpx;
  height: 18rpx;
  position: relative;
  opacity: 0.8;
}
.icon-list::before {
  content: '';
  position: absolute;
  top: 3rpx;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
}
.icon-list::after {
  content: '';
  position: absolute;
  bottom: 3rpx;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
}
/* 空状态文档（线框 + 折角） */
.icon-empty-doc {
  width: 44rpx;
  height: 56rpx;
  border: 2rpx solid rgba(255,255,255,0.6);
  border-radius: 4rpx;
  position: relative;
  opacity: 0.2;
  margin-bottom: 16rpx;
}
.icon-empty-doc::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 14rpx;
  height: 14rpx;
  background: linear-gradient(135deg, transparent 50%, rgba(255,255,255,0.6) 50%);
  border-radius: 0 4rpx 0 0;
}
.icon-empty-doc::after {
  content: '';
  position: absolute;
  top: 24rpx;
  left: 8rpx;
  right: 8rpx;
  height: 2rpx;
  background: rgba(255,255,255,0.6);
}
/* 按钮内图标尺寸 */
.matrix-btn-icon-svg {
  width: 20rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-action-svg {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

/* ===== 顶部提示 ===== */
.top-toast {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  padding: 20rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(81, 207, 102, 0.9);
  transform: translateY(-100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  backdrop-filter: blur(20rpx);
}
.top-toast-show {
  transform: translateY(0);
}
.top-toast-error {
  background: rgba(255, 107, 107, 0.9);
}

/* ===== 未登录状态 ===== */
.empty-auth {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
}

.empty-auth-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 无房间状态 ===== */
.empty-room {
  padding-top: 32rpx;
}

.create-card,
.join-card {
  padding: 36rpx 32rpx 40rpx;
}

/* 主按钮：深邃蓝 + 悬浮光晕 */
.create-card .btn-primary,
.join-card .btn-primary {
  background: #0A84FF;
  background: linear-gradient(135deg, #0A84FF, #0066CC);
  box-shadow: 0 8rpx 20rpx rgba(10, 132, 255, 0.2);
  letter-spacing: 2rpx;
  border-radius: 20rpx;
}

.create-card .btn-primary:active,
.join-card .btn-primary:active {
  box-shadow: 0 4rpx 12rpx rgba(10, 132, 255, 0.15);
  transform: scale(0.98);
}

/* 加入按钮：未满 6 位 → 禁用态 */
.join-card .btn-join-disabled {
  background: rgba(10, 132, 255, 0.2);
  box-shadow: none;
  color: rgba(255, 255, 255, 0.35);
}

/* 加入按钮：满 6 位 → 就绪态（更亮） */
.join-card .btn-join-ready {
  background: linear-gradient(135deg, #0A84FF, #0066CC);
  box-shadow: 0 8rpx 24rpx rgba(10, 132, 255, 0.3);
}

.card-header {
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.form-label {
  width: 80rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
  flex-shrink: 0;
}

/* 或分割线 */
.divider-glow {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 32rpx 0;
}
.divider-glow::before,
.divider-glow::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--glass-border-light), transparent);
}
.divider-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.join-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.btn-secondary-scan {
  width: 96rpx;
  height: 80rpx;
  background: var(--glass-bg);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0;
}
.btn-secondary-scan:active {
  background: var(--glass-bg-hover);
}

.scan-icon {
  font-size: 36rpx;
}

/* 加入房间头部行 */
.join-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.scan-btn-corner {
  padding: 8rpx 20rpx;
  background: rgba(79, 140, 255, 0.1);
  border: 1rpx solid rgba(79, 140, 255, 0.25);
  border-radius: 24rpx;
  transition: all 0.2s ease;
}

.scan-btn-corner:active {
  background: rgba(79, 140, 255, 0.2);
  transform: scale(0.95);
}

.scan-icon-text {
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 500;
}

/* ===== 记分规则选择器 ===== */
.mode-selector {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.mode-card {
  flex: 1;
  position: relative;
  padding: 28rpx 24rpx 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
}

.mode-card-active {
  border-color: rgba(79, 140, 255, 0.4);
  background: rgba(79, 140, 255, 0.08);
  box-shadow: 0 0 40rpx rgba(79, 140, 255, 0.1), inset 0 0 20rpx rgba(79, 140, 255, 0.03);
  transform: scale(1) translateY(-4rpx);
}

.mode-card-inactive {
  opacity: 1;
  transform: scale(0.97) translateY(4rpx);
}

.mode-card-inactive:active {
  transform: scale(0.98) translateY(2rpx);
}

.mode-card-inactive .mode-card-title {
  color: rgba(255, 255, 255, 0.6);
}

.mode-card-inactive .mode-card-desc {
  color: rgba(255, 255, 255, 0.3);
}

.mode-card-inactive .mode-icon-wrap {
  opacity: 0.3;
}

.mode-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.mode-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.mode-card-desc {
  display: block;
  font-size: 20rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
}

.mode-check {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mode-check::after {
  content: '';
  width: 16rpx;
  height: 8rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(-45deg);
  margin-top: -4rpx;
  animation: checkPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes checkPop {
  0% { transform: scale(0); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* 模式图标：自由流转（双向箭头） */
.mode-icon-free {
  position: relative;
  width: 60rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-arrow {
  position: absolute;
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 300;
  line-height: 1;
}

.icon-arrow-left {
  left: 0;
  top: 50%;
  transform: translateY(-50%);
}

.icon-arrow-right {
  right: 0;
  top: 50%;
  transform: translateY(-50%);
}

.icon-node-center {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--accent);
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

/* 模式图标：赢家统录（发散节点） */
.mode-icon-winner {
  position: relative;
  width: 60rpx;
  height: 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-node-top {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--accent);
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
}

.icon-line {
  position: absolute;
  width: 1rpx;
  height: 20rpx;
  background: rgba(79, 140, 255, 0.4);
  top: 16rpx;
}

.icon-line-left {
  left: 10rpx;
  transform: rotate(-20deg);
  transform-origin: top center;
}

.icon-line-center {
  left: 50%;
  transform: translateX(-50%);
}

.icon-line-right {
  right: 10rpx;
  transform: rotate(20deg);
  transform-origin: top center;
}

.icon-bottom-row {
  position: absolute;
  bottom: 0;
  display: flex;
  gap: 14rpx;
}

.icon-node-sm {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(79, 140, 255, 0.5);
}

/* ===== 扫码按钮（内联图标） ===== */
.scan-btn-inline {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 28rpx;
  transition: all 0.2s ease;
}

.scan-btn-inline:active {
  background: rgba(255, 255, 255, 0.08);
  transform: scale(0.95);
}

.scan-icon-svg {
  width: 32rpx;
  height: 32rpx;
  position: relative;
}

.scan-corner {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-color: var(--accent);
  border-style: solid;
  border-width: 0;
}

.scan-corner-tl {
  top: 0; left: 0;
  border-top-width: 2rpx;
  border-left-width: 2rpx;
}

.scan-corner-tr {
  top: 0; right: 0;
  border-top-width: 2rpx;
  border-right-width: 2rpx;
}

.scan-corner-bl {
  bottom: 0; left: 0;
  border-bottom-width: 2rpx;
  border-left-width: 2rpx;
}

.scan-corner-br {
  bottom: 0; right: 0;
  border-bottom-width: 2rpx;
  border-right-width: 2rpx;
}

.scan-line {
  position: absolute;
  top: 50%;
  left: 4rpx;
  right: 4rpx;
  height: 1rpx;
  background: var(--accent);
  transform: translateY(-50%);
  opacity: 0.6;
}

.scan-label {
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* ===== 6 格 OTP 输入 ===== */
.otp-container {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  margin: 24rpx 0 8rpx;
}

.otp-box {
  width: 80rpx;
  height: 92rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.otp-box-focus {
  border-color: var(--accent);
  box-shadow: 0 0 24rpx rgba(79, 140, 255, 0.15);
  background: rgba(79, 140, 255, 0.05);
  transform: scale(1.05);
}

.otp-box-filled {
  border-color: rgba(255, 255, 255, 0.15);
}

.otp-char {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 0;
  font-family: "SF Pro Display", -apple-system, monospace;
}

.otp-cursor {
  width: 2rpx;
  height: 32rpx;
  background: var(--accent);
  border-radius: 1rpx;
  animation: cursorBlink 1s ease-in-out infinite;
}

@keyframes cursorBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

.otp-hidden-input {
  position: absolute;
  left: -9999rpx;
  top: 0;
  width: 0;
  height: 0;
  opacity: 0;
}

/* ===== 已有房间快捷入口 ===== */
.has-room {
  padding-top: 32rpx;
  animation: fadeSlideUp 0.3s ease;
}

.room-quick-card {
  padding: 36rpx 32rpx;
}

.rq-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.rq-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rq-room-no {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 6rpx;
  font-variant-numeric: tabular-nums;
}

.rq-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-accent {
  background: rgba(79, 140, 255, 0.15);
  color: var(--accent);
  border: 1rpx solid rgba(79, 140, 255, 0.3);
}

.badge-success {
  background: rgba(81, 207, 102, 0.15);
  color: #51cf66;
  border: 1rpx solid rgba(81, 207, 102, 0.3);
}

.rq-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.rq-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.rq-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 0;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: var(--border-radius-sm);
  transition: all 0.2s ease;
  line-height: normal;
  margin: 0;
  font-size: inherit;
  color: inherit;
}

.rq-action-btn::after {
  border: none;
}

.rq-action-btn:active {
  background: rgba(79, 140, 255, 0.12);
  transform: scale(0.96);
}

.rq-action-icon {
  font-size: 36rpx;
}

.rq-action-btn [class^="icon-"] {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
}

.rq-action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ===== 房间内容 ===== */
.room-content {
  height: 100vh;
  overflow: hidden;
  animation: fadeSlideUp 0.3s ease;
}

/* 顶部信息卡片 */
.room-top-card {
  padding: 24rpx 28rpx;
  position: relative;
}

.hero-glow {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(79, 140, 255, 0.4), transparent);
}

.top-card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.top-card-info {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.top-card-label {
  font-size: 22rpx;
}

.top-card-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #0A84FF;
  letter-spacing: 4rpx;
  font-family: "SF Mono", "Menlo", "Courier New", monospace;
  font-variant-numeric: tabular-nums;
}

.top-card-actions {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.tc-action {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  opacity: 0.6;
  color: #fff;
}

.tc-action:active {
  opacity: 0.3;
  transform: scale(0.9);
}

.tc-audio-on {
  background: rgba(79, 140, 255, 0.1);
}

.tc-danger .tc-icon {
  opacity: 0.5;
}

/* QR码 */
.qr-section {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.qr-frame {
  padding: 12rpx;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid var(--glass-border);
  border-radius: 16rpx;
}

.qr-image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 10rpx;
  display: block;
}

/* ===== 成员网格（4 列） ===== */
.member-section {
  padding-bottom: 20rpx;
}

/* 模式切换按钮 */
.mode-toggle {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  background: rgba(79, 140, 255, 0.1);
  border: 1rpx solid rgba(79, 140, 255, 0.2);
  border-radius: 32rpx;
  transition: all 0.2s ease;
}
.mode-toggle:active {
  background: rgba(79, 140, 255, 0.2);
  transform: scale(0.95);
}
.mode-toggle-icon {
  font-size: 22rpx;
}
/* mode-toggle uses CSS icon classes now */
.mode-toggle [class^="icon-"] {
  width: 20rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent);
}
.mode-toggle-text {
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 500;
}

/* 座位模式容器 */
.seat-container {
  min-height: 560rpx;
  position: relative;
}

.member-grid-scroll {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.member-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx 6rpx;
}

.mg-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 4rpx;
  border-radius: var(--border-radius-sm);
  transition: all 0.2s ease;
  position: relative;
  min-width: 0;
  overflow: hidden;
}

.mg-cell:active {
  transform: scale(0.92);
  background: rgba(255,255,255,0.04);
}

.mg-cell-on {
  background: rgba(10, 132, 255, 0.06);
  border: 1rpx solid rgba(10, 132, 255, 0.5);
  box-shadow: 0 0 20rpx rgba(10, 132, 255, 0.1);
}

.mg-avatar-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mg-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.15);
  overflow: hidden;
  display: block;
}

.mg-cell .auto-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.auto-avatar-char {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.mg-glow {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(10, 132, 255, 0.5);
  box-shadow: 0 0 16rpx rgba(10, 132, 255, 0.3);
  animation: pulseGlow 1.5s ease-in-out infinite;
}

@keyframes pulseGlow {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(1.04); }
}

.mg-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.mg-score {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  max-width: 100%;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 1rpx;
}

.mg-pos {
  color: #ff8a65;
}

.mg-neg {
  color: #4dd0e1;
}

/* ===== 弹窗头部（共享） ===== */
.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
  border-radius: 50%;
}

.detail-close:active {
  background: rgba(255,255,255,0.08);
}

/* ===== 计分动画 ===== */
.transfer-anim-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 150;
  pointer-events: none;
}

.transfer-anim-flash {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 40%, rgba(79, 140, 255, 0.15), transparent 70%);
  transition: opacity 0.15s;
}

.transfer-anim-particle {
  position: absolute;
  width: 16px;
  height: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  will-change: transform, left, top;
}

.transfer-anim-trail {
  position: absolute;
  width: 16px;
  height: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  will-change: transform, left, top;
}

.transfer-anim-dot {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: radial-gradient(circle, #6aabff, rgba(79, 140, 255, 0.5));
  box-shadow: 0 0 16px 6px rgba(79, 140, 255, 0.7),
              0 0 32px 12px rgba(79, 140, 255, 0.4),
              0 0 48px 20px rgba(79, 140, 255, 0.2);
}

.transfer-anim-dot-trail {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79, 140, 255, 0.6), rgba(79, 140, 255, 0.2));
  box-shadow: 0 0 10px 4px rgba(79, 140, 255, 0.4);
}

.dot-trail-2 {
  width: 8px;
  height: 8px;
  background: radial-gradient(circle, rgba(120, 180, 255, 0.5), rgba(79, 140, 255, 0.1));
  box-shadow: 0 0 8px 3px rgba(79, 140, 255, 0.3);
}

.transfer-anim-amount {
  position: absolute;
  top: -36px;
  white-space: nowrap;
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 0 12px rgba(79, 140, 255, 0.9),
               0 0 24px rgba(79, 140, 255, 0.5),
               0 2px 4px rgba(0, 0, 0, 0.3);
  font-variant-numeric: tabular-nums;
}

/* ===== 数字键盘 ===== */
.numpad-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: all 0.25s ease;
}

.numpad-show {
  opacity: 1;
  visibility: visible;
}

.numpad-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(20, 20, 20, 0.85);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 40rpx 40rpx 0 0;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}

.numpad-show .numpad-sheet {
  transform: translateY(0);
}

.numpad-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.numpad-player-name {
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 12rpx;
}

.numpad-display {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  width: 100%;
  justify-content: center;
}

.numpad-display-value {
  font-size: 88rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  color: #fff;
  letter-spacing: 2rpx;
}

.numpad-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 400;
  align-self: flex-end;
  margin-bottom: 8rpx;
}

/* 留证区 */
.evidence-area {
  margin-bottom: 20rpx;
}

.evidence-dashed {
  border: 1rpx dashed rgba(255,255,255,0.12);
  border-radius: var(--border-radius-sm);
  padding: 20rpx;
  background: rgba(255,255,255,0.015);
  min-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.evidence-empty {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.evidence-icon {
  font-size: 28rpx;
  opacity: 0.6;
}

.evidence-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.evidence-thumbs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  width: 100%;
}

.evidence-thumb {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  flex-shrink: 0;
}

.thumb-img {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
  border: 1rpx solid var(--glass-border);
}

.thumb-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 28rpx;
  height: 28rpx;
  background: var(--danger);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  z-index: 2;
}

.evidence-add {
  width: 100rpx;
  height: 100rpx;
  border: 1rpx dashed rgba(255,255,255,0.15);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.evidence-add-icon {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

.numpad-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.numpad-key {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.04);
  border: none;
  border-radius: 16rpx;
  font-size: 40rpx;
  font-weight: 500;
  color: #fff;
  transition: background 0.15s ease;
}

.numpad-key:active {
  background: rgba(255, 255, 255, 0.15);
}

.numpad-key-func {
  background: transparent;
  color: rgba(255, 255, 255, 0.4);
  font-size: 32rpx;
}

.numpad-key-func:active {
  background: rgba(255, 255, 255, 0.08);
}

.numpad-actions {
  margin-top: 4rpx;
}

.numpad-confirm {
  width: 100%;
  height: 96rpx;
  background: #0A84FF;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  border-radius: var(--border-radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(10, 132, 255, 0.25);
  letter-spacing: 2rpx;
}

.numpad-confirm:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ===== 积分记录标题按钮（极简胶囊） ===== */
.matrix-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border: none;
  border-radius: 32rpx;
  transition: all 0.2s ease;
}

.matrix-btn:active {
  background: rgba(255, 255, 255, 0.15);
  transform: scale(0.95);
}

.matrix-btn-icon {
  font-size: 20rpx;
  opacity: 0.5;
}

.matrix-btn-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 400;
}

/* "我"过滤按钮 */
.filter-btn {
  padding: 8rpx 16rpx;
  opacity: 0.4;
  transition: all 0.2s ease;
}

.filter-btn-on {
  opacity: 1;
  background: rgba(10, 132, 255, 0.2);
}

/* ===== 积分记录滚动区域 ===== */
.score-records-scroll {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ===== 积分记录分组 ===== */
.score-record-card {
  overflow: visible;
}

.sr-time-header {
  position: sticky;
  top: 0;
  z-index: 5;
  padding: 16rpx 8rpx 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 500;
  font-variant-numeric: tabular-nums;
  background: rgba(18, 18, 18, 0.92);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.sr-loading {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

/* ===== 积分记录 ===== */
.empty-batches {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  gap: 8rpx;
}

.empty-icon-sm {
  font-size: 36rpx;
  opacity: 0.5;
}

.empty-hint-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

.score-records {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-top: 12rpx;
}

.sr-item {
  display: flex;
  align-items: center;
  padding: 16rpx 8rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}

.sr-item:last-child {
  border-bottom: none;
}


/* 3 列左对齐：名称让空间，金额优先显示全 */
.sr-col {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.sr-from {
  width: 35%;
  justify-content: flex-start;
}

.sr-amount {
  width: 30%;
  justify-content: flex-start;
  gap: 4rpx;
  flex-shrink: 0;
}

.sr-to {
  width: 35%;
  justify-content: flex-start;
}

.sr-avatar-wrap {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sr-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.auto-avatar-xs {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auto-avatar-char-xs {
  font-size: 18rpx;
  font-weight: 600;
  color: #fff;
}

.sr-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sr-amount-text {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--accent);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

.sr-arrow-icon {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.sr-amt-gray {
  color: var(--text-tertiary);
}

.sr-amt-red {
  color: #ff6b6b;
}

.sr-amt-green {
  color: #51cf66;
}

/* ===== 积分表格 ===== */
/* ===== 结束本轮按钮 ===== */
.settle-bar {
  position: fixed;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  z-index: 101;
}

.btn-settle {
  min-width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, var(--warning), #e67e22);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(243, 156, 18, 0.3);
  padding: 0 48rpx;
}
.btn-settle:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* ===== 通用工具 ===== */
.score-number {
  font-variant-numeric: tabular-nums;
}

.flex-1 {
  flex: 1;
  min-width: 0;
}

.text-center {
  text-align: center;
}

@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== 历史场次 ===== */
.history-scroll {
  max-height: 70vh;
}

.history-item {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: var(--border-radius-sm);
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}
.history-item:last-child {
  margin-bottom: 0;
}
.history-item:active {
  background: rgba(79, 140, 255, 0.1);
}

.history-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.history-players {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.history-player-avatar {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-avatar-img {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
}

.history-time-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* 历史详情批次 */
.detail-batch {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.detail-batch:last-child {
  border-bottom: none;
}

.detail-batch-time {
  margin-bottom: 8rpx;
  display: block;
}

.detail-batch-scores {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-batch-score {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.detail-batch-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.detail-batch-val {
  font-size: 24rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* ===== 分享面板 ===== */
.share-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 250;
  opacity: 0;
  visibility: hidden;
  transition: all 0.25s ease;
}
.share-show {
  opacity: 1;
  visibility: visible;
}
.share-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(20, 20, 20, 0.97);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border-top: 1rpx solid var(--glass-border);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}
.share-show .share-sheet {
  transform: translateY(0);
}
.share-qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 0;
}
.share-qr-frame {
  padding: 16rpx;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid var(--glass-border);
  border-radius: 20rpx;
}
.share-qr-image {
  width: 280rpx;
  height: 280rpx;
  border-radius: 12rpx;
  display: block;
}
.share-qr-placeholder {
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-qr-room-no {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--accent);
  font-variant-numeric: tabular-nums;
  letter-spacing: 8rpx;
}
.share-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}
.share-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  background: rgba(255,255,255,0.04);
  border-radius: var(--border-radius-sm);
  transition: all 0.2s ease;
  line-height: normal;
  margin: 0;
  font-size: inherit;
  color: inherit;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.share-action-btn::after {
  border: none;
}
.share-action-btn:active {
  background: rgba(79, 140, 255, 0.12);
  transform: scale(0.96);
}
.share-action-icon {
  font-size: 40rpx;
}
.share-action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ========== 座位编辑工具栏 ========== */
.seat-edit-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 12rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--border-radius-sm);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.seat-edit-btn {
  padding: 10rpx 24rpx;
  background: rgba(79, 140, 255, 0.15);
  border-radius: 24rpx;
  border: 1rpx solid rgba(79, 140, 255, 0.3);
  transition: all 0.2s ease;
}

.seat-edit-btn:active {
  background: rgba(79, 140, 255, 0.25);
  transform: scale(0.95);
}

.seat-edit-text {
  font-size: 24rpx;
  color: rgba(79, 140, 255, 0.9);
  font-weight: 500;
}

.seat-edit-active-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.seat-edit-done {
  background: rgba(255, 200, 0, 0.15);
  border-color: rgba(255, 200, 0, 0.3);
}

.seat-edit-done .seat-edit-text {
  color: rgba(255, 200, 0, 0.9);
}

.seat-edit-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
}

.layout-switcher {
  display: flex;
  gap: 8rpx;
  margin-left: auto;
}

.layout-opt {
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.2s ease;
}

.layout-opt:active {
  transform: scale(0.95);
}

.layout-opt text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.layout-active {
  background: rgba(79, 140, 255, 0.12);
  border-color: rgba(79, 140, 255, 0.3);
}

.layout-active text {
  color: rgba(79, 140, 255, 0.9);
}

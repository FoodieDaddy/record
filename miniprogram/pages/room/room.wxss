.room-page {
  padding: var(--spacing-md);
  padding-bottom: 160rpx;
  min-height: 100vh;
}

/* 隐藏所有滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}

/* ===== 纯色线框图标系统 ===== */
/* 锁 */
.icon-lock-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-lock {
  width: 28rpx;
  height: 22rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
  border-radius: 6rpx;
  position: relative;
}
.icon-lock::before {
  content: '';
  position: absolute;
  top: -14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 14rpx;
  border: 2rpx solid rgba(255,255,255,0.5);
  border-bottom: none;
  border-radius: 10rpx 10rpx 0 0;
}
/* 分享/导出 */
.icon-share {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-share::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: 10rpx;
  background: currentColor;
}
.icon-share::after {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%) rotate(45deg);
  width: 8rpx;
  height: 8rpx;
  border-top: 2rpx solid currentColor;
  border-right: 2rpx solid currentColor;
}
/* 链接 */
.icon-link {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 10rpx;
  position: relative;
  opacity: 0.8;
}
.icon-link::before {
  content: '';
  position: absolute;
  top: 50%;
  left: -6rpx;
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
.icon-link::after {
  content: '';
  position: absolute;
  top: 50%;
  right: -6rpx;
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
/* 剪贴板 */
.icon-clip {
  width: 22rpx;
  height: 26rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-clip::before {
  content: '';
  position: absolute;
  top: -4rpx;
  left: 4rpx;
  right: 4rpx;
  height: 6rpx;
  border: 2rpx solid currentColor;
  border-radius: 3rpx 3rpx 0 0;
}
/* 人物 */
.icon-person {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  position: relative;
  opacity: 0.8;
}
.icon-person::before {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 10rpx;
  border: 2rpx solid currentColor;
  border-bottom: none;
  border-radius: 12rpx 12rpx 0 0;
}
/* 图表 */
.icon-chart {
  width: 22rpx;
  height: 22rpx;
  position: relative;
  opacity: 0.8;
}
.icon-chart::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 6rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
.icon-chart::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10rpx;
  width: 6rpx;
  height: 14rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
/* 聊天 */
.icon-chat {
  width: 24rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 6rpx 6rpx 6rpx 0;
  position: relative;
  opacity: 0.8;
}
.icon-chat::before {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: -2rpx;
  width: 8rpx;
  height: 6rpx;
  border-left: 2rpx solid currentColor;
  transform: skewX(-20deg);
}
/* 图片 */
.icon-image {
  width: 22rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-image::before {
  content: '';
  position: absolute;
  bottom: 3rpx;
  left: 2rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 6rpx solid currentColor;
}
/* 相机 */
.icon-cam {
  width: 24rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-cam::before {
  content: '';
  position: absolute;
  top: -5rpx;
  left: 6rpx;
  width: 10rpx;
  height: 5rpx;
  border: 2rpx solid currentColor;
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
}
.icon-cam::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 8rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}
/* 音频开 */
.icon-audio-on {
  width: 20rpx;
  height: 20rpx;
  position: relative;
  opacity: 0.8;
}
.icon-audio-on::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 8rpx 8rpx 0;
}
.icon-audio-on::after {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 18rpx;
  border-right: 2rpx solid currentColor;
  border-radius: 0 12rpx 12rpx 0;
}
/* 音频关 */
.icon-audio-off {
  width: 20rpx;
  height: 20rpx;
  position: relative;
  opacity: 0.8;
}
.icon-audio-off::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 8rpx 8rpx 0;
}
.icon-audio-off::after {
  content: '';
  position: absolute;
  right: 0;
  top: 2rpx;
  width: 2rpx;
  height: 18rpx;
  background: currentColor;
  transform: rotate(45deg);
  transform-origin: center;
}
/* 门 */
.icon-door {
  width: 18rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 3rpx 6rpx 6rpx 3rpx;
  position: relative;
  opacity: 0.8;
}
.icon-door::before {
  content: '';
  position: absolute;
  top: 50%;
  right: 4rpx;
  transform: translateY(-50%);
  width: 4rpx;
  height: 4rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}
/* 垃圾桶 */
.icon-trash {
  width: 18rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 0 4rpx 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-trash::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 2rpx;
  right: 2rpx;
  height: 4rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
.icon-trash::after {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
/* 网格视图 */
.icon-grid {
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
  position: relative;
  opacity: 0.8;
}
.icon-grid::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
  transform: translateY(-50%);
}
.icon-grid::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: currentColor;
  transform: translateX(-50%);
}
/* 列表视图 */
.icon-list {
  width: 18rpx;
  height: 18rpx;
  position: relative;
  opacity: 0.8;
}
.icon-list::before {
  content: '';
  position: absolute;
  top: 3rpx;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
}
.icon-list::after {
  content: '';
  position: absolute;
  bottom: 3rpx;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
}
/* 空状态：雷达网格扫描仪 */
.icon-empty-doc {
  width: 64rpx;
  height: 64rpx;
  position: relative;
  margin-bottom: 20rpx;
  opacity: 0.15;
}
.icon-empty-doc::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 56rpx;
  height: 56rpx;
  border: 1.5rpx solid #0a84ff;
  border-radius: 50%;
  box-shadow:
    inset 0 0 0 14rpx transparent,
    inset 0 0 0 15.5rpx rgba(10, 132, 255, 0.4),
    inset 0 0 0 28rpx transparent,
    inset 0 0 0 29.5rpx rgba(10, 132, 255, 0.25);
}
.icon-empty-doc::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 1.5rpx;
  height: 28rpx;
  background: rgba(10, 132, 255, 0.5);
  transform: translate(-50%, -100%);
  transform-origin: bottom center;
  box-shadow:
    0 0 0 0 transparent,
    0 0 6rpx 1rpx rgba(10, 132, 255, 0.3);
}
/* 按钮内图标尺寸 */
.matrix-btn-icon-svg {
  width: 20rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-action-svg {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

/* ===== 顶部提示 ===== */
.top-toast {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  padding: 20rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(81, 207, 102, 0.9);
  transform: translateY(-100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  backdrop-filter: blur(20rpx);
}
.top-toast-show {
  transform: translateY(0);
}
.top-toast-error {
  background: rgba(255, 107, 107, 0.9);
}

/* ===== 未登录状态 ===== */
.empty-auth {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
}

.empty-auth-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 无房间状态 ===== */
.empty-room {
  padding-top: 32rpx;
}

/* ===== 赛博终端卡片 ===== */
.cyber-card {
  background: rgba(255, 255, 255, 0.02);
  border: 1rpx solid rgba(0, 170, 255, 0.18);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}
.cyber-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0, 170, 255, 0.015), transparent 40%);
  pointer-events: none;
}

/* 系统状态栏 */
.cyber-system-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 4rpx;
}
.cyber-system-name {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.25);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.cyber-system-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.cyber-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #30d158;
  box-shadow: 0 0 8rpx rgba(48, 209, 88, 0.6);
}
.cyber-status-text {
  font-size: 18rpx;
  color: #30d158;
  letter-spacing: 2rpx;
}

/* 分隔线 */
.cyber-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.04);
  margin: 20rpx 0;
}

/* 双层标题 */
.cyber-section-title {
  margin-bottom: 16rpx;
}
.cyber-cn {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
  line-height: 1.4;
}
.cyber-en {
  display: block;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.2);
  letter-spacing: 4rpx;
  font-family: monospace;
  margin-top: 2rpx;
}

/* ===== 模式选择卡 ===== */
.cyber-mode-cards {
  display: flex;
  gap: 16rpx;
}
.cyber-mode-card {
  flex: 1;
  padding: 20rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  background: transparent;
  transition: all 0.3s ease;
}
.cyber-mode-active {
  border-color: rgba(0, 191, 255, 0.5);
  background: rgba(0, 191, 255, 0.04);
}
.cyber-mode-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}
.cyber-mode-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  background: transparent;
  flex-shrink: 0;
  transition: all 0.3s ease;
}
.mode-dot-on {
  border-color: #00BFFF;
  background: #00BFFF;
  box-shadow: 0 0 12rpx #00BFFF;
}
.cyber-mode-name {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.6);
  transition: color 0.3s ease;
}
.cyber-mode-active .cyber-mode-name {
  color: #fff;
}
.cyber-mode-badge {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 6rpx;
  padding: 2rpx 8rpx;
  margin-left: auto;
  transition: all 0.3s ease;
}
.badge-on {
  color: #00BFFF;
  border-color: rgba(0, 191, 255, 0.4);
  background: rgba(0, 191, 255, 0.08);
}
.cyber-mode-desc {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.2);
  line-height: 1.5;
  padding-left: 22rpx;
}

/* ===== 录入方式卡片 ===== */
.cyber-cards {
  display: flex;
  gap: 16rpx;
}
.cyber-opt-card {
  flex: 1;
  position: relative;
  padding: 20rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  background: transparent;
  transition: all 0.3s ease;
  overflow: hidden;
}
.cyber-opt-active {
  border-color: rgba(0, 191, 255, 0.5);
  background: rgba(0, 191, 255, 0.04);
}
.cyber-opt-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 8rpx;
}
.cyber-opt-check {
  font-size: 18rpx;
  color: #00BFFF;
}
.cyber-opt-status-text {
  font-size: 16rpx;
  color: #00BFFF;
  letter-spacing: 2rpx;
}
.cyber-opt-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 6rpx;
  transition: color 0.3s ease;
}
.cyber-opt-active .cyber-opt-title {
  color: #fff;
}
.cyber-opt-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  line-height: 1.4;
}
.cyber-opt-hint {
  display: block;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.15);
  margin-top: 6rpx;
}
.cyber-opt-active .cyber-opt-hint {
  color: rgba(0, 191, 255, 0.4);
}

/* ===== 芯片选择器 ===== */
.cyber-chips {
  display: flex;
  gap: 16rpx;
}
.cyber-chip {
  flex: 1;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 12rpx 16rpx;
  color: rgba(255, 255, 255, 0.25);
  background: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  transition: all 0.3s ease;
}
.cyber-chip-active {
  color: #00BFFF;
  border-color: rgba(0, 191, 255, 0.5);
  background: rgba(0, 191, 255, 0.04);
}
.cyber-chip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  background: transparent;
  transition: all 0.3s ease;
  flex-shrink: 0;
}
.dot-on {
  border-color: #00BFFF;
  background: #00BFFF;
  box-shadow: 0 0 12rpx #00BFFF;
}
.cyber-chip-text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
}
.cyber-chip-main {
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}
.cyber-chip-sub {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.2);
}
.cyber-chip-active .cyber-chip-sub {
  color: rgba(0, 191, 255, 0.5);
}

/* 超时预设档位 */
.cyber-timeout-chips {
  margin-bottom: 16rpx;
}
.cyber-timeout-action {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.cyber-timeout-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  flex-shrink: 0;
  white-space: nowrap;
}

/* ===== 配置预览面板 ===== */
.cyber-preview {
  padding: 4rpx 0;
}
.cyber-preview-title {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.2);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  font-family: monospace;
}
.cyber-preview-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}
.cyber-preview-key {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}
.cyber-preview-val {
  font-size: 22rpx;
  color: #00BFFF;
  font-weight: 500;
}

/* ===== 启动房间按钮（切角） ===== */
.cyber-create-btn {
  padding: 8rpx 0;
}
.cyber-create-inner {
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  background: linear-gradient(135deg, rgba(0, 191, 255, 0.12), rgba(0, 120, 255, 0.06));
  border: 1rpx solid rgba(0, 191, 255, 0.35);
  border-radius: 12rpx;
  color: #00BFFF;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  clip-path: polygon(16rpx 0, calc(100% - 16rpx) 0, 100% 16rpx, 100% calc(100% - 16rpx), calc(100% - 16rpx) 100%, 16rpx 100%, 0 calc(100% - 16rpx), 0 16rpx);
}
.cyber-create-inner::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(0, 191, 255, 0.08), transparent);
  animation: cyberSweep 4s ease-in-out infinite;
}
.cyber-create-inner:active {
  background: linear-gradient(135deg, rgba(0, 191, 255, 0.2), rgba(0, 120, 255, 0.12));
  transform: scale(0.98);
}
.cyber-create-text {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
}
.cyber-create-sub {
  font-size: 16rpx;
  color: rgba(0, 191, 255, 0.4);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.btn-loading {
  opacity: 0.5;
}

@keyframes cyberSweep {
  0% { left: -100%; }
  50% { left: 100%; }
  100% { left: 100%; }
}

/* 主按钮：加入房间（保留原样式） */
.card-header {
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.form-label {
  width: 80rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
  flex-shrink: 0;
}

/* 或分割线 */
.divider-glow {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 32rpx 0;
}
.divider-glow::before,
.divider-glow::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--glass-border-light), transparent);
}
.divider-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.join-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.btn-secondary-scan {
  width: 96rpx;
  height: 80rpx;
  background: var(--glass-bg);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0;
}
.btn-secondary-scan:active {
  background: var(--glass-bg-hover);
}

.scan-icon {
  font-size: 36rpx;
}

/* ===== 扫描接入卡片 ===== */
.cyber-scan-card {
  padding: 24rpx;
  border: 1rpx solid rgba(0, 191, 255, 0.2);
  border-radius: 12rpx;
  background: rgba(0, 191, 255, 0.03);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s ease;
}
.cyber-scan-card:active {
  background: rgba(0, 191, 255, 0.08);
  transform: scale(0.98);
}
.cyber-scan-icon {
  width: 56rpx;
  height: 56rpx;
  position: relative;
}
.cyber-scan-corner {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-color: #00BFFF;
  border-style: solid;
  border-width: 0;
}
.cyber-scan-tl { top: 0; left: 0; border-top-width: 2rpx; border-left-width: 2rpx; }
.cyber-scan-tr { top: 0; right: 0; border-top-width: 2rpx; border-right-width: 2rpx; }
.cyber-scan-bl { bottom: 0; left: 0; border-bottom-width: 2rpx; border-left-width: 2rpx; }
.cyber-scan-br { bottom: 0; right: 0; border-bottom-width: 2rpx; border-right-width: 2rpx; }
.cyber-scan-line {
  position: absolute;
  top: 50%;
  left: 8rpx;
  right: 8rpx;
  height: 1rpx;
  background: #00BFFF;
  transform: translateY(-50%);
  opacity: 0.5;
  animation: scanPulse 2s ease-in-out infinite;
}
@keyframes scanPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.8; }
}
.cyber-scan-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}
.cyber-scan-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 4rpx;
}
.cyber-scan-sub {
  font-size: 18rpx;
  color: rgba(0, 191, 255, 0.5);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.cyber-scan-hint {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.2);
}

/* ===== 终端输入框 ===== */
.cyber-terminal-input {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.02);
  position: relative;
  transition: all 0.3s ease;
}
.cyber-terminal-input:active,
.cyber-terminal-input:focus-within {
  border-color: rgba(0, 191, 255, 0.4);
  background: rgba(0, 191, 255, 0.02);
}
.cyber-terminal-prefix {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(0, 191, 255, 0.4);
  font-family: monospace;
  letter-spacing: 2rpx;
  margin-right: 4rpx;
}
.cyber-terminal-field {
  flex: 1;
  height: 88rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #00BFFF;
  font-family: monospace;
  letter-spacing: 8rpx;
  background: transparent;
  caret-color: transparent;
}
.cyber-terminal-cursor {
  width: 2rpx;
  height: 36rpx;
  background: #00BFFF;
  border-radius: 1rpx;
  animation: cursorBlink 1s ease-in-out infinite;
  margin-left: 4rpx;
}
@keyframes cursorBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* ===== 房间状态反馈 ===== */
.cyber-room-status {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.02);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}
.cyber-status-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.cyber-room-status .cyber-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.dot-green {
  background: #30d158;
  box-shadow: 0 0 8rpx rgba(48, 209, 88, 0.6);
}
.dot-red {
  background: #ff453a;
  box-shadow: 0 0 8rpx rgba(255, 69, 58, 0.5);
}
.cyber-status-msg {
  font-size: 22rpx;
  letter-spacing: 1rpx;
}
.msg-green { color: #30d158; }
.msg-red { color: #ff453a; }
.cyber-room-preview {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}
.cyber-room-status .cyber-preview-row {
  display: flex;
  justify-content: space-between;
  padding: 6rpx 0;
}
.cyber-room-status .cyber-preview-key {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}
.cyber-room-status .cyber-preview-val {
  font-size: 22rpx;
  color: #00BFFF;
}

/* 按钮禁用态 */
.btn-dim {
  opacity: 0.35;
  pointer-events: none;
}

/* ===== 最近加入 ===== */
.cyber-recent-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.cyber-recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  background: transparent;
  transition: all 0.2s ease;
}
.cyber-recent-item:active {
  background: rgba(0, 191, 255, 0.04);
}
.cyber-recent-code {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-family: monospace;
  letter-spacing: 2rpx;
}
.cyber-recent-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.2);
}

/* ===== 已有房间快捷入口 ===== */
.has-room {
  padding-top: 32rpx;
  animation: fadeSlideUp 0.3s ease;
}

.room-quick-card {
  padding: 36rpx 32rpx;
}

.rq-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.rq-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rq-room-no {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 6rpx;
  font-variant-numeric: tabular-nums;
}

.rq-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-accent {
  background: rgba(79, 140, 255, 0.15);
  color: var(--accent);
  border: 1rpx solid rgba(79, 140, 255, 0.3);
}

.badge-success {
  background: rgba(81, 207, 102, 0.15);
  color: #51cf66;
  border: 1rpx solid rgba(81, 207, 102, 0.3);
}

.rq-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.rq-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.rq-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 0;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: var(--border-radius-sm);
  transition: all 0.2s ease;
  line-height: normal;
  margin: 0;
  font-size: inherit;
  color: inherit;
}

.rq-action-btn::after {
  border: none;
}

.rq-action-btn:active {
  background: rgba(79, 140, 255, 0.12);
  transform: scale(0.96);
}

.rq-action-icon {
  font-size: 36rpx;
}

.rq-action-btn [class^="icon-"] {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
}

.rq-action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ===== 房间内容 ===== */
.room-content {
  height: 100vh;
  overflow: hidden;
  animation: fadeSlideUp 0.3s ease;
}

/* ===== ROOM TERMINAL 顶部终端栏 ===== */
.room-terminal {
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(10,132,255,0.18);
  border-radius: 16rpx;
  background: rgba(255,255,255,0.035);
  position: relative;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.room-terminal::before {
  content: '';
  position: absolute;
  top: 0;
  left: 10%;
  right: 10%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(10,132,255,0.4), transparent);
}
.rt-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.rt-kicker {
  font-size: 18rpx;
  color: rgba(10,132,255,0.72);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.rt-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.rt-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #30D158;
  box-shadow: 0 0 8rpx rgba(48,209,88,0.6);
}
.rt-status-text {
  font-size: 16rpx;
  color: #30D158;
  letter-spacing: 2rpx;
  font-family: monospace;
}
.rt-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.rt-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.rt-room-no {
  font-size: 32rpx;
  font-weight: 700;
  color: #0A84FF;
  letter-spacing: 4rpx;
  font-family: "SF Mono", "Menlo", "Courier New", monospace;
  font-variant-numeric: tabular-nums;
}
.rt-meta-sep {
  font-size: 20rpx;
  color: rgba(255,255,255,0.15);
}
.rt-meta {
  font-size: 22rpx;
  color: rgba(255,255,255,0.56);
  font-variant-numeric: tabular-nums;
}
.rt-mode-tag {
  font-size: 18rpx;
  color: rgba(0,191,255,0.6);
  border: 1rpx solid rgba(0,191,255,0.2);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  letter-spacing: 1rpx;
}
.rt-actions {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.rt-action {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease, transform 0.2s ease;
  opacity: 0.6;
  color: #fff;
}
.rt-action:active {
  opacity: 0.3;
  transform: scale(0.9);
}

/* QR码 */
.qr-section {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.qr-frame {
  padding: 12rpx;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid var(--glass-border);
  border-radius: 16rpx;
}

.qr-image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 10rpx;
  display: block;
}

/* ===== 成员网格（4 列） ===== */
.member-section {
  padding-bottom: 20rpx;
}

.member-grid-scroll {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.member-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx 12rpx;
}

.mg-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 4rpx;
  padding: 16rpx 0;
  border-radius: var(--border-radius-sm);
  transition: all 0.2s ease;
  position: relative;
  min-width: 0;
}

.mg-cell:active {
  transform: scale(0.92);
  background: rgba(255,255,255,0.04);
}

.mg-cell-on {
  background: rgba(10, 132, 255, 0.06);
  border: 1rpx solid rgba(10, 132, 255, 0.5);
  box-shadow: 0 0 20rpx rgba(10, 132, 255, 0.1);
}

.mg-avatar-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mg-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.15);
  overflow: hidden;
  display: block;
}

.mg-cell .auto-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.auto-avatar-char {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.mg-glow {
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(10, 132, 255, 0.5);
  box-shadow: 0 0 16rpx rgba(10, 132, 255, 0.3);
  animation: pulseGlow 1.5s ease-in-out infinite;
}

@keyframes pulseGlow {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(1.04); }
}

.mg-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.mg-score {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  max-width: 120rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.5rpx;
  font-family: "SF Mono", "Menlo", "Courier New", monospace;
  font-variant-numeric: tabular-nums;
}

.mg-pos {
  color: #ff8a65;
}

.mg-neg {
  color: #4dd0e1;
}

/* ===== 弹窗头部（共享） ===== */
.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
  border-radius: 50%;
}

.detail-close:active {
  background: rgba(255,255,255,0.08);
}

/* ===== 计分动画 ===== */
.transfer-anim-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 150;
  pointer-events: none;
}

.transfer-anim-flash {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 40%, rgba(79, 140, 255, 0.15), transparent 70%);
  transition: opacity 0.15s;
}

.transfer-anim-particle {
  position: absolute;
  width: 16px;
  height: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  will-change: transform, left, top;
}

.transfer-anim-trail {
  position: absolute;
  width: 16px;
  height: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  will-change: transform, left, top;
}

.transfer-anim-dot {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: radial-gradient(circle, #6aabff, rgba(79, 140, 255, 0.5));
  box-shadow: 0 0 16px 6px rgba(79, 140, 255, 0.7),
              0 0 32px 12px rgba(79, 140, 255, 0.4),
              0 0 48px 20px rgba(79, 140, 255, 0.2);
}

.transfer-anim-dot-trail {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79, 140, 255, 0.6), rgba(79, 140, 255, 0.2));
  box-shadow: 0 0 10px 4px rgba(79, 140, 255, 0.4);
}

.dot-trail-2 {
  width: 8px;
  height: 8px;
  background: radial-gradient(circle, rgba(120, 180, 255, 0.5), rgba(79, 140, 255, 0.1));
  box-shadow: 0 0 8px 3px rgba(79, 140, 255, 0.3);
}

.transfer-anim-amount {
  position: absolute;
  top: -36px;
  white-space: nowrap;
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 0 12px rgba(79, 140, 255, 0.9),
               0 0 24px rgba(79, 140, 255, 0.5),
               0 2px 4px rgba(0, 0, 0, 0.3);
  font-variant-numeric: tabular-nums;
}

/* ===== 数字键盘 ===== */
.numpad-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: all 0.25s ease;
}

.numpad-show {
  opacity: 1;
  visibility: visible;
}

.numpad-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(20, 20, 20, 0.85);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 40rpx 40rpx 0 0;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}

.numpad-show .numpad-sheet {
  transform: translateY(0);
}

.numpad-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.numpad-player-name {
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 12rpx;
}

.numpad-display {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  width: 100%;
  justify-content: center;
}

.numpad-display-value {
  font-size: 88rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  color: #fff;
  letter-spacing: 2rpx;
}

.numpad-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 400;
  align-self: flex-end;
  margin-bottom: 8rpx;
}

/* 留证区 */
.evidence-area {
  margin-bottom: 20rpx;
}

.evidence-dashed {
  border: 1rpx dashed rgba(255,255,255,0.12);
  border-radius: var(--border-radius-sm);
  padding: 20rpx;
  background: rgba(255,255,255,0.015);
  min-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.evidence-empty {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.evidence-icon {
  font-size: 28rpx;
  opacity: 0.6;
}

.evidence-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.evidence-thumbs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  width: 100%;
}

.evidence-thumb {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  flex-shrink: 0;
}

.thumb-img {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
  border: 1rpx solid var(--glass-border);
}

.thumb-remove {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 28rpx;
  height: 28rpx;
  background: var(--danger);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  z-index: 2;
}

.evidence-add {
  width: 100rpx;
  height: 100rpx;
  border: 1rpx dashed rgba(255,255,255,0.15);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.evidence-add-icon {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

.numpad-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.numpad-key {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.04);
  border: none;
  border-radius: 16rpx;
  font-size: 40rpx;
  font-weight: 500;
  color: #fff;
  transition: background 0.15s ease;
}

.numpad-key:active {
  background: rgba(255, 255, 255, 0.15);
}

.numpad-key-func {
  background: transparent;
  color: rgba(255, 255, 255, 0.4);
  font-size: 32rpx;
}

.numpad-key-func:active {
  background: rgba(255, 255, 255, 0.08);
}

.numpad-actions {
  margin-top: 4rpx;
}

.numpad-confirm {
  width: 100%;
  height: 96rpx;
  background: #0A84FF;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  border-radius: var(--border-radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(10, 132, 255, 0.25);
  letter-spacing: 2rpx;
}

.numpad-confirm:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ===== 积分记录标题按钮（极简胶囊） ===== */
.matrix-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border: none;
  border-radius: 32rpx;
  transition: all 0.2s ease;
}

.matrix-btn:active {
  background: rgba(255, 255, 255, 0.15);
  transform: scale(0.95);
}

.matrix-btn-icon {
  font-size: 20rpx;
  opacity: 0.5;
}

.matrix-btn-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 400;
}

/* "我"过滤按钮 */
.filter-btn {
  padding: 8rpx 16rpx;
  opacity: 0.4;
  transition: all 0.2s ease;
}

.filter-btn-on {
  opacity: 1;
  background: rgba(10, 132, 255, 0.2);
}

/* ===== 积分记录滚动区域 ===== */
.score-records-scroll {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ===== 积分记录分组 ===== */
.score-record-card {
  overflow: visible;
}

.sr-time-header {
  position: sticky;
  top: 0;
  z-index: 5;
  padding: 16rpx 8rpx 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 500;
  font-variant-numeric: tabular-nums;
  background: rgba(18, 18, 18, 0.92);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.sr-loading {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

/* ===== 积分记录 ===== */
.empty-batches {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  gap: 8rpx;
}

.empty-icon-sm {
  font-size: 36rpx;
  opacity: 0.5;
}

.empty-hint-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

.score-records {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-top: 12rpx;
}

.sr-item {
  display: flex;
  align-items: center;
  padding: 16rpx 8rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}

.sr-item:last-child {
  border-bottom: none;
}


/* 3 列左对齐：名称让空间，金额优先显示全 */
.sr-col {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.sr-from {
  width: 35%;
  justify-content: flex-start;
}

.sr-amount {
  width: 30%;
  justify-content: flex-start;
  gap: 4rpx;
  flex-shrink: 0;
}

.sr-to {
  width: 35%;
  justify-content: flex-start;
}

.sr-avatar-wrap {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sr-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.auto-avatar-xs {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auto-avatar-char-xs {
  font-size: 18rpx;
  font-weight: 600;
  color: #fff;
}

.sr-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sr-amount-text {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--accent);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

.sr-arrow-icon {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.sr-amt-gray {
  color: #9CA3AF;
}

.sr-amt-red {
  color: #FF5A5A;
}

.sr-amt-green {
  color: #36FF74;
}

/* ===== 积分表格 ===== */

/* ===== 通用工具 ===== */
.score-number {
  font-variant-numeric: tabular-nums;
}

.flex-1 {
  flex: 1;
  min-width: 0;
}

.text-center {
  text-align: center;
}

@keyframes fadeSlideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== 历史场次 ===== */
.history-scroll {
  max-height: 70vh;
}

.history-item {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: var(--border-radius-sm);
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}
.history-item:last-child {
  margin-bottom: 0;
}
.history-item:active {
  background: rgba(79, 140, 255, 0.1);
}

.history-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.history-players {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.history-player-avatar {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-avatar-img {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
}

.history-time-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* 历史详情批次 */
.detail-batch {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.detail-batch:last-child {
  border-bottom: none;
}

.detail-batch-time {
  margin-bottom: 8rpx;
  display: block;
}

.detail-batch-scores {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-batch-score {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.detail-batch-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.detail-batch-val {
  font-size: 24rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* ===== 分享面板 ===== */
.share-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 250;
  opacity: 0;
  visibility: hidden;
  transition: all 0.25s ease;
}
.share-show {
  opacity: 1;
  visibility: visible;
}
.share-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(20, 20, 20, 0.97);
  backdrop-filter: blur(60rpx);
  -webkit-backdrop-filter: blur(60rpx);
  border-top: 1rpx solid var(--glass-border);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}
.share-show .share-sheet {
  transform: translateY(0);
}
.share-qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 0;
}
.share-qr-frame {
  padding: 16rpx;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid var(--glass-border);
  border-radius: 20rpx;
}
.share-qr-image {
  width: 280rpx;
  height: 280rpx;
  border-radius: 12rpx;
  display: block;
}
.share-qr-placeholder {
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-qr-room-no {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--accent);
  font-variant-numeric: tabular-nums;
  letter-spacing: 8rpx;
}
.share-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}
.share-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  background: rgba(255,255,255,0.04);
  border-radius: var(--border-radius-sm);
  transition: all 0.2s ease;
  line-height: normal;
  margin: 0;
  font-size: inherit;
  color: inherit;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.share-action-btn::after {
  border: none;
}
.share-action-btn:active {
  background: rgba(79, 140, 255, 0.12);
  transform: scale(0.96);
}
.share-action-icon {
  font-size: 40rpx;
}
.share-action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* WS 断线遮罩 */
.ws-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(20rpx);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}
.ws-mask--show {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}
.ws-mask__card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 64rpx;
}
.ws-mask__dot {
  width: 16rpx; height: 16rpx;
  background: #0A84FF;
  border-radius: 50%;
  animation: ws-breathe 1.6s ease-in-out infinite;
}
@keyframes ws-breathe {
  0%, 100% { transform: scale(1); opacity: 0.4; }
  50% { transform: scale(1.8); opacity: 1; }
}
.ws-mask__text {
  color: rgba(255,255,255,0.7);
  font-size: 28rpx;
}

/* 模态框打开时禁止底层滚动 */
.scroll-locked {
  overflow: hidden !important;
  pointer-events: none;
}

/* ===== 结算总览弹层 ===== */

.settle-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #0A0A0A;
  z-index: 9999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.settle-overlay--show {
  opacity: 1;
  pointer-events: auto;
}

.settle-overlay__inner {
  padding: 0 32rpx 60rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.settle-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0 16rpx;
}

.settle-header-info {
  display: flex;
  flex-direction: column;
}

.settle-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.settle-header-room {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
  margin-top: 4rpx;
}

.settle-close-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.settle-close-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.settle-section {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
}

.settle-chart-card {
  padding: 20rpx 12rpx;
}

.settle-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 20rpx;
  display: block;
}

.settle-rank-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.settle-rank-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.settle-rank-item:last-child {
  border-bottom: none;
}

.settle-rank-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.settle-rank-top3 {
  background: rgba(10, 132, 255, 0.15);
}

.settle-rank-num {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
}

.settle-rank-top3 .settle-rank-num {
  color: #0A84FF;
}

.settle-rank-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.settle-rank-avatar-img {
  width: 100%;
  height: 100%;
}

.settle-rank-avatar-char {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.settle-rank-name {
  flex: 1;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.settle-me-tag {
  font-size: 20rpx;
  color: #0A84FF;
  margin-left: 8rpx;
  vertical-align: middle;
}

.settle-rank-score {
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.settle-bottom-btn {
  margin-top: 40rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #0A84FF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settle-bottom-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

/* 身份重叠弹窗 */
.name-collision-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.25s ease;
}

.name-collision-mask.nc-show {
  opacity: 1;
  visibility: visible;
}

.name-collision-card {
  width: 620rpx;
  background: rgba(20, 20, 20, 0.95);
  backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: ncSlideUp 0.25s ease;
}

@keyframes ncSlideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.nc-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 69, 58, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.nc-icon {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF453A;
}

.nc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.nc-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.55);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.nc-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(10, 132, 255, 0.12);
  border: 1rpx solid rgba(10, 132, 255, 0.4);
  border-radius: 16rpx;
}

.nc-btn:active {
  background: rgba(10, 132, 255, 0.25);
}

.nc-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #0A84FF;
  letter-spacing: 2rpx;
  text-shadow: 0 0 12rpx rgba(10, 132, 255, 0.5);
}

/* ===== 录入本局按钮 ===== */
.round-start-wrap {
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}
.round-start-btn {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(10, 132, 255, 0.15);
  border: 1rpx solid rgba(10, 132, 255, 0.4);
  border-radius: 16rpx;
}
.round-start-btn:active {
  background: rgba(10, 132, 255, 0.3);
}
.round-start-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #0A84FF;
}

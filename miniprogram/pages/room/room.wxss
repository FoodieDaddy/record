  z-index: 1;
}

.seat-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(0,200,255,0.42);
}

.seat-state--online {
  color: rgba(48,209,88,0.76);
}

.seat-state--online .seat-dot {
  background: rgba(48,209,88,0.78);
  box-shadow: 0 0 12rpx rgba(48,209,88,0.24);
}

.seat-state--syncing {
  color: rgba(0,200,255,0.62);
}

.seat-state--syncing .seat-dot {
  background: rgba(0,200,255,0.62);
}

.seat-state--offline {
  color: rgba(226,242,255,0.34);
}

.seat-state--offline .seat-dot {
  background: rgba(226,242,255,0.20);
  box-shadow: none;
}

.seat-host-chip {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  padding: 2rpx 8rpx;
  border: 1rpx solid rgba(0,200,255,0.22);
  color: rgba(0,200,255,0.76);
  background: rgba(0,200,255,0.055);
  font-size: 16rpx;
  line-height: 1.4;
  clip-path: polygon(6rpx 0, 100% 0, 100% calc(100% - 6rpx), calc(100% - 6rpx) 100%, 0 100%, 0 6rpx);
}

.crew-seat.is-self .seat-dot {
  background: rgba(48,209,88,0.72);
  box-shadow: 0 0 12rpx rgba(48,209,88,0.22);
}

.crew-seat.is-empty .seat-dot {
  background: rgba(226,242,255,0.22);
  box-shadow: none;
}

.seat-dot.muted {
  background: rgba(226,242,255,0.22);
  box-shadow: none;
}

.seat-transfer-chip {
  margin-top: 8rpx;
  width: 100%;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid rgba(0,200,255,0.18);
  background: rgba(0,200,255,0.045);
  color: rgba(0,200,255,0.68);
  font-size: 17rpx;
  font-weight: 600;
  clip-path: polygon(8rpx 0, 100% 0, 100% calc(100% - 8rpx), calc(100% - 8rpx) 100%, 0 100%, 0 8rpx);
}

.seat-transfer-chip.is-ready {
  color: rgba(226,242,255,0.96);
  border-color: rgba(0,200,255,0.48);

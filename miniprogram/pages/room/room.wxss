.room-page {
  padding: 24rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
}

/* 隐藏所有滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}

/* ===== 纯色线框图标系统 ===== */
/* 锁 */
.icon-lock-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-lock {
  width: 28rpx;
  height: 22rpx;
  border: 2rpx solid var(--text-secondary);
  border-radius: 6rpx;
  position: relative;
}
.icon-lock::before {
  content: '';
  position: absolute;
  top: -14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 14rpx;
  border: 2rpx solid var(--text-secondary);
  border-bottom: none;
  border-radius: 10rpx 10rpx 0 0;
}
/* 分享/导出 */
.icon-share {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-share::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: 10rpx;
  background: currentColor;
}
.icon-share::after {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%) rotate(45deg);
  width: 8rpx;
  height: 8rpx;
  border-top: 2rpx solid currentColor;
  border-right: 2rpx solid currentColor;
}
/* 链接 */
.icon-link {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 10rpx;
  position: relative;
  opacity: 0.8;
}
.icon-link::before {
  content: '';
  position: absolute;
  top: 50%;
  left: -6rpx;
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
.icon-link::after {
  content: '';
  position: absolute;
  top: 50%;
  right: -6rpx;
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
/* 剪贴板 */
.icon-clip {
  width: 22rpx;
  height: 26rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-clip::before {
  content: '';
  position: absolute;
  top: -4rpx;
  left: 4rpx;
  right: 4rpx;
  height: 6rpx;
  border: 2rpx solid currentColor;
  border-radius: 3rpx 3rpx 0 0;
}
/* 人物 */
.icon-person {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  position: relative;
  opacity: 0.8;
}
.icon-person::before {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 10rpx;
  border: 2rpx solid currentColor;
  border-bottom: none;
  border-radius: 12rpx 12rpx 0 0;
}
/* 图表 */
.icon-chart {
  width: 22rpx;
  height: 22rpx;
  position: relative;
  opacity: 0.8;
}
.icon-chart::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 6rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
.icon-chart::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10rpx;
  width: 6rpx;
  height: 14rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
/* 聊天 */
.icon-chat {
  width: 24rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 6rpx 6rpx 6rpx 0;
  position: relative;
  opacity: 0.8;
}
.icon-chat::before {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: -2rpx;
  width: 8rpx;
  height: 6rpx;
  border-left: 2rpx solid currentColor;
  transform: skewX(-20deg);
}
/* 图片 */
.icon-image {
  width: 22rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-image::before {
  content: '';
  position: absolute;
  bottom: 3rpx;
  left: 2rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 6rpx solid currentColor;
}
/* 相机 */
.icon-cam {
  width: 24rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-cam::before {
  content: '';
  position: absolute;
  top: -5rpx;
  left: 6rpx;
  width: 10rpx;
  height: 5rpx;
  border: 2rpx solid currentColor;
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
}
.icon-cam::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 8rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}
/* 音频开 */
.icon-audio-on {
  width: 20rpx;
  height: 20rpx;
  position: relative;
  opacity: 0.8;
}
.icon-audio-on::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 8rpx 8rpx 0;
}
.icon-audio-on::after {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 18rpx;
  border-right: 2rpx solid currentColor;
  border-radius: 0 12rpx 12rpx 0;
}
/* 音频关 */
.icon-audio-off {
  width: 20rpx;
  height: 20rpx;
  position: relative;
  opacity: 0.8;
}
.icon-audio-off::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 8rpx 8rpx 0;
}
.icon-audio-off::after {
  content: '';
  position: absolute;
  right: 0;
  top: 2rpx;
  width: 2rpx;
  height: 18rpx;
  background: currentColor;
  transform: rotate(45deg);
  transform-origin: center;
}
/* 门 */
.icon-door {
  width: 18rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 3rpx 6rpx 6rpx 3rpx;
  position: relative;
  opacity: 0.8;
}
.icon-door::before {
  content: '';
  position: absolute;
  top: 50%;
  right: 4rpx;
  transform: translateY(-50%);
  width: 4rpx;
  height: 4rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}
/* 垃圾桶 */
.icon-trash {
  width: 18rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 0 4rpx 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-trash::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 2rpx;
  right: 2rpx;
  height: 4rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
.icon-trash::after {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
/* 网格视图 */
.icon-grid {
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
  position: relative;
  opacity: 0.8;
}
.icon-grid::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
  transform: translateY(-50%);
}
.icon-grid::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: currentColor;
  transform: translateX(-50%);
}
/* 列表视图 */
.icon-list {
  width: 18rpx;
  height: 18rpx;
  position: relative;
  opacity: 0.8;
}
.icon-list::before {
  content: '';
  position: absolute;
  top: 3rpx;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
}
.icon-list::after {
  content: '';
  position: absolute;
  bottom: 3rpx;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
}
/* 空状态：雷达网格扫描仪 */
.icon-empty-doc {
  width: 64rpx;
  height: 64rpx;
  position: relative;
  margin-bottom: 20rpx;
  opacity: 0.15;
}
.icon-empty-doc::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 56rpx;
  height: 56rpx;
  border: 1.5rpx solid var(--accent);
  border-radius: 50%;
  box-shadow:
    inset 0 0 0 14rpx transparent,
    inset 0 0 0 15.5rpx rgba(10, 132, 255, 0.4),
    inset 0 0 0 28rpx transparent,
    inset 0 0 0 29.5rpx rgba(10, 132, 255, 0.25);
}
.icon-empty-doc::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 1.5rpx;
  height: 28rpx;
  background: rgba(10, 132, 255, 0.5);
  transform: translate(-50%, -100%);
  transform-origin: bottom center;
  box-shadow:
    0 0 0 0 transparent,
    0 0 6rpx 1rpx rgba(10, 132, 255, 0.3);
}
/* 按钮内图标尺寸 */
.matrix-btn-icon-svg {
  width: 20rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-action-svg {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

/* ===== 顶部提示 ===== */
.top-toast {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  padding: 20rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  background: rgba(81, 207, 102, 0.9);
  transform: translateY(-100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  backdrop-filter: blur(20rpx);
}
.top-toast-show {
  transform: translateY(0);
}
.top-toast-error {
  background: rgba(255, 107, 107, 0.9);
}

/* ===== 未登录状态 ===== */
.empty-auth {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
}

.empty-auth-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 无房间状态 ===== */
.empty-room {
  padding-top: 32rpx;
}

/* ===== 赛博终端卡片 ===== */
.cyber-card {
  background: var(--bg-card);
  border: 1rpx solid rgba(10, 132, 255, 0.18);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}
.cyber-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(10, 132, 255, 0.015), transparent 40%);
  pointer-events: none;
}

/* 系统状态栏 */
.cyber-system-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 4rpx;
}
.cyber-system-name {
  font-size: 20rpx;
  color: var(--text-disabled);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.cyber-system-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.cyber-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 8rpx rgba(48, 209, 88, 0.6);
}
.cyber-status-text {
  font-size: 18rpx;
  color: var(--success);
  letter-spacing: 2rpx;
}

/* 分隔线 */
.cyber-divider {
  height: 1rpx;
  background: var(--glass-bg);
  margin: 20rpx 0;
}

/* 双层标题 */
.cyber-section-title {
  margin-bottom: 16rpx;
}
.cyber-cn {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #00C8FF;
  letter-spacing: 2rpx;
  line-height: 1.4;
}
.cyber-en {
  display: block;
  font-size: 18rpx;
  color: rgba(126, 156, 180, 0.34);
  letter-spacing: 4rpx;
  font-family: monospace;
  margin-top: 2rpx;
}

/* ===== 模式选择卡 ===== */
.cyber-mode-cards {
  display: flex;
  gap: 16rpx;
}
.cyber-mode-card {
  flex: 1;
  padding: 20rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  background: transparent;
}
.cyber-mode-active {
  border-color: rgba(0, 200, 255, 0.5);
  background: rgba(0, 200, 255, 0.04);
}
.cyber-mode-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}
.cyber-mode-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  border: 1rpx solid var(--text-disabled);
  background: transparent;
  flex-shrink: 0;
}
.mode-dot-on {
  border-color: var(--color-cyan);
  background: var(--color-cyan);
  box-shadow: 0 0 12rpx var(--color-cyan);
}
.cyber-mode-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  transition: color 0.3s ease;
}
.cyber-mode-active .cyber-mode-name {
  color: var(--text-primary);
}
.cyber-mode-badge {
  font-size: 16rpx;
  color: var(--text-disabled);
  border: 1rpx solid var(--glass-border-light);
  border-radius: 6rpx;
  padding: 2rpx 8rpx;
  margin-left: auto;
}
.badge-on {
  color: var(--color-cyan);
  border-color: rgba(0, 200, 255, 0.4);
  background: rgba(0, 200, 255, 0.08);
}
.cyber-mode-desc {
  display: block;
  font-size: 20rpx;
  color: var(--text-disabled);
  line-height: 1.5;
  padding-left: 22rpx;
}

/* ===== 录入方式卡片 ===== */
.cyber-cards {
  display: flex;
  gap: 16rpx;
}
.cyber-opt-card {
  flex: 1;
  position: relative;
  padding: 20rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  background: transparent;
  overflow: hidden;
}
.cyber-opt-active {
  border-color: rgba(0, 200, 255, 0.5);
  background: rgba(0, 200, 255, 0.04);
}
.cyber-opt-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 8rpx;
}
.cyber-opt-check {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-cyan);
  box-shadow: 0 0 8rpx rgba(0, 200, 255, 0.45);
  flex-shrink: 0;
}
.cyber-opt-status-text {
  font-size: 16rpx;
  color: var(--color-cyan);
  letter-spacing: 2rpx;
}
.cyber-opt-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
  transition: color 0.3s ease;
}
.cyber-opt-active .cyber-opt-title {
  color: var(--text-primary);
}
.cyber-opt-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
}
.cyber-opt-hint {
  display: block;
  font-size: 18rpx;
  color: var(--text-disabled);
  margin-top: 6rpx;
}
.cyber-opt-active .cyber-opt-hint {
  color: rgba(0, 200, 255, 0.4);
}

/* ===== 芯片选择器 ===== */
.cyber-chips {
  display: flex;
  gap: 16rpx;
}
.cyber-chip {
  flex: 1;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 12rpx 16rpx;
  color: var(--text-disabled);
  background: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
}
.cyber-chip-active {
  color: var(--color-cyan);
  border-color: rgba(0, 200, 255, 0.5);
  background: rgba(0, 200, 255, 0.04);
}
.cyber-chip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  border: 1rpx solid var(--text-disabled);
  background: transparent;
  flex-shrink: 0;
}
.dot-on {
  border-color: var(--color-cyan);
  background: var(--color-cyan);
  box-shadow: 0 0 12rpx var(--color-cyan);
}
.cyber-chip-text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
}
.cyber-chip-main {
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}
.cyber-chip-sub {
  font-size: 18rpx;
  color: var(--text-disabled);
}
.cyber-chip-active .cyber-chip-sub {
  color: rgba(0, 200, 255, 0.5);
}

/* 超时预设档位 */
.cyber-timeout-chips {
  margin-bottom: 16rpx;
}
.cyber-timeout-action {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.cyber-timeout-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
  white-space: nowrap;
}

/* ===== 配置预览面板 ===== */
.cyber-preview {
  padding: 4rpx 0;
}
.cyber-preview-title {
  display: block;
  font-size: 20rpx;
  color: var(--text-disabled);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  font-family: monospace;
}
.cyber-preview-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}
.cyber-preview-key {
  font-size: 22rpx;
  color: rgba(126, 156, 180, 0.30);
}
.cyber-preview-val {
  font-size: 22rpx;
  color: var(--color-cyan);
  font-weight: 500;
}

/* ===== 启动房间按钮（切角） ===== */
.cyber-create-btn {
  padding: 8rpx 0;
}
.cyber-create-inner {
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  background: linear-gradient(135deg, rgba(0, 200, 255, 0.12), rgba(10, 132, 255, 0.06));
  border: 1rpx solid rgba(0, 200, 255, 0.35);
  border-radius: 12rpx;
  color: var(--color-cyan);
  position: relative;
  overflow: hidden;
  clip-path: polygon(16rpx 0, calc(100% - 16rpx) 0, 100% 16rpx, 100% calc(100% - 16rpx), calc(100% - 16rpx) 100%, 16rpx 100%, 0 calc(100% - 16rpx), 0 16rpx);
}
.cyber-create-inner::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.08), transparent);
  animation: cyberSweep 4s ease-in-out infinite;
}
.cyber-create-inner:active {
  background: linear-gradient(135deg, rgba(0, 200, 255, 0.2), rgba(10, 132, 255, 0.12));
  transform: scale(0.98);
}
.cyber-create-text {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
}
.cyber-create-sub {
  font-size: 16rpx;
  color: rgba(0, 200, 255, 0.4);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.btn-loading {
  opacity: 0.5;
}

@keyframes cyberSweep {
  0% { left: -100%; }
  50% { left: 100%; }
  100% { left: 100%; }
}

/* 主按钮：加入房间（保留原样式） */
.card-header {
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.form-label {
  width: 80rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
  flex-shrink: 0;
}

/* 或分割线 */
.divider-glow {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 32rpx 0;
}
.divider-glow::before,
.divider-glow::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--glass-border-light), transparent);
}
.divider-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.join-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.btn-secondary-scan {
  width: 96rpx;
  height: 80rpx;
  background: var(--glass-bg);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--border-radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0;
}
.btn-secondary-scan:active {
  background: var(--glass-bg-hover);
}

.scan-icon {
  font-size: 36rpx;
}

/* ===== 扫描接入卡片 ===== */
.cyber-scan-card {
  padding: 24rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.2);
  border-radius: 12rpx;
  background: rgba(0, 200, 255, 0.03);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.cyber-scan-card:active {
  background: rgba(0, 200, 255, 0.08);
  transform: scale(0.98);
}
.cyber-scan-icon {
  width: 56rpx;
  height: 56rpx;
  position: relative;
}
.cyber-scan-corner {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-color: var(--color-cyan);
  border-style: solid;
  border-width: 0;
}
.cyber-scan-tl { top: 0; left: 0; border-top-width: 2rpx; border-left-width: 2rpx; }
.cyber-scan-tr { top: 0; right: 0; border-top-width: 2rpx; border-right-width: 2rpx; }
.cyber-scan-bl { bottom: 0; left: 0; border-bottom-width: 2rpx; border-left-width: 2rpx; }
.cyber-scan-br { bottom: 0; right: 0; border-bottom-width: 2rpx; border-right-width: 2rpx; }
.cyber-scan-line {
  position: absolute;
  top: 50%;
  left: 8rpx;
  right: 8rpx;
  height: 1rpx;
  background: var(--color-cyan);
  transform: translateY(-50%);
  opacity: 0.5;
  animation: scanPulse 2s ease-in-out infinite;
}
@keyframes scanPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.8; }
}
.cyber-scan-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}
.cyber-scan-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 4rpx;
}
.cyber-scan-sub {
  font-size: 18rpx;
  color: rgba(0, 200, 255, 0.5);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.cyber-scan-hint {
  font-size: 20rpx;
  color: var(--text-disabled);
}

/* ===== 终端输入框 ===== */
.cyber-terminal-input {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--glass-border-light);
  border-radius: 12rpx;
  background: var(--bg-card);
  position: relative;
}
.cyber-terminal-input:active,
.cyber-terminal-input:focus-within {
  border-color: rgba(0, 200, 255, 0.4);
  background: rgba(0, 200, 255, 0.02);
}
.cyber-terminal-prefix {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(0, 200, 255, 0.4);
  font-family: monospace;
  letter-spacing: 2rpx;
  margin-right: 4rpx;
}
.cyber-terminal-field {
  flex: 1;
  height: 88rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-cyan);
  font-family: monospace;
  letter-spacing: 8rpx;
  background: transparent;
  caret-color: transparent;
}
.cyber-terminal-cursor {
  width: 2rpx;
  height: 36rpx;
  background: var(--color-cyan);
  border-radius: 1rpx;
  animation: cursorBlink 1s ease-in-out infinite;
  margin-left: 4rpx;
}
@keyframes cursorBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* ===== 房间状态反馈 ===== */
.cyber-room-status {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: var(--bg-card);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}
.cyber-status-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.cyber-room-status .cyber-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.dot-green {
  background: var(--success);
  box-shadow: 0 0 8rpx rgba(48, 209, 88, 0.6);
}
.dot-red {
  background: var(--danger);
  box-shadow: 0 0 8rpx rgba(255, 69, 58, 0.5);
}
.cyber-status-msg {
  font-size: 22rpx;
  letter-spacing: 1rpx;
}
.msg-green { color: var(--success); }
.msg-red { color: var(--danger); }
.cyber-room-preview {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}
.cyber-room-status .cyber-preview-row {
  display: flex;
  justify-content: space-between;
  padding: 6rpx 0;
}
.cyber-room-status .cyber-preview-key {
  font-size: 22rpx;
  color: rgba(126, 156, 180, 0.30);
}
.cyber-room-status .cyber-preview-val {
  font-size: 22rpx;
  color: var(--color-cyan);
}

/* 按钮禁用态 */
.btn-dim {
  opacity: 0.35;
  pointer-events: none;
}

/* ===== 最近加入 ===== */
.cyber-recent-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.cyber-recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  background: transparent;
}
.cyber-recent-item:active {
  background: rgba(0, 200, 255, 0.04);
}
.cyber-recent-code {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-family: monospace;
  letter-spacing: 2rpx;
}
.cyber-recent-time {
  font-size: 20rpx;
  color: var(--text-disabled);
}

/* ===== 已有房间快捷入口 ===== */
.has-room {
  padding-top: 32rpx;
  animation: fadeSlideUp 0.3s ease;
}

.room-quick-card {
  padding: 36rpx 32rpx;
}

.rq-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.rq-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.rq-room-no {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 6rpx;
  font-variant-numeric: tabular-nums;
}

.rq-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-accent {
  background: rgba(10, 132, 255, 0.15);
  color: var(--accent);
  border: 1rpx solid rgba(10, 132, 255, 0.3);
}

.badge-success {
  background: rgba(81, 207, 102, 0.15);
  color: var(--success);
  border: 1rpx solid rgba(81, 207, 102, 0.3);
}

.rq-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.rq-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.rq-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 0;
  background: var(--glass-bg);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: var(--border-radius-sm);
  line-height: normal;
  margin: 0;
  font-size: inherit;
  color: inherit;
}

.rq-action-btn::after {
  border: none;
}

.rq-action-btn:active {
  background: rgba(10, 132, 255, 0.12);
  transform: scale(0.96);
}

.rq-action-icon {
  font-size: 36rpx;
}

.rq-action-btn [class^="icon-"] {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
}

.rq-action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ===== 房间内容 ===== */
.room-content {
  height: 100vh;
  overflow: hidden;
  animation: fadeSlideUp 0.3s ease;
}

/* ===== ROOM TERMINAL 顶部终端栏 ===== */
.room-terminal {
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(10,132,255,0.18);
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(10,132,255,0.035), transparent 62%),
    rgba(255,255,255,0.028);
  position: relative;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.room-terminal::before {
  content: '';
  position: absolute;
  top: 0;
  left: 10%;
  right: 10%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(10, 132, 255,0.3), transparent);
}
.rt-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.rt-kicker {
  font-size: 18rpx;
  color: rgba(0,200,255,0.66);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.rt-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.rt-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 8rpx rgba(54,255,116,0.6);
}
.rt-status-text {
  font-size: 16rpx;
  color: var(--success);
  letter-spacing: 2rpx;
  font-family: monospace;
}
.rt-main-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}
.rt-info-grid {
  flex: 1;
  min-width: 0;
  display: grid;
  grid-template-columns: 1fr 1.18fr 1fr;
  gap: 18rpx;
}
.rt-info-seg {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.rt-info-label {
  font-size: 16rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
  font-family: monospace;
}
.rt-info-value {
  max-width: 100%;
  font-size: 30rpx;
  font-weight: 700;
  color: #00C8FF;
  letter-spacing: 2rpx;
  font-family: "SF Mono", "Menlo", "Courier New", monospace;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.rt-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}
.rt-action {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(10,132,255,0.22);
  background: rgba(10,132,255,0.045);
  transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
  opacity: 0.86;
  color: #00C8FF;
}
.rt-action:active {
  opacity: 1;
  transform: scale(0.9);
  box-shadow: 0 0 12rpx rgba(10, 132, 255,0.3);
}

/* QR码 */
.qr-section {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.qr-frame {
  padding: 12rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--glass-border);
  border-radius: 16rpx;
}

.qr-image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 10rpx;
  display: block;
}

/* ===== PLAYER NETWORK 成员网络 ===== */
.player-network {
  padding: 24rpx;
  border: 1rpx solid rgba(10,132,255,0.18);
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(10,132,255,0.025), transparent 46%),
    rgba(255,255,255,0.028);
  margin-bottom: 16rpx;
}
.pn-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.pn-title-group {
  display: flex;
  flex-direction: column;
}
.pn-cn {
  font-size: 28rpx;
  font-weight: 600;
  color: #00C8FF;
  letter-spacing: 2rpx;
}
.pn-en {
  font-size: 18rpx;
  color: rgba(126, 156, 180, 0.34);
  letter-spacing: 4rpx;
  font-family: monospace;
  margin-top: 2rpx;
}
.pn-count {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
}
.pn-divider {
  height: 1rpx;
  background: var(--glass-bg);
  margin: 16rpx 0;
}

/* 成员矩阵 */
.member-grid-scroll {
  max-height: 600rpx;
}
.member-matrix {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  padding: 4rpx 0;
}
.mg-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 6rpx;
  min-width: 0;
  min-height: 150rpx;
  padding: 12rpx 4rpx 10rpx;
  border: 1rpx solid transparent;
  border-radius: 18rpx;
  transition: opacity 0.2s, transform 0.2s, background-color 0.2s;
  position: relative;
}
.mg-cell:active {
  transform: scale(0.92);
}
.mg-cell-selected {
  border-color: rgba(10,132,255,0.22);
  background: rgba(10,132,255,0.055);
  transform: translateY(-4rpx);
}

/* 头像容器 */
.mg-avatar-wrap {
  position: relative;
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* HOST 标签 */
.mg-host-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  font-size: 14rpx;
  color: var(--color-cyan);
  background: rgba(10, 132, 255,0.15);
  border: 1rpx solid rgba(10, 132, 255,0.3);
  border-radius: 6rpx;
  padding: 2rpx 8rpx;
  letter-spacing: 1rpx;
  font-family: monospace;
  pointer-events: none;
}

.mg-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 116rpx;
  min-height: 32rpx;
  line-height: 32rpx;
}
.mg-score {
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
  max-width: 116rpx;
  min-height: 36rpx;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: "SF Mono", "Menlo", "Courier New", monospace;
  font-variant-numeric: tabular-nums;
}

/* TARGET LOCKED */
.mg-target-lock {
  font-size: 14rpx;
  color: var(--color-cyan);
  letter-spacing: 2rpx;
  font-family: monospace;
  opacity: 0.8;
  animation: targetPulse 1.5s ease-in-out infinite;
}
@keyframes targetPulse {
  0%, 100% { opacity: 0.8; }
  50% { opacity: 0.4; }
}

.reduce-motion .ring-selected { animation: none; }
.reduce-motion .mg-target-lock { animation: none; opacity: 0.8; }

/* ===== 弹窗头部（共享） ===== */
.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
  border-radius: 50%;
}

.detail-close:active {
  background: var(--glass-bg-hover);
}

/* 弹窗头部内关闭图标：去除 fi 默认边框，保持轻量 */
.detail-header .fi {
  border: none;
  background: none;
  color: var(--text-tertiary);
}

/* ===== 计分动画 ===== */
.transfer-anim-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 150;
  pointer-events: none;
}

.transfer-anim-flash {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 40%, rgba(10, 132, 255, 0.15), transparent 70%);
  transition: opacity 0.15s;
}

.transfer-anim-particle {
  position: absolute;
  width: 16px;
  height: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  will-change: transform, left, top;
}

.transfer-anim-trail {
  position: absolute;
  width: 16px;
  height: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  will-change: transform, left, top;
}

.transfer-anim-dot {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: radial-gradient(circle, #6aabff, rgba(10, 132, 255, 0.5));
  box-shadow: 0 0 16px 6px rgba(10, 132, 255, 0.7),
              0 0 32px 12px rgba(10, 132, 255, 0.4),
              0 0 48px 20px rgba(10, 132, 255, 0.2);
}

.transfer-anim-dot-trail {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(10, 132, 255, 0.6), rgba(10, 132, 255, 0.2));
  box-shadow: 0 0 10px 4px rgba(10, 132, 255, 0.4);
}

.dot-trail-2 {
  width: 8px;
  height: 8px;
  background: radial-gradient(circle, rgba(120, 180, 255, 0.5), rgba(10, 132, 255, 0.1));
  box-shadow: 0 0 8px 3px rgba(10, 132, 255, 0.3);
}

.transfer-anim-amount {
  position: absolute;
  top: -36px;
  white-space: nowrap;
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  text-shadow: 0 0 12px rgba(10, 132, 255, 0.9),
               0 0 24px rgba(10, 132, 255, 0.5),
               0 2px 4px rgba(0, 0, 0, 0.3);
  font-variant-numeric: tabular-nums;
}

/* ===== TRANSFER TERMINAL 流转终端 ===== */
.transfer-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease, visibility 0.25s ease;
}
.transfer-show {
  opacity: 1;
  visibility: visible;
}
.transfer-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(16,16,16,0.97);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(10,132,255,0.2);
  border-radius: 32rpx 32rpx 0 0;
  padding: 28rpx 24rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}
.transfer-show .transfer-sheet {
  transform: translateY(0);
}
.transfer-header {
  text-align: center;
  margin-bottom: 20rpx;
}
.transfer-kicker {
  font-size: 18rpx;
  color: rgba(10,132,255,0.72);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.transfer-role-label {
  font-size: 14rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
  font-family: monospace;
}
.transfer-subtitle {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 8rpx;
}
.transfer-direction {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 16rpx 0;
}
.transfer-player {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.transfer-player-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.transfer-arrow-wrap {
  display: flex;
  align-items: center;
  gap: 4rpx;
  position: relative;
}
.transfer-arrow-line {
  width: 40rpx;
  height: 1rpx;
  background: rgba(10,132,255,0.4);
}
.transfer-arrow-beam {
  position: absolute;
  left: 0;
  top: 50%;
  width: 40rpx;
  height: 6rpx;
  margin-top: -3rpx;
  background: linear-gradient(90deg, rgba(10,132,255,0.08), rgba(10,132,255,0.35));
  border-radius: 6rpx;
  filter: blur(2rpx);
}
.transfer-arrow-head {
  font-size: 28rpx;
  color: #0A84FF;
}
/* AMOUNT 区域 */
.transfer-amount-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.transfer-amount-label {
  font-size: 16rpx;
  color: var(--text-secondary);
  letter-spacing: 3rpx;
  font-family: monospace;
  margin-bottom: 8rpx;
}
.transfer-display-value {
  font-size: 80rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

/* 实时预览 */
.transfer-preview {
  background: var(--bg-card);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}
.tp-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4rpx 0;
}
.tp-name {

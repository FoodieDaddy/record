/* === 编队席位矩阵 === */
.crew-section {
  margin-bottom: 24rpx;
}

.crew-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

/* 动态席位布局 */
.crew-stage {
  display: grid;
  gap: 14rpx;
}

.crew-stage.layout-solo {
  grid-template-columns: 1fr;
  padding: 0 128rpx;
}

.crew-stage.layout-duo {
  grid-template-columns: repeat(2, 1fr);
  padding: 0 24rpx;
}

.crew-stage.layout-compact {
  grid-template-columns: repeat(2, 1fr);
}

.crew-stage.layout-wide {
  grid-template-columns: repeat(3, 1fr);
}

.crew-stage.layout-matrix {
  grid-template-columns: repeat(4, 1fr);
}

.crew-seat {
  min-height: 188rpx;
  padding: 16rpx 10rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.025);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  clip-path: polygon(
    14rpx 0,
    100% 0,
    100% calc(100% - 14rpx),
    calc(100% - 14rpx) 100%,
    0 100%,
    0 14rpx
  );
  transition: border-color .18s, background-color .18s;
}

.crew-seat::before {
  content: '';
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 8rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(0,200,255,0.10);
  filter: blur(8rpx);
}

.crew-seat::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 8rpx;
  width: 42rpx;
  height: 8rpx;
  transform: translateX(-50%);
  border: 1rpx solid rgba(0,200,255,0.18);
  border-radius: 999rpx;
  opacity: 0.7;
}

.crew-seat.is-active {
  border-color: rgba(0,200,255,0.24);
  background: rgba(0,200,255,0.04);
}

.crew-seat.is-self {
  border-color: rgba(48,209,88,0.34);
}

.crew-seat.is-selected {
  border-color: rgba(0,200,255,0.72);
  background: rgba(0,200,255,0.09);
  transform: translateY(-4rpx);
}

.crew-seat.is-impact {
  animation: seatImpact .42s ease-out;
}

@keyframes seatImpact {
  0% {
    box-shadow: 0 0 0 rgba(0,200,255,0);
    transform: scale(1);
  }
  40% {
    box-shadow: 0 0 34rpx rgba(0,200,255,0.38);
    transform: scale(1.035);
  }
  100% {
    box-shadow: 0 0 0 rgba(0,200,255,0);
    transform: scale(1);
  }
}

.reduce-motion .crew-seat.is-impact {
  animation: none !important;
}

.crew-seat.is-selected::after {
  content: '';
  position: absolute;
  inset: 6rpx;
  border: 1rpx solid rgba(0,200,255,0.36);
  pointer-events: none;
  clip-path: polygon(
    10rpx 0,
    100% 0,
    100% calc(100% - 10rpx),
    calc(100% - 10rpx) 100%,
    0 100%,
    0 10rpx
  );
}

.seat-corner {
  position: absolute;
  top: 0;
  left: 0;
  width: 14rpx;
  height: 14rpx;
  border-top: 1rpx solid rgba(0,200,255,0.34);
  border-left: 1rpx solid rgba(0,200,255,0.34);
}

.crew-seat.is-empty .seat-corner {
  border-color: rgba(255,255,255,0.06);
}

/* 接入席位 */
.crew-seat.is-invite {

}

.self-gauge-compact {
  position: relative;
  z-index: 2;
  width: 360rpx;
  height: 150rpx;
  margin: -42rpx auto 0;
  overflow: visible;
}

.gauge-shell {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 0;
  height: 102rpx;
  background: linear-gradient(180deg, rgba(2,12,22,0.48), rgba(2,12,22,0.96));
  border-left: 1rpx solid rgba(0,200,255,0.12);
  border-right: 1rpx solid rgba(0,200,255,0.12);
}

.self-gauge-compact .gauge-arc-outer,
.self-gauge-compact .gauge-arc-inner {
  position: absolute;
  left: 0;
  bottom: 17rpx;
  box-sizing: border-box;
  border-bottom: none;
}

.self-gauge-compact .gauge-arc-outer {
  width: 360rpx;
  height: 180rpx;
  border: 2rpx solid rgba(0,200,255,0.28);
  border-bottom: none;
  border-top-left-radius: 360rpx;
  border-top-right-radius: 360rpx;
}

.self-gauge-compact.is-positive .gauge-arc-outer {
  border-color: rgba(48,209,88,0.34);
}

.self-gauge-compact.is-negative .gauge-arc-outer {
  border-color: rgba(255,159,10,0.36);
}

.self-gauge-compact .gauge-arc-inner {
  left: 36rpx;
  bottom: 20rpx;
  width: 288rpx;
  height: 144rpx;
  border: 1rpx solid rgba(0,200,255,0.13);
  border-bottom: none;
  border-top-left-radius: 288rpx;
  border-top-right-radius: 288rpx;
}

.self-gauge-compact .gauge-ticks {
  position: absolute;
  left: 50%;
  bottom: 19rpx;
  width: 0;
  height: 0;
}

.self-gauge-compact .gauge-tick {
  position: absolute;
  left: -1rpx;
  bottom: 0;
  width: 2rpx;
  height: 14rpx;
  background: rgba(0,200,255,0.30);
  transform-origin: center 148rpx;
}

.self-gauge-compact .gauge-tick.t1 { transform: rotate(-58deg); }
.self-gauge-compact .gauge-tick.t2 { transform: rotate(-29deg); }
.self-gauge-compact .gauge-tick.t3 { transform: rotate(0deg); height: 18rpx; background: rgba(0,200,255,0.48); }
.self-gauge-compact .gauge-tick.t4 { transform: rotate(29deg); }
.self-gauge-compact .gauge-tick.t5 { transform: rotate(58deg); }

.self-gauge-compact .gauge-title {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 62rpx;
  transform: none;
  z-index: 2;
  font-size: 20rpx;
  line-height: 24rpx;
  text-align: center;
  color: rgba(226,242,255,0.48);
  letter-spacing: 2rpx;
  font-family: inherit;
}

.self-gauge-compact .gauge-value {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 15rpx;
  transform: none;
  z-index: 2;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 60rpx;
  line-height: 62rpx;
  text-align: center;
  color: rgba(226,242,255,0.94);
  font-variant-numeric: tabular-nums;
}

.self-gauge-compact.is-positive .gauge-value {
  color: rgba(48,209,88,0.9);
}

.self-gauge-compact.is-negative .gauge-value {
  color: rgba(255,159,10,0.92);
}

.gauge-status {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -10rpx;
  z-index: 2;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 6rpx;
  font-size: 18rpx;
  line-height: 20rpx;
  color: rgba(226,242,255,0.42);
}

.gauge-status-dot {
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: rgba(48,209,88,0.9);
  box-shadow: 0 0 7rpx rgba(48,209,88,0.38);
}

.deck-spine-v2 {
  width: 1rpx;
  height: 24rpx;
  margin: -2rpx auto 0;
  background: linear-gradient(180deg, rgba(0,200,255,0.32), rgba(0,200,255,0.08));
}

.deck-terminal {
  position: relative;
  z-index: 1;
  height: 218rpx;
  margin: 8rpx 24rpx 0;
  padding: 16rpx 20rpx;

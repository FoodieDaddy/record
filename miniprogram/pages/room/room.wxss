/* === 脉冲控制 === */
.pulse-control {
  margin-bottom: 24rpx;
}

.target-chip {
  font-size: 22rpx;
  color: rgba(0,200,255,0.72);
  padding: 6rpx 14rpx;
  border: 1rpx solid rgba(0,200,255,0.22);
  border-radius: 16rpx;
}

.pulse-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx 0;
}

.pulse-step {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(0,200,255,0.22);
  border-radius: 12rpx;
  background: rgba(255,255,255,0.025);
  color: rgba(0,200,255,0.82);
  font-size: 32rpx;
  font-weight: 600;
  padding: 0;
  line-height: 1;
}

.pulse-step::after {
  display: none;
}

.pulse-input {
  flex: 1;
  height: 72rpx;
  text-align: center;
  font-size: 40rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  color: rgba(0,200,255,0.92);
  background: rgba(255,255,255,0.035);
  border: 1rpx solid rgba(0,200,255,0.18);
  border-radius: 12rpx;
  caret-color: rgba(0,200,255,0.88);
}

.pulse-submit {
  margin-top: 16rpx;
}

.pulse-hint {
  text-align: center;
  font-size: 22rpx;
  color: rgba(226,242,255,0.38);
  margin-top: 12rpx;
}

/* === 脉冲控制台 === */
.pulse-dock {
  position: relative;
  margin: 24rpx 0;
  padding: 22rpx 20rpx 20rpx;
  border: 1rpx solid rgba(0,200,255,0.24);
  background: rgba(3,10,18,0.72);
  box-shadow: none;
  clip-path: polygon(
    20rpx 0,
    100% 0,
    100% calc(100% - 20rpx),
    calc(100% - 20rpx) 100%,
    0 100%,
    0 20rpx
  );
}

.pulse-dock-target {
  display: flex;
  justify-content: space-between;
  align-items: stretch;
  gap: 16rpx;
  margin-bottom: 12rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(0,200,255,0.12);
}

.pulse-dock-target--idle {
  color: rgba(226,242,255,0.52);
}

.pulse-flow-line {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dock-node {
  min-width: 96rpx;
  max-width: 184rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.dock-node--target {
  align-items: flex-end;
}

.dock-node-label {
  font-size: 18rpx;
  color: rgba(226,242,255,0.38);
}

.dock-target-label {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(0,200,255,0.48);
}

.dock-source-name,
.dock-target-name {
  max-width: 190rpx;
  font-size: 24rpx;
  color: rgba(0,200,255,0.92);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dock-source-name {
  color: rgba(226,242,255,0.74);
}

.dock-flow-beam {
  flex: 1;
  min-width: 64rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(226,242,255,0.12), rgba(0,200,255,0.82));
  position: relative;
}

.dock-flow-beam::after {
  content: '';
  position: absolute;
  right: -4rpx;
  top: -5rpx;
  width: 10rpx;
  height: 10rpx;
  border-top: 2rpx solid rgba(0,200,255,0.9);
  border-right: 2rpx solid rgba(0,200,255,0.9);
  transform: rotate(45deg);
}

.dock-delta-preview {
  flex: 0 0 190rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
}

.dock-delta-item {
  min-width: 0;
  padding: 8rpx 10rpx;
  border: 1rpx solid rgba(0,200,255,0.14);
  background: rgba(0,200,255,0.035);
}

.delta-label {
  display: block;
  font-size: 17rpx;
  color: rgba(226,242,255,0.42);
}

.delta-value {
  display: block;
  margin-top: 2rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 24rpx;
  color: rgba(0,200,255,0.92);
}

.dock-idle-copy {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: rgba(226,242,255,0.42);
}

.dock-idle-mark {
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid rgba(0,200,255,0.28);
  transform: rotate(45deg);
}

.pulse-dock-main {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 176rpx;
  gap: 12rpx;
  align-items: stretch;
}

.pulse-input-box {
  min-width: 0;
  height: 72rpx;
  display: grid;
  grid-template-columns: 132rpx minmax(0, 1fr);
  align-items: center;
  border: 1rpx solid rgba(0,200,255,0.22);
  background: rgba(0,200,255,0.045);
  clip-path: polygon(12rpx 0, 100% 0, 100% calc(100% - 12rpx), calc(100% - 12rpx) 100%, 0 100%, 0 12rpx);
}

.pulse-input-label {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid rgba(0,200,255,0.14);
  color: rgba(226,242,255,0.48);
  font-size: 22rpx;
  font-weight: 600;
}

.pulse-dock-input {
  height: 72rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  text-align: left;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 34rpx;
  color: rgba(0,200,255,0.96);
  border: 0;
  background: transparent;
  caret-color: rgba(0,200,255,0.88);
}

.pulse-fire-btn {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(0,200,255,0.48);
  background: rgba(0,200,255,0.12);
  color: rgba(226,242,255,0.96);
  font-size: 24rpx;
  font-weight: 700;
  padding: 0;
  line-height: 1;
  border-radius: 0;
  clip-path: polygon(12rpx 0, 100% 0, 100% calc(100% - 12rpx), calc(100% - 12rpx) 100%, 0 100%, 0 12rpx);
}

.pulse-fire-btn::after {
  display: none;
}

.pulse-fire-btn.is-disabled {
  opacity: 0.38;
  border-color: rgba(0,200,255,0.18);
  background: rgba(0,200,255,0.04);
}

.pulse-fire-btn.is-loading {
  opacity: 0.58;
}

.pulse-quick-head {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(226,242,255,0.34);
}

.pulse-quick-row {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
}

.pulse-quick-chip {
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.026);
  color: rgba(226,242,255,0.56);
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 22rpx;
  clip-path: polygon(8rpx 0, 100% 0, 100% calc(100% - 8rpx), calc(100% - 8rpx) 100%, 0 100%, 0 8rpx);
}

.pulse-quick-chip.is-active {
  color: rgba(0,200,255,0.94);
  border-color: rgba(0,200,255,0.38);
  background: rgba(0,200,255,0.10);
}

.pulse-quick-clear {
  color: rgba(226,242,255,0.42);
  font-family: inherit;
}

.pulse-dock-waiting {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 0;
  font-size: 23rpx;
  color: rgba(255,255,255,0.40);
}

.waiting-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255,159,10,0.6);
  animation: waiting-pulse 2s ease-in-out infinite;
}

@keyframes waiting-pulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 1; }
}

.pulse-dock.is-locked {
  border-color: rgba(0,200,255,0.38);
}

/* 脉冲飞行动画层 */
.pulse-flight-layer {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 120;
}

.pulse-flight-dot {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: rgba(0,200,255,0.96);
  box-shadow:
    0 0 16rpx rgba(0,200,255,0.86),
    0 0 42rpx rgba(10,132,255,0.46);
  animation: pulseFlight .72s cubic-bezier(.18,.82,.22,1) forwards;
}

.pulse-tail {
  position: absolute;
  right: 8rpx;
  top: 7rpx;
  width: 80rpx;
  height: 4rpx;
  transform-origin: right center;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.64));
  filter: blur(1rpx);
}

.pulse-flight-value {
  position: absolute;
  left: 24rpx;
  top: -20rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 22rpx;
  color: rgba(0,200,255,0.96);
  text-shadow: 0 0 14rpx rgba(0,200,255,0.42);
}

@keyframes pulseFlight {
  0% {
    opacity: 0;
    transform: translate3d(0,0,0) scale(.55);
  }
  12% {
    opacity: 1;
    transform: translate3d(calc(var(--dx) * .08), calc(var(--dy) * .02 - 18rpx), 0) scale(1);
  }
  58% {
    opacity: 1;
    transform: translate3d(calc(var(--dx) * .72), calc(var(--dy) * .62 - 32rpx), 0) scale(.9);
  }
  100% {
    opacity: 0;
    transform: translate3d(var(--dx), var(--dy), 0) scale(.3);
  }
}

.reduce-motion .pulse-flight-dot {
  animation: none !important;
  opacity: 0;
}

/* === 脉冲轨迹 === */
.blackbox-console {
  margin-bottom: 24rpx;
  overflow: hidden;
}

.blackbox-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.blackbox-toggle-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.blackbox-toggle-btn {
  height: 52rpx;
  min-width: 148rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid rgba(0,200,255,0.28);
  color: rgba(0,200,255,0.92);
  background: rgba(0,200,255,0.065);
  font-size: 22rpx;
  font-weight: 600;
  clip-path: polygon(10rpx 0, 100% 0, 100% calc(100% - 10rpx), calc(100% - 10rpx) 100%, 0 100%, 0 10rpx);
}

.blackbox-panel {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(0,200,255,0.12);
}

.blackbox-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.blackbox-tab {
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255,255,255,0.08);
  color: rgba(226,242,255,0.46);
  background: rgba(255,255,255,0.022);
  font-size: 22rpx;
  font-weight: 600;
  clip-path: polygon(10rpx 0, 100% 0, 100% calc(100% - 10rpx), calc(100% - 10rpx) 100%, 0 100%, 0 10rpx);
}

.blackbox-tab.is-active {
  color: rgba(0,200,255,0.94);
  border-color: rgba(0,200,255,0.36);
  background: rgba(0,200,255,0.08);
}

.blackbox-view {
  min-height: 160rpx;
}

.trace-section {
  margin-bottom: 24rpx;
}

.trace-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 20rpx;
  color: rgba(226,242,255,0.46);
}

.trace-list {
  margin-top: 20rpx;
}

.trace-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin: 4rpx 0 16rpx;
}

.trace-stat {
  min-width: 0;
  padding: 12rpx 10rpx;
  border: 1rpx solid rgba(0,200,255,0.12);
  background: rgba(0,200,255,0.035);
  clip-path: polygon(8rpx 0, 100% 0, 100% calc(100% - 8rpx), calc(100% - 8rpx) 100%, 0 100%, 0 8rpx);
}

.trace-stat-label {
  display: block;
  font-size: 17rpx;
  color: rgba(226,242,255,0.38);
  white-space: nowrap;
}

.trace-stat-value {
  display: block;
  margin-top: 4rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 24rpx;
  color: rgba(0,200,255,0.86);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.trace-chart-panel {
  margin: 12rpx 0 16rpx;
  padding: 10rpx 0 0;
  border: 1rpx solid rgba(255,255,255,0.06);
  background: rgba(255,255,255,0.018);
  overflow: hidden;
}

.trace-toolbar {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin: 14rpx 0 4rpx;
}

.trace-filter {
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.025);
  color: rgba(226,242,255,0.48);
  font-size: 22rpx;
  font-weight: 600;
  clip-path: polygon(10rpx 0, 100% 0, 100% calc(100% - 10rpx), calc(100% - 10rpx) 100%, 0 100%, 0 10rpx);
}

.trace-filter.is-active {
  color: rgba(0,200,255,0.94);
  border-color: rgba(0,200,255,0.34);
  background: rgba(0,200,255,0.08);
}

.trace-item {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0 18rpx 22rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.trace-item--crew {
  display: grid;
  grid-template-columns: minmax(112rpx, 1fr) 86rpx minmax(112rpx, 1fr) auto;
  grid-template-areas:
    "from beam to value"
    "from time to value";
  column-gap: 12rpx;
  row-gap: 4rpx;
  padding: 16rpx 0 16rpx 18rpx;
}

.trace-item--crew .trace-line {
  position: absolute;
  left: 0;
  top: 14rpx;
  bottom: 14rpx;
}

.trace-party {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.trace-party--from {
  grid-area: from;
}

.trace-party--to {
  grid-area: to;
}

.trace-party text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 21rpx;
  color: rgba(226,242,255,0.82);
}

.trace-beam {
  grid-area: beam;
  align-self: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  font-size: 16rpx;
  color: rgba(0,200,255,0.54);
}

.trace-beam-line {
  width: 64rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(0,200,255,0.10), rgba(0,200,255,0.72));
  position: relative;
}

.trace-beam-line::after {
  content: '';
  position: absolute;
  right: -2rpx;
  top: -4rpx;
  width: 0;
  height: 0;
  border-top: 5rpx solid transparent;
  border-bottom: 5rpx solid transparent;
  border-left: 8rpx solid rgba(0,200,255,0.72);
}

.trace-time {
  grid-area: time;
  align-self: start;
  text-align: center;
  font-size: 18rpx;
  color: rgba(226,242,255,0.34);
}

.trace-item--crew .trace-value {
  grid-area: value;
  align-self: center;
  justify-self: end;
  padding-right: 6rpx;
}

.trace-item.is-new {
  background: rgba(0,200,255,0.04);
}

.trace-item.is-mine {
  background: rgba(0,200,255,0.045);
}

.trace-item.is-mine .trace-line {

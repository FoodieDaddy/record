}

.seat-name {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(226,242,255,0.82);
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;

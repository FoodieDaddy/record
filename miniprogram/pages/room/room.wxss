/* ===== 编队接入面板 ===== */
.share-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  z-index: 250;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease, visibility 0.25s ease;
}
.share-show {
  opacity: 1;
  visibility: visible;
}
.share-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #0A0F18;
  border-top: 1rpx solid rgba(10, 132, 255, 0.15);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 28rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}
.share-show .share-sheet {
  transform: translateY(0);
}
.share-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}
.share-title-area {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.share-kicker {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(10, 132, 255, 0.72);
  font-family: monospace;
  text-transform: uppercase;
}
.share-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.share-qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 0;
}
.share-qr-frame {
  width: 280rpx;
  height: 280rpx;
  padding: 16rpx;
  background: var(--bg-card);
  border: 1rpx solid rgba(10, 132, 255, 0.12);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.share-qr-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  display: block;
}
.share-qr-placeholder {
  background: rgba(10, 132, 255, 0.04);
}
.share-qr-room-no {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-cyan);
  font-variant-numeric: tabular-nums;
  letter-spacing: 8rpx;
}
.share-qr-hint {
  font-size: 22rpx;
  color: rgba(140, 176, 205, 0.38);
}
.share-qr-loading {
  gap: 16rpx;
}
.share-qr-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid rgba(10, 132, 255, 0.2);
  border-top-color: var(--color-cyan);
  border-radius: 50%;
  animation: qr-spin 0.8s linear infinite;
}
@keyframes qr-spin {
  to { transform: rotate(360deg); }
}
.share-qr-loading-text {
  font-size: 24rpx;
  color: rgba(140, 176, 205, 0.38);
}
.share-qr-fail {
  gap: 8rpx;
}
.share-qr-fail-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}
.share-qr-fail-hint {
  font-size: 24rpx;
  color: rgba(140, 176, 205, 0.38);
}
.share-qr-retry {
  margin-top: 12rpx;
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.3);
  border-radius: 8rpx;
}
.share-qr-retry-text {
  font-size: 24rpx;
  color: var(--color-cyan);
}
.share-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}
.share-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  background: var(--bg-card);
  border: 1rpx solid var(--glass-border-light);
  border-radius: 16rpx;
  line-height: normal;
  margin: 0;
  font-size: inherit;
  color: inherit;
}
.share-action-btn::after {
  border: none;
}
.share-action-btn:active {
  background: rgba(10, 132, 255, 0.12);
  border-color: rgba(10, 132, 255, 0.3);
}
.share-action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* WS 断线遮罩 */
.ws-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(20rpx);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}
.ws-mask--show {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}
.ws-mask__card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 64rpx;
}
.ws-mask__dot {
  width: 16rpx; height: 16rpx;
  background: #0A84FF;
  border-radius: 50%;
  animation: ws-breathe 1.6s ease-in-out infinite;
}
@keyframes ws-breathe {
  0%, 100% { transform: scale(1); opacity: 0.4; }
  50% { transform: scale(1.8); opacity: 1; }
}
.ws-mask__text {
  color: var(--text-primary);
  font-size: 28rpx;
}

/* 模态框打开时禁止底层滚动 */
.scroll-locked {
  overflow: hidden !important;
  pointer-events: none;
}

/* ===== 战局报告弹层 ===== */

.settle-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 900;
  background: #05070A;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.23, 1, 0.32, 1);
}

.settle-overlay--show {
  transform: translateY(0);
}

.settle-overlay__inner {
  height: 100%;
  padding: 0 28rpx 60rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 20% 0%, rgba(0, 175, 255, 0.06), transparent 32%),
    radial-gradient(circle at 90% 18%, rgba(94, 92, 230, 0.04), transparent 30%),
    transparent;
}

.settle-top-bar {
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 0 8rpx;
}

.settle-close-cyber { padding: 8rpx; }

.settle-close-ring {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(0, 175, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: settleBreathe 3s ease-in-out infinite;
}
.settle-close-ring .fi {
  border: none;
  background: none;
  color: rgba(0, 175, 255, 0.72);
}

@keyframes settleBreathe {
  0%, 100% { border-color: rgba(0, 175, 255, 0.25); box-shadow: 0 0 0 rgba(0, 175, 255, 0); }
  50% { border-color: rgba(0, 175, 255, 0.50); box-shadow: 0 0 16rpx rgba(0, 175, 255, 0.15); }
}

.settle-close-x {

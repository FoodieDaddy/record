/* ===== 编队内容 ===== */
.room-content {
  height: 100vh;
  overflow: hidden;
  animation: fadeSlideUp 0.3s ease;
}

/* ===== ROOM TERMINAL 顶部终端栏 ===== */
.room-terminal {
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(10,132,255,0.18);
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(10,132,255,0.035), transparent 62%),
    rgba(255,255,255,0.028);
  position: relative;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.room-terminal::before {
  content: '';
  position: absolute;
  top: 0;
  left: 10%;
  right: 10%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(10, 132, 255,0.3), transparent);
}
.rt-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.rt-kicker {
  font-size: 18rpx;
  color: rgba(0,200,255,0.66);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.rt-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.rt-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 8rpx rgba(54,255,116,0.6);
}
.rt-status-text {
  font-size: 16rpx;
  color: var(--success);
  letter-spacing: 2rpx;
  font-family: monospace;
}
.rt-main-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}
.rt-info-grid {
  flex: 1;
  min-width: 0;
  display: grid;
  grid-template-columns: 1fr 1.18fr 1fr;
  gap: 18rpx;
}
.rt-info-seg {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.rt-info-label {
  font-size: 16rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
  font-family: monospace;
}
.rt-info-value {
  max-width: 100%;
  font-size: 30rpx;
  font-weight: 700;
  color: #00C8FF;
  letter-spacing: 2rpx;
  font-family: "SF Mono", "Menlo", "Courier New", monospace;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.rt-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}
.rt-action {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(10,132,255,0.22);
  background: rgba(10,132,255,0.045);
  transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
  opacity: 0.86;
  color: #00C8FF;
}
.rt-action:active {
  opacity: 1;
  transform: scale(0.9);
  box-shadow: 0 0 12rpx rgba(10, 132, 255,0.3);
}

/* QR码 */
.qr-section {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.qr-frame {
  padding: 12rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--glass-border);
  border-radius: 16rpx;
}

.qr-image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 10rpx;
  display: block;
}

/* ===== PLAYER NETWORK 成员网络 ===== */
.player-network {
  padding: 24rpx;
  border: 1rpx solid rgba(10,132,255,0.18);
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(10,132,255,0.025), transparent 46%),
    rgba(255,255,255,0.028);
  margin-bottom: 16rpx;
}
.pn-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.pn-title-group {
  display: flex;
  flex-direction: column;
}
.pn-cn {
  font-size: 28rpx;
  font-weight: 600;
  color: #00C8FF;
  letter-spacing: 2rpx;
}
.pn-en {
  font-size: 18rpx;
  color: rgba(126, 156, 180, 0.34);
  letter-spacing: 4rpx;
  font-family: monospace;
  margin-top: 2rpx;
}
.pn-count {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
}
.pn-divider {
  height: 1rpx;
  background: var(--glass-bg);
  margin: 16rpx 0;
}

/* 成员矩阵 */
.member-grid-scroll {
  max-height: 600rpx;
}
.member-matrix {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  padding: 4rpx 0;
}
.mg-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 6rpx;
  min-width: 0;
  min-height: 150rpx;
  padding: 12rpx 4rpx 10rpx;
  border: 1rpx solid transparent;
  border-radius: 18rpx;
  transition: opacity 0.2s, transform 0.2s, background-color 0.2s;
  position: relative;
}
.mg-cell:active {
  transform: scale(0.92);
}
.mg-cell-selected {
  border-color: rgba(10,132,255,0.22);
  background: rgba(10,132,255,0.055);
  transform: translateY(-4rpx);
}

/* 识别徽标容器 */
.mg-avatar-wrap {
  position: relative;
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* HOST 标签 */
.mg-host-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  font-size: 14rpx;
  color: var(--color-cyan);
  background: rgba(10, 132, 255,0.15);
  border: 1rpx solid rgba(10, 132, 255,0.3);
  border-radius: 6rpx;
  padding: 2rpx 8rpx;
  letter-spacing: 1rpx;
  font-family: monospace;
  pointer-events: none;
}

.mg-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 116rpx;
  min-height: 32rpx;
  line-height: 32rpx;
}
.mg-score {
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
  max-width: 116rpx;
  min-height: 36rpx;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: "SF Mono", "Menlo", "Courier New", monospace;
  font-variant-numeric: tabular-nums;
}

/* TARGET LOCKED */
.mg-target-lock {
  font-size: 14rpx;
  color: var(--color-cyan);
  letter-spacing: 2rpx;
  font-family: monospace;
  opacity: 0.8;
  animation: targetPulse 1.5s ease-in-out infinite;
}
@keyframes targetPulse {
  0%, 100% { opacity: 0.8; }
  50% { opacity: 0.4; }
}

.reduce-motion .ring-selected { animation: none; }
.reduce-motion .mg-target-lock { animation: none; opacity: 0.8; }

/* ===== 弹窗头部（共享） ===== */
.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
  border-radius: 50%;
}

.detail-close:active {
  background: var(--glass-bg-hover);
}

/* 弹窗头部内关闭图标：去除 fi 默认边框，保持轻量 */
.detail-header .fi {
  border: none;
  background: none;
  color: var(--text-tertiary);
}

/* ===== 计分动画 ===== */
.transfer-anim-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 150;
  pointer-events: none;
}

.transfer-anim-flash {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 40%, rgba(10, 132, 255, 0.15), transparent 70%);
  transition: opacity 0.15s;
}

.transfer-anim-beam-wrapper {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  will-change: transform, opacity;
  transform-origin: center center;
  /* 初始不可见，使用计算好的角度 */
  opacity: 0;
  transform: translate3d(0, 0, 0) scale(0) rotate(var(--angle, 0deg));
}

.beam-core {
  width: 120rpx;
  height: 6rpx;
  background: linear-gradient(90deg, transparent 0%, #fff 80%, rgba(10, 132, 255, 0.8) 100%);
  border-radius: 6rpx;
  box-shadow: 0 0 12rpx 4rpx rgba(10, 132, 255, 0.9),
              0 0 24rpx 8rpx rgba(10, 132, 255, 0.4);
}

.beam-trail {
  position: absolute;
  right: 60rpx; /* 跟随在核心后面 */
  width: 200rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(10, 132, 255, 0.6) 100%);
  filter: blur(2px);
}

.beam-rings {
  position: absolute;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 200, 255, 0.8);
  box-shadow: 0 0 10rpx rgba(0, 200, 255, 0.6);
  transform: scaleY(0.4) rotate(90deg); /* 让圆环垂直于光束 */
}

/* 终点命中反馈（冲击波 Ripple） */
.impact-ripple-container {
  position: absolute;
  width: 2rpx;
  height: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 140;
}

.impact-ripple-wave {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(0, 255, 255, 0.8);
  opacity: 0;
  transform: scale(0.1);
  box-shadow: inset 0 0 20rpx rgba(0, 255, 255, 0.4),
              0 0 20rpx rgba(0, 255, 255, 0.6);
}

.impact-ripple-hex {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, rgba(10, 132, 255, 0.4) 0%, transparent 60%);
  opacity: 0;
  transform: scale(0.1) rotate(0deg);
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
}

/* 终点命中飘字（Decryption Float Text） */
.impact-float-text {
  position: absolute;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 48rpx;
  font-weight: 800;
  color: #00ffcc;
  text-shadow: 0 0 10rpx rgba(0, 255, 204, 0.8),
               0 4rpx 8rpx rgba(0, 0, 0, 0.8);
  opacity: 0;
  transform: translate(-50%, 0) scale(0.5);
  pointer-events: none;
  z-index: 160;
}

/* ===== 动画绑定 ===== */
.transfer-anim-beam-wrapper.is-flying {
  /* 波纹先扩散，激光延迟 300ms 触发，并变慢（1200ms）以抵消网络延迟 */
  animation: warpBeamFlight 1200ms cubic-bezier(0.4, 0.1, 0.2, 1) 300ms forwards;
}

.launch-ripple-container {
  position: absolute;
  width: 2rpx;
  height: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 130;
}

.launch-ripple-container.is-active .launch-ripple-wave {
  animation: launchRippleExpand 600ms ease-out forwards;
}

.launch-ripple-wave {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(0, 200, 255, 0.9);
  opacity: 0;
  transform: scale(0.1);
  box-shadow: inset 0 0 20rpx rgba(0, 200, 255, 0.5),
              0 0 20rpx rgba(0, 200, 255, 0.7);
}

.impact-ripple-container.is-impacting .impact-ripple-wave {
  animation: rippleExpand 500ms ease-out forwards;
}

.impact-ripple-container.is-impacting .impact-ripple-hex {
  animation: hexBurst 600ms cubic-bezier(0.1, 0.9, 0.2, 1) forwards;
}

.impact-float-text.is-floating {
  animation: floatUpDecrypt 1000ms cubic-bezier(0.1, 0.9, 0.2, 1) forwards;
}

.transfer-anim-flash.is-active {
  animation: particleFlash 120ms ease-out forwards;
}

/* ===== 关键帧定义 ===== */
@keyframes warpBeamFlight {
  0% {
    opacity: 0;
    transform: translate3d(0, 0, 0) scaleX(0.1) rotate(var(--angle));
  }
  15% {
    opacity: 1;
    transform: translate3d(calc(var(--dx) * 0.1), calc(var(--dy) * 0.1), 0) scaleX(1.5) rotate(var(--angle));
  }
  80% {
    opacity: 1;
    transform: translate3d(calc(var(--dx) * 0.9), calc(var(--dy) * 0.9), 0) scaleX(1) rotate(var(--angle));
  }
  100% {
    opacity: 0;
    transform: translate3d(var(--dx), var(--dy), 0) scaleX(0.2) rotate(var(--angle));
  }
}

@keyframes rippleExpand {
  0% {
    opacity: 1;
    transform: scale(0.1);
    border-width: 8rpx;
  }
  100% {
    opacity: 0;
    transform: scale(1.5);
    border-width: 0rpx;
  }
}

@keyframes hexBurst {
  0% {
    opacity: 0.8;
    transform: scale(0.2) rotate(-30deg);
  }
  100% {
    opacity: 0;
    transform: scale(1.2) rotate(30deg);
  }
}

@keyframes floatUpDecrypt {
  0% {
    opacity: 0;
    transform: translate(-50%, 0) scale(0.5);
    filter: blur(4rpx);
    color: #fff;
  }
  15% {
    opacity: 1;
    transform: translate(-50%, -20rpx) scale(1.1);
    filter: blur(0);
    color: #00ffcc;
  }
  70% {
    opacity: 0.8;
    transform: translate(-50%, -60rpx) scale(1);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -80rpx) scale(0.9);
  }
}

@keyframes launchRippleExpand {
  0% { opacity: 1; transform: scale(0.1); border-width: 10rpx; }
  100% { opacity: 0; transform: scale(1.5); border-width: 0rpx; }
}

@keyframes particleFlash {
  0% { opacity: 0.6; }
  100% { opacity: 0; }
}

.reduce-motion .transfer-anim-particle.is-flying,
.reduce-motion .transfer-anim-trail.is-flying,
.reduce-motion .transfer-anim-flash.is-active {
  animation: none !important;
}

.reduce-motion .ship-craft.motion-score-impact {
  animation: none !important;
}

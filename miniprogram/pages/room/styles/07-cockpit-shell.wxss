}

.pulse-input {
  flex: 1;
  height: 72rpx;
  text-align: center;
  font-size: 40rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  color: rgba(0,200,255,0.92);
  background: rgba(255,255,255,0.035);
  border: 1rpx solid rgba(0,200,255,0.18);
  border-radius: 12rpx;

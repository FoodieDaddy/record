/* === 脉冲控制 === */
.pulse-control {
  margin-bottom: 24rpx;
}

.target-chip {
  font-size: 22rpx;
  color: rgba(0,200,255,0.72);
  padding: 6rpx 14rpx;
  border: 1rpx solid rgba(0,200,255,0.22);

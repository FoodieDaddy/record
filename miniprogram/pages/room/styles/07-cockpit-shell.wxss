/* ============================================================
   驾驶舱 Phase 1 — HUD 样式
   ============================================================ */

/* === 页面根节点 === */
/* 注意：不要同时使用 .room-page 和 .cockpit-page，这里仅保留背景和颜色，
   padding 统一由 .room-page（00-base.wxss）管理，避免简写覆盖 */
.cockpit-page {
  box-sizing: border-box;
  color: var(--text-primary);
  background:
    radial-gradient(circle at 20% 0%, rgba(10,132,255,0.12), transparent 32%),
    radial-gradient(circle at 90% 18%, rgba(94,92,230,0.08), transparent 30%),
    #0A0A0A;
}

/* 驾驶舱视口：idle 状态需要额外底部空间 */
.cockpit-viewport--idle {
  min-height: 1120rpx;
  margin-bottom: var(--sr-tabbar-safe-height, calc(140rpx + env(safe-area-inset-bottom)));
}

.room-custom-nav {
  position: relative;
  margin: -32rpx -28rpx 0;
  flex-shrink: 0;
  box-sizing: border-box;
  overflow: hidden;
  background:
    radial-gradient(circle at 22% 10%, rgba(0,200,255,0.12), transparent 34%),
    radial-gradient(circle at 78% 0%, rgba(94,92,230,0.10), transparent 30%),
    linear-gradient(180deg, rgba(1,8,18,0.98), rgba(4,12,24,0.92));
  border-bottom: 1rpx solid rgba(0,200,255,0.12);
}

.room-custom-nav::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: linear-gradient(180deg, transparent, rgba(5,14,26,0.84));
  pointer-events: none;
}

.room-custom-nav__stars {
  position: absolute;
  inset: 0;
  opacity: 0.34;
  background-image:
    radial-gradient(circle at 18% 48%, rgba(226,242,255,0.40) 0 2rpx, transparent 3rpx),
    radial-gradient(circle at 62% 32%, rgba(0,200,255,0.34) 0 2rpx, transparent 3rpx),
    radial-gradient(circle at 86% 62%, rgba(226,242,255,0.28) 0 1rpx, transparent 2rpx);
  pointer-events: none;
}

.room-custom-nav__bar {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 210rpx;
  box-sizing: border-box;
}

.room-custom-nav__title {
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
  color: rgba(245,250,255,0.96);
}

/* === 驾驶舱 Header === */
.cockpit-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(226,242,255,0.22);
}

.status-dot--on {
  background: rgba(48,209,88,0.88);
  box-shadow: 0 0 8rpx rgba(48,209,88,0.4);
}

/* === HUD 面板 === */
.sr-hud-panel {
  position: relative;
  border: 1rpx solid rgba(0,200,255,0.22);
  background: rgba(3,10,18,0.64);
  clip-path: polygon(
    24rpx 0,
    calc(100% - 24rpx) 0,
    100% 24rpx,
    100% calc(100% - 24rpx),
    calc(100% - 24rpx) 100%,
    24rpx 100%,
    0 calc(100% - 24rpx),
    0 24rpx
  );
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* === 通用卡片 === */
.sr-card {
  border-radius: 28rpx;
  border: 1rpx solid rgba(10,132,255,0.18);
  background: rgba(255,255,255,0.035);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.cockpit-viewport {
  position: relative;
  box-sizing: border-box;
  min-height: 980rpx;
  overflow: hidden;
}

.cockpit-viewport--idle {
  min-height: 1120rpx;
  margin-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.cockpit-viewport--connecting {
  min-height: 620rpx;
}

/* === 通用按钮 === */
.sr-btn {
  position: relative;
  height: 82rpx;
  border-radius: 0;
  margin: 0;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 600;
  letter-spacing: 1rpx;
  background: rgba(255,255,255,0.025);
  color: var(--text-primary);
  border: 1rpx solid rgba(10,132,255,0.26);
  clip-path: polygon(
    18rpx 0,
    100% 0,
    100% calc(100% - 18rpx),
    calc(100% - 18rpx) 100%,
    0 100%,
    0 18rpx
  );
  transition: opacity .18s, transform .18s, border-color .18s, background-color .18s;
}

.sr-btn::after {
  display: none;
}

.sr-btn-primary {
  border-color: rgba(0,200,255,0.48);
  background: linear-gradient(90deg, rgba(10,132,255,0.20), rgba(0,200,255,0.10));
  color: rgba(226,242,255,0.96);
}

.sr-btn-secondary {
  border-color: rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.035);
}

.sr-btn-danger-outline {
  border-color: rgba(255,69,58,0.38);
  color: rgba(255,126,118,0.96);
  background: transparent;
}

.sr-btn--disabled {
  opacity: 0.38;
  pointer-events: none;
}

.sr-btn--loading {
  opacity: 0.64;
}

.btn-text {
  position: relative;
  z-index: 1;
}

/* === 启动核心 === */
.launch-deck {
  position: relative;
  text-align: center;
  padding: 48rpx 32rpx;
  overflow: hidden;
  min-height: 560rpx;
}

/* 扫描线 */
.idle-scanline {
  position: absolute;
  left: 0;
  right: 0;
  top: -30%;
  height: 40%;
  background: linear-gradient(to bottom, transparent, rgba(0,200,255,0.06), transparent);
  animation: idleScan 4.8s linear infinite;
  pointer-events: none;
}

@keyframes idleScan {
  0% { transform: translateY(0); opacity: 0; }
  20% { opacity: 1; }
  100% { transform: translateY(360%); opacity: 0; }
}

.deck-grid {
  position: absolute;
  inset: 0;
  opacity: 0.28;
  background:
    linear-gradient(rgba(0,200,255,0.08) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0,200,255,0.08) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  mask-image: radial-gradient(circle at center, #000, transparent 72%);
  -webkit-mask-image: radial-gradient(circle at center, #000, transparent 72%);
  pointer-events: none;
}

.launch-core {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  margin: 36rpx auto 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.core-ring {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(0,200,255,0.22);
}

.core-ring-outer {
  inset: 0;
  animation: coreRotate 12s linear infinite;
}

.core-ring-inner {
  inset: 30rpx;
  border-color: rgba(0,200,255,0.14);
  animation: coreRotate 8s linear infinite reverse;
}

@keyframes coreRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 轨道呼吸 */
.core-orbit {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(0,200,255,0.22);
}

.core-orbit-a {
  inset: 0;
  animation: coreBreath 3.2s ease-in-out infinite;
}

.core-orbit-b {
  inset: 34rpx;
  border-color: rgba(10,132,255,0.18);
  animation: coreBreath 3.2s ease-in-out infinite reverse;
}

@keyframes coreBreath {
  0%, 100% { transform: scale(0.98); opacity: 0.58; }
  50% { transform: scale(1.03); opacity: 0.92; }
}

/* 核心脉冲 */
.core-pulse {
  position: absolute;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0,200,255,0.18), rgba(0,200,255,0.02) 62%, transparent);
  animation: corePulse 2.4s ease-in-out infinite;
}

@keyframes corePulse {
  0%, 100% { transform: scale(0.86); opacity: 0.44; }
  50% { transform: scale(1.08); opacity: 0.9; }
}

.launch-core.is-igniting .core-ring,
.launch-core.is-igniting .core-orbit {
  border-color: rgba(0,200,255,0.56);
  box-shadow: 0 0 24rpx rgba(0,200,255,0.2);
}

.launch-core.is-igniting .core-pulse {
  background: radial-gradient(circle, rgba(0,200,255,0.36), rgba(0,200,255,0.06) 62%, transparent);
}

.core-center {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.core-label {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(0,200,255,0.46);
  font-family: 'DIN Alternate', Menlo, monospace;
}

.core-title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(226,242,255,0.92);
  margin-top: 8rpx;
}

.core-desc {
  font-size: 22rpx;
  color: rgba(226,242,255,0.46);
  margin-top: 8rpx;
}

/* === 启动配置 === */
.launch-config {
  margin: 32rpx 0;
  text-align: left;
}

.config-kicker {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(0,200,255,0.38);
  font-family: 'DIN Alternate', Menlo, monospace;
  margin-bottom: 12rpx;
}

.config-chips {
  display: flex;
  gap: 16rpx;
}

.config-chip {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 0;
  font-size: 24rpx;
  color: rgba(226,242,255,0.56);
  transition: border-color .18s, background-color .18s;
  clip-path: polygon(14rpx 0, 100% 0, 100% calc(100% - 14rpx), calc(100% - 14rpx) 100%, 0 100%, 0 14rpx);
}

.config-chip--on {
  border-color: rgba(0,200,255,0.34);
  background: rgba(0,200,255,0.06);
  color: rgba(226,242,255,0.92);
}

.chip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(226,242,255,0.22);
}

.chip-dot--on {
  background: rgba(0,200,255,0.88);
  border-color: rgba(0,200,255,0.88);
}

/* === 启动按钮区 === */
.launch-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 32rpx;
}

.launch-btn {
  position: relative;
  overflow: hidden;
}

.btn-energy {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.12), transparent);
  opacity: 0.42;
  pointer-events: none;
  animation: btnEnergy 3s ease-in-out infinite;
}

@keyframes btnEnergy {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* 加入编队按钮微弱边框呼吸 */
.sr-btn-secondary {
  animation: secondaryGlow 4s ease-in-out infinite;
}

@keyframes secondaryGlow {
  0%, 100% { border-color: rgba(255,255,255,0.12); }
  50% { border-color: rgba(0,200,255,0.22); }
}

/* 按钮按压态 */
.sr-btn:active {
  transform: scale(0.97);
  border-color: rgba(0,200,255,0.52);
}

/* === 启动过渡层 === */
.launch-transition {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
}

.launch-transition-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 50% 40%, rgba(0,200,255,0.06), transparent 60%),
    #0A0A0A;
}

.launch-ring {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.launch-ring-outer {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(0,200,255,0.35);
  animation: launchRingPulse 1.6s ease-in-out infinite;
}

.launch-ring-inner {
  position: absolute;
  inset: 24rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0,200,255,0.52);
  animation: launchRingPulse 1.6s ease-in-out 0.3s infinite;
}

@keyframes launchRingPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.92); }
  50% { opacity: 1; transform: scale(1.08); }
}

.launch-phase-text {
  position: relative;
  z-index: 1;
  font-family: 'Courier New', Courier, monospace;
  font-size: 28rpx;
  color: rgba(0,200,255,0.88);
  letter-spacing: 4rpx;
  animation: phaseTextFade 0.4s ease-out;
}

@keyframes phaseTextFade {
  0% { opacity: 0; transform: translateY(8rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

.launch-phase-bar {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 16rpx;
}

.launch-phase-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.18);
  transition: background-color 0.3s, box-shadow 0.3s;
}

.launch-phase-dot--active {
  background: rgba(0,200,255,0.88);
  box-shadow: 0 0 12rpx rgba(0,200,255,0.4);
}

.reduce-motion .launch-ring-outer,
.reduce-motion .launch-ring-inner,
.reduce-motion .launch-phase-text {
  animation: none !important;
}

/* === 接入弹窗 === */
.cockpit-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.72);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.launch-slow-actions {
  position: absolute;
  left: 72rpx;
  right: 72rpx;
  bottom: calc(96rpx + env(safe-area-inset-bottom));
  z-index: 3;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.launch-slow-btn {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(226,242,255,0.12);
  color: rgba(226,242,255,0.64);
  background: rgba(255,255,255,0.035);
  font-size: 24rpx;
  font-weight: 600;
  clip-path: polygon(14rpx 0, 100% 0, 100% calc(100% - 14rpx), calc(100% - 14rpx) 100%, 0 100%, 0 14rpx);
}

.launch-slow-btn--primary {
  border-color: rgba(0,200,255,0.34);
  color: rgba(0,200,255,0.92);
  background: rgba(0,200,255,0.08);
}

.join-panel {
  width: 100%;
  max-width: 600rpx;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.panel-kicker {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(0,200,255,0.46);
  font-family: 'DIN Alternate', Menlo, monospace;
  margin-bottom: 6rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(226,242,255,0.96);
}

.panel-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(226,242,255,0.46);
}

.icon-close {
  width: 24rpx;
  height: 24rpx;
  position: relative;
}

.icon-close::before,
.icon-close::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 2rpx;
  background: currentColor;
}

.icon-close::before { transform: translate(-50%, -50%) rotate(45deg); }
.icon-close::after { transform: translate(-50%, -50%) rotate(-45deg); }

.code-input-wrap {
  margin-bottom: 24rpx;
}

.code-input {
  width: 100%;
  height: 96rpx;
  text-align: center;
  font-size: 48rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  letter-spacing: 12rpx;
  color: rgba(0,200,255,0.92);
  background: rgba(255,255,255,0.035);
  border: 1rpx solid rgba(0,200,255,0.22);
  border-radius: 12rpx;
  caret-color: rgba(0,200,255,0.88);
}

.input-placeholder {
  color: rgba(226,242,255,0.24);
  letter-spacing: 4rpx;
  font-size: 28rpx;
}

/* === 重入卡片 === */
.reentry-card {
  margin-top: 16rpx;
}

.reentry-head {
  margin-bottom: 16rpx;
}

.reentry-kicker {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(0,200,255,0.46);
  font-family: 'DIN Alternate', Menlo, monospace;
  margin-bottom: 4rpx;
}

.reentry-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(226,242,255,0.92);
}

.reentry-code {
  font-size: 36rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  color: rgba(0,200,255,0.92);
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.reentry-meta {
  display: flex;
  gap: 24rpx;
  font-size: 22rpx;
  color: rgba(226,242,255,0.46);
  margin-bottom: 20rpx;
}

.reentry-actions {
  margin-top: 8rpx;
}

/* === 驾驶舱一体化外壳 === */
.cockpit-shell {
  position: relative;
  min-height: 980rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  clip-path: polygon(20rpx 0, calc(100% - 20rpx) 0, 100% 20rpx, 100% calc(100% - 20rpx), calc(100% - 20rpx) 100%, 20rpx 100%, 0 calc(100% - 20rpx), 0 20rpx);
}

/* === 舷窗区域 === */
.cockpit-window {
  position: relative;
  height: 560rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0,200,255,0.22);
  background:
    radial-gradient(circle at 18% 12%, rgba(10,132,255,0.12), transparent 32%),
    linear-gradient(180deg, rgba(3,10,18,0.96), rgba(0,0,0,0.98));
}

.reduce-motion .cockpit-window {
  transition: none;
}

/* 角落读数 */
.window-corner {
  position: absolute;
  z-index: 2;
  pointer-events: none;
}

.window-corner--tl {
  top: 28rpx;
  left: 28rpx;
}

.window-corner--tr {
  top: 28rpx;
  right: 28rpx;
}

.window-corner-value {
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(0,200,255,0.58);
  font-variant-numeric: tabular-nums;
  letter-spacing: 2rpx;
}

/* 舷窗底部读数 */
.window-bottom-readout {
  position: absolute;
  bottom: 20rpx;
  z-index: 2;
  font-size: 18rpx;
  color: rgba(0,200,255,0.38);
  letter-spacing: 2rpx;
  pointer-events: none;
}

.window-bottom-readout--mode {
  left: 28rpx;
}

.window-bottom-readout--link {
  right: 28rpx;
}

/* === 驾驶台区域 === */
.cockpit-deck {
  position: relative;
  z-index: 2;
  min-height: 360rpx;
  transform: translateY(-40rpx);
  padding: 0 4rpx 24rpx;
  background:
    linear-gradient(180deg, rgba(0,200,255,0.03), rgba(3,10,18,0.94) 30%),
    rgba(3,10,18,0.92);
  border: 1rpx solid rgba(0,200,255,0.18);
  border-top: none;
}

/* === 驾驶台唇缘 === */
.deck-lip {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent 8%, rgba(0,200,255,0.28) 30%, rgba(0,200,255,0.36) 50%, rgba(0,200,255,0.28) 70%, transparent 92%);
  z-index: 3;
}

/* 驾驶台深度线 */
.deck-depth-lines {
  position: absolute;
  inset: 0;
  opacity: 0.18;
  background-image:
    linear-gradient(rgba(0,200,255,0.10) 1rpx, transparent 1rpx);
  background-size: 100% 56rpx;
  pointer-events: none;
}

/* === 半圆脉冲仪表 === */
.self-gauge-module {
  position: relative;
  width: 480rpx;
  height: 200rpx;
  margin: -90rpx auto 0;
  overflow: hidden;
  z-index: 4;
}

/* 弧线容器 — 外环 */
.gauge-arc {
  position: absolute;
  left: 0;
  bottom: -200rpx;
  width: 480rpx;
  height: 480rpx;
  border-radius: 50%;
  clip-path: inset(0 0 50% 0);
}

.gauge-arc--outer {
  border: 2rpx solid rgba(0,200,255,0.28);
}

.is-positive .gauge-arc--outer {
  border-color: rgba(48,209,88,0.32);
}

.is-negative .gauge-arc--outer {
  border-color: rgba(255,159,10,0.32);
}

.gauge-arc--inner {
  left: 28rpx;
  bottom: -172rpx;
  width: 424rpx;
  height: 424rpx;
  border: 1rpx solid rgba(0,200,255,0.12);
}

.gauge-ticks {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 0;
  height: 0;
}

.gauge-tick {
  position: absolute;
  left: -1rpx;
  bottom: 0;
  width: 2rpx;
  height: 14rpx;
  background: rgba(0,200,255,0.24);
  transform-origin: center 200rpx;
}

.gauge-tick--mid {
  height: 20rpx;
  background: rgba(0,200,255,0.42);
}

.gauge-title {
  position: absolute;
  left: 50%;
  bottom: 52rpx;
  transform: translateX(-50%);
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(226,242,255,0.42);
  font-family: 'Courier New', Courier, monospace;
  z-index: 1;
}

.gauge-value {
  position: absolute;
  left: 50%;
  bottom: 16rpx;
  transform: translateX(-50%);
  font-family: 'DIN Alternate', 'SF Mono', Menlo, monospace;
  font-size: 56rpx;
  line-height: 1;
  color: rgba(226,242,255,0.94);
  font-variant-numeric: tabular-nums;
  z-index: 1;
}

.is-positive .gauge-value {
  color: rgba(48,209,88,0.92);
}

.is-negative .gauge-value {
  color: rgba(255,159,10,0.92);
}

.gauge-link {
  position: absolute;
  left: 50%;
  bottom: -6rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 18rpx;
  color: rgba(226,242,255,0.44);
  z-index: 1;
}

.gauge-link-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(226,242,255,0.22);
}

.gauge-link-dot--on {
  background: rgba(48,209,88,0.88);
  box-shadow: 0 0 6rpx rgba(48,209,88,0.4);
}

.gauge-stand {
  position: absolute;
  left: 50%;
  bottom: -8rpx;
  transform: translateX(-50%);
  width: 120rpx;
  height: 6rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.22), transparent);
  border-radius: 3rpx;
}

/* === 驾驶台中轴线 === */
.deck-spine {
  width: 1rpx;
  height: 24rpx;
  margin: 8rpx auto 0;
  background: linear-gradient(180deg, rgba(0,200,255,0.28), rgba(0,200,255,0.08));
}

/* === 终端屏幕 === */
.terminal-screen {
  margin-top: 16rpx;
  width: 100%;
}

/* 编队信息行 */
.terminal-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx;
  margin-bottom: 14rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.terminal-room-code {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.terminal-meta-label {
  font-size: 18rpx;
  color: rgba(226,242,255,0.42);
  letter-spacing: 1rpx;
}

.terminal-meta-value {
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(0,200,255,0.92);
  letter-spacing: 3rpx;
  font-variant-numeric: tabular-nums;
}

.terminal-copy-btn {
  padding: 4rpx 12rpx;
  border: 1rpx solid rgba(0,200,255,0.28);
  font-size: 18rpx;
  color: rgba(0,200,255,0.72);
}

.terminal-copy-btn:active {
  border-color: rgba(0,200,255,0.52);
  background: rgba(0,200,255,0.08);
}

.terminal-chip-row {
  display: flex;
  gap: 8rpx;
}

.terminal-chip {
  font-size: 18rpx;
  color: rgba(0,200,255,0.62);
  padding: 2rpx 10rpx;
  border: 1rpx solid rgba(0,200,255,0.14);
  font-variant-numeric: tabular-nums;
}

/* 实时脉冲行 */
.terminal-pulse-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
  padding: 0 4rpx;
}

.terminal-pulse-title {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(0,200,255,0.78);
  letter-spacing: 1rpx;
}

.terminal-pulse-badges {
  display: flex;
  gap: 12rpx;
}

.terminal-badge {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  color: rgba(0,200,255,0.62);
  font-variant-numeric: tabular-nums;
  padding: 2rpx 10rpx;
  border: 1rpx solid rgba(0,200,255,0.14);
}

/* 最近流向 */
.terminal-last-event {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 10rpx;
  margin-bottom: 10rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
  background: rgba(255,255,255,0.015);
}

.terminal-event-flow {
  font-size: 22rpx;
  color: rgba(226,242,255,0.62);
}

.terminal-event-value {
  font-family: 'Courier New', Courier, monospace;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(0,200,255,0.82);
  font-variant-numeric: tabular-nums;
}

.terminal-event-value.positive,
.terminal-event-value.is-positive {
  color: rgba(48,209,88,0.86);
}

.terminal-event-value.negative,
.terminal-event-value.is-negative {
  color: rgba(255,159,10,0.9);
}

/* === 脉冲轨迹预览行 === */
.terminal-trajectory-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
  padding: 0 4rpx;
}

.trajectory-label {
  font-size: 18rpx;
  color: rgba(226,242,255,0.32);
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.trajectory-sparkline {
  position: relative;
  flex: 1;
  height: 40rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0,200,255,0.08);
  background: rgba(0,0,0,0.16);
}

.trajectory-sparkline.is-empty {
  display: flex;
  align-items: center;
  justify-content: center;
}

.spark-dot {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(0,200,255,0.62);
  transform: translateX(-50%);
}

.spark-base-line {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(0,200,255,0.12);
}

.trajectory-waiting {
  font-size: 18rpx;
  color: rgba(226,242,255,0.22);
  white-space: nowrap;
}

.trajectory-action {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  text-align: center;
  border: 1rpx solid rgba(0,200,255,0.18);
  font-size: 20rpx;
  color: rgba(0,200,255,0.72);
}

.trajectory-action:active {
  border-color: rgba(0,200,255,0.42);
  background: rgba(0,200,255,0.04);
}

.terminal-chart {
  margin-top: 12rpx;
  border: 1rpx solid rgba(0,200,255,0.08);
  background: rgba(0,0,0,0.24);
  border-radius: 8rpx;
  overflow: hidden;
}

.reduce-motion .self-gauge-module,
.reduce-motion .terminal-screen {
  transition: none;
}

/* === 角落 HUD 读数 === */
.vch-value--faint {
  color: rgba(0,200,255,0.38);
}

/* === 外部航船标记 === */
.ship-target {
  position: absolute;
  width: 90rpx;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  color: rgba(226,242,255,0.78);
  transition: opacity .18s, transform .18s;
}

.ship-target:active {
  transform: translate(-50%, -50%) scale(0.92);
}

.ship-target--offline {
  opacity: 0.42;
}

/* 飞船剪影 — CSS-only 三角头 + 翼条 + 护盾环 */
.ship-silhouette {
  position: relative;
  width: 48rpx;
  height: 48rpx;
}

.ship-shield-ring {
  position: absolute;
  inset: -4rpx;
  border: 1rpx solid rgba(0,200,255,0.32);
  border-radius: 50%;
  pointer-events: none;
}

.ship-nose {
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 10rpx solid rgba(0,200,255,0.42);
}

.ship-wing {
  position: absolute;
  top: 50%;
  width: 12rpx;
  height: 3rpx;
  background: rgba(0,200,255,0.32);
  transform: translateY(-50%);
}

.ship-wing--left {
  left: -10rpx;
  transform: translateY(-50%) rotate(-12deg);
}

.ship-wing--right {
  right: -10rpx;
  transform: translateY(-50%) rotate(12deg);
}

.ship-core {
  position: absolute;
  inset: 6rpx;
  border-radius: 50%;
  background: rgba(0,200,255,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  z-index: 1;
}

.ship-avatar-mini {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.ship-avatar-char {
  font-size: 18rpx;
  font-weight: 700;
  color: rgba(0,200,255,0.88);
}

.ship-link-dot {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(226,242,255,0.22);
  z-index: 3;
}

.ship-link-dot--on {
  background: rgba(48,209,88,0.88);
  box-shadow: 0 0 6rpx rgba(48,209,88,0.4);
}

/* 飞船标签 */
.ship-label {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  min-width: 0;
}

.ship-name {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 16rpx;
  line-height: 1.2;
  color: rgba(226,242,255,0.72);
  text-align: center;
}

.ship-pulse {
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 18rpx;
  color: rgba(0,200,255,0.72);
  font-variant-numeric: tabular-nums;
}

.ship-target--positive .ship-pulse {
  color: rgba(48,209,88,0.86);
}

.ship-target--negative .ship-pulse {
  color: rgba(255,159,10,0.9);
}

/* 新成员接入动画 */
.ship-target--new {
  animation: shipJoin 0.45s ease-out;
}

@keyframes shipJoin {
  0% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.6);
  }
  60% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.06);
  }
  100% {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

.ship-target--new .ship-shield-ring {
  border-color: rgba(0,200,255,0.62);
  box-shadow: 0 0 12rpx rgba(0,200,255,0.2);
}

.reduce-motion .ship-target--new {
  animation: none;
}

.starfield {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.22) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 70% 42%, rgba(0,200,255,0.18) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 46% 76%, rgba(255,255,255,0.16) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 12% 68%, rgba(255,255,255,0.14) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 84% 20%, rgba(0,200,255,0.14) 0 1rpx, transparent 2rpx),
    linear-gradient(180deg, rgba(3,10,18,0.96), rgba(0,0,0,0.98));
}

.starfield--layer2 {
  opacity: 0.6;
  background:
    radial-gradient(circle at 35% 55%, rgba(255,255,255,0.12) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 62% 18%, rgba(255,255,255,0.10) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 88% 65%, rgba(0,200,255,0.08) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 8% 82%, rgba(255,255,255,0.10) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 52% 92%, rgba(255,255,255,0.08) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 78% 8%, rgba(255,255,255,0.10) 0 1rpx, transparent 2rpx);
  pointer-events: none;
}

.windshield-grid {
  position: absolute;
  inset: 24rpx;
  opacity: 0.28;
  background-image:
    linear-gradient(rgba(0,200,255,0.10) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0,200,255,0.08) 1rpx, transparent 1rpx),
    linear-gradient(120deg, transparent 0 48%, rgba(0,200,255,0.10) 49%, transparent 50%),
    linear-gradient(60deg, transparent 0 48%, rgba(0,200,255,0.08) 49%, transparent 50%);
  background-size: 56rpx 56rpx, 56rpx 56rpx, 220rpx 220rpx, 220rpx 220rpx;
  mask-image: radial-gradient(ellipse at center, black 0 58%, transparent 78%);
  -webkit-mask-image: radial-gradient(ellipse at center, black 0 58%, transparent 78%);
  pointer-events: none;
}

.windshield-frame {
  position: absolute;
  inset: 18rpx;
  border: 1rpx solid rgba(0,200,255,0.22);
  clip-path: polygon(42rpx 0, calc(100% - 42rpx) 0, 100% 54rpx, 100% calc(100% - 54rpx), calc(100% - 42rpx) 100%, 42rpx 100%, 0 calc(100% - 54rpx), 0 54rpx);
  pointer-events: none;
}

.windshield-frame::before,
.windshield-frame::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 28%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.32));
}

.windshield-frame::before {
  left: 28rpx;
}

.windshield-frame::after {
  right: 28rpx;
  transform: rotate(180deg);
}

/* 角落 HUD 标签 */
.viewport-corner-hud {
  position: absolute;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  pointer-events: none;
}

.viewport-corner-hud--tl {
  top: 32rpx;
  left: 32rpx;
}

.viewport-corner-hud--tr {
  top: 32rpx;
  right: 32rpx;
  align-items: flex-end;
}

.viewport-corner-hud--bl {
  bottom: 32rpx;
  left: 32rpx;
}

.viewport-corner-hud--br {
  bottom: 32rpx;
  right: 32rpx;
  align-items: flex-end;
}

.vch-label {
  font-size: 18rpx;
  color: rgba(226,242,255,0.38);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.vch-value {
  font-family: 'Courier New', Courier, monospace;
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(0,200,255,0.68);
  font-variant-numeric: tabular-nums;
}

.windshield-horizon {
  position: absolute;
  left: 12%;
  right: 12%;
  top: 56%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0,200,255,0.28), transparent);
  opacity: 0.7;
}

.cockpit-glass-readout {
  position: absolute;
  top: 40rpx;
  left: 44rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: rgba(0,200,255,0.34);
}

/* === 舷窗中央脉冲 HUD === */
.viewport-pulse-center {
  position: absolute;
  left: 50%;
  top: 66%;
  transform: translate(-50%, -50%);
  z-index: 3;
  pointer-events: none;
}

.vpulse-ring {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.vpulse-ring-outer {
  position: absolute;
  inset: 0;
  border: 1rpx solid rgba(0,200,255,0.32);
  border-radius: 50%;
  box-shadow: 0 0 32rpx rgba(0,200,255,0.10);
  animation: vpulseBreathe 3.2s ease-in-out infinite;
}

.vpulse-ring-inner {
  position: absolute;
  inset: 20rpx;
  border: 1rpx solid rgba(0,200,255,0.18);
  border-radius: 50%;
  animation: vpulseBreathe 3.2s ease-in-out infinite reverse;
}

@keyframes vpulseBreathe {
  0%, 100% { transform: scale(0.97); opacity: 0.5; }
  50% { transform: scale(1.02); opacity: 0.85; }
}

.reduce-motion .vpulse-ring-outer,
.reduce-motion .vpulse-ring-inner {
  animation: none;
}

.vpulse-title {
  font-size: 20rpx;
  color: rgba(226,242,255,0.56);
  position: relative;
  z-index: 1;
}

.vpulse-value {
  margin-top: 6rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 64rpx;
  line-height: 1;
  color: rgba(226,242,255,0.94);
  font-variant-numeric: tabular-nums;
  position: relative;
  z-index: 1;
}

.vpulse-link {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 18rpx;
  color: rgba(226,242,255,0.44);
  position: relative;
  z-index: 1;
}

/* === 本舰信息条 === */
.ownship-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
  margin-bottom: 24rpx;
}

.ownship-bar-call {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(226,242,255,0.92);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 50%;
}

.ownship-bar-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ownship-bar-tag {
  font-size: 20rpx;
  color: rgba(0,200,255,0.68);
  padding: 4rpx 12rpx;
  border: 1rpx solid rgba(0,200,255,0.18);
}

.ownship-bar-sep {
  font-size: 18rpx;
  color: rgba(226,242,255,0.22);
}

.standby-window-copy {
  position: absolute;
  left: 64rpx;
  right: 64rpx;
  top: 148rpx;
  z-index: 2;
  text-align: center;
}

.standby-kicker {
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 18rpx;
  letter-spacing: 5rpx;
  color: rgba(0,200,255,0.42);
}

.standby-title {
  margin-top: 14rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: rgba(226,242,255,0.94);
}

.standby-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(226,242,255,0.56);
}

.ship-field {
  position: absolute;
  top: 18%;
  bottom: 48%;
  left: 18%;
  right: 18%;
  z-index: 2;
}


.empty-formation {
  position: absolute;
  left: 50%;
  top: 46%;
  transform: translate(-50%, -50%);
  width: 320rpx;
  text-align: center;
  padding: 28rpx;
  border: 1rpx solid rgba(0,200,255,0.16);
  background: rgba(3,10,18,0.54);
  clip-path: polygon(18rpx 0, calc(100% - 18rpx) 0, 100% 18rpx, 100% calc(100% - 18rpx), calc(100% - 18rpx) 100%, 18rpx 100%, 0 calc(100% - 18rpx), 0 18rpx);
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(226,242,255,0.9);
}

.empty-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(226,242,255,0.5);
}

.ownship-reticle {
  position: absolute;
  left: 50%;
  bottom: 120rpx;
  width: 132rpx;
  height: 82rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(226,242,255,0.48);
  font-size: 18rpx;
  letter-spacing: 2rpx;
  z-index: 2;
}

.reticle-line {
  position: absolute;
  background: rgba(0,200,255,0.28);
}

.reticle-line--x {
  left: 0;
  right: 0;
  height: 1rpx;
}

.reticle-line--y {
  top: 0;
  bottom: 0;
  width: 1rpx;
}

.reticle-core {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border: 1rpx solid rgba(0,200,255,0.52);
  border-radius: 50%;
}

.cockpit-id-panel {
  position: absolute;
  left: 34rpx;
  bottom: 34rpx;
  z-index: 3;
  min-width: 208rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(0,200,255,0.22);
  background: rgba(0,0,0,0.32);
}

.cockpit-id-panel--idle {
  bottom: 420rpx;
}

.hud-label {
  display: block;
  font-size: 18rpx;
  color: rgba(226,242,255,0.42);
  letter-spacing: 2rpx;
}

.hud-code {
  display: block;
  margin-top: 4rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 38rpx;
  color: rgba(0,200,255,0.92);
  letter-spacing: 4rpx;
}

.cockpit-stats {
  position: absolute;
  right: 34rpx;
  bottom: 34rpx;
  z-index: 3;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  width: 360rpx;
}

.cockpit-stats--idle {
  left: 286rpx;
  right: 34rpx;
  bottom: 420rpx;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  width: auto;
}

.hud-stat {
  min-width: 0;
  padding: 12rpx 14rpx;
  border: 1rpx solid rgba(0,200,255,0.12);
  background: rgba(3,10,18,0.54);
  clip-path: polygon(8rpx 0, 100% 0, 100% calc(100% - 8rpx), calc(100% - 8rpx) 100%, 0 100%, 0 8rpx);
}

.hud-stat-label {
  display: block;
  font-size: 17rpx;
  color: rgba(226,242,255,0.42);

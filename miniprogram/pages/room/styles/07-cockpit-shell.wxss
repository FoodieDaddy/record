}

.pulse-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx 0;
}

.pulse-step {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;

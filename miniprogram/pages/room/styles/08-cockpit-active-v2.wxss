/* === active v6：驾驶舱重构 — 大型HUD舷窗 + 实体控制台 + 任务终端 === */

/* ===== active 状态页面禁止滚动 ===== */
.room-page--active {
  overflow: hidden;
  min-height: 100vh;
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom)) !important;
}

/* ===== 驾驶舱状态条（极简） ===== */
.cockpit-status-strip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 22rpx;
  background: rgba(2, 8, 16, 0.48);
  border-bottom: 1rpx solid rgba(0, 200, 255, 0.08);
  flex-shrink: 0;
}

.css-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.28);
}

.css-status-dot--online {
  background: rgba(48, 209, 88, 0.88);
  box-shadow: 0 0 6rpx rgba(48, 209, 88, 0.38);
}

.css-status-dot--connecting {
  background: rgba(255, 159, 10, 0.88);
  box-shadow: 0 0 6rpx rgba(255, 159, 10, 0.38);
  animation: statusPulse 1.6s ease-in-out infinite;
}

.css-status-dot--idle {
  background: rgba(255, 255, 255, 0.28);
}

@keyframes statusPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.35; }
}

.css-status-label {
  font-size: 20rpx;
  color: rgba(226, 242, 255, 0.56);
  letter-spacing: 1rpx;
  font-weight: 400;
}

/* ===== 单屏驾驶舱容器 ===== */
.cockpit-active-screen {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  padding: 6rpx 12rpx 12rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* ===== 旧滚动容器（已废弃） ===== */
.cockpit-scroll { display: none; }

/* ===== 抬头：HUD 舷窗主面板 ===== */
.cockpit-hud-zone {
  flex: 1 1 640rpx;
  min-height: 480rpx;
  max-height: 920rpx;
  position: relative;
  width: 100%;
  overflow: hidden;
  border: 1rpx solid rgba(0, 200, 255, 0.22);
  clip-path: polygon(
    28rpx 0, calc(100% - 28rpx) 0,
    100% 28rpx, 100% calc(100% - 28rpx),
    calc(100% - 28rpx) 100%, 28rpx 100%,
    0 calc(100% - 28rpx), 0 28rpx
  );
}

/* ===== 旧容器兼容 ===== */
.cockpit-glass-frame,
.cockpit-main-frame { display: none; }

/* ===== 深空背景层 ===== */
.deep-space-bg,
.deep-space-stars,
.deep-space-nebula,
.deep-space-grid,
.deep-space-vignette {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.deep-space-bg {
  z-index: 0;
  background:
    radial-gradient(circle at 20% 0%, rgba(10, 132, 255, 0.16), transparent 32%),
    radial-gradient(circle at 85% 12%, rgba(94, 92, 230, 0.10), transparent 28%),
    linear-gradient(180deg, #060E18 0%, #030810 40%, #020408 100%);
}

.deep-space-stars {
  z-index: 1;
  background:
    radial-gradient(circle at 14% 8%, rgba(226, 242, 255, 0.42) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 32% 18%, rgba(0, 200, 255, 0.34) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 58% 6%, rgba(226, 242, 255, 0.28) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 76% 24%, rgba(0, 200, 255, 0.24) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 22% 38%, rgba(226, 242, 255, 0.22) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 48% 32%, rgba(226, 242, 255, 0.20) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 82% 44%, rgba(0, 200, 255, 0.18) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 68% 52%, rgba(226, 242, 255, 0.16) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 38% 58%, rgba(0, 200, 255, 0.14) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 10% 62%, rgba(226, 242, 255, 0.18) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 88% 56%, rgba(0, 200, 255, 0.16) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 52% 22%, rgba(226, 242, 255, 0.12) 0 1rpx, transparent 2rpx);
  opacity: 0.92;
}

.deep-space-nebula {
  z-index: 2;
  background:
    radial-gradient(ellipse 56% 32% at 50% 10%, rgba(0, 200, 255, 0.08), transparent 62%),
    radial-gradient(ellipse 44% 40% at 18% 48%, rgba(10, 132, 255, 0.055), transparent 66%),
    radial-gradient(ellipse 40% 30% at 84% 62%, rgba(94, 92, 230, 0.045), transparent 68%);
}

.deep-space-grid {
  z-index: 3;
  opacity: 0.18;
  background-image:
    linear-gradient(rgba(0, 200, 255, 0.10) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 200, 255, 0.08) 1rpx, transparent 1rpx);
  background-size: 80rpx 80rpx;
  mask-image: radial-gradient(ellipse at 50% 24%, black 0 42%, transparent 72%);
  -webkit-mask-image: radial-gradient(ellipse at 50% 24%, black 0 42%, transparent 72%);
}

.deep-space-vignette {
  z-index: 4;
  background:
    linear-gradient(180deg, transparent 0 40%, rgba(0, 0, 0, 0.24) 60%, rgba(0, 0, 0, 0.46) 100%),
    radial-gradient(ellipse at center, transparent 0 56%, rgba(0, 0, 0, 0.42) 100%);
}

/* ===== HUD 顶部读数 ===== */
.main-hud-row {
  position: relative;
  z-index: 6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx 0;
}

.main-hud-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.14);
  background: rgba(2, 10, 18, 0.50);
  clip-path: polygon(10rpx 0, 100% 0, 100% calc(100% - 10rpx), calc(100% - 10rpx) 100%, 0 100%, 0 10rpx);
}

.main-hud-tag__kicker {
  font-family: 'Courier New', Courier, monospace;
  font-size: 17rpx;
  color: rgba(0, 200, 255, 0.36);
  letter-spacing: 1rpx;
}

.main-hud-tag__value {
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 24rpx;
  color: rgba(0, 200, 255, 0.86);
  letter-spacing: 3rpx;
  font-variant-numeric: tabular-nums;
}

.cockpit-lower-chassis::after {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 22rpx;
  content: '';
  pointer-events: none;
  background:
    repeating-linear-gradient(90deg, transparent 0 54rpx, rgba(0, 175, 255, 0.08) 55rpx 56rpx),
    linear-gradient(180deg, rgba(0, 175, 255, 0.025), rgba(0, 0, 0, 0.64));
  border-top: 1rpx solid rgba(80, 141, 170, 0.12);
}

.cockpit-chassis-ridge {
  position: absolute;
  top: 9rpx;
  right: 8%;
  left: 8%;
  height: 2rpx;
  z-index: 2;
  pointer-events: none;
  background: linear-gradient(90deg, transparent, rgba(0, 175, 255, 0.30) 24%, rgba(190, 226, 242, 0.18) 50%, rgba(0, 175, 255, 0.30) 76%, transparent);
  box-shadow: 0 -3rpx 14rpx rgba(0, 175, 255, 0.12);
}

.cockpit-console-wing {
  position: absolute;
  top: 22rpx;
  bottom: 0;
  z-index: 3;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(29, 47, 60, 0.96), rgba(8, 15, 21, 0.98) 30%, rgba(2, 6, 9, 0.99)),
    repeating-linear-gradient(90deg, transparent 0 36rpx, rgba(255, 255, 255, 0.018) 37rpx);
  border-top: 1rpx solid rgba(123, 191, 222, 0.20);
  box-shadow:
    inset 0 10rpx 24rpx rgba(0, 0, 0, 0.40),
    0 -5rpx 18rpx rgba(0, 0, 0, 0.70);
}

.cockpit-console-wing--left {
  left: 0;
  width: 43%;
  padding: 22rpx 42rpx 20rpx 18rpx;
  clip-path: polygon(0 12%, 82% 0, 100% 100%, 0 100%);
  box-sizing: border-box;
}

.cockpit-console-wing--right {
  right: 0;
  width: 43%;
  padding: 22rpx 18rpx 20rpx 42rpx;
  clip-path: polygon(18% 0, 100% 12%, 100% 100%, 0 100%);
  box-sizing: border-box;
}

.cockpit-mfd {
  position: fixed;
  bottom: calc(40rpx + env(safe-area-inset-bottom));

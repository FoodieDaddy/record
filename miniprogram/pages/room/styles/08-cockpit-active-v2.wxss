  border-radius: 50%;
  background: #32D74B;
  box-shadow: 0 0 8rpx rgba(50, 215, 75, 0.68);
}

.console-pulse-log__list {
  position: absolute;
  inset: 0 10rpx;
  padding-top: 40rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.console-pulse-log__item {
  position: relative;
  height: 26rpx;
  min-height: 26rpx;
  padding-right: 5rpx;
  padding-left: 5rpx;
  color: rgba(167, 211, 226, 0.38);
  background: transparent;
  transform-origin: left center;
}

.console-pulse-log__item--new {
  color: rgba(207, 239, 249, 0.80);
  animation: pulse-stream-write 760ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
}

.console-pulse-log__item:nth-child(1) {
  animation: pulse-stream-rise-old 520ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.console-pulse-log__item:nth-child(2) {
  animation: pulse-stream-rise-mid 520ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.console-pulse-log__item:nth-child(3) {
  animation: pulse-stream-rise-new 520ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.console-pulse-log__item--new:nth-child(1),
.console-pulse-log__item--new:nth-child(2),
.console-pulse-log__item--new:nth-child(3) {
  animation: pulse-stream-write 760ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
}

.console-pulse-log__item--new::after {
  position: absolute;
  top: 3rpx;
  bottom: 3rpx;
  left: 0;
  width: 2rpx;
  content: '';
  background: #00C8FF;
  box-shadow: 0 0 12rpx rgba(0, 200, 255, 0.78);
}

.console-pulse-log__empty {
  position: absolute;
  inset: 0 10rpx;
  padding-top: 40rpx;
  box-sizing: border-box;
  background: radial-gradient(ellipse at 50% 30%, rgba(0, 175, 255, 0.025), transparent 72%);
}

.console-pulse-log__idle-line {
  width: 42%;
  height: 1rpx;
  margin: 28rpx auto 0;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.22), transparent);
  animation: pulse-idle-scan 2.4s ease-in-out infinite;
}

@keyframes pulse-readout-roll {
  0% {
    transform: translateY(0);
    filter: blur(2rpx);
    opacity: 0.28;
  }
  56% {
    transform: translateY(-76rpx);
    filter: blur(1rpx);
    opacity: 0.76;
  }
  100% {
    transform: translateY(-38rpx);
    filter: blur(0);
    opacity: 1;
  }
}

@keyframes pulse-stream-rise-old {
  from {
    transform: translateY(25rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 0.28;
  }
}

@keyframes pulse-stream-rise-mid {
  from {
    transform: translateY(25rpx);
    opacity: 0.16;
  }
  to {
    transform: translateY(0);
    opacity: 0.62;
  }
}

@keyframes pulse-stream-rise-new {
  from {
    transform: translateY(25rpx);
    opacity: 0.34;
  }
  to {
    transform: translateY(0);
    opacity: 0.94;
  }
}

@keyframes pulse-stream-write {
  0% {
    clip-path: inset(0 100% 0 0);
    transform: translateY(25rpx);
    opacity: 0;
  }
  38% {
    clip-path: inset(0 0 0 0);
    transform: translateY(0);
    opacity: 1;
  }
  100% {
    clip-path: inset(0 0 0 0);
    transform: translateY(0);
    opacity: 0.92;
  }
}

@keyframes pulse-idle-scan {
  0%,
  100% {
    transform: scaleX(0.45);
    opacity: 0.28;
  }
  50% {
    transform: scaleX(1);
    opacity: 0.75;
  }
}

/* 脉冲记录：收发方向配色，底部短线关闭 */
.pulse-log-sheet {
  padding: 24rpx 24rpx 58rpx;
}

.pulse-log-ar__toolbar {
  display: none;
}

.pulse-log-ar__stream {
  height: 100%;
}

.pulse-log-ar__row--mine {
  color: rgba(232, 248, 252, 0.94);
}

.pulse-log-ar__row--outgoing {
  color: rgba(255, 224, 172, 0.92);
  border-left-color: rgba(255, 159, 10, 0.82);
  background: linear-gradient(90deg, rgba(255, 159, 10, 0.13), transparent 74%);
}

.pulse-log-ar__row--incoming {
  color: rgba(196, 255, 239, 0.94);
  border-left-color: rgba(52, 232, 196, 0.82);
  background: linear-gradient(90deg, rgba(52, 232, 196, 0.13), transparent 74%);
}

.pulse-log-ar__row--outgoing .pulse-log-ar__time {
  color: rgba(255, 188, 92, 0.52);
}

.pulse-log-ar__row--incoming .pulse-log-ar__time {
  color: rgba(86, 232, 204, 0.52);
}

.pulse-log-ar__row--outgoing .pulse-log-ar__amount {
  color: #FFB340;
  text-shadow: 0 0 12rpx rgba(255, 159, 10, 0.26);
}

.pulse-log-ar__row--incoming .pulse-log-ar__amount {
  color: #34E8C4;
  text-shadow: 0 0 12rpx rgba(52, 232, 196, 0.28);
}

.pulse-log-ar__close-handle {
  position: absolute;
  right: 0;
  bottom: 4rpx;
  left: 0;
  z-index: 6;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pulse-log-ar__close-line {
  width: 82rpx;
  height: 5rpx;
  border-radius: 5rpx;
  background: rgba(166, 218, 235, 0.48);
  box-shadow: 0 0 14rpx rgba(0, 175, 255, 0.16);
  transition: width 120ms ease, background 120ms ease, box-shadow 120ms ease;
}

.pulse-log-ar__close-handle--press .pulse-log-ar__close-line {
  width: 104rpx;
  background: rgba(197, 239, 252, 0.82);
  box-shadow: 0 0 20rpx rgba(0, 200, 255, 0.34);
}

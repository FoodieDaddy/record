}

.hud-log-item__val.is-negative {
  color: #FF9F0A;
  border-color: rgba(255, 159, 10, 0.24);
  background: rgba(255, 159, 10, 0.08);
}

.hud-log-item__val.is-neutral {
  color: rgba(201, 232, 248, 0.54);
}

.reduce-motion .hud-log-item {
  animation: none !important;
}

/* ===== 第一人称座舱控制台 ===== */
.cockpit-lower-chassis {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 76;
  height: calc(176rpx + env(safe-area-inset-bottom));
  overflow: visible;
  pointer-events: auto;
  background:
    linear-gradient(90deg, rgba(0, 0, 0, 0.94), rgba(8, 17, 25, 0.90) 36%, rgba(8, 17, 25, 0.90) 64%, rgba(0, 0, 0, 0.94)),
    linear-gradient(180deg, #172532 0%, #070D13 28%, #020508 100%);
  clip-path: polygon(0 22%, 34% 5%, 42% 0, 58% 0, 66% 5%, 100% 22%, 100% 100%, 0 100%);
  box-shadow:
    0 -16rpx 50rpx rgba(0, 0, 0, 0.92),
    inset 0 2rpx 0 rgba(114, 186, 222, 0.12),
    inset 0 22rpx 40rpx rgba(0, 0, 0, 0.36);

/* === active v6：驾驶舱重构 — 大型HUD舷窗 + 实体控制台 + 任务终端 === */

/* ===== active 状态页面禁止滚动 ===== */
.room-page--active {
  overflow: hidden;
  min-height: 100vh;
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom)) !important;
}

/* ===== 驾驶舱状态条（极简） ===== */
.cockpit-status-strip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 22rpx;
  background: rgba(2, 8, 16, 0.48);
  border-bottom: 1rpx solid rgba(0, 200, 255, 0.08);
  flex-shrink: 0;
}

.css-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.28);
}

.css-status-dot--online {
  background: rgba(48, 209, 88, 0.88);
  box-shadow: 0 0 6rpx rgba(48, 209, 88, 0.38);
}

.css-status-dot--connecting {
  background: rgba(255, 159, 10, 0.88);
  box-shadow: 0 0 6rpx rgba(255, 159, 10, 0.38);
  animation: statusPulse 1.6s ease-in-out infinite;
}

.css-status-dot--idle {
  background: rgba(255, 255, 255, 0.28);
}

@keyframes statusPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.35; }
}

.css-status-label {
  font-size: 20rpx;
  color: rgba(226, 242, 255, 0.56);
  letter-spacing: 1rpx;
  font-weight: 400;
}

/* ===== 单屏驾驶舱容器 ===== */
.cockpit-active-screen {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  padding: 10rpx 16rpx 16rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* ===== 旧滚动容器（已废弃） ===== */
.cockpit-scroll { display: none; }

/* ===== 抬头：HUD 舷窗主面板 ===== */
.cockpit-hud-zone {
  flex: 1 1 640rpx;
  min-height: 480rpx;
  max-height: 740rpx;
  position: relative;
  width: 100%;
  overflow: hidden;
  border: 1rpx solid rgba(0, 200, 255, 0.22);
  clip-path: polygon(
    28rpx 0, calc(100% - 28rpx) 0,
    100% 28rpx, 100% calc(100% - 28rpx),
    calc(100% - 28rpx) 100%, 28rpx 100%,
    0 calc(100% - 28rpx), 0 28rpx
  );
}

/* ===== 旧容器兼容 ===== */
.cockpit-glass-frame,
.cockpit-main-frame { display: none; }

/* ===== 深空背景层 ===== */
.deep-space-bg,
.deep-space-stars,
.deep-space-nebula,
.deep-space-grid,
.deep-space-vignette {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.deep-space-bg {
  z-index: 0;
  background:
    radial-gradient(circle at 20% 0%, rgba(10, 132, 255, 0.16), transparent 32%),
    radial-gradient(circle at 85% 12%, rgba(94, 92, 230, 0.10), transparent 28%),
    linear-gradient(180deg, #060E18 0%, #030810 40%, #020408 100%);
}

.deep-space-stars {
  z-index: 1;
  background:
    radial-gradient(circle at 14% 8%, rgba(226, 242, 255, 0.42) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 32% 18%, rgba(0, 200, 255, 0.34) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 58% 6%, rgba(226, 242, 255, 0.28) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 76% 24%, rgba(0, 200, 255, 0.24) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 22% 38%, rgba(226, 242, 255, 0.22) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 48% 32%, rgba(226, 242, 255, 0.20) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 82% 44%, rgba(0, 200, 255, 0.18) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 68% 52%, rgba(226, 242, 255, 0.16) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 38% 58%, rgba(0, 200, 255, 0.14) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 10% 62%, rgba(226, 242, 255, 0.18) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 88% 56%, rgba(0, 200, 255, 0.16) 0 1rpx, transparent 2rpx),
    radial-gradient(circle at 52% 22%, rgba(226, 242, 255, 0.12) 0 1rpx, transparent 2rpx);
  opacity: 0.92;
}

.deep-space-nebula {
  z-index: 2;
  background:
    radial-gradient(ellipse 56% 32% at 50% 10%, rgba(0, 200, 255, 0.08), transparent 62%),
    radial-gradient(ellipse 44% 40% at 18% 48%, rgba(10, 132, 255, 0.055), transparent 66%),
    radial-gradient(ellipse 40% 30% at 84% 62%, rgba(94, 92, 230, 0.045), transparent 68%);
}

.deep-space-grid {
  z-index: 3;
  opacity: 0.18;
  background-image:
    linear-gradient(rgba(0, 200, 255, 0.10) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 200, 255, 0.08) 1rpx, transparent 1rpx);
  background-size: 80rpx 80rpx;
  mask-image: radial-gradient(ellipse at 50% 24%, black 0 42%, transparent 72%);
  -webkit-mask-image: radial-gradient(ellipse at 50% 24%, black 0 42%, transparent 72%);
}

.deep-space-vignette {
  z-index: 4;
  background:
    linear-gradient(180deg, transparent 0 40%, rgba(0, 0, 0, 0.24) 60%, rgba(0, 0, 0, 0.46) 100%),
    radial-gradient(ellipse at center, transparent 0 56%, rgba(0, 0, 0, 0.42) 100%);
}

/* ===== HUD 顶部读数 ===== */
.main-hud-row {
  position: relative;
  z-index: 6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx 0;
}

.main-hud-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.14);
  background: rgba(2, 10, 18, 0.50);
  clip-path: polygon(10rpx 0, 100% 0, 100% calc(100% - 10rpx), calc(100% - 10rpx) 100%, 0 100%, 0 10rpx);
}

.main-hud-tag__kicker {
  font-family: 'Courier New', Courier, monospace;
  font-size: 17rpx;
  color: rgba(0, 200, 255, 0.36);
  letter-spacing: 1rpx;
}

.main-hud-tag__value {
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 24rpx;
  color: rgba(0, 200, 255, 0.86);
  letter-spacing: 3rpx;
  font-variant-numeric: tabular-nums;
}

/* ===== 成员观测层 ===== */
.observation-zone {
  position: relative;
  z-index: 5;
  height: 320rpx;
  overflow: visible;
}

/* 成员识别卡 */
.hud-member {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translate(-50%, -50%);
  pointer-events: auto;
  z-index: 2;
  width: 110rpx;
}

.hud-member__ring {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 200, 255, 0.32);
  padding: 3rpx;
  box-sizing: border-box;
  background: rgba(2, 10, 18, 0.68);
  box-shadow:
    0 0 12rpx rgba(0, 200, 255, 0.10),
    inset 0 0 8rpx rgba(0, 200, 255, 0.06);
}

.hud-member__avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.08);
}

.hud-member__online-dot {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(226, 242, 255, 0.18);
  border: 2rpx solid rgba(2, 10, 18, 0.90);
  box-sizing: border-box;
}

.hud-member__name {
  margin-top: 10rpx;
  font-size: 18rpx;
  line-height: 22rpx;
  color: rgba(226, 242, 255, 0.94);
  letter-spacing: 1rpx;
  text-align: center;
  max-width: 110rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.hud-member__score {
  margin-top: 4rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 20rpx;
  line-height: 22rpx;
  letter-spacing: 1rpx;
  font-variant-numeric: tabular-nums;
  text-align: center;
}

.hud-member__score.is-positive { color: rgba(48, 209, 88, 0.88); }
.hud-member__score.is-negative { color: rgba(255, 159, 10, 0.86); }
.hud-member__score.is-zero { color: rgba(0, 200, 255, 0.64); }

/* 在线态 */
.hud-member--online .hud-member__ring {
  border-color: rgba(48, 209, 88, 0.40);
  box-shadow:
    0 0 14rpx rgba(48, 209, 88, 0.12),
    inset 0 0 8rpx rgba(48, 209, 88, 0.06);
}
.hud-member--online .hud-member__online-dot {
  background: rgba(48, 209, 88, 0.88);
  box-shadow: 0 0 6rpx rgba(48, 209, 88, 0.40);
}

/* 新加入动画 */
.hud-member--new { animation: memberArrive 0.5s ease-out; }
@keyframes memberArrive {
  0% { opacity: 0; transform: translate(-50%, -50%) scale(0.3); }
  60% { opacity: 1; transform: translate(-50%, -50%) scale(1.08); }
  100% { transform: translate(-50%, -50%) scale(1); }
}

/* 脉冲冲击 (静态高亮风格) */
.hud-member--impact .hud-member__ring {
  border-color: rgba(255, 255, 255, 1);
  background: rgba(10, 132, 255, 0.45);
  box-shadow: 
    0 0 36rpx rgba(10, 132, 255, 0.95),
    inset 0 0 24rpx rgba(10, 132, 255, 0.8);
  transform: scale(1.15);
  transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* 点击反馈 */
.hud-member--tap .hud-member__ring {
  border-color: rgba(0, 200, 255, 0.68);
  box-shadow:
    0 0 22rpx rgba(0, 200, 255, 0.36),
    inset 0 0 12rpx rgba(0, 200, 255, 0.18);
  transform: scale(0.92);
  transition: transform 0.10s ease, border-color 0.10s ease;
}

.hud-member--tap .hud-member__name {
  color: rgba(0, 200, 255, 0.96);
}

/* 头像首字徽标 */
.hud-member__avatar--char {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 200, 255, 0.12);
}
.hud-member__avatar--char text {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(0, 200, 255, 0.86);
  line-height: 1;
}

.reduce-motion .hud-member--new { animation: none !important; }
.reduce-motion .hud-member--impact .hud-member__ring { box-shadow: none !important; }
.reduce-motion .hud-member--tap .hud-member__ring { transition: none !important; }

/* ===== 旧 formation-ship 隐藏 ===== */
.observation-zone .formation-ship,
.observation-zone .ship-craft { display: none; }

/* ===== 空态：远距离信标扫描 ===== */
.observation-empty {
  position: absolute;
  left: 50%;
  top: 46%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  pointer-events: none;
}

/* 扫描脉冲环 */
.scan-beacon-visual {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-pulse-ring {
  position: absolute;
  inset: 0;
  border: 1rpx solid rgba(0, 200, 255, 0.14);
  border-radius: 50%;
  opacity: 0.6;
}

.scan-pulse-ring--mid {
  inset: 22rpx;
  border-color: rgba(0, 200, 255, 0.20);
  opacity: 0.8;
}

.scan-pulse-ring--outer {
  inset: 44rpx;
  border-color: rgba(0, 200, 255, 0.10);
  border-style: dashed;
  opacity: 0.4;
}

/* 占位航船点 */
.scan-placeholder-dots {
  position: absolute;
  inset: 0;
}

.scan-placeholder-dot {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.28);
  box-shadow: 0 0 8rpx rgba(0, 200, 255, 0.12);
}

.scan-placeholder-dot--1 { top: 28rpx; left: 50%; transform: translateX(-50%); }
.scan-placeholder-dot--2 { bottom: 28rpx; left: 26rpx; }
.scan-placeholder-dot--3 { bottom: 28rpx; right: 26rpx; }

.observation-empty__title {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(226, 242, 255, 0.48);
  letter-spacing: 4rpx;
}

.observation-empty__desc {
  font-size: 19rpx;
  color: rgba(226, 242, 255, 0.28);
  letter-spacing: 2rpx;
}

.observation-empty__hint {
  font-size: 16rpx;
  color: rgba(0, 200, 255, 0.24);
  letter-spacing: 1rpx;
  margin-top: 4rpx;
  font-family: 'Courier New', Courier, monospace;
}

/* 坐标标记 */
.observation-grid-marks {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

.coord-mark {
  position: absolute;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 16rpx;
  color: rgba(0, 200, 255, 0.18);
  letter-spacing: 2rpx;
}

.coord-mark--tl { top: 16rpx; left: 24rpx; }
.coord-mark--tr { top: 16rpx; right: 24rpx; }

/* ===== 本舰脉冲仪表（HUD下半区） ===== */
.pulse-instrument {
  position: absolute;
  left: 50%;
  bottom: 30rpx;
  transform: translateX(-50%);
  z-index: 6;
  width: 320rpx;
  height: 136rpx;
  text-align: center;
}

.pulse-instrument__arc-outer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 10rpx;
  height: 130rpx;
  border: 2rpx solid rgba(0, 200, 255, 0.28);
  border-bottom: none;
  border-top-left-radius: 320rpx;
  border-top-right-radius: 320rpx;
}

/* 能量瞬间填充层（功率仪动效） */
.pulse-instrument__power-track {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 10rpx;
  height: 130rpx;
  border: 6rpx solid rgba(0, 200, 255, 0.9);
  border-bottom: none;
  border-top-left-radius: 320rpx;
  border-top-right-radius: 320rpx;
  box-shadow: 0 0 24rpx rgba(0, 200, 255, 0.8),
              inset 0 0 12rpx rgba(0, 200, 255, 0.6);
  opacity: 0;
  pointer-events: none;
}

.pulse-instrument.is-positive .pulse-instrument__arc-outer {
  border-color: rgba(48, 209, 88, 0.32);
}
.pulse-instrument.is-positive .pulse-instrument__power-track {
  border-color: rgba(48, 209, 88, 0.95);
  box-shadow: 0 0 24rpx rgba(48, 209, 88, 0.8), inset 0 0 12rpx rgba(48, 209, 88, 0.6);
}

.pulse-instrument.is-negative .pulse-instrument__arc-outer {
  border-color: rgba(255, 159, 10, 0.34);
}
.pulse-instrument.is-negative .pulse-instrument__power-track {
  border-color: rgba(255, 159, 10, 0.95);
  box-shadow: 0 0 24rpx rgba(255, 159, 10, 0.8), inset 0 0 12rpx rgba(255, 159, 10, 0.6);
}

/* 激活充能动画 */
.pulse-instrument.is-powering .pulse-instrument__power-track {
  animation: powerSurgeWipe 900ms cubic-bezier(0.1, 0.9, 0.2, 1) forwards;
}

@keyframes powerSurgeWipe {
  0% { 
    opacity: 0; 
    clip-path: inset(0 100% 0 0); 
  }
  15% { 
    opacity: 1; 
    clip-path: inset(0 0 0 0); 
  }
  70% {
    opacity: 0.8;
    clip-path: inset(0 0 0 0);
  }
  100% { 
    opacity: 0; 
    clip-path: inset(0 0 0 0);
  }
}

.pulse-instrument__arc-inner {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 12rpx;
  height: 98rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.12);
  border-bottom: none;
  border-top-left-radius: 280rpx;
  border-top-right-radius: 280rpx;
}

/* 刻度线 */
.pulse-instrument__ticks {
  position: absolute;
  left: 46rpx;
  right: 46rpx;
  bottom: 28rpx;
  height: 108rpx;
  pointer-events: none;
}

.pulse-instrument__tick {
  position: absolute;
  left: 50%;
  bottom: -2rpx;
  width: 1rpx;
  height: 10rpx;
  background: rgba(0, 200, 255, 0.22);
  transform-origin: bottom center;
}

.pulse-instrument__title {
  position: relative;
  z-index: 2;
  display: block;
  padding-top: 14rpx;
  font-size: 17rpx;
  line-height: 20rpx;
  color: rgba(226, 242, 255, 0.48);
  letter-spacing: 3rpx;
}

.pulse-instrument__value {
  position: relative;
  z-index: 2;
  display: block;
  margin-top: 2rpx;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 48rpx;
  line-height: 52rpx;
  color: rgba(226, 242, 255, 0.96);
  font-variant-numeric: tabular-nums;
}

.pulse-instrument.is-positive .pulse-instrument__value {
  color: rgba(48, 209, 88, 0.92);
}
.pulse-instrument.is-negative .pulse-instrument__value {
  color: rgba(255, 159, 10, 0.92);
}

.pulse-instrument__status {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  font-size: 15rpx;
  line-height: 18rpx;
  color: rgba(226, 242, 255, 0.40);
}

.pulse-instrument__dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(48, 209, 88, 0.88);
  box-shadow: 0 0 6rpx rgba(48, 209, 88, 0.38);
}

.pulse-instrument__base {
  position: absolute;
  left: 50%;
  bottom: 2rpx;
  transform: translateX(-50%);
  width: 100rpx;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.20), transparent);
  border-radius: 2rpx;
}

/* ===== HUD 下沿唇缘 ===== */
.cockpit-dashboard-lip {
  position: absolute;
  z-index: 7;
  left: 0;
  right: 0;
  bottom: 0;
  height: 4rpx;
  background: linear-gradient(90deg, transparent 6%, rgba(0, 200, 255, 0.26) 28%, rgba(0, 200, 255, 0.38) 50%, rgba(0, 200, 255, 0.26) 72%, transparent 94%);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.50);
}

/* ===== 座舱包围：左右边框 ===== */
.cockpit-frame-left,
.cockpit-frame-right {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 36rpx;
  z-index: 8;
  pointer-events: none;
}

.cockpit-frame-left {
  left: 0;
  background: linear-gradient(90deg, rgba(2, 8, 16, 0.78), transparent);
  border-right: 1rpx solid rgba(0, 200, 255, 0.08);
}

.cockpit-frame-right {
  right: 0;
  background: linear-gradient(270deg, rgba(2, 8, 16, 0.78), transparent);
  border-left: 1rpx solid rgba(0, 200, 255, 0.08);
}

/* 座舱包围：顶部弧形玻璃边缘 */
.cockpit-canopy-arc {
  position: absolute;
  left: 8%;
  right: 8%;
  top: -2rpx;
  height: 32rpx;
  z-index: 8;
  pointer-events: none;
  border-top: 2rpx solid rgba(0, 200, 255, 0.14);
  border-left: 1rpx solid rgba(0, 200, 255, 0.08);
  border-right: 1rpx solid rgba(0, 200, 255, 0.08);
  border-radius: 50% 50% 0 0;
  background: linear-gradient(180deg, rgba(2, 8, 16, 0.54), transparent);
}

/* ===== 飞船控制台 V2（与 HUD 融合） ===== */
.cockpit-console-v2 {
  flex-shrink: 0;
  position: relative;
  width: 100%;
  padding: 12rpx 20rpx 10rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(4, 12, 20, 0.96), rgba(2, 8, 16, 0.98));
  border-top: 2rpx solid rgba(0, 200, 255, 0.18);
}

/* 左右装饰舂线 */
.ccv2-rail {
  position: absolute;
  top: 8rpx;
  bottom: 8rpx;
  width: 3rpx;
  pointer-events: none;
}
.ccv2-rail--left {
  left: 10rpx;
  background: linear-gradient(180deg, rgba(0, 200, 255, 0.28), rgba(0, 200, 255, 0.06));
}
.ccv2-rail--right {
  right: 10rpx;
  background: linear-gradient(180deg, rgba(0, 200, 255, 0.28), rgba(0, 200, 255, 0.06));
}

/* 主按键面板 */
.ccv2-panel {
  display: flex;
  align-items: stretch;
  gap: 0;
  position: relative;
  border: 1rpx solid rgba(0, 200, 255, 0.16);
  background: linear-gradient(180deg, rgba(6, 16, 28, 0.92), rgba(2, 8, 16, 0.96));
  clip-path: polygon(
    12rpx 0, calc(100% - 12rpx) 0,
    100% 12rpx, 100% calc(100% - 12rpx),
    calc(100% - 12rpx) 100%, 12rpx 100%,
    0 calc(100% - 12rpx), 0 12rpx
  );
  overflow: hidden;
}

/* 中央分隔竖线 */
.ccv2-divider {
  width: 1rpx;
  background: linear-gradient(180deg, transparent 10%, rgba(0, 200, 255, 0.22) 50%, transparent 90%);
  flex-shrink: 0;
}

/* 主功能按钮 */
.ccv2-btn {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  -webkit-tap-highlight-color: transparent;
  user-select: none;
  overflow: hidden;
}

/* 按钮底部扫描光 */
.ccv2-btn__glow {
  position: absolute;
  left: 10%;
  right: 10%;
  bottom: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.32), transparent);
  pointer-events: none;
}

.ccv2-btn__body {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  position: relative;
  z-index: 1;
}

/* 指示灯 */
.ccv2-btn__indicator {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-bottom: 4rpx;
}
.ccv2-btn__indicator--cyan {
  background: rgba(0, 200, 255, 0.7);
  box-shadow: 0 0 8rpx rgba(0, 200, 255, 0.5);
}
.ccv2-btn__indicator--green {
  background: rgba(48, 209, 88, 0.7);
  box-shadow: 0 0 8rpx rgba(48, 209, 88, 0.5);
}

.ccv2-btn__label {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(226, 242, 255, 0.92);
  letter-spacing: 4rpx;
  line-height: 1.2;
}

.ccv2-btn__sub {
  font-size: 14rpx;
  font-family: 'Courier New', Courier, monospace;
  color: rgba(0, 200, 255, 0.28);
  letter-spacing: 3rpx;
  line-height: 1;
}

/* 按下反馈 */
.ccv2-btn--press {
  background: rgba(0, 200, 255, 0.06);
}
.ccv2-btn--press .ccv2-btn__glow {
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.6), transparent);
}
.ccv2-btn--press .ccv2-btn__label {
  color: rgba(0, 200, 255, 0.96);
}
.ccv2-btn--press .ccv2-btn__indicator--cyan {
  background: rgba(0, 200, 255, 1);
  box-shadow: 0 0 14rpx rgba(0, 200, 255, 0.8);
}
.ccv2-btn--press .ccv2-btn__indicator--green {
  background: rgba(48, 209, 88, 1);
  box-shadow: 0 0 14rpx rgba(48, 209, 88, 0.8);
}

/* ===== 紧急按钮（解散/撤离）===== */
.ccv2-emergency {
  position: absolute;
  right: 24rpx;
  bottom: -2rpx;
  display: flex;
  align-items: center;
  -webkit-tap-highlight-color: transparent;
  user-select: none;
  z-index: 2;
}

.ccv2-emergency__guard {
  position: absolute;
  inset: -6rpx -8rpx;
  border: 1rpx dashed rgba(255, 69, 58, 0.22);
  border-radius: 8rpx;
  pointer-events: none;
}

.ccv2-emergency__btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  background: rgba(12, 4, 4, 0.92);
  border: 1rpx solid rgba(255, 69, 58, 0.28);
  border-radius: 6rpx;
  position: relative;
}

.ccv2-emergency__led {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(255, 69, 58, 0.6);
  box-shadow: 0 0 6rpx rgba(255, 69, 58, 0.3);
  flex-shrink: 0;
}

.ccv2-emergency__text {
  font-size: 18rpx;
  font-weight: 500;
  color: rgba(255, 126, 118, 0.72);
  letter-spacing: 2rpx;
}

/* 紧急按钮按下 */
.ccv2-emergency--press .ccv2-emergency__btn {
  background: rgba(255, 69, 58, 0.12);
  border-color: rgba(255, 69, 58, 0.52);
}
.ccv2-emergency--press .ccv2-emergency__led {
  background: rgba(255, 69, 58, 1);
  box-shadow: 0 0 12rpx rgba(255, 69, 58, 0.6);
}
.ccv2-emergency--press .ccv2-emergency__text {
  color: rgba(255, 126, 118, 1);
}

.reduce-motion .ccv2-btn--press,
.reduce-motion .ccv2-emergency--press .ccv2-emergency__btn {
  transition: none !important;
}

/* ===== 输出脉冲终端 ===== */
.output-terminal {
  flex: 1 0 180rpx;
  min-height: 120rpx;
  max-height: 220rpx;
  position: relative;
  margin: 6rpx 12rpx 0;
  padding: 14rpx 16rpx 10rpx;
  background: rgba(2, 8, 16, 0.52);
  border: 1rpx solid rgba(0, 200, 255, 0.10);
  clip-path: polygon(10rpx 0, calc(100% - 10rpx) 0, 100% 6rpx, 100% calc(100% - 6rpx), calc(100% - 10rpx) 100%, 10rpx 100%, 0 calc(100% - 6rpx), 0 6rpx);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.terminal-scanline {
  position: absolute;
  left: 10%;
  right: 10%;
  top: 4rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.08), transparent);
  pointer-events: none;
  z-index: 1;
}

.terminal-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
  flex-shrink: 0;
}

.terminal-header__title {
  font-size: 17rpx;
  font-weight: 600;
  color: rgba(0, 200, 255, 0.54);
  letter-spacing: 2rpx;
}

.terminal-entries {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 3rpx;
}

.terminal-entry {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 17rpx;
}

.terminal-entry--new {
  color: rgba(0, 200, 255, 0.72);
}

.terminal-entry__time {
  font-family: 'Courier New', Courier, monospace;
  font-size: 14rpx;
  color: rgba(226, 242, 255, 0.24);
  white-space: nowrap;
  flex-shrink: 0;
}

.terminal-entry__text {
  font-size: 17rpx;
  color: rgba(226, 242, 255, 0.48);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.terminal-entry__value {
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 16rpx;
  color: rgba(0, 200, 255, 0.56);
  flex-shrink: 0;
}

.terminal-entry__value.is-positive {
  color: rgba(48, 209, 88, 0.86);
}

.terminal-entry__value.is-negative {
  color: rgba(255, 159, 10, 0.90);
}

.terminal-empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  color: rgba(226, 242, 255, 0.24);
}


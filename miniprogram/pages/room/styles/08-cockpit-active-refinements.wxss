/* ===== 编队页最终布局：第一人称 HUD + 底部控制台 ===== */
.room-page--active {
  min-height: 100vh;
  height: 100vh;
  padding-bottom: var(--sr-tabbar-safe-height, calc(140rpx + env(safe-area-inset-bottom))) !important;
  overflow: hidden;
}

.room-page--active .room-custom-nav {
  margin-bottom: 0;
  background: rgba(2, 8, 16, 0.76);
  border-bottom: 1rpx solid rgba(0, 200, 255, 0.10);
}

.room-page--active .room-custom-nav::after {
  display: none;
}

.room-page--active .room-custom-nav__bar {
  justify-content: flex-start;
  padding: 0 32rpx;
}

.room-page--active .cockpit-nav-hud {
  max-width: calc(100% - 190rpx);
  gap: 14rpx;
}

.room-page--active .cockpit-nav-hud__link {
  color: rgba(204, 231, 242, 0.68);
  font-size: 20rpx;
}

.room-page--active .cockpit-nav-hud__formation {
  overflow: hidden;
}

.room-page--active .cockpit-nav-hud__code {
  font-family: Menlo, monospace;
  font-size: 20rpx;
}

.room-page--active .cockpit-nav-hud__crew {
  font-size: 18rpx;
}

.room-page--active .cockpit-active {
  position: relative;
  width: auto;
  height: auto;
  flex: 1;
  min-height: 0;
  overflow: hidden;
  background: #02070d;
}

.room-page--active .cockpit-active-screen {
  position: relative;
  inset: auto;
  display: block;
  width: 100%;
  height: 100%;
  padding: 0 12rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.room-page--active .cockpit-hud-zone {
  position: absolute;
  top: 0;
  right: 12rpx;
  bottom: 168rpx;
  left: 12rpx;
  z-index: 1;
  width: auto;
  height: auto;
  min-height: 0;
  max-height: none !important;
  overflow: hidden;
  border: 1rpx solid rgba(0, 200, 255, 0.16);
  border-bottom: none;
  clip-path: none;
}

.room-page--active .main-hud-row {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  z-index: 12;
  padding: 12rpx 22rpx 0;
}

.room-page--active .main-hud-tag {
  padding: 6rpx 14rpx;
  background: rgba(1, 10, 18, 0.62);
}

.room-page--active .observation-zone {
  position: absolute !important;
  top: 62rpx !important;
  right: 26rpx;
  bottom: 126rpx;
  left: 26rpx;
  width: auto;
  height: auto !important;
  overflow: visible;
}

.room-page--active .pulse-instrument {
  bottom: -2rpx !important;
  z-index: 14;
  transform: translateX(-50%) scale(0.82);
  transform-origin: center bottom;
}

.room-page--active .cockpit-dashboard-lip {
  bottom: 0;
}

.room-page--active .cockpit-console-v2,
.room-page--active .output-terminal {
  position: absolute;
  bottom: 0;
  z-index: 30;
  height: 168rpx;
  min-height: 0;
  max-height: none !important;
  box-sizing: border-box;
}

.room-page--active .output-terminal {
  left: 12rpx;
  width: 42%;
  margin: 0 !important;
  padding: 12rpx 12rpx 8rpx;
  background:
    linear-gradient(180deg, rgba(5, 18, 29, 0.96), rgba(1, 7, 12, 0.99));
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  border-left: 3rpx solid rgba(0, 200, 255, 0.42);
  clip-path: polygon(0 14rpx, 12rpx 0, 100% 0, 100% 100%, 0 100%);
}

.room-page--active .terminal-entries {
  flex: 1;
  min-height: 0;
}

.room-page--active .terminal-entry {
  min-height: 30rpx;
  font-size: 16rpx;
  line-height: 30rpx;
}

.room-page--active .terminal-entry__time {
  font-size: 13rpx;
}

.room-page--active .terminal-entry__value {
  font-size: 16rpx;
}

.room-page--active .cockpit-console-v2 {
  right: 12rpx;
  width: calc(58% - 4rpx);
  padding: 18rpx 16rpx 12rpx !important;
  background:
    linear-gradient(180deg, rgba(19, 37, 50, 0.98), rgba(5, 12, 18, 0.99) 42%, #020507 100%) !important;
  border: 1rpx solid rgba(92, 164, 196, 0.22) !important;
  border-top: 2rpx solid rgba(0, 200, 255, 0.25) !important;
  clip-path: polygon(12rpx 0, 100% 14rpx, 100% 100%, 0 100%, 0 14rpx);
  box-shadow: 0 -12rpx 30rpx rgba(0, 0, 0, 0.70) !important;
}

.room-page--active .ccv2-panel {
  height: 100%;
  gap: 6rpx;
}

.room-page--active .ccv2-divider {
  width: 1rpx;
  height: 74%;
}

.room-page--active .ccv2-btn {
  height: 100% !important;
  min-height: 0;
  padding: 18rpx 4rpx 10rpx;
  background:
    linear-gradient(180deg, rgba(24, 44, 57, 0.94), rgba(5, 12, 17, 0.99)) !important;
  border: 1rpx solid rgba(89, 147, 172, 0.26);
  border-bottom: 5rpx solid rgba(0, 0, 0, 0.86);
  border-radius: 4rpx !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06) !important;
}

.room-page--active .ccv2-btn__indicator {
  width: 22rpx !important;
  height: 4rpx !important;
  margin-bottom: 12rpx !important;
  border-radius: 2rpx !important;
}

.room-page--active .ccv2-btn__label {
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.room-page--active .ccv2-btn--press {
  transform: translateY(3rpx) !important;
}

/* ===== 控制台三段式：信标 / 最近脉冲 / 航迹 ===== */
.room-page--active .cockpit-hud-zone {
  bottom: 178rpx;
}

.room-page--active .observation-zone {
  top: 18rpx !important;
}

.room-page--active .main-hud-row {
  display: none;
}

.room-page--active .output-terminal {
  display: none;
}

.room-page--active .cockpit-console-v2 {
  right: 12rpx;
  left: 12rpx;
  width: auto;
  height: 178rpx;
  padding: 14rpx 16rpx 12rpx !important;
  clip-path: polygon(18rpx 0, calc(100% - 18rpx) 0, 100% 16rpx, 100% 100%, 0 100%, 0 16rpx);
}

.room-page--active .ccv2-panel {
  display: grid;
  grid-template-columns: 116rpx minmax(0, 1fr) 116rpx;
  align-items: stretch;
  gap: 10rpx;
}

.room-page--active .ccv2-btn {
  width: 116rpx;
  height: 100% !important;
  padding: 20rpx 4rpx 12rpx;
}

.room-page--active .ccv2-btn__indicator {
  margin-bottom: 16rpx !important;
}

.room-page--active .ccv2-btn__label {
  font-size: 25rpx;
}

.console-pulse-log {
  position: relative;
  min-width: 0;
  padding: 12rpx 14rpx 10rpx;
  overflow: hidden;
  background:
    linear-gradient(rgba(0, 200, 255, 0.025) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 200, 255, 0.02) 1rpx, transparent 1rpx),
    rgba(1, 8, 14, 0.90);
  background-size: 18rpx 18rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  clip-path: polygon(10rpx 0, calc(100% - 10rpx) 0, 100% 10rpx, 100% 100%, 0 100%, 0 10rpx);
  box-sizing: border-box;
}

.console-pulse-log::after {
  position: absolute;
  right: 12%;
  bottom: 0;
  left: 12%;
  height: 1rpx;
  content: '';
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.46), transparent);
}

.console-pulse-log__head {
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(0, 200, 255, 0.10);
}

.console-pulse-log__title {
  color: rgba(207, 235, 246, 0.62);
  font-size: 17rpx;
  font-weight: 650;
  letter-spacing: 1rpx;
}

.console-pulse-log__filter {
  padding: 3rpx 8rpx;
  color: rgba(0, 200, 255, 0.66);
  font-size: 14rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  border-radius: 3rpx;
}

.console-pulse-log__list {
  padding-top: 5rpx;
}

.console-pulse-log__item {
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 0 6rpx;
  color: rgba(170, 203, 216, 0.46);
  font-size: 15rpx;
  box-sizing: border-box;
  border-left: 2rpx solid transparent;
}

.console-pulse-log__item--mine {
  color: rgba(220, 243, 251, 0.84);
  background: linear-gradient(90deg, rgba(0, 175, 255, 0.11), transparent);
  border-left-color: rgba(0, 200, 255, 0.72);
}

.console-pulse-log__route {
  min-width: 0;
  max-width: calc(100% - 96rpx);
  flex: 0 1 auto;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.console-pulse-log__value {
  flex-shrink: 0;
  margin-left: 12rpx;
  color: rgba(205, 232, 242, 0.62);
  font-family: Menlo, monospace;
  font-size: 16rpx;
  font-weight: 700;
}

.console-pulse-log__value.is-positive {
  color: #32D74B;
}

.console-pulse-log__value.is-negative {
  color: #FF9F0A;
}

.console-pulse-log__empty {
  height: 94rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(126, 174, 194, 0.30);
  font-size: 16rpx;
  letter-spacing: 2rpx;
}

/* 无标题栏的脉冲详情面板 */


/* ===== 座舱 AR 统一视觉 ===== */
.room-page--active .pulse-instrument {
  bottom: -12rpx !important;
  transform: translateX(-50%) scale(0.88);
}

.room-page--active .pulse-instrument__title {
  display: none;
}

.room-page--active .pulse-instrument__value {
  top: 44rpx;
  margin: 0;
  font-size: 58rpx;
  line-height: 58rpx;
}

.room-page--active .pulse-instrument__status {
  top: 108rpx;
  margin: 0;
}

.room-page--active .pulse-instrument__dot {
  width: 7rpx;
  height: 7rpx;
}

.room-page--active .cockpit-console-v2 {
  overflow: visible;
  background:
    radial-gradient(ellipse 34% 90% at 50% 0, rgba(0, 175, 255, 0.075), transparent 70%),
    linear-gradient(180deg, rgba(13, 30, 42, 0.98), rgba(3, 9, 14, 0.995)) !important;
  border-top-color: rgba(0, 200, 255, 0.20) !important;
}

.room-page--active .cockpit-console-v2::before {
  position: absolute;
  top: -42rpx;
  left: 50%;
  width: 300rpx;
  height: 58rpx;
  content: '';
  transform: translateX(-50%);
  pointer-events: none;
  border-top: 2rpx solid rgba(0, 200, 255, 0.22);
  border-radius: 50% 50% 0 0;
  background: linear-gradient(180deg, rgba(5, 18, 27, 0.56), rgba(5, 18, 27, 0));
  box-shadow: 0 -8rpx 24rpx rgba(0, 175, 255, 0.045);
}

.room-page--active .ccv2-btn {
  background:
    linear-gradient(180deg, rgba(18, 39, 51, 0.78), rgba(3, 10, 15, 0.96)) !important;
  border-color: rgba(78, 145, 174, 0.20);
  border-bottom-color: rgba(0, 0, 0, 0.72);
  clip-path: polygon(10rpx 0, calc(100% - 10rpx) 0, 100% 10rpx, 100% 100%, 0 100%, 0 10rpx);
}

.console-pulse-log {
  background:
    linear-gradient(rgba(0, 200, 255, 0.018) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 200, 255, 0.015) 1rpx, transparent 1rpx),
    rgba(1, 7, 12, 0.72);
  background-size: 18rpx 18rpx;
  border-color: rgba(0, 200, 255, 0.12);
}

/* 脉冲记录：悬浮于实景前方的单层数据流 */


/* 信标：仅保留识别核心 */
.beacon-overlay {
  padding: 48rpx;
  background:
    radial-gradient(circle at 50% 48%, rgba(0, 145, 210, 0.13), transparent 34%),
    rgba(0, 3, 7, 0.60);
  backdrop-filter: blur(5px);
  -webkit-backdrop-filter: blur(5px);
}

.beacon-panel {
  width: auto;
  min-width: 410rpx;
  max-width: 500rpx;
  padding: 58rpx 30rpx 22rpx;
  background:
    radial-gradient(circle at 50% 42%, rgba(0, 175, 255, 0.08), transparent 55%),
    rgba(1, 10, 16, 0.70);
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  box-shadow:
    inset 0 0 54rpx rgba(0, 175, 255, 0.035),
    0 24rpx 70rpx rgba(0, 0, 0, 0.48);
}

.beacon-panel__head,
.beacon-code-label,
.beacon-copy-btn,
.beacon-bottom-bar {
  display: none;
}

.beacon-panel__close {
  top: 10rpx;
  right: 10rpx;
  width: 42rpx;
  height: 42rpx;
  background: transparent;
  border-color: rgba(0, 200, 255, 0.12);
}

.beacon-code-row {
  margin: 0 0 12rpx;
  padding: 0;
  align-items: center;
  border: none;
}

.beacon-code-value {
  font-size: 34rpx;
  line-height: 42rpx;
  letter-spacing: 8rpx;
}

.beacon-qr-section {
  margin: 0;
}

.beacon-qr-frame {
  width: 300rpx;
  height: 300rpx;
  padding: 12rpx;
}

.beacon-manage-entry {
  height: 38rpx;
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: rgba(255, 126, 118, 0.30);
  font-size: 16rpx;
}

.beacon-manage-entry__dot {
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: rgba(255, 69, 58, 0.38);
}

/* ===== 弧形投影控制台 ===== */
.room-page--active .pulse-instrument {
  display: none !important;
}

.room-page--active .cockpit-console-v2 {
  right: 8rpx;
  left: 8rpx;
  width: auto;
  height: 190rpx;
  padding: 34rpx 18rpx 10rpx !important;
  overflow: hidden;
  clip-path: none;
  border: 0 !important;
  border-top: 2rpx solid rgba(0, 200, 255, 0.22) !important;
  border-radius: 50% 50% 0 0 / 54rpx 54rpx 0 0;
  background:
    radial-gradient(ellipse 48% 82% at 50% 0, rgba(0, 175, 255, 0.11), transparent 72%),
    linear-gradient(90deg, rgba(0, 200, 255, 0.04), transparent 18%, transparent 82%, rgba(0, 200, 255, 0.04)),
    linear-gradient(180deg, rgba(9, 26, 37, 0.94), rgba(1, 7, 11, 0.99) 72%) !important;
  box-shadow:
    0 -16rpx 42rpx rgba(0, 0, 0, 0.70),
    inset 0 18rpx 34rpx rgba(0, 175, 255, 0.025) !important;
}

.room-page--active .cockpit-console-v2::before {
  position: absolute;
  top: 10rpx;
  right: 12rpx;
  left: 12rpx;
  display: block;
  height: 58rpx;
  content: '';
  pointer-events: none;
  border-top: 1rpx solid rgba(0, 200, 255, 0.17);
  border-radius: 50% 50% 0 0 / 42rpx 42rpx 0 0;
  background: radial-gradient(ellipse at 50% 0, rgba(0, 200, 255, 0.055), transparent 68%);
}

.room-page--active .cockpit-console-v2::after {
  position: absolute;
  right: 18%;
  bottom: 7rpx;
  left: 18%;
  height: 1rpx;
  content: '';
  pointer-events: none;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.18), transparent);
}

.room-page--active .cockpit-hud-zone {
  bottom: 176rpx;
}

.room-page--active .ccv2-rail {
  display: none;
}

.room-page--active .ccv2-panel {
  position: relative;
  z-index: 2;
  grid-template-columns: 110rpx minmax(0, 1fr) 110rpx;
  align-items: stretch;
  gap: 8rpx;
}

.room-page--active .ccv2-btn {
  position: relative;
  width: 110rpx;
  height: 126rpx !important;
  align-self: end;
  padding: 20rpx 4rpx 8rpx;
  overflow: visible;
  border: 0 !important;
  border-radius: 50% !important;
  clip-path: none;
  background:
    radial-gradient(ellipse at 50% 52%, rgba(0, 175, 255, 0.09), transparent 62%) !important;
  box-shadow: none !important;
}

.room-page--active .ccv2-btn::before {
  position: absolute;
  top: 20rpx;
  left: 50%;
  width: 90rpx;
  height: 66rpx;
  content: '';
  transform: translateX(-50%);
  pointer-events: none;
  border-top: 1rpx solid rgba(0, 200, 255, 0.46);
  border-right: 1rpx solid rgba(0, 200, 255, 0.15);
  border-left: 1rpx solid rgba(0, 200, 255, 0.15);
  border-radius: 50%;
  box-shadow:
    inset 0 10rpx 22rpx rgba(0, 175, 255, 0.04),
    0 -4rpx 14rpx rgba(0, 175, 255, 0.07);
}

.room-page--active .ccv2-btn::after {
  position: absolute;
  bottom: 16rpx;
  left: 50%;
  width: 64rpx;
  height: 1rpx;
  content: '';
  transform: translateX(-50%);
  pointer-events: none;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.50), transparent);
}

.room-page--active .ccv2-btn--beacon {
  transform: rotate(-4deg) translateY(5rpx);
}

.room-page--active .ccv2-btn--trace {
  transform: rotate(4deg) translateY(5rpx);
  background:
    radial-gradient(ellipse at 50% 52%, rgba(48, 209, 88, 0.075), transparent 62%) !important;
}

.room-page--active .ccv2-btn--trace::before {
  border-top-color: rgba(48, 209, 88, 0.42);
  border-right-color: rgba(48, 209, 88, 0.13);
  border-left-color: rgba(48, 209, 88, 0.13);
  box-shadow:
    inset 0 10rpx 22rpx rgba(48, 209, 88, 0.035),
    0 -4rpx 14rpx rgba(48, 209, 88, 0.055);
}

.room-page--active .ccv2-btn--trace::after {
  background: linear-gradient(90deg, transparent, rgba(48, 209, 88, 0.48), transparent);
}

.room-page--active .ccv2-btn__body {
  gap: 7rpx;
  text-shadow: 0 0 12rpx rgba(0, 175, 255, 0.20);
}

.room-page--active .ccv2-btn__glow {
  display: none;
}

.room-page--active .ccv2-btn__indicator {
  width: 28rpx !important;
  height: 3rpx !important;
  margin-bottom: 8rpx !important;
  opacity: 0.92;
}

.room-page--active .ccv2-btn__label {
  color: rgba(210, 241, 252, 0.88);
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
}

.room-page--active .ccv2-btn--press,
.room-page--active .ccv2-btn--beacon.ccv2-btn--press,
.room-page--active .ccv2-btn--trace.ccv2-btn--press {
  transform: scale(0.94) translateY(5rpx) !important;
  filter: brightness(1.35);
}

.console-pulse-log {
  height: 142rpx;
  align-self: end;
  padding: 8rpx 10rpx 7rpx;
  overflow: hidden;
  border: 0;
  clip-path: none;
  background:
    linear-gradient(rgba(0, 200, 255, 0.012) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 200, 255, 0.01) 1rpx, transparent 1rpx),
    radial-gradient(ellipse at 50% 12%, rgba(0, 175, 255, 0.065), transparent 68%);
  background-size: 20rpx 20rpx, 20rpx 20rpx, auto;
  box-shadow: none;
}

.console-pulse-log::before {
  position: absolute;
  top: 38rpx;
  right: 0;
  left: 0;
  z-index: 3;
  height: 14rpx;
  content: '';
  pointer-events: none;
  background: linear-gradient(180deg, rgba(2, 12, 18, 0.92), transparent);
}

.console-pulse-readout {
  position: absolute;
  top: -2rpx;
  left: 50%;
  z-index: 4;
  width: 220rpx;
  height: 46rpx;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-bottom: 1rpx solid rgba(0, 200, 255, 0.20);
  background:
    linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.07) 18%, rgba(0, 200, 255, 0.07) 82%, transparent),
    radial-gradient(ellipse at 50% 58%, rgba(0, 175, 255, 0.12), transparent 68%);
  pointer-events: none;
}

.console-pulse-readout::before,
.console-pulse-readout::after {
  position: absolute;
  top: 9rpx;
  width: 1rpx;
  height: 24rpx;
  content: '';
  background: linear-gradient(180deg, transparent, rgba(0, 200, 255, 0.48), transparent);
}

.console-pulse-readout::before {
  left: 42rpx;
}

.console-pulse-readout::after {
  right: 42rpx;
}

.console-pulse-readout__digits {
  width: 152rpx;
  height: 38rpx;
  overflow: hidden;
}

.console-pulse-readout__digit-track {
  height: 114rpx;
  display: flex;
  flex-direction: column;
  transform: translateY(-38rpx);
}

.console-pulse-readout__digit-track text {
  flex-shrink: 0;
  height: 38rpx;
  color: rgba(226, 244, 252, 0.96);
  font-family: Menlo, monospace;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 38rpx;
  text-align: center;
  letter-spacing: 1rpx;
  text-shadow:
    0 0 6rpx rgba(0, 200, 255, 0.34),
    0 0 18rpx rgba(0, 175, 255, 0.13);
}

.console-pulse-readout.is-condensed .console-pulse-readout__digit-track text {
  font-size: 27rpx;
  letter-spacing: 0;
}

.console-pulse-readout.is-compact .console-pulse-readout__digit-track text {
  font-size: 23rpx;
  letter-spacing: -1rpx;
}

.console-pulse-readout.is-rolling .console-pulse-readout__digit-track {
  animation: pulse-readout-roll 900ms cubic-bezier(0.18, 0.82, 0.24, 1) both;
}

.console-pulse-readout.is-positive .console-pulse-readout__digit-track text {
  color: #32D74B;
}

.console-pulse-readout.is-negative .console-pulse-readout__digit-track text {
  color: #FF9F0A;
}

.console-pulse-readout__ticks {
  position: absolute;
  top: 18rpx;
  width: 34rpx;
  height: 8rpx;
  opacity: 0.62;
  background: repeating-linear-gradient(90deg, rgba(0, 200, 255, 0.58) 0 2rpx, transparent 2rpx 7rpx);
}

.console-pulse-readout__ticks--left {
  left: 2rpx;
}

.console-pulse-readout__ticks--right {
  right: 2rpx;
  transform: scaleX(-1);
}

.console-pulse-readout__dot {
  position: absolute;
  bottom: 1rpx;
  left: 50%;
  width: 5rpx;
  height: 5rpx;
  transform: translateX(-50%);
  border-radius: 50%;
  background: #32D74B;
  box-shadow: 0 0 8rpx rgba(50, 215, 75, 0.68);
}

.console-pulse-log__list {
  position: absolute;
  inset: 0 10rpx;
  padding-top: 40rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.console-pulse-log__item {
  position: relative;
  height: 26rpx;
  min-height: 26rpx;
  padding-right: 5rpx;
  padding-left: 5rpx;
  color: rgba(167, 211, 226, 0.38);
  background: transparent;
  transform-origin: left center;
}

.console-pulse-log__item--new {
  color: rgba(207, 239, 249, 0.80);
  animation: pulse-stream-write 760ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
}

.console-pulse-log__item:nth-child(1) {
  animation: pulse-stream-rise-old 520ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.console-pulse-log__item:nth-child(2) {
  animation: pulse-stream-rise-mid 520ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.console-pulse-log__item:nth-child(3) {
  animation: pulse-stream-rise-new 520ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.console-pulse-log__item--new:nth-child(1),
.console-pulse-log__item--new:nth-child(2),
.console-pulse-log__item--new:nth-child(3) {
  animation: pulse-stream-write 760ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
}

.console-pulse-log__item--new::after {
  position: absolute;
  top: 3rpx;
  bottom: 3rpx;
  left: 0;
  width: 2rpx;
  content: '';
  background: #00C8FF;
  box-shadow: 0 0 12rpx rgba(0, 200, 255, 0.78);
}

.console-pulse-log__empty {
  position: absolute;
  inset: 0 10rpx;
  padding-top: 40rpx;
  box-sizing: border-box;
  background: radial-gradient(ellipse at 50% 30%, rgba(0, 175, 255, 0.025), transparent 72%);
}

.console-pulse-log__idle-line {
  width: 42%;
  height: 1rpx;
  margin: 28rpx auto 0;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.22), transparent);
  animation: pulse-idle-scan 2.4s ease-in-out infinite;
}

@keyframes pulse-readout-roll {
  0% {
    transform: translateY(0);
    filter: blur(2rpx);
    opacity: 0.28;
  }
  56% {
    transform: translateY(-76rpx);
    filter: blur(1rpx);
    opacity: 0.76;
  }
  100% {
    transform: translateY(-38rpx);
    filter: blur(0);
    opacity: 1;
  }
}

@keyframes pulse-stream-rise-old {
  from {
    transform: translateY(25rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 0.28;
  }
}

@keyframes pulse-stream-rise-mid {
  from {
    transform: translateY(25rpx);
    opacity: 0.16;
  }
  to {
    transform: translateY(0);
    opacity: 0.62;
  }
}

@keyframes pulse-stream-rise-new {
  from {
    transform: translateY(25rpx);
    opacity: 0.34;
  }
  to {
    transform: translateY(0);
    opacity: 0.94;
  }
}

@keyframes pulse-stream-write {
  0% {
    clip-path: inset(0 100% 0 0);
    transform: translateY(25rpx);
    opacity: 0;
  }
  38% {
    clip-path: inset(0 0 0 0);
    transform: translateY(0);
    opacity: 1;
  }
  100% {
    clip-path: inset(0 0 0 0);
    transform: translateY(0);
    opacity: 0.92;
  }
}

@keyframes pulse-idle-scan {
  0%,
  100% {
    transform: scaleX(0.45);
    opacity: 0.28;
  }
  50% {
    transform: scaleX(1);
    opacity: 0.75;
  }
}


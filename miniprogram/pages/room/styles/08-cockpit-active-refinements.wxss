/* ===== 编队页最终布局：第一人称 HUD + 底部控制台 ===== */
.room-page--active {
  min-height: 100vh;
  height: 100vh;
  padding-bottom: var(--sr-tabbar-safe-height, calc(140rpx + env(safe-area-inset-bottom))) !important;
  overflow: hidden;
}

.room-page--active .room-custom-nav {
  margin-bottom: 0;
  background: rgba(2, 8, 16, 0.76);
  border-bottom: 1rpx solid rgba(0, 200, 255, 0.10);
}

.room-page--active .room-custom-nav::after {
  display: none;
}

.room-page--active .room-custom-nav__bar {
  justify-content: flex-start;
  padding: 0 32rpx;
}

.room-page--active .cockpit-nav-hud {
  max-width: calc(100% - 190rpx);
  gap: 14rpx;
}

.room-page--active .cockpit-nav-hud__link {
  color: rgba(204, 231, 242, 0.68);
  font-size: 20rpx;
}

.room-page--active .cockpit-nav-hud__formation {
  overflow: hidden;
}

.room-page--active .cockpit-nav-hud__code {
  font-family: Menlo, monospace;
  font-size: 20rpx;
}

.room-page--active .cockpit-nav-hud__crew {
  font-size: 18rpx;
}

.room-page--active .cockpit-active {
  position: relative;
  width: auto;
  height: auto;
  flex: 1;
  min-height: 0;
  overflow: hidden;
  background: #02070d;
}

.room-page--active .cockpit-active-screen {
  position: relative;
  inset: auto;
  display: block;
  width: 100%;
  height: 100%;
  padding: 0 12rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.room-page--active .cockpit-hud-zone {
  position: absolute;
  top: 0;
  right: 12rpx;
  bottom: 168rpx;
  left: 12rpx;
  z-index: 1;
  width: auto;
  height: auto;
  min-height: 0;
  max-height: none !important;
  overflow: hidden;
  border: 1rpx solid rgba(0, 200, 255, 0.16);
  border-bottom: none;
  clip-path: none;
}

.room-page--active .main-hud-row {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  z-index: 12;
  padding: 12rpx 22rpx 0;
}

.room-page--active .main-hud-tag {
  padding: 6rpx 14rpx;
  background: rgba(1, 10, 18, 0.62);
}

.room-page--active .observation-zone {
  position: absolute !important;
  top: 62rpx !important;
  right: 26rpx;
  bottom: 126rpx;
  left: 26rpx;
  width: auto;
  height: auto !important;
  overflow: visible;
}

.room-page--active .pulse-instrument {
  bottom: -2rpx !important;
  z-index: 14;
  transform: translateX(-50%) scale(0.82);
  transform-origin: center bottom;
}

.room-page--active .cockpit-dashboard-lip {
  bottom: 0;
}

.room-page--active .cockpit-console-v2,
.room-page--active .output-terminal {
  position: absolute;
  bottom: 0;
  z-index: 30;
  height: 168rpx;
  min-height: 0;
  max-height: none !important;
  box-sizing: border-box;
}

.room-page--active .output-terminal {
  left: 12rpx;
  width: 42%;
  margin: 0 !important;
  padding: 12rpx 12rpx 8rpx;
  background:
    linear-gradient(180deg, rgba(5, 18, 29, 0.96), rgba(1, 7, 12, 0.99));
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  border-left: 3rpx solid rgba(0, 200, 255, 0.42);
  clip-path: polygon(0 14rpx, 12rpx 0, 100% 0, 100% 100%, 0 100%);
}

.room-page--active .terminal-entries {
  flex: 1;
  min-height: 0;
}

.room-page--active .terminal-entry {
  min-height: 30rpx;
  font-size: 16rpx;
  line-height: 30rpx;
}

.room-page--active .terminal-entry__time {
  font-size: 13rpx;
}

.room-page--active .terminal-entry__value {
  font-size: 16rpx;
}

.room-page--active .cockpit-console-v2 {
  right: 12rpx;
  width: calc(58% - 4rpx);
  padding: 18rpx 16rpx 12rpx !important;
  background:
    linear-gradient(180deg, rgba(19, 37, 50, 0.98), rgba(5, 12, 18, 0.99) 42%, #020507 100%) !important;
  border: 1rpx solid rgba(92, 164, 196, 0.22) !important;
  border-top: 2rpx solid rgba(0, 200, 255, 0.25) !important;
  clip-path: polygon(12rpx 0, 100% 14rpx, 100% 100%, 0 100%, 0 14rpx);
  box-shadow: 0 -12rpx 30rpx rgba(0, 0, 0, 0.70) !important;
}

.room-page--active .ccv2-panel {
  height: 100%;
  gap: 6rpx;
}

.room-page--active .ccv2-divider {
  width: 1rpx;
  height: 74%;
}

.room-page--active .ccv2-btn {
  height: 100% !important;
  min-height: 0;
  padding: 18rpx 4rpx 10rpx;
  background:
    linear-gradient(180deg, rgba(24, 44, 57, 0.94), rgba(5, 12, 17, 0.99)) !important;
  border: 1rpx solid rgba(89, 147, 172, 0.26);
  border-bottom: 5rpx solid rgba(0, 0, 0, 0.86);
  border-radius: 4rpx !important;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06) !important;
}

.room-page--active .ccv2-btn__indicator {
  width: 22rpx !important;
  height: 4rpx !important;
  margin-bottom: 12rpx !important;
  border-radius: 2rpx !important;
}

.room-page--active .ccv2-btn__label {
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.room-page--active .ccv2-btn--press {
  transform: translateY(3rpx) !important;
}

/* ===== 控制台三段式：信标 / 最近脉冲 / 航迹 ===== */
.room-page--active .cockpit-hud-zone {
  bottom: 178rpx;
}

.room-page--active .observation-zone {
  top: 18rpx !important;
}

.room-page--active .main-hud-row {
  display: none;
}

.room-page--active .output-terminal {
  display: none;
}

.room-page--active .cockpit-console-v2 {
  right: 12rpx;
  left: 12rpx;
  width: auto;
  height: 178rpx;
  padding: 14rpx 16rpx 12rpx !important;
  clip-path: polygon(18rpx 0, calc(100% - 18rpx) 0, 100% 16rpx, 100% 100%, 0 100%, 0 16rpx);
}

.room-page--active .ccv2-panel {
  display: grid;
  grid-template-columns: 116rpx minmax(0, 1fr) 116rpx;
  align-items: stretch;
  gap: 10rpx;
}

.room-page--active .ccv2-btn {
  width: 116rpx;
  height: 100% !important;
  padding: 20rpx 4rpx 12rpx;
}

.room-page--active .ccv2-btn__indicator {
  margin-bottom: 16rpx !important;
}

.room-page--active .ccv2-btn__label {
  font-size: 25rpx;
}

.console-pulse-log {
  position: relative;
  min-width: 0;
  padding: 12rpx 14rpx 10rpx;
  overflow: hidden;
  background:
    linear-gradient(rgba(0, 200, 255, 0.025) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 200, 255, 0.02) 1rpx, transparent 1rpx),
    rgba(1, 8, 14, 0.90);
  background-size: 18rpx 18rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  clip-path: polygon(10rpx 0, calc(100% - 10rpx) 0, 100% 10rpx, 100% 100%, 0 100%, 0 10rpx);
  box-sizing: border-box;
}

.console-pulse-log::after {
  position: absolute;
  right: 12%;
  bottom: 0;
  left: 12%;
  height: 1rpx;
  content: '';
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.46), transparent);
}

.console-pulse-log__head {
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(0, 200, 255, 0.10);
}

.console-pulse-log__title {
  color: rgba(207, 235, 246, 0.62);
  font-size: 17rpx;
  font-weight: 650;
  letter-spacing: 1rpx;
}

.console-pulse-log__filter {
  padding: 3rpx 8rpx;
  color: rgba(0, 200, 255, 0.66);
  font-size: 14rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  border-radius: 3rpx;
}

.console-pulse-log__list {
  padding-top: 5rpx;
}

.console-pulse-log__item {
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 0 6rpx;
  color: rgba(170, 203, 216, 0.46);
  font-size: 15rpx;
  box-sizing: border-box;
  border-left: 2rpx solid transparent;
}

.console-pulse-log__item--mine {
  color: rgba(220, 243, 251, 0.84);
  background: linear-gradient(90deg, rgba(0, 175, 255, 0.11), transparent);
  border-left-color: rgba(0, 200, 255, 0.72);
}

.console-pulse-log__route {
  min-width: 0;
  max-width: calc(100% - 96rpx);
  flex: 0 1 auto;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.console-pulse-log__value {
  flex-shrink: 0;
  margin-left: 12rpx;
  color: rgba(205, 232, 242, 0.62);
  font-family: Menlo, monospace;
  font-size: 16rpx;
  font-weight: 700;
}

.console-pulse-log__value.is-positive {
  color: #32D74B;
}

.console-pulse-log__value.is-negative {
  color: #FF9F0A;
}

.console-pulse-log__empty {
  height: 94rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(126, 174, 194, 0.30);
  font-size: 16rpx;
  letter-spacing: 2rpx;
}

/* 无标题栏的脉冲详情面板 */


/* ===== 座舱 AR 统一视觉 ===== */
.room-page--active .pulse-instrument {
  bottom: -12rpx !important;
  transform: translateX(-50%) scale(0.88);
}

.room-page--active .pulse-instrument__title {
  display: none;
}

.room-page--active .pulse-instrument__value {
  top: 44rpx;
  margin: 0;
  font-size: 58rpx;
  line-height: 58rpx;
}

.room-page--active .pulse-instrument__status {
  top: 108rpx;
  margin: 0;
}

.room-page--active .pulse-instrument__dot {
  width: 7rpx;
  height: 7rpx;
}

.room-page--active .cockpit-console-v2 {
  overflow: visible;
  background:
    radial-gradient(ellipse 34% 90% at 50% 0, rgba(0, 175, 255, 0.075), transparent 70%),
    linear-gradient(180deg, rgba(13, 30, 42, 0.98), rgba(3, 9, 14, 0.995)) !important;
  border-top-color: rgba(0, 200, 255, 0.20) !important;
}

.room-page--active .cockpit-console-v2::before {
  position: absolute;
  top: -42rpx;
  left: 50%;
  width: 300rpx;
  height: 58rpx;
  content: '';
  transform: translateX(-50%);
  pointer-events: none;
  border-top: 2rpx solid rgba(0, 200, 255, 0.22);
  border-radius: 50% 50% 0 0;
  background: linear-gradient(180deg, rgba(5, 18, 27, 0.56), rgba(5, 18, 27, 0));
  box-shadow: 0 -8rpx 24rpx rgba(0, 175, 255, 0.045);
}

.room-page--active .ccv2-btn {
  background:
    linear-gradient(180deg, rgba(18, 39, 51, 0.78), rgba(3, 10, 15, 0.96)) !important;
  border-color: rgba(78, 145, 174, 0.20);
  border-bottom-color: rgba(0, 0, 0, 0.72);
  clip-path: polygon(10rpx 0, calc(100% - 10rpx) 0, 100% 10rpx, 100% 100%, 0 100%, 0 10rpx);
}

.console-pulse-log {
  background:
    linear-gradient(rgba(0, 200, 255, 0.018) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 200, 255, 0.015) 1rpx, transparent 1rpx),
    rgba(1, 7, 12, 0.72);
  background-size: 18rpx 18rpx;
  border-color: rgba(0, 200, 255, 0.12);
}

/* 脉冲记录：悬浮于实景前方的单层数据流 */


/* 信标：仅保留识别核心 */
.beacon-overlay {
  padding: 48rpx;
  background:
    radial-gradient(circle at 50% 48%, rgba(0, 145, 210, 0.13), transparent 34%),
    rgba(0, 3, 7, 0.60);
  backdrop-filter: blur(5px);
  -webkit-backdrop-filter: blur(5px);
}

.beacon-panel {
  width: auto;
  min-width: 410rpx;
  max-width: 500rpx;
  padding: 58rpx 30rpx 22rpx;
  background:
    radial-gradient(circle at 50% 42%, rgba(0, 175, 255, 0.08), transparent 55%),
    rgba(1, 10, 16, 0.70);
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  box-shadow:
    inset 0 0 54rpx rgba(0, 175, 255, 0.035),
    0 24rpx 70rpx rgba(0, 0, 0, 0.48);
}

.beacon-panel__head,
.beacon-code-label,
.beacon-copy-btn,
.beacon-bottom-bar {
  display: none;
}

.beacon-panel__close {
  top: 10rpx;
  right: 10rpx;
  width: 42rpx;
  height: 42rpx;
  background: transparent;
  border-color: rgba(0, 200, 255, 0.12);
}

.beacon-code-row {
  margin: 0 0 12rpx;
  padding: 0;
  align-items: center;
  border: none;
}

.beacon-code-value {
  font-size: 34rpx;
  line-height: 42rpx;
  letter-spacing: 8rpx;
}

.beacon-qr-section {
  margin: 0;
}

.beacon-qr-frame {
  width: 300rpx;
  height: 300rpx;
  padding: 12rpx;
}

.beacon-manage-entry {
  height: 38rpx;
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: rgba(255, 126, 118, 0.30);
  font-size: 16rpx;
}

.beacon-manage-entry__dot {
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: rgba(255, 69, 58, 0.38);
}

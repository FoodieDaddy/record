/* ===== VR 悬浮触控阵列（驾驶舱输入层） ===== */

/* 背景遮罩：局部暗化，HUD 和驾驶舱仍可识别 */
.pulse-vr-overlay {
  position: fixed;
  inset: 0;
  z-index: 1200;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  padding:
    calc(180rpx + env(safe-area-inset-top))
    48rpx
    calc(260rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(ellipse at 50% 68%, rgba(0, 200, 255, 0.06), transparent 56%),
    radial-gradient(ellipse at 50% 70%, rgba(0, 0, 0, 0.42), transparent 58%);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.22s ease, visibility 0.22s ease;
}

.pulse-vr-overlay--show {
  opacity: 1;
  visibility: visible;
}

/* AR 悬浮面板容器 */
.pulse-vr-cluster {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 620rpx;
  max-width: 640rpx;
  max-height: 620rpx;
  padding: 20rpx 24rpx 24rpx;
  box-sizing: border-box;
  background: rgba(3, 10, 18, 0.94);
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  clip-path: polygon(
    16rpx 0, calc(100% - 16rpx) 0,
    100% 16rpx, 100% calc(100% - 16rpx),
    calc(100% - 16rpx) 100%, 16rpx 100%,
    0 calc(100% - 16rpx), 0 16rpx
  );
  box-shadow:
    inset 0 1rpx 0 rgba(0, 200, 255, 0.06),
    0 16rpx 48rpx rgba(0, 0, 0, 0.56);
  overflow: hidden;
}

/* 面板扫描线 */
.pulse-vr-scanline {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  top: 10rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.20), transparent);
  z-index: 2;
  pointer-events: none;
}

/* AR 面板四角装饰 */
.pulse-vr-corner {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  z-index: 2;
  pointer-events: none;
}

.pulse-vr-corner--tl {
  top: 8rpx;
  left: 8rpx;
  border-top: 1rpx solid rgba(0, 200, 255, 0.28);
  border-left: 1rpx solid rgba(0, 200, 255, 0.28);
}

.pulse-vr-corner--tr {
  top: 8rpx;
  right: 8rpx;
  border-top: 1rpx solid rgba(0, 200, 255, 0.28);
  border-right: 1rpx solid rgba(0, 200, 255, 0.28);
}

.pulse-vr-corner--bl {
  bottom: 8rpx;
  left: 8rpx;
  border-bottom: 1rpx solid rgba(0, 200, 255, 0.28);
  border-left: 1rpx solid rgba(0, 200, 255, 0.28);
}

.pulse-vr-corner--br {
  bottom: 8rpx;
  right: 8rpx;
  border-bottom: 1rpx solid rgba(0, 200, 255, 0.28);
  border-right: 1rpx solid rgba(0, 200, 255, 0.28);
}

/* ===== 目标锁定条：很薄的 HUD 锁定条 ===== */
.pulse-lock-strip {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18rpx;
  box-sizing: border-box;
  background: rgba(2, 14, 26, 0.64);
  border: 1rpx solid rgba(0, 200, 255, 0.20);
  clip-path: polygon(
    14rpx 0,
    calc(100% - 14rpx) 0,
    100% 14rpx,
    100% 100%,
    0 100%,
    0 14rpx
  );
  margin-bottom: 12rpx;
}

.pulse-lock-target {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.pulse-lock-text {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.pulse-lock-name {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(226,242,255,0.90);
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pulse-lock-sub {
  font-size: 16rpx;
  color: rgba(0,200,255,0.40);
  letter-spacing: 2rpx;
}

/* HUD 读数屏：输入值显示 */
.pulse-lock-value {
  position: relative;
  min-width: 130rpx;
  max-width: 150rpx;
  height: 52rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  box-sizing: border-box;
  border: 1rpx solid rgba(0,200,255,0.20);
  background: rgba(0,200,255,0.04);
  clip-path: polygon(10rpx 0, 100% 0, 100% calc(100% - 10rpx), calc(100% - 10rpx) 100%, 0 100%, 0 10rpx);
}

.pulse-lock-value text {
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 40rpx;
  font-weight: 600;
  color: rgba(226,242,255,0.94);
  letter-spacing: 2rpx;
  font-variant-numeric: tabular-nums;
}

/* ===== 悬浮按键阵列：独立 VR 触控块（稳定三列） ===== */
.pulse-vr-grid {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 0 4rpx;
}

/* 按键行：横向三列 */
.transfer-key-row {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
  width: 100%;
}

/* 独立 VR 悬浮按钮 */
.vr-key {
  position: relative;
  width: 32%;
  height: 76rpx;
  box-sizing: border-box;
  padding: 0;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(236, 248, 255, 0.90);
  font-size: 32rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', Menlo, monospace;
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.14), transparent 42%),
    rgba(2, 18, 32, 0.48);
  border: 1rpx solid rgba(0, 200, 255, 0.24);
  clip-path: polygon(
    12rpx 0,
    calc(100% - 12rpx) 0,
    100% 12rpx,
    100% calc(100% - 12rpx),
    calc(100% - 12rpx) 100%,
    12rpx 100%,
    0 calc(100% - 12rpx),
    0 12rpx
  );
  box-shadow:
    0 0 0 1rpx rgba(0, 200, 255, 0.04) inset,
    0 8rpx 22rpx rgba(0, 0, 0, 0.36);
  -webkit-tap-highlight-color: transparent;
  transition: transform 0.10s ease, border-color 0.10s ease, background-color 0.10s ease;
  margin: 0;
  line-height: 1;
}

/* 新键盘按键：使用 flex:1 稳定三列 */
.transfer-key {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  position: relative;
  color: rgba(236, 248, 255, 0.90);
  font-size: 32rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', Menlo, monospace;
  background:
    radial-gradient(circle at 50% 0%, rgba(0, 200, 255, 0.14), transparent 42%),
    rgba(2, 18, 32, 0.48);
  border: 1rpx solid rgba(0, 200, 255, 0.24);
  clip-path: polygon(
    12rpx 0,
    calc(100% - 12rpx) 0,
    100% 12rpx,
    100% calc(100% - 12rpx),
    calc(100% - 12rpx) 100%,
    12rpx 100%,
    0 calc(100% - 12rpx),
    0 12rpx
  );
  box-shadow:
    0 0 0 1rpx rgba(0, 200, 255, 0.04) inset,
    0 8rpx 22rpx rgba(0, 0, 0, 0.36);
  -webkit-tap-highlight-color: transparent;
  transition: transform 0.10s ease, border-color 0.10s ease, background-color 0.10s ease;
  line-height: 1;
}

/* transfer-key 变体样式 */
.transfer-key--close {
  font-family: 'Courier New', Courier, monospace;
  font-size: 36rpx;
  font-weight: 400;
  color: rgba(150, 180, 200, 0.54);
  background: rgba(4, 12, 22, 0.34);
  border-color: rgba(120, 160, 190, 0.16);
}

.transfer-key--close:active {
  color: rgba(150, 180, 200, 0.74);
  background: rgba(4, 12, 22, 0.52);
  border-color: rgba(120, 160, 190, 0.26);
}

.transfer-key--launch {
  border-color: rgba(0, 200, 255, 0.64);
  background:
    radial-gradient(circle at 38% 50%, rgba(0, 200, 255, 0.28), transparent 50%),
    rgba(0, 52, 82, 0.58);
  box-shadow: 0 0 18rpx rgba(0, 200, 255, 0.16);
  color: rgba(226, 242, 255, 0.96);
}

.transfer-key--launch::after {
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.44), transparent);
}

.transfer-key--launch:active {
  background:
    radial-gradient(circle at 38% 50%, rgba(0, 200, 255, 0.42), transparent 50%),
    rgba(0, 72, 108, 0.66);
  border-color: rgba(0, 200, 255, 0.84);
  box-shadow: 0 0 28rpx rgba(0, 200, 255, 0.26);
}

.transfer-key--disabled {
  opacity: 0.28;
  pointer-events: none;
}

.vr-key::before {
  content: '';
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 6rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent);
  pointer-events: none;
}

.vr-key::after {
  content: '';
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 6rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.32), transparent);
  pointer-events: none;
}

.vr-key:active {
  transform: translateY(2rpx);
  border-color: rgba(0, 200, 255, 0.52);
  background-color: rgba(0, 200, 255, 0.10);
}

/* 关闭按钮（左下角 ×）：弱化，非清空 */
.vr-key--close {
  font-family: 'Courier New', Courier, monospace;
  font-size: 36rpx;
  font-weight: 400;
  color: rgba(150, 180, 200, 0.54);
  background: rgba(4, 12, 22, 0.34);
  border-color: rgba(120, 160, 190, 0.16);
}

.vr-key--close:active {
  color: rgba(150, 180, 200, 0.74);
  background: rgba(4, 12, 22, 0.52);
  border-color: rgba(120, 160, 190, 0.26);
}

/* 发射按钮（右下角）：脉冲发射核心 */
.vr-key--launch {
  border-color: rgba(0, 200, 255, 0.64);
  background:
    radial-gradient(circle at 38% 50%, rgba(0, 200, 255, 0.28), transparent 50%),
    rgba(0, 52, 82, 0.58);
  box-shadow: 0 0 18rpx rgba(0, 200, 255, 0.16);
}

.vr-key--launch::after {
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.44), transparent);
}

.vr-key--launch:active {
  background:
    radial-gradient(circle at 38% 50%, rgba(0, 200, 255, 0.42), transparent 50%),
    rgba(0, 72, 108, 0.66);
  border-color: rgba(0, 200, 255, 0.84);
  box-shadow: 0 0 28rpx rgba(0, 200, 255, 0.26);
}

.vr-key--disabled {
  opacity: 0.28;
  pointer-events: none;
}

/* ===== 脉冲发射图标（CSS-only） ===== */
.pulse-launch-glyph {
  position: relative;
  width: 58rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 能量圆核 */
.pulse-launch-core {
  position: absolute;
  left: 2rpx;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 200, 255, 0.82);
  transform: translateY(-50%);
  box-shadow: 0 0 6rpx rgba(0, 200, 255, 0.36);
}

/* 中间向右三角发射箭头 */
.pulse-launch-triangle {
  position: absolute;
  left: 20rpx;
  top: 50%;
  width: 0;
  height: 0;
  border-left: 20rpx solid rgba(0, 200, 255, 0.74);
  border-top: 9rpx solid transparent;
  border-bottom: 9rpx solid transparent;
  transform: translateY(-50%);
  filter: drop-shadow(0 0 3rpx rgba(0, 200, 255, 0.42));
}

/* 右侧两条短光束 */
.pulse-launch-ray {
  position: absolute;
  left: 42rpx;
  width: 12rpx;
  height: 2rpx;
  background: rgba(0, 200, 255, 0.62);
}

.pulse-launch-ray--one {
  top: 8rpx;
}

.pulse-launch-ray--two {
  bottom: 8rpx;
}

/* ===== 输入面板打开时弱化底层元素 ===== */
.room-page--input-open .cockpit-console,
.room-page--input-open .task-terminal,
.room-page--input-open .console-bridge {
  opacity: 0.35;
  pointer-events: none;
  transition: opacity 0.22s ease;
}

/* ===== reduce-motion 降级 ===== */
.reduce-motion .pulse-vr-overlay {
  transition: none !important;
}

.reduce-motion .pulse-vr-cluster,
.reduce-motion .pulse-vr-scanline {
  transition: none !important;
}

.reduce-motion .vr-key {
  transition: none !important;
}

.reduce-motion .vr-key:active {
  transform: none !important;
}

/* ===== 旧样式兼容（保留防报错） ===== */
.pulse-holo-overlay,
.pulse-holo-panel,
.pulse-holo-anchor,
.pulse-holo-top,
.pulse-holo-target,
.pulse-holo-target-text,
.pulse-holo-target-name,
.pulse-holo-target-lock,
.pulse-holo-display,
.pulse-holo-display-value,
.pulse-holo-grid,
.holo-key,
.holo-key--close,
.holo-key--launch,
.holo-key--disabled,
.pulse-launch-glyph {
  display: none;
}

.pulse-ar-overlay,
.pulse-ar-panel,
.pulse-ar-head,
.pulse-ar-target,
.pulse-ar-target-name,
.pulse-ar-display,
.pulse-ar-display-value,
.pulse-ar-keypad,
.pulse-ar-key,
.pulse-ar-key--cancel,
.pulse-ar-key--launch,
.pulse-ar-key--disabled,
.pulse-launch-icon {
  display: none;
}

/* ===== 旧底部抽屉样式兼容（保留防报错） ===== */
.transfer-overlay,
.transfer-sheet,
.transfer-header,
.transfer-title-row,
.transfer-title,
.transfer-sender-info,
.transfer-sender-name,
.transfer-display-compact,
.transfer-suggestions,
.suggestion-grid,
.suggestion-chip,
.suggestion-amount,
.suggestion-label,
.transfer-bottom-row,
.transfer-numpad,
.transfer-numpad--compact,
.transfer-confirm-wrap,
.transfer-confirm,
.transfer-confirm-disabled,
.transfer-confirm-text,
.transfer-key,
.transfer-key-func,
.numpad-func-icon,
.numpad-func-icon--del {
  display: none;
}

/* ===== 脉冲记录标题按钮（极简胶囊） ===== */
.matrix-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: var(--glass-bg-hover);
  border: none;
  border-radius: 32rpx;
}

.matrix-btn:active {
  background: var(--text-disabled);
  transform: scale(0.95);
}

.matrix-btn-icon {
  font-size: 20rpx;
  opacity: 0.5;
}

.matrix-btn-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

/* flow-log-panel / space-scan-panel 样式已迁移到组件内部 */

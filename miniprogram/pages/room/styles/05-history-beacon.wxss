/* ===== 脉冲表格 ===== */

/* ===== 通用工具 ===== */
.score-number {
  font-variant-numeric: tabular-nums;
}

.flex-1 {
  flex: 1;
  min-width: 0;
}

.text-center {
  text-align: center;
}


/* ===== 历史场次 ===== */
.history-scroll {
  max-height: 70vh;
}

.history-item {
  background: var(--glass-bg);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: var(--border-radius-sm);
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}
.history-item:last-child {
  margin-bottom: 0;
}
.history-item:active {
  background: rgba(10, 132, 255, 0.1);
}

.history-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.history-players {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.history-player-avatar {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.history-avatar-img {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
}

.history-time-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* 历史详情批次 */
.detail-batch {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.detail-batch:last-child {
  border-bottom: none;
}

.detail-batch-time {
  margin-bottom: 8rpx;
  display: block;
}

.detail-batch-scores {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-batch-score {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.detail-batch-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.detail-batch-val {
  font-size: 24rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

/* ===== 信标面板 ===== */
.beacon-code-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
  background: rgba(0, 200, 255, 0.04);
  border: 1rpx solid rgba(0, 200, 255, 0.12);
  border-radius: 12rpx;
}

.beacon-code-label {
  font-size: 22rpx;
  color: rgba(226, 242, 255, 0.42);
  letter-spacing: 2rpx;
  flex-shrink: 0;
}

.beacon-code-value {
  flex: 1;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 36rpx;
  font-weight: 700;
  color: rgba(0, 200, 255, 0.88);
  letter-spacing: 6rpx;
  font-variant-numeric: tabular-nums;
}

.beacon-mini-btn {
  flex-shrink: 0;
  padding: 8rpx 24rpx;
  margin: 0;
  border: 1rpx solid rgba(0, 200, 255, 0.30);
  background: rgba(0, 200, 255, 0.08);
  color: rgba(0, 200, 255, 0.88);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  line-height: 1.3;
  border-radius: 8rpx;
  -webkit-tap-highlight-color: transparent;
}

.beacon-mini-btn::after {
  display: none;
}

.beacon-mini-btn:active {
  background: rgba(0, 200, 255, 0.16);
  border-color: rgba(0, 200, 255, 0.48);
}

.beacon-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

/* ===== 编队接入面板 ===== */
.share-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  z-index: 250;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease, visibility 0.25s ease;
}
.share-show {
  opacity: 1;
  visibility: visible;
}
.share-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #0A0F18;
  border-top: 1rpx solid rgba(10, 132, 255, 0.15);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 28rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
}
.share-show .share-sheet {
  transform: translateY(0);
}
.share-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}
.share-title-area {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.share-kicker {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(10, 132, 255, 0.72);
  font-family: monospace;
  text-transform: uppercase;
}
.share-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.share-qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 0;
}
.share-qr-frame {
  width: 280rpx;
  height: 280rpx;
  padding: 16rpx;
  background: var(--bg-card);
  border: 1rpx solid rgba(10, 132, 255, 0.12);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.share-qr-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  display: block;
}
.share-qr-placeholder {
  background: rgba(10, 132, 255, 0.04);
}
.share-qr-room-no {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-cyan);
  font-variant-numeric: tabular-nums;
  letter-spacing: 8rpx;
}
.share-qr-hint {
  font-size: 22rpx;
  color: rgba(140, 176, 205, 0.38);
}
.share-qr-loading {
  gap: 16rpx;
}
.share-qr-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid rgba(10, 132, 255, 0.2);
  border-top-color: var(--color-cyan);
  border-radius: 50%;
  animation: qr-spin 0.8s linear infinite;
}
@keyframes qr-spin {
  to { transform: rotate(360deg); }
}
.share-qr-loading-text {
  font-size: 24rpx;
  color: rgba(140, 176, 205, 0.38);
}
.share-qr-fail {
  gap: 8rpx;
}
.share-qr-fail-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}
.share-qr-fail-hint {
  font-size: 24rpx;
  color: rgba(140, 176, 205, 0.38);
}
.share-qr-retry {
  margin-top: 12rpx;
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.3);
  border-radius: 8rpx;
}
.share-qr-retry-text {
  font-size: 24rpx;
  color: var(--color-cyan);
}
.share-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}
.share-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  background: var(--bg-card);
  border: 1rpx solid var(--glass-border-light);
  border-radius: 16rpx;
  line-height: normal;
  margin: 0;
  font-size: inherit;
  color: inherit;
}
.share-action-btn::after {
  border: none;
}
.share-action-btn:active {
  background: rgba(10, 132, 255, 0.12);
  border-color: rgba(10, 132, 255, 0.3);
}
.share-action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ===== 信标面板底部危险区 ===== */
.beacon-danger-zone {
  margin-top: 32rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
  display: flex;
  justify-content: center;
}

.beacon-danger-btn {
  padding: 10rpx 32rpx;
  margin: 0;
  border: 1rpx solid rgba(255, 69, 58, 0.18);
  background: transparent;
  color: rgba(255, 150, 140, 0.56);
  font-size: 22rpx;
  letter-spacing: 2rpx;
  font-weight: 600;
  line-height: 1.4;
  border-radius: 8rpx;
  -webkit-tap-highlight-color: transparent;
}

.beacon-danger-btn::after {
  display: none;
}

.beacon-danger-btn:active {
  border-color: rgba(255, 69, 58, 0.36);
  background: rgba(255, 69, 58, 0.06);
  color: rgba(255, 150, 140, 0.78);
}

/* WS 断线遮罩 */
.ws-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.28);
  z-index: 880;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}
.ws-mask--show {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}
.ws-mask__card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 48rpx 64rpx;
}
.ws-mask__dot {
  width: 16rpx; height: 16rpx;
  background: #0A84FF;
  border-radius: 50%;
  animation: ws-breathe 1.6s ease-in-out infinite;
}
@keyframes ws-breathe {
  0%, 100% { transform: scale(1); opacity: 0.4; }
  50% { transform: scale(1.8); opacity: 1; }
}
.ws-mask__text {
  color: var(--text-primary);
  font-size: 28rpx;
}

/* 模态框打开时禁止底层滚动 */
.scroll-locked {
  overflow: hidden !important;
  pointer-events: none;
}

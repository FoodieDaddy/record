/* ===== 纯色线框图标系统 ===== */
/* 锁 */
.icon-lock-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-lock {
  width: 28rpx;
  height: 22rpx;
  border: 2rpx solid var(--text-secondary);
  border-radius: 6rpx;
  position: relative;
}
.icon-lock::before {
  content: '';
  position: absolute;
  top: -14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 14rpx;
  border: 2rpx solid var(--text-secondary);
  border-bottom: none;
  border-radius: 10rpx 10rpx 0 0;
}
/* 分享/导出 */
.icon-share {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-share::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: 10rpx;
  background: currentColor;
}
.icon-share::after {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%) rotate(45deg);
  width: 8rpx;
  height: 8rpx;
  border-top: 2rpx solid currentColor;
  border-right: 2rpx solid currentColor;
}
/* 链接 */
.icon-link {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 10rpx;
  position: relative;
  opacity: 0.8;
}
.icon-link::before {
  content: '';
  position: absolute;
  top: 50%;
  left: -6rpx;
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
.icon-link::after {
  content: '';
  position: absolute;
  top: 50%;
  right: -6rpx;
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
/* 剪贴板 */
.icon-clip {
  width: 22rpx;
  height: 26rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-clip::before {
  content: '';
  position: absolute;
  top: -4rpx;
  left: 4rpx;
  right: 4rpx;
  height: 6rpx;
  border: 2rpx solid currentColor;
  border-radius: 3rpx 3rpx 0 0;
}
/* 人物 */
.icon-person {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  position: relative;
  opacity: 0.8;
}
.icon-person::before {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 10rpx;
  border: 2rpx solid currentColor;
  border-bottom: none;
  border-radius: 12rpx 12rpx 0 0;
}
/* 图表 */
.icon-chart {
  width: 22rpx;
  height: 22rpx;
  position: relative;
  opacity: 0.8;
}
.icon-chart::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 6rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
.icon-chart::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10rpx;
  width: 6rpx;
  height: 14rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
/* 聊天 */
.icon-chat {
  width: 24rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 6rpx 6rpx 6rpx 0;
  position: relative;
  opacity: 0.8;
}
.icon-chat::before {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: -2rpx;
  width: 8rpx;
  height: 6rpx;
  border-left: 2rpx solid currentColor;
  transform: skewX(-20deg);
}
/* 图片 */
.icon-image {
  width: 22rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-image::before {
  content: '';
  position: absolute;
  bottom: 3rpx;
  left: 2rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 6rpx solid currentColor;
}
/* 相机 */
.icon-cam {
  width: 24rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-cam::before {
  content: '';
  position: absolute;
  top: -5rpx;
  left: 6rpx;
  width: 10rpx;
  height: 5rpx;
  border: 2rpx solid currentColor;
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
}
.icon-cam::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 8rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}
/* 音频开 */
.icon-audio-on {
  width: 20rpx;
  height: 20rpx;
  position: relative;
  opacity: 0.8;
}
.icon-audio-on::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 8rpx 8rpx 0;
}
.icon-audio-on::after {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 18rpx;
  border-right: 2rpx solid currentColor;
  border-radius: 0 12rpx 12rpx 0;
}
/* 音频关 */
.icon-audio-off {
  width: 20rpx;
  height: 20rpx;
  position: relative;
  opacity: 0.8;
}
.icon-audio-off::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 8rpx 8rpx 0;
}
.icon-audio-off::after {
  content: '';
  position: absolute;
  right: 0;
  top: 2rpx;
  width: 2rpx;
  height: 18rpx;
  background: currentColor;
  transform: rotate(45deg);
  transform-origin: center;
}
/* 门 */
.icon-door {
  width: 18rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 3rpx 6rpx 6rpx 3rpx;
  position: relative;
  opacity: 0.8;
}
.icon-door::before {
  content: '';
  position: absolute;
  top: 50%;
  right: 4rpx;
  transform: translateY(-50%);
  width: 4rpx;
  height: 4rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}
/* 垃圾桶 */
.icon-trash {
  width: 18rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 0 0 4rpx 4rpx;
  position: relative;
  opacity: 0.8;
}
.icon-trash::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 2rpx;
  right: 2rpx;
  height: 4rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
}
.icon-trash::after {
  content: '';
  position: absolute;
  top: 2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
}
/* 网格视图 */
.icon-grid {
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
  position: relative;
  opacity: 0.8;
}
.icon-grid::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
  transform: translateY(-50%);
}
.icon-grid::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: currentColor;
  transform: translateX(-50%);
}
/* 列表视图 */
.icon-list {
  width: 18rpx;
  height: 18rpx;
  position: relative;
  opacity: 0.8;
}
.icon-list::before {
  content: '';
  position: absolute;
  top: 3rpx;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
}
.icon-list::after {
  content: '';
  position: absolute;
  bottom: 3rpx;
  left: 0;
  right: 0;
  height: 2rpx;
  background: currentColor;
}
/* 空状态：雷达网格扫描仪 */
.icon-empty-doc {
  width: 64rpx;
  height: 64rpx;
  position: relative;
  margin-bottom: 20rpx;
  opacity: 0.15;
}
.icon-empty-doc::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 56rpx;
  height: 56rpx;
  border: 1.5rpx solid var(--accent);
  border-radius: 50%;
  box-shadow:
    inset 0 0 0 14rpx transparent,
    inset 0 0 0 15.5rpx rgba(10, 132, 255, 0.4),
    inset 0 0 0 28rpx transparent,
    inset 0 0 0 29.5rpx rgba(10, 132, 255, 0.25);
}
.icon-empty-doc::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 1.5rpx;
  height: 28rpx;
  background: rgba(10, 132, 255, 0.5);
  transform: translate(-50%, -100%);
  transform-origin: bottom center;
  box-shadow:
    0 0 0 0 transparent,
    0 0 6rpx 1rpx rgba(10, 132, 255, 0.3);
}
/* 按钮内图标尺寸 */
.matrix-btn-icon-svg {
  width: 20rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-action-svg {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

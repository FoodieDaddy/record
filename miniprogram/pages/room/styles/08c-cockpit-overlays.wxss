/* ===== 更多操作面板 ===== */
.more-panel-overlay {
  position: fixed;
  inset: 0;
  z-index: 1020;
  background: rgba(0, 0, 0, 0.56);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.18s ease;
}

.more-panel-overlay--show {
  opacity: 1;
  pointer-events: auto;
}

.more-panel {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.92);
  width: calc(100vw - 80rpx);
  max-width: 500rpx;
  background: rgba(3, 12, 24, 0.92);
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  clip-path: polygon(16rpx 0, calc(100% - 16rpx) 0, 100% 16rpx, 100% calc(100% - 16rpx), calc(100% - 16rpx) 100%, 16rpx 100%, 0 calc(100% - 16rpx), 0 16rpx);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.60);
  padding: 24rpx 28rpx 28rpx;
  transition: transform 0.18s ease;
  z-index: 1021;
}

.more-panel-overlay--show .more-panel {
  transform: translate(-50%, -50%) scale(1);
}

.more-panel__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.more-panel__title {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(226, 242, 255, 0.88);
  letter-spacing: 2rpx;
}

.more-panel__close {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-panel__close-x {
  position: relative;
  width: 20rpx;
  height: 20rpx;
}

.more-panel__close-x::before,
.more-panel__close-x::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: rgba(226, 242, 255, 0.40);
}

.more-panel__close-x::before { transform: rotate(45deg); }
.more-panel__close-x::after { transform: rotate(-45deg); }

.more-panel__actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.more-panel__btn {
  height: 72rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 20rpx;
  background: rgba(0, 200, 255, 0.06);
  border: 1rpx solid rgba(0, 200, 255, 0.14);
  border-radius: 8rpx;
  border-bottom-width: 2rpx;
  font-size: 22rpx;
  color: rgba(226, 242, 255, 0.82);
  letter-spacing: 2rpx;
}

.more-panel__btn--danger {
  background: rgba(255, 69, 58, 0.06);
  border-color: rgba(255, 69, 58, 0.18);
  color: rgba(255, 69, 58, 0.82);
}

.more-panel__btn-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.more-panel__btn-icon--copy {
  border: 2rpx solid rgba(0, 200, 255, 0.30);
  border-radius: 4rpx;
  position: relative;
}

.more-panel__btn-icon--copy::after {
  content: '';
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 10rpx;
  height: 10rpx;
  border: 2rpx solid rgba(0, 200, 255, 0.30);
  border-radius: 2rpx;
  background: rgba(3, 12, 24, 0.92);
}

.more-panel__btn-icon--danger {
  border: 2rpx solid rgba(255, 69, 58, 0.30);
  border-radius: 50%;
  position: relative;
}

.more-panel__btn-icon--danger::before,
.more-panel__btn-icon--danger::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 50%;
  height: 2rpx;
  background: rgba(255, 69, 58, 0.30);
  transform: translate(-50%, -50%) rotate(45deg);
}

.more-panel__btn-icon--danger::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.reduce-motion .more-panel-overlay {
  transition: none !important;
}

.reduce-motion .more-panel {
  transition: none !important;
}

.reduce-motion .more-panel-overlay--show .more-panel {
  transform: translate(-50%, -50%) scale(1);
}

/* ===== 信标面板 (AR 浮空终端) ===== */
.beacon-overlay {
  position: fixed;
  inset: 0;
  z-index: 1030;
  background: radial-gradient(ellipse at 50% 40%, rgba(2, 10, 28, 0.44), rgba(0, 0, 0, 0.64));
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.18s ease;
}

.beacon-overlay--show {
  opacity: 1;
  pointer-events: auto;
}

.beacon-panel {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.92);
  width: calc(100vw - 72rpx);
  max-width: 520rpx;
  background: rgba(3, 12, 24, 0.90);
  border: 1rpx solid rgba(0, 200, 255, 0.20);
  clip-path: polygon(18rpx 0, calc(100% - 18rpx) 0, 100% 18rpx, 100% calc(100% - 18rpx), calc(100% - 18rpx) 100%, 18rpx 100%, 0 calc(100% - 18rpx), 0 18rpx);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.64);
  padding: 28rpx 28rpx 20rpx;
  transition: transform 0.18s ease;
  z-index: 1031;
  overflow: hidden;
}

.beacon-overlay--show .beacon-panel {
  transform: translate(-50%, -50%) scale(1);
}

.beacon-panel__scanline {
  position: absolute;
  left: 10%;
  right: 10%;
  top: 6rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 200, 255, 0.10), transparent);
  pointer-events: none;
}

.beacon-panel__head {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 18rpx;
  position: relative;
}

.beacon-panel__title {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(226, 242, 255, 0.88);
  letter-spacing: 3rpx;
}

.beacon-panel__kicker {
  font-family: 'Courier New', Courier, monospace;
  font-size: 9rpx;
  color: rgba(0, 200, 255, 0.20);
  letter-spacing: 2rpx;
}

.beacon-panel__close {
  position: absolute;
  right: -8rpx;
  top: -8rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.beacon-close-x {
  position: relative;
  width: 22rpx;
  height: 22rpx;
}

.beacon-close-x::before,
.beacon-close-x::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: rgba(226, 242, 255, 0.36);
}

.beacon-close-x::before { transform: rotate(45deg); }
.beacon-close-x::after { transform: rotate(-45deg); }

.beacon-code-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 20rpx;
  background: rgba(0, 200, 255, 0.04);
  border: 1rpx solid rgba(0, 200, 255, 0.10);
  border-radius: 6rpx;
}

.beacon-code-label {
  font-size: 18rpx;
  color: rgba(226, 242, 255, 0.36);
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.beacon-code-value {
  flex: 1;
  font-family: 'DIN Alternate', Menlo, monospace;
  font-size: 30rpx;
  color: rgba(0, 200, 255, 0.88);
  letter-spacing: 6rpx;
  font-variant-numeric: tabular-nums;
}

.beacon-copy-btn {
  height: 52rpx;
  padding: 0 20rpx;
  background: rgba(0, 200, 255, 0.10);
  border: 1rpx solid rgba(0, 200, 255, 0.20);
  border-radius: 6rpx;
  font-size: 18rpx;
  color: rgba(0, 200, 255, 0.76);
  letter-spacing: 2rpx;
  flex-shrink: 0;
  line-height: 52rpx;
}

.beacon-qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
}

.beacon-qr-frame {
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(0, 200, 255, 0.12);
  border-radius: 8rpx;
  padding: 12rpx;
  box-sizing: border-box;
}

.beacon-qr-frame--loading,
.beacon-qr-frame--fail {
  border-style: dashed;
}

.beacon-qr-image {
  width: 100%;
  height: 100%;
}

.beacon-qr-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid rgba(0, 200, 255, 0.16);
  border-top-color: rgba(0, 200, 255, 0.56);
  border-radius: 50%;
}

.beacon-qr-loading-text,
.beacon-qr-fail-text {
  font-size: 18rpx;
  color: rgba(226, 242, 255, 0.32);
  margin-top: 10rpx;
}

.beacon-qr-retry {
  margin-top: 10rpx;
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.18);
  border-radius: 4rpx;
  font-size: 18rpx;
  color: rgba(0, 200, 255, 0.56);
}

.beacon-qr-hint {
  margin-top: 12rpx;
  font-size: 17rpx;
  color: rgba(226, 242, 255, 0.28);
  letter-spacing: 1rpx;
  text-align: center;
}

.beacon-bottom-bar {
  display: flex;
  justify-content: center;
  padding-top: 4rpx;
}

.beacon-bottom-close {
  padding: 10rpx 48rpx;
  border: 1rpx solid rgba(226, 242, 255, 0.12);
  border-radius: 6rpx;
  font-size: 18rpx;
  color: rgba(226, 242, 255, 0.36);
  letter-spacing: 2rpx;
}

.reduce-motion .beacon-overlay {
  transition: none !important;
}

.reduce-motion .beacon-panel {
  transition: none !important;
}

.reduce-motion .beacon-overlay--show .beacon-panel {
  transform: translate(-50%, -50%) scale(1);
}

/* ===== reduce-motion 通用 ===== */
.reduce-motion .more-panel-overlay--show .more-panel {
  transform: translate(-50%, -50%) scale(1);
}

.cockpit-active {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

/* 强制重写：实体 3D 飞船按钮 v3 */
.cockpit-console-v2 {
  flex-shrink: 0;
  background: #070D14 !important;
  padding: 24rpx 32rpx 20rpx !important;
  box-shadow: inset 0 4rpx 20rpx rgba(0, 0, 0, 0.9) !important;
  border-top: 1rpx solid rgba(0, 200, 255, 0.15) !important;
}

.ccv2-btn {
  background: linear-gradient(135deg, #1A2632 0%, #0D141A 100%) !important;
  height: 100rpx !important;
  border-radius: 12rpx !important;
  box-shadow:
    0 8rpx 0 0 #05080C,
    0 12rpx 20rpx rgba(0, 0, 0, 0.6),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12) !important;
}

.ccv2-btn--press {
  transform: translateY(6rpx) !important;
  box-shadow:
    0 2rpx 0 0 #05080C,
    0 4rpx 10rpx rgba(0, 0, 0, 0.8),
    inset 0 4rpx 12rpx rgba(0, 0, 0, 0.6) !important;
}

.ccv2-btn__indicator {
  width: 24rpx !important;
  height: 4rpx !important;
  border-radius: 2rpx !important;
  margin-bottom: 8rpx !important;
}

.output-terminal {
  max-height: 120rpx !important;
  margin: 0 24rpx !important;
}

.session-page {
  padding: var(--spacing-md);
  padding-bottom: 48rpx;
}

.header-card {
  margin-bottom: var(--spacing-sm);
}

.session-title {
  font-size: 36rpx;
  font-weight: 700;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: block;
}

/* 排行榜 */
.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: var(--glass-bg);
  border-radius: 16rpx;
  animation: fadeSlideIn 0.3s ease both;
}

@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateX(-16rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  background: var(--glass-bg);
  color: var(--text-secondary);
}

.rank-top {
  background: var(--accent-light);
  color: var(--accent);
}

.rank-name {
  font-size: 28rpx;
  margin-left: 8rpx;
}

.rank-score {
  font-size: 32rpx;
  font-weight: 700;
  min-width: 100rpx;
  text-align: right;
}

/* 记分表单 */
.score-form {
  margin-bottom: var(--spacing-sm);
}

.score-input-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.score-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.player-name {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.score-input {
  width: 180rpx;
  background: var(--glass-bg);
  border: 1rpx solid var(--glass-border);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 图片上传 */
.image-section {
  margin-bottom: 24rpx;
}

.image-preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.image-preview-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  border: 1rpx solid var(--glass-border);
}

.remove-img {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: var(--danger);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.add-image-btn {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border-radius: 12rpx;
  padding: 0;
}

.submit-btn {
  width: 100%;
  margin-top: 8rpx;
}

/* 流水 */
.batch-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--glass-border);
}
.batch-item:last-child {
  border-bottom: none;
}

.batch-header {
  margin-bottom: 12rpx;
}

.batch-scores {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.batch-score-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
}

.batch-images {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
}

.batch-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--glass-border);
}

/* 海报弹窗 */
.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.poster-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
}

.poster-image {
  width: 600rpx;
  height: 800rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--glass-border);
}

.poster-actions {
  margin-top: 32rpx;
  width: 600rpx;
}

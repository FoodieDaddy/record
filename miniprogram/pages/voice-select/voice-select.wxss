/* ===== 页面容器 ===== */
.page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

/* ===== HUD 状态条 ===== */
.sync-hud {
  position: fixed;
  top: calc(env(safe-area-inset-top, 0px) + 88rpx);
  left: 32rpx;
  right: 32rpx;
  z-index: 999;
  height: 56rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border: 1rpx solid rgba(0, 200, 255, 0.22);
  background: rgba(3, 10, 18, 0.92);
  color: rgba(226, 242, 255, 0.88);
  font-size: 24rpx;
  pointer-events: none;
  opacity: 0;
  transform: translateY(-8rpx);
  transition: opacity 0.3s ease, transform 0.3s ease;
  clip-path: polygon(
    12rpx 0, calc(100% - 12rpx) 0,
    100% 12rpx, 100% calc(100% - 12rpx),
    calc(100% - 12rpx) 100%, 12rpx 100%,
    0 calc(100% - 12rpx), 0 12rpx
  );
}

.sync-hud--show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.sync-hud--error {
  border-color: rgba(255, 69, 58, 0.35);
}

.sync-hud--warning {
  border-color: rgba(255, 159, 10, 0.35);
}

.sync-hud__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-cyan);
  margin-right: 14rpx;
  flex-shrink: 0;
}

.sync-hud--error .sync-hud__dot {
  background: #FF453A;
}

.sync-hud--warning .sync-hud__dot {
  background: #FF9F0A;
}

.sync-hud__text {
  font-family: monospace;
  letter-spacing: 1rpx;
}

.reduce-motion .sync-hud {
  transition: none !important;
}

/* ===== 蒙层 ===== */
.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.mask.visible {
  opacity: 1;
  pointer-events: auto;
}

/* ===== 抽屉主体 ===== */
.sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 75vh;
  background: rgba(30, 30, 30, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.sheet.slide-up {
  transform: translateY(0);
}

/* ===== 把手 ===== */
.handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: var(--text-disabled);
  margin: 16rpx auto 0;
  flex-shrink: 0;
}

/* ===== Header ===== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.header-kicker {
  display: block;
  font-size: 18rpx;
  font-weight: 500;
  color: rgba(0, 200, 255, 0.48);
  letter-spacing: 4rpx;
  margin-bottom: 4rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 1rpx;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(126, 156, 180, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1;
}

/* 飞控线图标关闭按钮 */
.fi.fi--close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(126, 156, 180, 0.10);
  background: var(--bg-card);
  color: var(--text-secondary);
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.fi.fi--close::before,
.fi.fi--close::after {
  content: '';
  position: absolute;
  width: 20rpx;
  height: 2rpx;
  background: currentColor;
  top: 50%;
  left: 50%;
}
.fi.fi--close::before { transform: translate(-50%, -50%) rotate(45deg); }
.fi.fi--close::after { transform: translate(-50%, -50%) rotate(-45deg); }

/* ===== 内容区 ===== */
.content {
  flex: 1;
  display: flex;
  overflow: hidden;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 左侧分类栏 ===== */
.sidebar {
  width: 200rpx;
  flex-shrink: 0;
  padding: 8rpx 0;
}

.sidebar-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 20rpx;
  margin: 4rpx 12rpx;
  border-radius: 16rpx;
}

.sidebar-item.active {
  background: var(--glass-bg-hover);
}

.sidebar-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(10,132,255,0.35);
  border-radius: 4rpx;
  position: relative;
}
.sidebar-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(10,132,255,0.45);
  transform: translate(-50%, -50%);
}
.sidebar-item.active .sidebar-icon {
  border-color: rgba(0,200,255,0.6);
}
.sidebar-item.active .sidebar-icon::after {
  background: var(--color-cyan);
  box-shadow: 0 0 8rpx rgba(0,200,255,0.5);
}

.sidebar-name {
  font-size: 26rpx;
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sidebar-item.active .sidebar-name {
  color: var(--text-primary);
  font-weight: 600;
}

/* ===== 右侧音色列表 ===== */
.voice-list {
  flex: 1;
  padding: 8rpx 24rpx 8rpx 0;
}

.section-title {
  font-size: 22rpx;
  color: rgba(126, 156, 180, 0.30);
  letter-spacing: 2rpx;
  padding: 12rpx 0 8rpx 16rpx;
}

/* ===== 音色卡片 ===== */
.voice-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
  background: var(--glass-bg);
  border: 1px solid transparent;
  position: relative;
}

.voice-status-dot {
  position: absolute;
  left: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-cyan);
  box-shadow: 0 0 8rpx rgba(0, 200, 255, 0.6);
}

.voice-card.selected {
  background: rgba(10, 132, 255, 0.1);
  border-color: rgba(10, 132, 255, 0.5);
}

.voice-card.playing {
  background: var(--glass-bg);
}

.voice-info {
  flex: 1;
  min-width: 0;
  padding-left: 12rpx;
}

.voice-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.voice-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.voice-action {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.check-icon {
  width: 80rpx;
  height: 32rpx;
  position: relative;
}

.check-icon::after {
  content: '接入中';
  position: absolute;
  left: 0;
  top: 0;
  font-size: 18rpx;
  color: var(--color-cyan);
  font-family: monospace;
  letter-spacing: 1rpx;
  white-space: nowrap;
}

.play-icon {
  width: 24rpx;
  height: 24rpx;
  position: relative;
}

.play-icon::after {
  content: '';
  position: absolute;
  left: 6rpx;
  top: 2rpx;
  width: 0;
  height: 0;
  border-left: 16rpx solid var(--text-tertiary);
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
}

.play-icon.spin {
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ===== 动效静默 ===== */
.reduce-motion .play-icon.spin {
  animation: none !important;
}
.reduce-motion .mask,
.reduce-motion .sheet,
.reduce-motion .sidebar-item,
.reduce-motion .voice-card {
  transition: none !important;
}

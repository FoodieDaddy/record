/* ===== 页面容器 ===== */
.page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

/* ===== 蒙层 ===== */
.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.mask.visible {
  opacity: 1;
  pointer-events: auto;
}

/* ===== 抽屉主体 ===== */
.sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 75vh;
  background: rgba(30, 30, 30, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.sheet.slide-up {
  transform: translateY(0);
}

/* ===== 把手 ===== */
.handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.2);
  margin: 16rpx auto 0;
  flex-shrink: 0;
}

/* ===== Header ===== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1;
}

/* ===== 内容区 ===== */
.content {
  flex: 1;
  display: flex;
  overflow: hidden;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 左侧分类栏 ===== */
.sidebar {
  width: 200rpx;
  flex-shrink: 0;
  padding: 8rpx 0;
}

.sidebar-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 20rpx;
  margin: 4rpx 12rpx;
  border-radius: 16rpx;
}

.sidebar-item.active {
  background: rgba(255, 255, 255, 0.08);
}

.sidebar-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.sidebar-name {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sidebar-item.active .sidebar-name {
  color: #ffffff;
  font-weight: 600;
}

/* ===== 右侧音色列表 ===== */
.voice-list {
  flex: 1;
  padding: 8rpx 24rpx 8rpx 0;
}

.section-title {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  letter-spacing: 2rpx;
  padding: 12rpx 0 8rpx 16rpx;
}

/* ===== 音色卡片 ===== */
.voice-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid transparent;
}

.voice-card.selected {
  background: rgba(10, 132, 255, 0.1);
  border-color: rgba(10, 132, 255, 0.5);
}

.voice-card.playing {
  background: rgba(255, 255, 255, 0.06);
}

.voice-info {
  flex: 1;
  min-width: 0;
}

.voice-name {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.voice-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.voice-action {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.check-icon {
  width: 32rpx;
  height: 32rpx;
  position: relative;
}

.check-icon::after {
  content: '';
  position: absolute;
  left: 6rpx;
  top: 8rpx;
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #0A84FF;
  border-bottom: 3rpx solid #0A84FF;
  transform: rotate(-45deg);
}

.play-icon {
  width: 24rpx;
  height: 24rpx;
  position: relative;
}

.play-icon::after {
  content: '';
  position: absolute;
  left: 6rpx;
  top: 2rpx;
  width: 0;
  height: 0;
  border-left: 16rpx solid rgba(255, 255, 255, 0.4);
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
}

.play-icon.spin {
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ===== 动效静默 ===== */
.reduce-motion .play-icon.spin {
  animation: none !important;
}
.reduce-motion .mask,
.reduce-motion .sheet,
.reduce-motion .sidebar-item,
.reduce-motion .voice-card {
  transition: none !important;
}

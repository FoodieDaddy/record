.page-container {
  min-height: 100vh;
  background: #0a0a0a;
  padding: 24rpx;
}

.loading-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: #0a84ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text,
.empty-text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
  margin-top: 24rpx;
}

.empty-hint {
  color: rgba(255, 255, 255, 0.3);
  font-size: 24rpx;
  margin-top: 12rpx;
}

/* Hero Number */
.hero-score-panel {
  margin-bottom: 20rpx;
}

.hero-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.hero-value {
  font-size: 80rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.1;
}

.text-positive {
  color: #34c759;
}

.text-negative {
  color: #ff453a;
}

/* 趋势图 */
.trend-section {
  margin-bottom: 32rpx;
  animation: fadeInUp 0.4s ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.trend-title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 16rpx;
  display: block;
}

.trend-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 20rpx;
  backdrop-filter: blur(20px);
}

/* 房间列表 */
.room-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.room-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 28rpx;
  backdrop-filter: blur(20px);
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.room-no {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
}

.room-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.room-members {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.member-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
}

.member-avatar-sm {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.member-avatar-char {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.member-avatar-img {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.member-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.member-score {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
}

.member-score.positive {
  color: #34c759;
}

.member-score.negative {
  color: #ff453a;
}

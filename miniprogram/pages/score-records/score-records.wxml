<scroll-view class="page-container" scroll-y enhanced show-scrollbar="{{false}}">

  <!-- 趋势图 -->
  <view class="trend-section" wx:if="{{trendPoints.length > 0}}">
    <view class="hero-score-panel">
      <view class="hero-label">[ 近期场域总收支 | NET YIELD ]</view>
      <view class="hero-value {{ totalNetScore > 0 ? 'text-positive' : totalNetScore < 0 ? 'text-negative' : '' }}">
        {{ totalNetScore > 0 ? '+' : '' }}{{ totalNetScore }}
      </view>
    </view>
    <view class="trend-card">
      <trend-chart points="{{trendPoints}}" highlight-color="#0A84FF" />
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{roomsLoading && rooms.length === 0}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!roomsLoading && rooms.length === 0 && trendPoints.length === 0}}">
    <text class="empty-text">暂无积分记录</text>
    <text class="empty-hint">完成对局结算后将生成积分数据</text>
  </view>

  <!-- 房间列表 -->
  <view class="room-list" wx:if="{{rooms.length > 0}}">
    <view
      class="room-card"
      wx:for="{{rooms}}"
      wx:key="roomId"
      data-room-id="{{item.roomId}}"
      bindtap="onRoomTap"
    >
      <view class="room-header">
        <text class="room-no">{{item.roomNo}}</text>
        <text class="room-time">{{item.createdAt}}</text>
      </view>
      <view class="room-members">
        <view
          class="member-tag"
          wx:for="{{item.members}}"
          wx:for-item="m"
          wx:key="userId"
        >
          <view class="member-avatar-sm" style="background:{{m.avatarBgColor}};" wx:if="{{!m.avatarUrl}}">
            <text class="member-avatar-char">{{m.avatarChar}}</text>
          </view>
          <image
            wx:else
            class="member-avatar-img"
            src="{{m.avatarUrl}}"
            mode="aspectFill"
            binderror="onAvatarError"
            data-room-id="{{item.roomId}}"
            data-user-id="{{m.userId}}"
          />
          <text class="member-name">{{m.nickname}}</text>
          <text class="member-score {{m.finalScore > 0 ? 'positive' : m.finalScore < 0 ? 'negative' : ''}}">{{m.finalScore > 0 ? '+' : ''}}{{m.finalScore || 0}}</text>
        </view>
      </view>
    </view>
  </view>

</scroll-view>

.page-container {
  min-height: 100vh;
  background: #0A0A0A;
  padding: 0 32rpx 60rpx;
  box-sizing: border-box;
}

/* ===== 顶部栏 ===== */

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0 16rpx;
}

.header-info {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.header-room {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
  margin-top: 4rpx;
}

.close-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ===== 加载态 ===== */

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: #0A84FF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-top: 20rpx;
}

/* ===== 卡片通用 ===== */

.section-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-top: 24rpx;
}

.chart-card {
  padding: 20rpx 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 20rpx;
  display: block;
}

/* ===== 排名列表 ===== */

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rank-top3 {
  background: rgba(10, 132, 255, 0.15);
}

.rank-num {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
}

.rank-top3 .rank-num {
  color: #0A84FF;
}

.rank-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rank-avatar-img {
  width: 100%;
  height: 100%;
}

.rank-avatar-char {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.rank-name {
  flex: 1;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.me-tag {
  font-size: 20rpx;
  color: #0A84FF;
  margin-left: 8rpx;
  vertical-align: middle;
}

.rank-score {
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 16rpx;
}

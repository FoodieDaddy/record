<scroll-view class="page-container {{!animationEnabled ? 'reduce-motion' : ''}}" scroll-y enhanced show-scrollbar="{{false}}">

  <!-- 加载态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-dots">
      <view class="loading-dot dot-1"></view>
      <view class="loading-dot dot-2"></view>
      <view class="loading-dot dot-3"></view>
    </view>
    <text class="loading-label">正在生成档案...</text>
    <text class="loading-hint">正在解析任务数据</text>
  </view>

  <block wx:else>
    <!-- MATCH DOSSIER 标题 -->
    <view class="dossier-header">
      <text class="dossier-kicker">DOSSIER</text>
      <text class="dossier-title">任务档案</text>
      <view class="dossier-meta" wx:if="{{roomNo}}">
        <text class="dossier-room">ROOM {{roomNo}}</text>
        <text class="dossier-time" wx:if="{{settleTime}}">{{settleTime}}</text>
      </view>
    </view>

    <!-- 1. 最终排名 -->
    <view class="section-card" wx:if="{{rankedMembers.length > 0}}">
      <view class="card-header">
        <view class="card-title">实时序列</view>
        <view class="card-kicker">SEQUENCE</view>
        <view class="card-line"></view>
      </view>
      <view class="rank-list">
        <view class="rank-item {{index === 0 ? 'rank-champion' : ''}}"
          wx:for="{{rankedMembers}}" wx:key="userId">
          <view class="rank-badge {{index < 3 ? 'rank-top3' : ''}} {{index === 0 ? 'badge-champion' : ''}}">
            <text class="rank-num">{{index + 1}}</text>
          </view>
          <view class="rank-avatar" style="background: {{item.avatarColor}}">
            <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="rank-avatar-img" mode="aspectFill" />
            <text wx:else class="rank-avatar-char">{{item.avatarChar}}</text>
          </view>
          <text class="rank-name" style="color: {{item.userId == myUserId ? '#00AFFF' : 'rgba(255,255,255,0.85)'}}">
            {{item.nickname}}
            <text wx:if="{{item.userId == myUserId}}" class="me-tag">我</text>
          </text>
          <text class="rank-score"
            style="color: {{item.finalScore > 0 ? '#32D74B' : item.finalScore < 0 ? '#FF453A' : 'rgba(255,255,255,0.35)'}}">
            {{item.finalScore > 0 ? '+' : ''}}{{item.finalScore}}
          </text>
        </view>
      </view>
    </view>

    <!-- 2. 任务复盘 -->
    <battle-summary
      winner="{{winner}}"
      loser="{{loser}}"
      maxSingle="{{maxSingle}}"
      totalTransfer="{{totalTransfer}}"
      transferCount="{{transferCount}}"
      memberCount="{{memberCount}}"
      roomNo="{{roomNo}}"
      settleTime="{{settleTime}}" />

    <!-- 3. 数值演化轨迹 -->
    <view class="section-card" wx:if="{{series.length > 0}}">
      <view class="card-header">
        <view class="card-title">数值演化轨迹</view>
        <view class="card-kicker">TIMELINE</view>
        <view class="card-line"></view>
      </view>
      <view class="chart-wrap">
        <score-chart
          timestamps="{{timestamps}}"
          series="{{series}}"
          visibleUsers="{{visibleUsers}}"
          eventMarkers="{{eventMarkers}}"
          highlightUser="{{myUserId}}" />
      </view>
    </view>

    <!-- 4. 数值关系网络 -->
    <score-network
      wx:if="{{networkNodes.length > 0}}"
      nodes="{{networkNodes}}"
      links="{{networkLinks}}"
      my-user-id="{{myUserId}}" />

    <!-- 5. 本轮行为信号 -->
    <persona-signal
      wx:if="{{behaviorSignals}}"
      activity="{{behaviorSignals.activity}}"
      volatility="{{behaviorSignals.volatility}}"
      concentration="{{behaviorSignals.concentration}}"
      density="{{behaviorSignals.density}}"
      low-sample="{{lowSample}}" />

    <view style="height: 60rpx;"></view>
  </block>
</scroll-view>

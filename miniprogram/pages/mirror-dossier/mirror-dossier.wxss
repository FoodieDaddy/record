/* ===== Persona Dossier — 人格档案页 ===== */

.dossier-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 16rpx 28rpx calc(env(safe-area-inset-bottom) + 40rpx);
  background: #05070A;
  color: rgba(255, 255, 255, 0.92);
}

/* ---- 页面标题 ---- */
.dossier-header {
  padding: 12rpx 0 28rpx;
}

.dossier-kicker {
  display: block;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(0, 175, 255, 0.50);
}

.dossier-title {
  display: block;
  margin-top: 4rpx;
  font-size: 36rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 2rpx;
}

.dossier-date {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.25);
}

/* ---- 分段 ---- */
.dossier-section {
  border-radius: 18rpx;
  border: 1rpx solid rgba(0, 175, 255, 0.12);
  background: #0A0F18;
  padding: 24rpx 26rpx;
  margin-bottom: 16rpx;
}

.section-kicker {
  display: block;
  margin-top: 4rpx;
  font-size: 17rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.34);
  text-transform: uppercase;
}

.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #00C8FF;
  letter-spacing: 2rpx;
  margin-bottom: 14rpx;
}

.section-body {
  padding: 4rpx 0;
}

/* ---- KV 行 ---- */
.kv-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.kv-row:last-child {
  border-bottom: none;
}

.kv-key {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.38);
}

.kv-val {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.80);
}

.kv-val-lg {
  font-size: 28rpx;
  color: #00AFFF;
  font-family: 'SF Mono', 'Courier New', monospace;
  letter-spacing: 2rpx;
}

.summary-text {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.5;
}

/* ---- 可信度 ---- */
.confidence-display {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 12rpx;
}

.conf-num {
  font-size: 52rpx;
  font-weight: 800;
  color: #00AFFF;
  font-family: 'SF Mono', 'Courier New', monospace;
}

.conf-pct {
  font-size: 24rpx;
  color: rgba(0, 175, 255, 0.60);
}

.conf-bar-track {
  height: 6rpx;
  border-radius: 3rpx;
  background: rgba(255, 255, 255, 0.06);
  overflow: hidden;
}

.conf-bar-fill {
  height: 100%;
  border-radius: 3rpx;
  background: linear-gradient(90deg, rgba(0, 175, 255, 0.50), rgba(0, 175, 255, 0.85));
}

/* ---- 偏差 ---- */
.dev-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.dev-label-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
}

.dev-type-text {
  font-size: 32rpx;
  font-weight: 800;
  font-family: 'SF Mono', 'Courier New', monospace;
  letter-spacing: 4rpx;
}

.dev-blue {
  color: #00AFFF;
}

.dev-orange {
  color: #FFAA33;
}

.dev-arrow-line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.dev-arrow-dash {
  width: 40rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(0, 175, 255, 0.30), rgba(255, 170, 51, 0.30));
}

.dev-pct {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(255, 170, 51, 0.80);
}

/* ---- 判读 ---- */
.reading-item {
  padding: 12rpx 16rpx;
  border-left: 3rpx solid rgba(0, 175, 255, 0.25);
  background: rgba(0, 175, 255, 0.02);
  margin-bottom: 10rpx;
  border-radius: 4rpx;
}

.reading-item:last-child {
  margin-bottom: 0;
}

.reading-label {
  display: block;
  font-size: 18rpx;
  color: rgba(0, 175, 255, 0.50);
  letter-spacing: 2rpx;
  margin-bottom: 4rpx;
}

.reading-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.72);
  line-height: 1.6;
}

/* ---- 信号标签 ---- */
.signal-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.signal-tag-item {
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(0, 175, 255, 0.15);
  background: rgba(0, 175, 255, 0.04);
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: rgba(0, 175, 255, 0.75);
}

/* ---- 操作按钮区 ---- */
.dossier-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.action-btn-primary {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.36);
  background: rgba(10, 132, 255, 0.08);
  box-shadow: 0 0 28rpx rgba(10, 132, 255, 0.12);
}

.action-btn-primary:active {
  background: rgba(10, 132, 255, 0.16);
}

.action-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: #0A84FF;
}

.action-btn-secondary {
  width: 220rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.025);
}

.action-btn-secondary:active {
  background: rgba(255, 255, 255, 0.06);
}

.action-btn-sec-text {
  font-size: 26rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.62);
}

/* ---- 隐藏 Canvas ---- */
.persona-card-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 750rpx;
  height: 1000rpx;
}

/* ---- 底部面板 ---- */
.card-panel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.72);
}

.card-panel {
  width: 100%;
  padding: 24rpx 32rpx calc(env(safe-area-inset-bottom) + 48rpx);
  border-radius: 36rpx 36rpx 0 0;
  border-top: 1rpx solid rgba(10, 132, 255, 0.24);
  background:
    radial-gradient(circle at 20% 0%, rgba(10, 132, 255, 0.12), transparent 38%),
    rgba(6, 10, 16, 0.96);
  box-shadow: 0 -24rpx 80rpx rgba(0, 0, 0, 0.58);
  box-sizing: border-box;
}

.panel-handle {
  width: 72rpx;
  height: 6rpx;
  margin: 0 auto 30rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
}

.panel-head {
  margin-bottom: 18rpx;
}

.panel-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 3rpx;
}

.panel-kicker {
  display: block;
  margin-top: 8rpx;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(10, 132, 255, 0.58);
}

.panel-desc {
  display: block;
  font-size: 25rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.52);
  margin-bottom: 30rpx;
}

.panel-actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.panel-action-btn {
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.035);
}

.panel-action-btn:active {
  background: rgba(255, 255, 255, 0.08);
}

.panel-action-primary {
  border-color: rgba(10, 132, 255, 0.36);
  background: rgba(10, 132, 255, 0.08);
}

.panel-action-primary:active {
  background: rgba(10, 132, 255, 0.16);
}

.panel-action-ghost {
  background: transparent;
  border-color: rgba(255, 255, 255, 0.06);
}

.panel-action-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.72);
}

.panel-action-primary .panel-action-text {
  color: #0A84FF;
}

.panel-action-ghost .panel-action-text {
  color: rgba(255, 255, 255, 0.42);
}

/* ---- 预览弹窗 ---- */
.card-preview-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(0, 0, 0, 0.82);
  box-sizing: border-box;
}

.card-preview-panel {
  width: 100%;
  max-height: 92vh;
  padding: 28rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.24);
  background: rgba(6, 10, 16, 0.96);
  box-sizing: border-box;
}

.preview-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.preview-title {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
}

.preview-close-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.close-line {
  position: absolute;
  width: 24rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.42);
  border-radius: 1rpx;
}

.close-line-tl {
  transform: rotate(45deg);
}

.close-line-tr {
  transform: rotate(-45deg);
}

.preview-img {
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: #0A0A0A;
}

.preview-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.preview-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.035);
  padding: 0;
  margin: 0;
  line-height: 80rpx;
  box-sizing: border-box;
}

.preview-btn::after {
  border: none;
}

.preview-btn:active {
  background: rgba(255, 255, 255, 0.08);
}

.preview-btn-primary {
  border-color: rgba(10, 132, 255, 0.36);
  background: rgba(10, 132, 255, 0.08);
}

.preview-btn-primary:active {
  background: rgba(10, 132, 255, 0.16);
}

.preview-btn-share {
  color: rgba(255, 255, 255, 0.72);
}

.preview-btn-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.72);
}

.preview-btn-primary .preview-btn-text {
  color: #0A84FF;
}

.preview-copy-btn {
  margin-top: 18rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: transparent;
}

.preview-copy-btn:active {
  background: rgba(255, 255, 255, 0.04);
}

.preview-copy-text {
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.46);
}

/* ---- Skeleton ---- */
.skeleton-card {
  height: 200rpx;
  border-radius: 18rpx;
  background: rgba(0, 175, 255, 0.03);
  border: 1rpx solid rgba(0, 175, 255, 0.06);
  margin-bottom: 16rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-card.short {
  height: 120rpx;
}

@keyframes shimmer {
  0% { opacity: 0.4; }
  50% { opacity: 0.7; }
  100% { opacity: 0.4; }
}

/* ---- Reduce Motion ---- */
.reduce-motion .skeleton-card {
  animation: none !important;
}

.reduce-motion {
  animation: none !important;
  transition: none !important;
}

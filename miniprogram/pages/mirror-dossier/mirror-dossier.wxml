<view class="dossier-page {{reduceMotion ? 'reduce-motion' : ''}}">

  <!-- Loading -->
  <block wx:if="{{loading}}">
    <view class="skeleton-card"></view>
    <view class="skeleton-card short"></view>
  </block>

  <block wx:else>

    <!-- 页面标题 -->
    <view class="dossier-header">
      <text class="dossier-kicker">DOSSIER</text>
      <text class="dossier-title">人格档案</text>
      <text class="dossier-date">GENERATED {{generatedAt}}</text>
    </view>

    <!-- 人格协议 -->
    <view class="dossier-section" wx:if="{{mbti.mbtiType}}">
      <text class="section-title">人格协议</text>
      <text class="section-kicker">PROTOCOL</text>
      <view class="section-body">
        <view class="kv-row">
          <text class="kv-key">类型</text>
          <text class="kv-val kv-val-lg">{{mbti.mbtiType}} {{mbti.mbtiTitle}}</text>
        </view>
        <view class="kv-row">
          <text class="kv-key">置信度</text>
          <text class="kv-val">{{mbti.confidence}}%</text>
        </view>
        <view class="kv-row">
          <text class="kv-key">来源</text>
          <text class="kv-val">{{mbti.mbtiSource === 'test' ? '20题校准' : '直接输入'}}</text>
        </view>
      </view>
    </view>

    <!-- 可信度 -->
    <view class="dossier-section">
      <text class="section-title">人格可信度</text>
      <text class="section-kicker">CONFIDENCE</text>
      <view class="section-body">
        <view class="confidence-display">
          <text class="conf-num">{{personaConfidence}}</text>
          <text class="conf-pct">%</text>
        </view>
        <view class="conf-bar-track">
          <view class="conf-bar-fill" style="width: {{personaConfidence}}%;"></view>
        </view>
      </view>
    </view>

    <!-- 任务画像 -->
    <view class="dossier-section" wx:if="{{battlePersona.generated}}">
      <text class="section-title">任务画像</text>
      <text class="section-kicker">MIRROR</text>
      <view class="section-body">
        <view class="kv-row">
          <text class="kv-key">画像类型</text>
          <text class="kv-val">{{battlePersona.title}}</text>
        </view>
        <view class="kv-row">
          <text class="kv-key">样本量</text>
          <text class="kv-val">{{battlePersona.sampleSize}} 场</text>
        </view>
        <text class="summary-text" wx:if="{{battlePersona.summary}}">{{battlePersona.summary}}</text>
      </view>
    </view>

    <!-- 人格偏差 -->
    <view class="dossier-section" wx:if="{{personaMatch.available}}">
      <text class="section-title">人格偏差</text>
      <text class="section-kicker">DEVIATION</text>
      <view class="section-body">
        <view class="dev-row">
          <text class="dev-label-text">校准人格</text>
          <text class="dev-type-text dev-blue">{{mbti.mbtiType}}</text>
        </view>
        <view class="dev-arrow-line">
          <view class="dev-arrow-dash"></view>
          <text class="dev-pct">{{personaMatch.deviationPercent}}%</text>
        </view>
        <view class="dev-row">
          <text class="dev-label-text">行为人格</text>
          <text class="dev-type-text dev-orange">{{personaMatch.inferredMbtiType}}</text>
        </view>
        <text class="summary-text" wx:if="{{personaMatch.summary}}">{{personaMatch.summary}}</text>
      </view>
    </view>

    <!-- 系统判读 -->
    <view class="dossier-section" wx:if="{{reading.available}}">
      <text class="section-title">系统判读</text>
      <text class="section-kicker">READING</text>
      <view class="section-body">
        <view class="reading-item" wx:if="{{reading.observation}}">
          <text class="reading-label">观测</text>
          <text class="reading-text">{{reading.observation}}</text>
        </view>
        <view class="reading-item" wx:if="{{reading.deviation}}">
          <text class="reading-label">偏差</text>
          <text class="reading-text">{{reading.deviation}}</text>
        </view>
        <view class="reading-item" wx:if="{{reading.risk}}">
          <text class="reading-label">风险</text>
          <text class="reading-text">{{reading.risk}}</text>
        </view>
        <view class="reading-item" wx:if="{{reading.growthAdvice}}">
          <text class="reading-label">建议</text>
          <text class="reading-text">{{reading.growthAdvice}}</text>
        </view>
        <view class="reading-item" wx:if="{{!reading.observation && reading.text}}">
          <text class="reading-label">判断</text>
          <text class="reading-text">{{reading.text}}</text>
        </view>
      </view>
    </view>

    <!-- 人格信号 -->
    <view class="dossier-section" wx:if="{{personaSignals.length > 0}}">
      <text class="section-title">人格信号</text>
      <text class="section-kicker">SIGNAL</text>
      <view class="section-body">
        <view class="signal-tags">
          <text class="signal-tag-item" wx:for="{{personaSignals}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="dossier-actions">
      <view class="action-btn-primary flight-primary" bindtap="openCardPanel">
        <text class="action-btn-text">生成档案卡</text>
      </view>
      <view class="action-btn-secondary flight-secondary" bindtap="copyDossier">
        <text class="action-btn-sec-text">复制文字</text>
      </view>
    </view>

  </block>

  <!-- 隐藏 Canvas -->
  <canvas
    type="2d"
    id="personaCardCanvas"
    class="persona-card-canvas"
  ></canvas>

  <!-- 底部操作面板 -->
  <view
    wx:if="{{showCardPanel}}"
    class="card-panel-mask"
    catchtouchmove="noop"
    bindtap="closeCardPanel"
  >
    <view class="card-panel" catchtap="noop">
      <view class="panel-handle"></view>
      <view class="panel-head">
        <text class="panel-title">档案输出舱</text>
        <text class="panel-kicker">OUTPUT BAY</text>
      </view>
      <text class="panel-desc">将当前人格档案生成图片卡片，便于保存或分享。</text>
      <view class="panel-actions">
        <view class="panel-action-btn panel-action-primary" bindtap="generateCard">
          <text class="panel-action-text">生成预览</text>
        </view>
        <view class="panel-action-btn" bindtap="copyDossier">
          <text class="panel-action-text">复制文字</text>
        </view>
        <view class="panel-action-btn panel-action-ghost" bindtap="closeCardPanel">
          <text class="panel-action-text">取消</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 预览弹窗 -->
  <view
    wx:if="{{showCardPreview}}"
    class="card-preview-mask"
    catchtouchmove="noop"
  >
    <view class="card-preview-panel">
      <view class="preview-head">
        <text class="preview-title">档案卡预览</text>
        <view class="preview-close-icon" bindtap="closeCardPreview">
          <view class="close-line close-line-tl"></view>
          <view class="close-line close-line-tr"></view>
        </view>
      </view>
      <image
        class="preview-img"
        src="{{cardTempPath}}"
        mode="widthFix"
      />
      <view class="preview-actions">
        <view class="preview-btn preview-btn-primary" bindtap="saveCard">
          <text class="preview-btn-text">保存到相册</text>
        </view>
        <button class="preview-btn preview-btn-share" open-type="share">
          <text class="preview-btn-text">分享给朋友</text>
        </button>
      </view>
      <view class="preview-copy-btn" bindtap="copyDossier">
        <text class="preview-copy-text">复制文字</text>
      </view>
    </view>
  </view>

</view>

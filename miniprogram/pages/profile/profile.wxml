<view class="terminal-page {{!animationEnabled ? 'reduce-motion' : ''}}">
  <!-- 未登录 -->
  <view wx:if="{{!isLoggedIn}}" class="empty-state">
    <view class="empty-state__icon">
      <view class="svg-icon svg-icon--lock"></view>
    </view>
    <text class="empty-state__title">尚未登录</text>
    <text class="empty-state__desc">登录后即可管理个人信息</text>
    <button class="btn-primary" style="width:320rpx;" bindtap="goLogin">去登录</button>
  </view>

  <!-- 已登录 -->
  <view wx:else>
    <!-- 背景光晕 -->
    <view class="terminal__glow" aria-hidden="true"></view>

    <!-- 1. PLAYER IDENTITY -->
    <view class="term-card term-card--identity">
      <text class="term-kicker">PLAYER IDENTITY</text>
      <view class="identity__row">
        <button class="identity__avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <view class="identity__avatar-ring">
            <view class="identity__avatar-auto" style="background:{{avatarColor}};" wx:if="{{!avatarUrl}}">
              <text class="identity__avatar-char">{{avatarChar}}</text>
            </view>
            <image class="identity__avatar-img" src="{{avatarUrl}}" wx:else></image>
          </view>
        </button>
        <view class="identity__info">
          <view class="identity__name-row">
            <input
              class="identity__name-input"
              type="nickname"
              value="{{nickname}}"
              placeholder="点击授权昵称"
              maxlength="6"
              bindinput="onNicknameInput"
              bindblur="onNicknameBlur"
            />
            <view class="identity__dice-btn" bindtap="shuffleNickname">
              <view class="svg-icon svg-icon--dice"></view>
            </view>
          </view>
          <text class="identity__tag">{{playerTag}}</text>
        </view>
      </view>
      <view class="identity__meta">
        <text class="identity__meta-item">Joined {{daysSinceJoined}} Days</text>
      </view>
      <text class="identity__saving" wx:if="{{saving}}">保存中...</text>
    </view>

    <!-- 2. SCORE OVERVIEW -->
    <view class="term-card term-card--stats">
      <text class="term-kicker">SCORE OVERVIEW</text>
      <view class="stats-row">
        <view class="stats-col">
          <text class="stats-col__value">{{totalScore}}</text>
          <text class="stats-col__label">TOTAL SCORE</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-col">
          <text class="stats-col__value">{{winRate}}%</text>
          <text class="stats-col__label">WIN RATE</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-col">
          <text class="stats-col__value">{{matchCount}}</text>
          <text class="stats-col__label">MATCHES</text>
        </view>
      </view>
    </view>

    <!-- 3. PERSONA MODULE -->
    <view class="term-card term-card--persona" wx:if="{{mbtiCalibrated}}">
      <text class="term-kicker">PERSONA MODULE</text>
      <view class="persona__main">
        <view class="persona__left">
          <text class="persona__type">{{mbtiType}}</text>
          <text class="persona__title">{{mbtiTitle}}</text>
        </view>
        <view class="persona__sync-badge">SYNCED</view>
      </view>
      <view class="persona__traits">
        <text class="persona__trait" wx:for="{{traits}}" wx:key="*this">[{{item}}]</text>
      </view>
    </view>

    <!-- 未校准时的提示 -->
    <view class="term-card term-card--persona term-card--dim" wx:if="{{!mbtiCalibrated}}">
      <text class="term-kicker">PERSONA MODULE</text>
      <text class="term-empty-text">完成 MBTI 校准后解锁人格模块</text>
    </view>

    <!-- 4. BATTLE PROFILE -->
    <view class="term-card term-card--battle" wx:if="{{battleDimensions.length > 0}}">
      <text class="term-kicker">BATTLE PROFILE</text>
      <view class="hud-bar" wx:for="{{battleDimensions}}" wx:key="key">
        <text class="hud-bar__label">{{item.label}}</text>
        <view class="hud-bar__track">
          <view class="hud-bar__fill" style="width:{{item.value}}%;"></view>
        </view>
        <text class="hud-bar__value">{{item.value}}%</text>
      </view>
    </view>

    <!-- 5. ACHIEVEMENTS -->
    <view class="term-card term-card--achievements">
      <text class="term-kicker">ACHIEVEMENTS</text>
      <view class="achievements-row">
        <view class="achievement-badge {{item.unlocked ? 'achievement-badge--on' : ''}}" wx:for="{{achievements}}" wx:key="key">
          <view class="achievement-badge__icon">
            <text wx:if="{{item.unlocked}}">&#x25C9;</text>
            <text wx:else>&#x25CB;</text>
          </view>
          <text class="achievement-badge__label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- 6. DATA CENTER -->
    <view class="term-card term-card--nav">
      <text class="term-kicker">DATA CENTER</text>
      <view class="nav-link" bindtap="goScoreRecords">
        <text class="nav-link__label">积分记录</text>
        <view class="svg-icon svg-icon--arrow"></view>
      </view>
      <view class="nav-link" bindtap="goScoreRecords">
        <text class="nav-link__label">房间历史</text>
        <view class="svg-icon svg-icon--arrow"></view>
      </view>
      <view class="nav-link" bindtap="goBattleFile">
        <text class="nav-link__label">战绩档案</text>
        <view class="svg-icon svg-icon--arrow"></view>
      </view>
      <view class="nav-link nav-link--last" bindtap="goExportData">
        <text class="nav-link__label">导出数据</text>
        <view class="svg-icon svg-icon--arrow"></view>
      </view>
    </view>

    <!-- 7. SYSTEM SETTINGS -->
    <view class="term-card term-card--settings-link" bindtap="goSettings">
      <text class="term-kicker">SYSTEM SETTINGS</text>
      <view class="nav-link nav-link--last">
        <text class="nav-link__label">设置中心</text>
        <view class="svg-icon svg-icon--arrow"></view>
      </view>
    </view>

    <!-- 8. 退出登录 -->
    <view class="logout-btn" bindtap="onLogout">
      <text class="logout-btn__text">退出登录</text>
    </view>
  </view>
</view>

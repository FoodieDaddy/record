<view class="profile-page">
  <!-- 未登录 -->
  <view wx:if="{{!isLoggedIn}}" class="empty-auth">
    <view class="empty-auth-icon">🔐</view>
    <text class="text-lg text-bold" style="margin-bottom:12rpx;">尚未登录</text>
    <text class="text-secondary" style="margin-bottom:40rpx;">登录后即可管理个人信息</text>
    <button class="btn-primary" style="width:320rpx;" bindtap="goLogin">去登录</button>
  </view>

  <!-- 已登录 -->
  <view wx:else>
    <!-- 头像 + 昵称卡片 -->
    <view class="glass-card-glow user-card">
      <button class="avatar-ring-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <view class="auto-avatar-lg" style="background:{{avatarColor}};" wx:if="{{!avatarUrl}}">
          <text class="auto-avatar-char-lg">{{avatarChar}}</text>
        </view>
        <image class="avatar-lg" src="{{avatarUrl}}" wx:else></image>
      </button>
      <view class="nickname-row">
        <input class="nickname-input" type="nickname" value="{{nickname}}" bindinput="onNicknameInput" placeholder="输入昵称" maxlength="20" />
        <view class="btn-shuffle" bindtap="shuffleNickname">
          <text class="shuffle-icon">🎲</text>
        </view>
      </view>
      <text class="hint-text">点击头像或昵称可修改</text>
      <button class="btn-primary save-btn" bindtap="saveProfile" loading="{{saving}}" disabled="{{saving}}">保存</button>
    </view>

    <!-- 积分记录 -->
    <view class="glass-card menu-section">
      <view class="menu-item" bindtap="goScoreRecords">
        <view class="menu-item-left">
          <text class="menu-icon">📊</text>
          <text class="menu-label">积分记录</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goHistoryRooms">
        <view class="menu-item-left">
          <text class="menu-icon">🏠</text>
          <text class="menu-label">历史房间</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 设置 -->
    <view class="glass-card settings-section">
      <text class="section-title">设置</text>
      <view class="setting-row">
        <view class="setting-info">
          <text class="setting-label">计分语音播报</text>
          <text class="text-tertiary text-xs">计分后自动语音通知</text>
        </view>
        <switch class="setting-switch" checked="{{voiceEnabled}}" bindchange="onVoiceToggle" color="#4f8cff" />
      </view>
      <!-- 播报音色入口 -->
      <view class="setting-row" wx:if="{{voiceEnabled}}" bindtap="openVoiceSheet">
        <view class="setting-info">
          <text class="setting-label">播报音色</text>
        </view>
        <view class="setting-value-row">
          <text class="setting-value">{{voiceName}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>
      <view class="setting-row">
        <view class="setting-info">
          <text class="setting-label">计分动画</text>
          <text class="text-tertiary text-xs">计分时显示积分飞行动画</text>
        </view>
        <switch class="setting-switch" checked="{{animationEnabled}}" bindchange="onAnimationToggle" color="#4f8cff" />
      </view>
    </view>

    <!-- 音色选择抽屉 -->
    <view class="voice-sheet-mask {{voiceSheetVisible ? 'show' : ''}}" bindtap="closeVoiceSheet"></view>
    <view class="voice-sheet {{voiceSheetVisible ? 'show' : ''}}">
      <view class="voice-sheet-handle"></view>
      <view class="voice-sheet-title">选择音色</view>
      <view class="voice-sheet-body">
        <!-- 左侧分类 -->
        <scroll-view class="voice-cat-list" scroll-y enhanced show-scrollbar="{{false}}">
          <view
            class="voice-cat-item {{activeCatIndex === index ? 'active' : ''}}"
            wx:for="{{voiceCategories}}"
            wx:key="id"
            data-index="{{index}}"
            bindtap="onCatTap"
          >{{item.name}}</view>
        </scroll-view>
        <!-- 右侧音色列表 -->
        <scroll-view
          class="voice-list"
          scroll-y
          enhanced
          show-scrollbar="{{false}}"
          scroll-into-view="{{scrollToCat}}"
          scroll-with-animation
        >
          <block wx:for="{{voiceCategories}}" wx:key="id" wx:for-item="cat" wx:for-index="catIdx">
            <view class="voice-group-header" id="cat-{{cat.id}}">{{cat.name}}</view>
            <view
              class="voice-item {{item.id === selectedVoiceId ? 'active' : ''}} {{playingVoiceId === item.id ? 'playing' : ''}}"
              wx:for="{{cat.voices}}"
              wx:key="id"
              data-voice="{{item}}"
              data-cat-index="{{catIdx}}"
              bindtap="onVoiceTap"
            >
              <view class="voice-item-info">
                <text class="voice-item-name">{{item.name}}</text>
                <text class="voice-item-desc">{{item.desc}}</text>
              </view>
              <view class="voice-item-right">
                <view class="voice-wave" wx:if="{{playingVoiceId === item.id}}">
                  <view class="wave-bar"></view>
                  <view class="wave-bar"></view>
                  <view class="wave-bar"></view>
                </view>
                <text class="voice-check" wx:elif="{{item.id === selectedVoiceId}}">✓</text>
              </view>
            </view>
          </block>
        </scroll-view>
      </view>
    </view>

    <!-- 退出登录 -->
    <button class="btn-logout" bindtap="onLogout">退出登录</button>
  </view>
</view>

<view class="terminal-page {{!animationEnabled ? 'reduce-motion' : ''}} {{voiceSheetVisible || nicknameDrawerVisible ? 'terminal-page--overlay-open' : ''}}">
  <!-- 未登录 -->
  <view wx:if="{{!isLoggedIn}}" class="empty-state">
    <view class="empty-state__icon">
      <view class="svg-icon svg-icon--lock"></view>
    </view>
    <text class="empty-state__title">终端未接入</text>
    <text class="empty-state__desc">接入终端后可管理本舰档案</text>
    <view class="btn-clip" style="width:320rpx;" bindtap="goLogin">
      <text>接入终端</text>
    </view>
  </view>

  <!-- 已登录 -->
  <view wx:else>
    <view class="terminal__glow" aria-hidden="true"></view>

    <!-- HUD 状态条 -->
    <view class="sync-hud {{hudVisible ? 'sync-hud--show' : ''}} {{hudType === 'error' ? 'sync-hud--error' : hudType === 'warning' ? 'sync-hud--warning' : ''}}" bindtap="onHudTap">
      <view class="sync-hud__dot"></view>
      <text class="sync-hud__text">{{hudText}}</text>
    </view>

    <!-- 左上角舱位状态 Tab -->
    <view class="bay-status-tab bay-status-tab--{{identityBayState}}">
      <view class="bay-status-tab__dot"></view>
      <text class="bay-status-tab__label">{{identityBayLabel}}</text>
    </view>

    <!-- 1. 本舰档案 -->
    <view class="profile-hud">
      <view class="profile-hud__kicker">
        <text class="profile-hud__kicker-zh">本舰档案</text>
        <text class="profile-hud__kicker-en">SHIP PROFILE</text>
      </view>

      <!-- 铭牌主体：识别徽标 + 呼号 + 等级 + 最强成就 -->
      <view class="profile-hud__body">
        <view class="profile-hud__left">
          <button class="profile-hud__avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <helmet-avatar
              src="{{avatarUrl || ''}}"
              nickname="{{nickname}}"
              size="lg"
              active="{{true}}"
              controller="{{true}}"
              showStatus="{{true}}"
              reduceMotion="{{!animationEnabled}}"
            />
          </button>
        </view>
        <view class="profile-hud__right">
          <text class="profile-hud__code">{{playerCode}}</text>
          <view class="profile-hud__name-wrap">
            <text class="profile-hud__name {{isLongCrewName ? 'profile-hud__name--long' : ''}}">{{nickname || '未命名航船'}}</text>
          </view>
          <view class="profile-hud__level-row">
            <text class="profile-hud__level">Lv.{{level}}</text>
            <text class="profile-hud__level-title">{{levelTitle}}</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="profile-hud__actions">
        <view class="btn-clip btn-clip--sm" bindtap="openNicknameDrawer">
          <text>校准呼号</text>
        </view>
        <view class="profile-hud__link" bindtap="goLevelArchive">
          <text class="profile-hud__link-text">授权档案</text>
          <view class="svg-icon svg-icon--arrow"></view>
        </view>
      </view>
    </view>

    <!-- 2. 授权状态 -->
    <view class="term-card term-card--ship-status">
      <text class="term-kicker">授权状态</text>
      <text class="term-kicker-sub">IDENTITY STATUS</text>
      <view class="ship-status__row">
        <view class="ship-status__item">
          <text class="ship-status__label">航行经验</text>
          <text class="ship-status__value ship-status__value--blue">{{levelExp}}</text>
          <view class="ship-status__bar">
            <view class="ship-status__bar-fill bar-blue" style="width:{{levelProgress}}%;"></view>
          </view>
        </view>
        <view class="ship-status__sep"></view>
        <view class="ship-status__item">
          <text class="ship-status__label">稳定读数</text>
          <text class="ship-status__value ship-status__value--purple">{{stability !== null ? stability : '--'}}</text>
          <view class="ship-status__bar">
            <view class="ship-status__bar-fill bar-purple" style="width:{{stability !== null ? stability : 2}}%;"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 3. 装备协议 -->
    <view class="term-card term-card--equip">
      <text class="term-kicker">装备协议</text>
      <text class="term-kicker-sub">EQUIPMENT</text>

      <!-- 通讯协议 -->
      <view class="equip-slot">
        <view class="equip-slot__info">
          <text class="equip-slot__name">通讯协议</text>
          <text class="equip-slot__value">{{voiceEnabled ? '声波链路 ON' : '声波链路 OFF'}}</text>
        </view>
        <view class="equip-slot__toggle {{voiceEnabled ? 'equip-slot__toggle--on' : ''}}" bindtap="onVoiceSwitch">
          <text class="equip-slot__toggle-text">{{voiceEnabled ? 'ONLINE' : 'OFFLINE'}}</text>
        </view>
      </view>

      <!-- 通讯音色 -->
      <view class="equip-slot equip-slot--sub {{voiceEnabled ? '' : 'equip-slot--hidden'}}" bindtap="openVoiceSheet">
        <view class="equip-slot__info">
          <text class="equip-slot__name">通讯音色</text>
          <text class="equip-slot__value">{{voiceName}}</text>
        </view>
        <view class="svg-icon svg-icon--arrow"></view>
      </view>

      <!-- 视觉协议 -->
      <view class="equip-slot">
        <view class="equip-slot__info">
          <text class="equip-slot__name">视觉协议</text>
          <text class="equip-slot__value">{{animEnabled ? '动态扫描 ON' : '动态扫描 OFF'}}</text>
        </view>
        <view class="equip-slot__toggle {{animEnabled ? 'equip-slot__toggle--on' : ''}}" bindtap="onAnimSwitch">
          <text class="equip-slot__toggle-text">{{animEnabled ? 'ONLINE' : 'OFFLINE'}}</text>
        </view>
      </view>

      <!-- 触感协议 -->
      <view class="equip-slot">
        <view class="equip-slot__info">
          <text class="equip-slot__name">触感协议</text>
          <text class="equip-slot__value">{{vibrateEnabled ? '触感反馈 ON' : '触感反馈 OFF'}}</text>
        </view>
        <view class="equip-slot__toggle {{vibrateEnabled ? 'equip-slot__toggle--on' : ''}}" bindtap="onVibrateSwitch">
          <text class="equip-slot__toggle-text">{{vibrateEnabled ? 'ONLINE' : 'OFFLINE'}}</text>
        </view>
      </view>
    </view>

    <!-- 4. 终端控制 -->
    <view class="terminal-control">
      <text class="term-kicker">终端控制</text>
      <text class="term-kicker-sub">TERMINAL CONTROL</text>
      <view class="terminate-btn" bindtap="onLogout">
        <text class="terminate-btn__en">TERMINATE</text>
        <text class="terminate-btn__zh">断开终端</text>
      </view>
    </view>
    <view class="terminal-bottom-spacer"></view>
  </view>

  <!-- 本舰呼号校准悬浮终端 -->
  <view wx:if="{{nicknameDrawerVisible}}" class="callsign-overlay {{!animationEnabled ? 'reduce-motion' : ''}}" bindtap="closeNicknameDrawer">
    <view class="callsign-float {{callsignKeyboardHeight > 0 ? 'is-keyboard' : ''}}" catchtap="noop">
      <view class="callsign-status">
        <view class="callsign-status__dot"></view>
        <text class="callsign-status__text">呼号校准待写入</text>
      </view>

      <view class="callsign-field">
        <text class="callsign-field__label">当前呼号</text>
        <text class="callsign-field__value">{{nickname || '未命名航船'}}</text>
      </view>

      <view class="callsign-field">
        <text class="callsign-field__label">新呼号</text>
        <view class="callsign-input-row">
          <input
            class="callsign-input"
            type="nickname"
            value="{{drawerNickname}}"
            placeholder="输入本舰呼号"
            adjust-position="{{false}}"
            cursor-spacing="80"
            bindinput="onDrawerNicknameInput"
            bindblur="onDrawerNicknameInput"
            bindchange="onDrawerNicknameInput"
            bindkeyboardheightchange="onCallsignKeyboardHeightChange"
          />
          <view class="callsign-generate" bindtap="onRandomNickname">
            <text class="callsign-generate__text">生成呼号</text>
          </view>
        </view>
        <text class="callsign-hint {{drawerNicknameOverflow ? 'callsign-hint--warn' : ''}}">{{drawerNicknameOverflow ? '呼号过长，建议 6 个汉字以内' : '最多 6 个汉字'}}</text>
      </view>

      <view class="callsign-actions">
        <view class="callsign-btn callsign-btn--cancel" bindtap="closeNicknameDrawer">
          <text>取消</text>
        </view>
        <view class="callsign-btn callsign-btn--confirm" bindtap="confirmNicknameDrawer">
          <text>写入呼号</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 音色选择弹层 -->
  <view wx:if="{{voiceSheetVisible}}" class="voice-mask voice-mask--show" bindtap="closeVoiceSheet" catchtouchmove="noop"></view>
  <view wx:if="{{voiceSheetVisible}}" class="voice-sheet voice-sheet--show">
    <view class="voice-sheet__handle"></view>
    <view class="voice-sheet__close" bindtap="closeVoiceSheet">关闭</view>
    <view class="voice-sheet__header">
      <text class="voice-sheet__kicker">VOICE CHANNEL</text>
      <text class="voice-sheet__title">通讯频道校准</text>
    </view>
    <view class="voice-sheet__body">
      <!-- 左侧频道分类 -->
      <scroll-view class="voice-sheet__cat-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          class="voice-sheet__cat-item {{activeVoiceCatId === item.id ? 'voice-sheet__cat-item--active' : ''}}"
          wx:for="{{voiceCategories}}"
          wx:key="id"
          data-cat-id="{{item.id}}"
          bindtap="onCatTap"
        >
          <text class="voice-sheet__cat-en">{{item.enLabel}}</text>
          <text class="voice-sheet__cat-zh">{{item.zhLabel}}</text>
        </view>
      </scroll-view>
      <!-- 右侧音色槽位 -->
      <scroll-view
        class="voice-sheet__voice-list"
        scroll-y
        enhanced
        show-scrollbar="{{false}}"
        scroll-into-view="{{scrollToCat}}"
        scroll-with-animation
      >
        <block wx:for="{{voiceCategories}}" wx:key="id" wx:for-item="cat" wx:for-index="catIdx">
          <view class="voice-sheet__group-header" id="cat-{{cat.id}}">{{cat.enLabel}}</view>
          <view
            class="voice-sheet__voice-item {{item.id === selectedVoiceId ? 'voice-sheet__voice-item--active' : ''}} {{playingVoiceId === item.id ? 'voice-sheet__voice-item--playing' : ''}}"
            wx:for="{{cat.voices}}"
            wx:key="id"
            data-voice="{{item}}"
            data-cat-id="{{cat.id}}"
            bindtap="onVoiceTap"
          >
            <view class="voice-sheet__voice-status" wx:if="{{item.id === selectedVoiceId}}"></view>
            <view class="voice-sheet__voice-info">
              <text class="voice-sheet__voice-name">{{item.name}}</text>
              <text class="voice-sheet__voice-desc">{{item.desc}}</text>
            </view>
            <view class="voice-sheet__voice-right">
              <view class="voice-sheet__wave" wx:if="{{playingVoiceId === item.id}}">
                <view class="voice-sheet__wave-bar"></view>
                <view class="voice-sheet__wave-bar"></view>
                <view class="voice-sheet__wave-bar"></view>
              </view>
              <text class="voice-sheet__selected" wx:elif="{{item.id === selectedVoiceId}}">接入中</text>
            </view>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>

  <!-- 系统全局左上角提示 -->
  <sr-toast id="srToast" reduceMotion="{{!animationEnabled}}" />

</view>

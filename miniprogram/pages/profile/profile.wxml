<view class="terminal-page {{!animationEnabled ? 'reduce-motion' : ''}}">
  <!-- 未登录 -->
  <view wx:if="{{!isLoggedIn}}" class="empty-state">
    <view class="empty-state__icon">
      <view class="svg-icon svg-icon--lock"></view>
    </view>
    <text class="empty-state__title">尚未登录</text>
    <text class="empty-state__desc">登录后即可管理个人信息</text>
    <button class="btn-primary" style="width:320rpx;" bindtap="goLogin">去登录</button>
  </view>

  <!-- 已登录 -->
  <view wx:else>
    <view class="terminal__glow" aria-hidden="true"></view>

    <!-- 0. SYSTEM STATUS -->
    <view class="status-bar">
      <view class="status-bar__dot {{isLoggedIn ? 'status-bar__dot--online' : ''}}"></view>
      <text class="status-bar__label">系统状态</text>
      <text class="status-bar__value">{{isLoggedIn ? '在线' : '离线'}}</text>
    </view>

    <!-- 1. PLAYER PROFILE -->
    <view class="term-card term-card--identity">
      <text class="term-kicker">身份档案</text>
      <text class="term-kicker-sub">PROFILE</text>
      <view class="identity__row">
        <button class="identity__avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <helmet-avatar
            src="{{avatarUrl}}"
            size="lg"
            active="{{true}}"
            controller="{{true}}"
            showStatus="{{false}}"
            reduceMotion="{{!animationEnabled}}"
          />
        </button>
        <view class="identity__info">
          <text class="identity__kicker">成员代号</text>
          <view class="identity__name-row">
            <input
              class="identity__name-input"
              type="nickname"
              value="{{nickname}}"
              placeholder="点击授权代号"
              maxlength="6"
              bindinput="onNicknameInput"
              bindblur="onNicknameBlur"
            />
            <view class="identity__dice-btn" bindtap="shuffleNickname">
              <view class="svg-icon svg-icon--dice"></view>
            </view>
          </view>
          <view class="identity__tag-row">
            <text class="identity__player-code">{{playerCode}}</text>
            <text class="identity__tag-sep">·</text>
            <text class="identity__level-tag">Lv.{{level}}</text>
            <text class="identity__tag-sep">·</text>
            <text class="identity__status-tag">{{levelTitle}}</text>
          </view>
        </view>
      </view>
      <view class="identity__meta">
        <view class="identity__meta-col">
          <text class="identity__meta-label">加入时间</text>
          <text class="identity__meta-value">{{daysSinceJoined}} Days</text>
        </view>
        <view class="identity__meta-col">
          <text class="identity__meta-label">累计任务</text>
          <text class="identity__meta-value">{{matchCount}} Missions</text>
        </view>
        <view class="identity__meta-col">
          <text class="identity__meta-label">档案状态</text>
          <text class="identity__meta-value identity__meta-value--active">已同步</text>
        </view>
      </view>
      <text class="identity__saving" wx:if="{{saving}}">保存中...</text>
    </view>

    <!-- 2. DATA MATRIX -->
    <view class="term-card term-card--stats">
      <text class="term-kicker">数据矩阵</text>
      <text class="term-kicker-sub">MATRIX</text>
      <view class="stats-grid">
        <view class="stats-cell">
          <text class="stats-cell__label">净数值</text>
          <text class="stats-cell__value {{totalScore > 0 ? 'stats-cell__value--positive' : totalScore < 0 ? 'stats-cell__value--negative' : ''}}">{{totalScore}}</text>
          <text class="stats-cell__sub">累计数值</text>
        </view>
        <view class="stats-cell">
          <text class="stats-cell__label">胜率</text>
          <text class="stats-cell__value">{{winRate}}%</text>
          <text class="stats-cell__sub">胜率</text>
        </view>
        <view class="stats-cell">
          <text class="stats-cell__label">任务数</text>
          <text class="stats-cell__value">{{matchCount}}</text>
          <text class="stats-cell__sub">样本数</text>
        </view>
        <view class="stats-cell">
          <text class="stats-cell__label">稳定性</text>
          <text class="stats-cell__value">{{stability !== null ? stability : '--'}}</text>
          <text class="stats-cell__sub">人格稳定度</text>
        </view>
      </view>
      <view class="stats__footer" bindtap="goScoreRecords">
        <text class="stats__footer-hint">查看全部脉冲日志</text>
        <view class="svg-icon svg-icon--arrow"></view>
      </view>
    </view>

    <!-- 3. IDENTITY LEVEL -->
    <view class="term-card term-card--level">
      <text class="term-kicker">身份等级</text>
      <text class="term-kicker-sub">LEVEL</text>
      <view class="level__header">
        <text class="level__lv">Lv.{{level}}</text>
        <text class="level__title">{{levelTitle}}</text>
      </view>
      <view class="level__bar-track">
        <view class="level__bar-fill" style="width:{{levelProgress}}%;"></view>
      </view>
      <view class="level__exp-row">
        <text class="level__exp-text">EXP {{levelExpDisplay}} / {{levelExpRange}}</text>
        <text class="level__exp-pct">{{levelProgress}}%</text>
      </view>
      <text class="level__next-hint" wx:if="{{level < 5 && levelRemainingExp > 0}}">距离 Lv.{{level + 1}} 还差 {{levelRemainingExp}} EXP</text>
      <text class="level__next-hint level__next-hint--ready" wx:elif="{{level < 5}}">等级进度已就绪，继续完成样本</text>
      <view class="level__route">
        <view class="level__node {{level >= 1 ? 'level__node--done' : ''}} {{level == 1 ? 'level__node--current' : ''}}">
          <view class="level__node-dot"></view>
          <text class="level__node-label">观察员</text>
        </view>
        <view class="level__node-line {{level >= 2 ? 'level__node-line--done' : ''}}"></view>
        <view class="level__node {{level >= 2 ? 'level__node--done' : ''}} {{level == 2 ? 'level__node--current' : ''}}">
          <view class="level__node-dot"></view>
          <text class="level__node-label">参与者</text>
        </view>
        <view class="level__node-line {{level >= 3 ? 'level__node-line--done' : ''}}"></view>
        <view class="level__node {{level >= 3 ? 'level__node--done' : ''}} {{level == 3 ? 'level__node--current' : ''}}">
          <view class="level__node-dot"></view>
          <text class="level__node-label">执行者</text>
        </view>
        <view class="level__node-line {{level >= 4 ? 'level__node-line--done' : ''}}"></view>
        <view class="level__node {{level >= 4 ? 'level__node--done' : ''}} {{level == 4 ? 'level__node--current' : ''}}">
          <view class="level__node-dot"></view>
          <text class="level__node-label">掌控者</text>
        </view>
        <view class="level__node-line {{level >= 5 ? 'level__node-line--done' : ''}}"></view>
        <view class="level__node {{level >= 5 ? 'level__node--done' : ''}} {{level == 5 ? 'level__node--current' : ''}}">
          <view class="level__node-dot"></view>
          <text class="level__node-label">候选者</text>
        </view>
      </view>
    </view>

    <!-- 4. BADGE COLLECTION -->
    <view class="term-card term-card--achievements">
      <text class="term-kicker">成就记录</text>
      <text class="term-kicker-sub">BADGE</text>
      <scroll-view class="achievements-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
        <view class="achievements-track">
          <view class="achievement-badge {{item.unlocked ? 'achievement-badge--on' : ''}}" wx:for="{{achievements}}" wx:key="id">
            <view class="achievement-badge__icon">
              <view class="achievement-badge__ring">
                <view class="svg-icon svg-icon--badge-{{item.icon}}"></view>
              </view>
            </view>
            <text class="achievement-badge__label">{{item.name}}</text>
            <text class="achievement-badge__code">{{item.code}}</text>
            <view class="achievement-badge__progress" wx:if="{{!item.unlocked}}">
              <view class="achievement-badge__progress-track">
                <view class="achievement-badge__progress-fill" style="width:{{item.progressPct}}%;"></view>
              </view>
              <text class="achievement-badge__progress-text">{{item.progressText}}</text>
            </view>
            <text class="achievement-badge__unlocked-text" wx:else>已解锁</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 5. SYSTEM CONTROL -->
    <view class="term-card term-card--system">
      <text class="term-kicker">系统控制</text>
      <text class="term-kicker-sub">CONTROL</text>

      <!-- 语音播报 -->
      <view class="sys-row">
        <view class="sys-row__label-group">
          <text class="sys-row__label-zh">声音协议</text>
          <text class="sys-row__label-en">VOICE</text>
        </view>
        <view class="cyber-switch {{voiceEnabled ? 'cyber-switch--on' : ''}}" bindtap="onVoiceToggle">
          <text class="cyber-switch__text">{{voiceEnabled ? 'ON' : 'OFF'}}</text>
        </view>
      </view>

      <!-- 音色模块 -->
      <view class="sys-row sys-row--sub {{voiceEnabled ? '' : 'sys-row--hidden'}}" bindtap="openVoiceSheet">
        <view class="sys-row__label-group">
          <text class="sys-row__label-zh">音色选择</text>
          <text class="sys-row__label-en">TIMBRE</text>
        </view>
        <view class="sys-row__value">
          <text class="sys-row__value-text">{{voiceName}}</text>
          <view class="svg-icon svg-icon--arrow"></view>
        </view>
      </view>

      <!-- 计分动效 -->
      <view class="sys-row">
        <view class="sys-row__label-group">
          <text class="sys-row__label-zh">动效协议</text>
          <text class="sys-row__label-en">FX</text>
        </view>
        <view class="cyber-switch {{animEnabled ? 'cyber-switch--on' : ''}}" bindtap="onAnimToggle">
          <text class="cyber-switch__text">{{animEnabled ? 'ON' : 'OFF'}}</text>
        </view>
      </view>

      <!-- 触感反馈 -->
      <view class="sys-row">
        <view class="sys-row__label-group">
          <text class="sys-row__label-zh">触感协议</text>
          <text class="sys-row__label-en">HAPTIC</text>
        </view>
        <view class="cyber-switch {{vibrateEnabled ? 'cyber-switch--on' : ''}}" bindtap="onVibrateToggle">
          <text class="cyber-switch__text">{{vibrateEnabled ? 'ON' : 'OFF'}}</text>
        </view>
      </view>

      <!-- 关于终端 -->
      <view class="sys-row sys-row--link" bindtap="goAbout">
        <view class="sys-row__label-group">
          <text class="sys-row__label-zh">终端信息</text>
          <text class="sys-row__label-en">ABOUT</text>
        </view>
        <view class="svg-icon svg-icon--arrow"></view>
      </view>
    </view>

    <!-- 6. TERMINATE SESSION -->
    <view class="terminate-btn" bindtap="onLogout">
      <text class="terminate-btn__en">TERMINATE</text>
      <text class="terminate-btn__zh">断开终端</text>
    </view>
  </view>

  <!-- 音色选择弹层 -->
  <view wx:if="{{voiceSheetVisible}}" class="voice-mask voice-mask--show" bindtap="closeVoiceSheet"></view>
  <view wx:if="{{voiceSheetVisible}}" class="voice-sheet voice-sheet--show">
    <view class="voice-sheet__header">
      <text class="voice-sheet__kicker">VOICE</text>
      <text class="voice-sheet__title">声音协议</text>
    </view>
    <view class="voice-sheet__body">
      <!-- 左侧分类 -->
      <scroll-view class="voice-sheet__cat-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          class="voice-sheet__cat-item {{activeVoiceCatId === item.id ? 'voice-sheet__cat-item--active' : ''}}"
          wx:for="{{voiceCategories}}"
          wx:key="id"
          data-cat-id="{{item.id}}"
          bindtap="onCatTap"
        >
          <text class="voice-sheet__cat-en">{{item.enLabel}}</text>
          <text class="voice-sheet__cat-zh">{{item.zhLabel}}</text>
        </view>
      </scroll-view>
      <!-- 右侧音色列表 -->
      <scroll-view
        class="voice-sheet__voice-list"
        scroll-y
        enhanced
        show-scrollbar="{{false}}"
        scroll-into-view="{{scrollToCat}}"
        scroll-with-animation
      >
        <block wx:for="{{voiceCategories}}" wx:key="id" wx:for-item="cat" wx:for-index="catIdx">
          <view class="voice-sheet__group-header" id="cat-{{cat.id}}">{{cat.enLabel}}</view>
          <view
            class="voice-sheet__voice-item {{item.id === selectedVoiceId ? 'voice-sheet__voice-item--active' : ''}} {{playingVoiceId === item.id ? 'voice-sheet__voice-item--playing' : ''}}"
            wx:for="{{cat.voices}}"
            wx:key="id"
            data-voice="{{item}}"
            data-cat-id="{{cat.id}}"
            bindtap="onVoiceTap"
          >
            <view class="voice-sheet__voice-info">
              <text class="voice-sheet__voice-name">{{item.name}}</text>
              <text class="voice-sheet__voice-desc">{{item.desc}}</text>
            </view>
            <view class="voice-sheet__voice-right">
              <view class="voice-sheet__wave" wx:if="{{playingVoiceId === item.id}}">
                <view class="voice-sheet__wave-bar"></view>
                <view class="voice-sheet__wave-bar"></view>
                <view class="voice-sheet__wave-bar"></view>
              </view>
              <text class="voice-sheet__selected" wx:elif="{{item.id === selectedVoiceId}}">已选</text>
            </view>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>
</view>

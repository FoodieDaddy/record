.profile-page {
  padding: var(--spacing-md);
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
}

/* ===== 未登录 ===== */
.empty-auth {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
}

.empty-auth-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

/* ===== 用户卡片 ===== */
.user-card {
  padding: 32rpx;
}

.user-card-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 24rpx;
}

.avatar-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(79, 140, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.avatar-ring::before {
  content: '';
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(79, 140, 255, 0.1);
}

.auto-avatar-lg {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auto-avatar-char-lg {
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
}

.avatar-lg {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nickname-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nickname-input {
  flex: 1;
  height: 72rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: var(--border-radius-xs);
  padding: 0 20rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 500;
}

.btn-shuffle {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: var(--border-radius-xs);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0;
}

.btn-shuffle:active {
  background: rgba(79, 140, 255, 0.15);
}

.shuffle-icon {
  font-size: 32rpx;
}

.save-btn {
  margin-top: 0;
}

/* ===== 设置 ===== */
.settings-section {
  padding: 28rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.setting-label {
  font-size: 28rpx;
  font-weight: 500;
}

.voice-type-group {
  display: flex;
  gap: 8rpx;
}

.voice-type-btn {
  padding: 10rpx 28rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.voice-type-active {
  background: rgba(79, 140, 255, 0.15);
  border-color: rgba(79, 140, 255, 0.4);
  color: var(--accent);
}

/* ===== 历史房间 ===== */
.history-section {
  padding: 28rpx;
}

.empty-history {
  padding: 32rpx 0;
  text-align: center;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-top: 12rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}

.history-item:last-child {
  border-bottom: none;
}

.hi-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.hi-room-no {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  font-variant-numeric: tabular-nums;
}

.hi-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.hi-time {
  font-size: 22rpx;
}

/* ===== 账号/授权 ===== */
.auth-section {
  padding: 28rpx;
}

.auth-status {
  display: flex;
  align-items: center;
}

.auth-ok {
  font-size: 28rpx;
  color: var(--success);
  font-weight: 600;
}

/* ===== 退出登录 ===== */
.btn-logout {
  margin-top: 32rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
  border: 1rpx solid rgba(248, 113, 113, 0.3);
  color: var(--danger);
  font-size: 28rpx;
  border-radius: var(--border-radius-sm);
}

.btn-logout:active {
  background: rgba(248, 113, 113, 0.08);
}

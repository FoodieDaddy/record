.profile-page {
  padding: var(--spacing-md);
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
}

/* ===== 未登录 ===== */
.empty-auth {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
}

.empty-auth-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

/* ===== 用户卡片 ===== */
.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.avatar-ring-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0 0 24rpx;
  background: transparent;
  overflow: hidden;
  line-height: normal;
}

.avatar-ring-btn::after {
  display: none;
}

.auto-avatar-lg {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auto-avatar-char-lg {
  font-size: 46rpx;
  font-weight: 600;
  color: #fff;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.nickname-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.nickname-input {
  width: 280rpx;
  height: 72rpx;
  background: transparent;
  border: none;
  text-align: center;
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 600;
}

.btn-shuffle {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0;
}

.btn-shuffle:active {
  background: rgba(79, 140, 255, 0.15);
}

.shuffle-icon {
  font-size: 28rpx;
}

.hint-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
  margin-bottom: 32rpx;
}

.save-btn {
  width: 100%;
  margin-top: 0;
}

/* ===== 菜单入口 ===== */
.menu-section {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
  transition: background 0.15s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(79, 140, 255, 0.08);
}

.menu-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

/* ===== 设置 ===== */
.settings-section {
  padding: 28rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.setting-label {
  font-size: 28rpx;
  font-weight: 500;
}

.voice-type-group {
  display: flex;
  gap: 8rpx;
}

.voice-type-btn {
  padding: 10rpx 28rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.voice-type-active {
  background: rgba(79, 140, 255, 0.15);
  border-color: rgba(79, 140, 255, 0.4);
  color: var(--accent);
}

/* ===== 退出登录 ===== */
.btn-logout {
  margin-top: 32rpx;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
  border: 1rpx solid rgba(248, 113, 113, 0.3);
  color: var(--danger);
  font-size: 28rpx;
  font-weight: 500;
  border-radius: var(--border-radius-sm);
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-logout:active {
  background: rgba(248, 113, 113, 0.08);
}

/* ===== 页面根节点 ===== */
.terminal-page {
  --primary: #00C8FF;
  --primary-dim: rgba(0, 170, 255, 0.15);
  --primary-glow: rgba(0, 170, 255, 0.25);
  --bg: #05070A;
  --card-bg: #0A0F18;
  --card-border: rgba(0, 170, 255, 0.15);
  --card-radius: 18rpx;
  --success: #36FF74;
  --danger: #FF4D4F;
  --text-main: rgba(255, 255, 255, 0.92);
  --text-secondary: #7C8698;
  --text-muted: rgba(255, 255, 255, 0.38);

  position: relative;
  padding: 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  background: var(--bg);
}

/* 背景光晕 */
.terminal__glow {
  position: fixed;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 800rpx;
  height: 600rpx;
  background:
    radial-gradient(circle at 20% 0%, rgba(0, 170, 255, 0.10), transparent 32%),
    radial-gradient(circle at 90% 18%, rgba(94, 92, 230, 0.06), transparent 30%);
  pointer-events: none;
  z-index: 0;
}


/* ===== 未登录空态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
}

.empty-state__icon {
  margin-bottom: 32rpx;
}

.empty-state__title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.empty-state__desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
}

.btn-primary {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: var(--primary);
  border: none;
  border-radius: 12rpx;
  letter-spacing: 2rpx;
}

.btn-primary::after {
  display: none;
}


/* ===== SYSTEM STATUS ===== */
.status-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.status-bar__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.24);
  flex-shrink: 0;
}

.status-bar__dot--online {
  background: var(--success);
  box-shadow: 0 0 8rpx rgba(54, 255, 116, 0.5);
  animation: breathe 2s ease-in-out infinite;
}

.status-bar__label {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.status-bar__value {
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: var(--text-secondary);
  font-family: monospace;
  margin-left: auto;
}


/* ===== 通用卡片 ===== */
.term-card {
  position: relative;
  z-index: 1;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: var(--card-radius);
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.term-kicker {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary);
  letter-spacing: 4rpx;
  margin-bottom: 4rpx;
}

.term-kicker-sub {
  display: block;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.34);
  margin-bottom: 20rpx;
  font-weight: 400;
}


/* ===== 1. PLAYER PROFILE ===== */
.term-card--identity {
  padding: 36rpx 32rpx 28rpx;
}

.identity__row {
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  margin-bottom: 20rpx;
}

.identity__avatar-btn {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  background: transparent;
  overflow: visible;
  line-height: normal;
  flex-shrink: 0;
}

.identity__avatar-btn::after {
  display: none;
}

.identity__info {
  flex: 1;
  min-width: 0;
}

.identity__kicker {
  display: block;
  font-size: 16rpx;
  letter-spacing: 3rpx;
  color: rgba(0, 170, 255, 0.56);
  font-weight: 600;
  margin-bottom: 6rpx;
}

.identity__name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.identity__name-input {
  flex: 1;
  height: 56rpx;
  background: transparent;
  border: none;
  color: var(--text-main);
  font-size: 36rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.identity__name-input::placeholder {
  color: var(--text-muted);
  font-weight: 400;
}

.identity__dice-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1rpx solid rgba(0, 170, 255, 0.2);
  border-radius: 12rpx;
  background: rgba(0, 170, 255, 0.04);
}

.identity__dice-btn:active {
  opacity: 0.5;
  background: rgba(0, 170, 255, 0.1);
}

.identity__tag-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.identity__player-code {
  font-size: 20rpx;
  color: var(--primary);
  font-family: monospace;
  letter-spacing: 2rpx;
  opacity: 0.8;
}

.identity__tag-sep {
  font-size: 18rpx;
  color: var(--text-muted);
}

.identity__level-tag {
  font-size: 20rpx;
  color: var(--primary);
  font-family: monospace;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.identity__status-tag {
  font-size: 18rpx;
  color: var(--success);
  font-family: monospace;
  letter-spacing: 2rpx;
}

.identity__meta {
  display: flex;
  gap: 0;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.identity__meta-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.identity__meta-label {
  font-size: 18rpx;
  color: var(--text-muted);
}

.identity__meta-value {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-family: monospace;
  letter-spacing: 1rpx;
}

.identity__meta-value--active {
  color: var(--success);
}

.identity__saving {
  display: block;
  font-size: 20rpx;
  color: var(--primary);
  margin-top: 8rpx;
  opacity: 0.8;
  animation: pulse 1.2s ease-in-out infinite;
}


/* ===== 2. DATA MATRIX ===== */
.term-card--stats {
  padding: 28rpx 32rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.stats-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.02);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.stats-cell__label {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: var(--text-muted);
  font-weight: 600;
}

.stats-cell__value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-main);
  font-family: monospace;
  letter-spacing: 1rpx;
}

.stats-cell__value--positive {
  color: var(--success);
}

.stats-cell__value--negative {
  color: var(--danger);
}

.stats-cell__sub {
  font-size: 18rpx;
  color: var(--text-muted);
}

.stats__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.stats__footer:active {
  opacity: 0.6;
}

.stats__footer-hint {
  font-size: 22rpx;
  color: var(--primary);
  opacity: 0.7;
}


/* ===== 3. IDENTITY LEVEL ===== */
.term-card--level {
  padding: 28rpx 32rpx;
}

.level__header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.level__lv {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--primary);
  font-family: monospace;
  letter-spacing: 2rpx;
}

.level__title {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.level__bar-track {
  width: 100%;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.level__bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), #00E5FF);
  border-radius: 6rpx;
  transition: width 0.6s ease;
}

.level__exp-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.level__exp-text {
  font-size: 20rpx;
  color: var(--text-muted);
  font-family: monospace;
  letter-spacing: 1rpx;
}

.level__exp-pct {
  font-size: 20rpx;
  color: var(--primary);
  font-family: monospace;
  font-weight: 600;
}

.level__next-hint {
  display: block;
  font-size: 20rpx;
  color: var(--text-muted);
  margin-bottom: 20rpx;
  font-family: monospace;
}

/* 等级路线图 */
.level__route {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0 8rpx;
}

.level__node {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0.3;
}

.level__node--done {
  opacity: 0.7;
}

.level__node--current {
  opacity: 1;
}

.level__node-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  background: transparent;
}

.level__node--done .level__node-dot {
  border-color: var(--primary);
  background: rgba(0, 170, 255, 0.15);
}

.level__node--current .level__node-dot {
  border-color: var(--primary);
  background: var(--primary);
  box-shadow: 0 0 12rpx var(--primary-glow);
}

.level__node-label {
  font-size: 18rpx;
  color: var(--text-muted);
  white-space: nowrap;
}

.level__node--done .level__node-label {
  color: var(--text-secondary);
}

.level__node--current .level__node-label {
  color: var(--primary);
  font-weight: 600;
}

.level__node-line {
  flex: 1;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.08);
  margin: 0 4rpx;
  margin-bottom: 28rpx;
}

.level__node-line--done {
  background: var(--primary-dim);
}


/* ===== 4. BADGE COLLECTION ===== */
.term-card--achievements {
  padding: 28rpx 0 28rpx 32rpx;
}

.achievements-scroll {
  width: 100%;
  white-space: nowrap;
}

.achievements-track {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 32rpx;
}

.achievement-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 150rpx;
  flex-shrink: 0;
  opacity: 0.3;
}

.achievement-badge--on {
  opacity: 1;
}

.achievement-badge__icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.achievement-badge__ring {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.02);
  display: flex;
  align-items: center;
  justify-content: center;
}

.achievement-badge--on .achievement-badge__ring {
  border-color: var(--primary);
  background: rgba(0, 170, 255, 0.08);
  box-shadow: 0 0 12rpx var(--primary-dim);
}

.achievement-badge__ring .svg-icon {
  opacity: 0.4;
}

.achievement-badge--on .achievement-badge__ring .svg-icon {
  opacity: 0.9;
}

.achievement-badge__label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.56);
  text-align: center;
  white-space: nowrap;
}

.achievement-badge--on .achievement-badge__label {
  color: var(--text-main);
}

.achievement-badge__code {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.28);
  font-family: monospace;
  letter-spacing: 1rpx;
}

.achievement-badge--on .achievement-badge__code {
  color: var(--primary);
  opacity: 0.7;
}

.achievement-badge__progress {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.achievement-badge__progress-track {
  width: 80%;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 2rpx;
  overflow: hidden;
}

.achievement-badge__progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 2rpx;
  opacity: 0.5;
}

.achievement-badge__progress-text {
  font-size: 16rpx;
  color: var(--text-muted);
  font-family: monospace;
}

.achievement-badge__unlocked-text {
  font-size: 16rpx;
  color: var(--success);
  font-family: monospace;
  letter-spacing: 1rpx;
}


/* ===== 5. SYSTEM CONTROL ===== */
.term-card--system {
  padding: 28rpx 32rpx;
}

.sys-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.sys-row:last-child {
  border-bottom: none;
}

.sys-row--sub {
  padding-left: 24rpx;
  max-height: 100rpx;
  opacity: 1;
  overflow: hidden;
  transition: max-height 0.35s cubic-bezier(0.32, 0.72, 0, 1),
              opacity 0.25s ease,
              padding 0.35s ease;
}

.sys-row--hidden {
  max-height: 0;
  opacity: 0;
  padding-top: 0;
  padding-bottom: 0;
  pointer-events: none;
}

.sys-row--link:active {
  opacity: 0.6;
}

.sys-row__label-group {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.sys-row__label-en {
  font-size: 18rpx;
  color: rgba(10,132,255,0.52);
  letter-spacing: 4rpx;
}

.sys-row__label-zh {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 1rpx;
}

.sys-row__value {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.sys-row__value-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 赛博开关 */
.cyber-switch {
  flex-shrink: 0;
  width: 80rpx;
  height: 44rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
}

.cyber-switch__text {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.38);
  font-family: monospace;
  transition: color 0.2s;
}

.cyber-switch--on {
  border-color: rgba(0, 170, 255, 0.5);
  background: rgba(0, 170, 255, 0.08);
  box-shadow: 0 0 12rpx rgba(0, 170, 255, 0.15);
}

.cyber-switch--on .cyber-switch__text {
  color: var(--primary);
}

.cyber-switch:active {
  transform: scale(0.95);
}


/* ===== 6. TERMINATE SESSION ===== */
.terminate-btn {
  margin-top: 24rpx;
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  border: 1rpx solid rgba(255, 77, 79, 0.35);
  border-radius: var(--card-radius);
  background: transparent;
}

.terminate-btn:active {
  background: rgba(255, 77, 79, 0.06);
}

.terminate-btn__en {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 77, 79, 0.6);
  font-weight: 600;
}

.terminate-btn__zh {
  font-size: 24rpx;
  color: var(--danger);
  font-weight: 500;
}


/* ===== 音色选择弹层 ===== */
.voice-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.72);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.voice-mask--show {
  opacity: 1;
  visibility: visible;
}

.voice-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 70vh;
  z-index: 1000;
  background: #0A0F18;
  border: 1rpx solid rgba(0, 170, 255, 0.15);
  border-bottom: none;
  border-radius: 28rpx 28rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
}

.voice-sheet--show {
  transform: translateY(0);
}

.voice-sheet__header {
  padding: 28rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.voice-sheet__kicker {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--primary);
  letter-spacing: 4rpx;
  margin-bottom: 4rpx;
}

.voice-sheet__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
}

.voice-sheet__body {
  flex: 1;
  display: flex;
  overflow: hidden;
  padding-bottom: env(safe-area-inset-bottom);
}

.voice-sheet__cat-list {
  width: 30%;
  background: rgba(255, 255, 255, 0.02);
  height: 100%;
  border-right: 1rpx solid rgba(255, 255, 255, 0.04);
}

.voice-sheet__cat-item {
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  transition: background 0.2s;
  position: relative;
}

.voice-sheet__cat-en {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: var(--text-muted);
  transition: color 0.2s;
}

.voice-sheet__cat-zh {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.24);
  transition: color 0.2s;
}

.voice-sheet__cat-item--active .voice-sheet__cat-en {
  color: var(--text-main);
}

.voice-sheet__cat-item--active .voice-sheet__cat-zh {
  color: var(--text-muted);
}

.voice-sheet__cat-item--active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  bottom: 20%;
  width: 6rpx;
  background: var(--primary);
  border-radius: 0 3rpx 3rpx 0;
}

.voice-sheet__voice-list {
  width: 70%;
  height: 100%;
  padding: 0 24rpx;
}

.voice-sheet__group-header {
  padding: 24rpx 0 12rpx;
  font-size: 20rpx;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 3rpx;
  font-weight: 600;
}

.voice-sheet__voice-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  border: 1rpx solid transparent;
  transition: background 0.15s, border-color 0.15s;
}

.voice-sheet__voice-item:active {
  background: rgba(255, 255, 255, 0.04);
}

.voice-sheet__voice-item--active {
  background: rgba(0, 170, 255, 0.06);
  border-color: rgba(0, 170, 255, 0.2);
}

.voice-sheet__voice-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.voice-sheet__voice-name {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 500;
}

.voice-sheet__voice-item--active .voice-sheet__voice-name {
  color: var(--primary);
}

.voice-sheet__voice-desc {
  font-size: 22rpx;
  color: var(--text-muted);
}

.voice-sheet__voice-right {
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.voice-sheet__selected {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--primary);
  letter-spacing: 2rpx;
  font-family: monospace;
}

/* 声浪波纹动画 */
.voice-sheet__wave {
  display: flex;
  align-items: center;
  gap: 4rpx;
  height: 32rpx;
}

.voice-sheet__wave-bar {
  width: 6rpx;
  background: var(--primary);
  border-radius: 3rpx;
  animation: waveAnim 0.6s ease-in-out infinite alternate;
}

.voice-sheet__wave-bar:nth-child(1) {
  height: 12rpx;
  animation-delay: 0s;
}

.voice-sheet__wave-bar:nth-child(2) {
  height: 20rpx;
  animation-delay: 0.2s;
}

.voice-sheet__wave-bar:nth-child(3) {
  height: 12rpx;
  animation-delay: 0.4s;
}

@keyframes waveAnim {
  0% { height: 8rpx; }
  100% { height: 28rpx; }
}

.voice-sheet__voice-item--playing .voice-sheet__voice-name {
  color: var(--primary);
}


/* ===== 动效 ===== */
@keyframes pulse {
  0%, 100% { opacity: 0.8; }
  50% { opacity: 0.4; }
}

@keyframes breathe {
  0%, 100% { opacity: 1; box-shadow: 0 0 8rpx rgba(54, 255, 116, 0.5); }
  50% { opacity: 0.6; box-shadow: 0 0 4rpx rgba(54, 255, 116, 0.3); }
}

.reduce-motion .identity__saving {
  animation: none !important;
}

.reduce-motion .status-bar__dot--online {
  animation: none !important;
}

.reduce-motion .terminal__glow,
.reduce-motion .level__bar-fill,
.reduce-motion .term-card,
.reduce-motion .cyber-switch,
.reduce-motion .voice-sheet,
.reduce-motion .voice-mask,
.reduce-motion .sys-row--sub {
  transition: none !important;
  animation: none !important;
}

.reduce-motion .voice-sheet__wave-bar {
  animation: none !important;
}

<view class="mirror-page {{reduceMotion ? 'reduce-motion' : ''}}">

  <!-- Header -->
  <view class="mirror-header">
    <view class="header-left">
      <text class="page-title">镜像</text>
      <text class="page-subtitle">多维测试终端</text>
    </view>
    <view class="header-right" bindtap="openArchive">
      <text class="archive-entry">档案</text>
    </view>
  </view>

  <!-- Skeleton Loading -->
  <block wx:if="{{loading}}">
    <view class="skeleton-card skeleton"></view>
    <view class="skeleton-card skeleton"></view>
    <view class="skeleton-grid">
      <view class="skeleton-item skeleton"></view>
      <view class="skeleton-item skeleton"></view>
      <view class="skeleton-item skeleton"></view>
    </view>
  </block>

  <!-- Content -->
  <block wx:else>

    <!-- 人格镜像卡 -->
    <mirror-personality-card
      profile="{{profile}}"
      bind:start-test="startMbtiTest"
      bind:direct-input="openMbtiPicker"
    />

    <!-- 今日场域 -->
    <mirror-today-field
      todayField="{{todayField}}"
      bind:open-tool="openTool"
    />

    <!-- 快速占测 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">快速占测</text>
        <text class="section-meta">QUICK TEST</text>
      </view>
      <view class="tool-grid">
        <mirror-tool-card
          wx:for="{{quickTools}}"
          wx:key="code"
          tool="{{item}}"
          bindtap="openTool"
          data-code="{{item.code}}"
          data-locked="{{item.locked}}"
          data-lockreason="{{item.lockReason}}"
        />
      </view>
    </view>

    <!-- 命盘画像 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">命盘画像</text>
        <text class="section-meta">PROFILE</text>
      </view>
      <view class="tool-grid">
        <mirror-tool-card
          wx:for="{{profileTools}}"
          wx:key="code"
          tool="{{item}}"
          bindtap="openTool"
          data-code="{{item.code}}"
          data-locked="{{item.locked}}"
          data-lockreason="{{item.lockReason}}"
        />
      </view>
    </view>

    <!-- 高级推演 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">高级推演</text>
        <text class="section-meta">ADVANCED</text>
      </view>
      <view class="advanced-list">
        <view
          wx:for="{{advancedTools}}"
          wx:key="code"
          class="advanced-row {{item.locked ? 'locked' : ''}}"
          bindtap="openTool"
          data-code="{{item.code}}"
          data-locked="{{item.locked}}"
          data-lockreason="{{item.lockReason}}"
        >
          <view class="advanced-info">
            <text class="advanced-name">{{item.name}}</text>
            <text class="advanced-desc">{{item.desc}}</text>
          </view>
          <text class="advanced-arrow" wx:if="{{!item.locked}}">></text>
          <text class="advanced-lock" wx:if="{{item.locked}}">{{item.lockReason}}</text>
        </view>
      </view>
    </view>

    <!-- 最近结果 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">最近结果</text>
        <text class="section-meta">ARCHIVE</text>
      </view>
      <block wx:if="{{recentReports.length > 0}}">
        <view class="recent-list">
          <view
            wx:for="{{recentReports}}"
            wx:key="id"
            class="recent-row"
            bindtap="openReport"
            data-id="{{item.id}}"
          >
            <view class="recent-info">
              <text class="recent-tool">{{item.toolName}}</text>
              <text class="recent-title">{{item.title}}</text>
            </view>
            <view class="recent-right">
              <text class="recent-tag" wx:if="{{item.tag}}">{{item.tag}}</text>
              <text class="recent-time">{{item.timeText}}</text>
            </view>
          </view>
        </view>
      </block>
      <view class="empty-state" wx:else>
        <text class="empty-text">暂无镜像结果</text>
      </view>
    </view>

    <!-- 底部安全提示 -->
    <view class="disclaimer">
      <text class="disclaimer-text">镜像结果仅作为娱乐化策略参考，不代表真实输赢预测。</text>
    </view>

  </block>

  <!-- MBTI 滑动测试 -->
  <mbti-swipe-test
    wx:if="{{showSwipeTest}}"
    bind:complete="handleMbtiComplete"
    bind:close="closeMbtiTest"
    reduceMotion="{{reduceMotion}}"
  />

  <!-- MBTI 直接输入 -->
  <mbti-picker-modal
    wx:if="{{showMbtiPicker}}"
    bind:confirm="handleMbtiDirectInput"
    bind:close="closeMbtiPicker"
    reduceMotion="{{reduceMotion}}"
  />

</view>

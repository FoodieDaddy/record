<view class="mirror-bay {{reduceMotion ? 'reduce-motion' : ''}}" style="padding-top: {{customNavHeight}}px;">

  <!-- 统一沉浸式导航条 -->
  <view
    class="sr-custom-nav"
    style="height: {{customNavHeight}}px; padding-top: {{customNavTop}}px;"
  >
    <view class="sr-custom-nav__stars"></view>
    <view class="sr-custom-nav__bar" style="height: {{customNavBarHeight}}px;">
      <view class="cockpit-nav-hud">
        <view class="cockpit-nav-hud__link">
          <view class="css-status-dot css-status-dot--{{cockpitView.statusDot || 'idle'}}"></view>
          <text>{{cockpitView.statusLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 深空背景层 -->
  <view class="mirror-space-bg" wx:if="{{!isInitialLoading}}">
    <view class="mirror-nebula"></view>
    <view class="mirror-scanlines"></view>
    <view class="mirror-hud-corner mirror-hud-tl"></view>
    <view class="mirror-hud-corner mirror-hud-tr"></view>
    <view class="mirror-hud-corner mirror-hud-bl"></view>
    <view class="mirror-hud-corner mirror-hud-br"></view>
  </view>

  <!-- Loading Skeleton -->
  <block wx:if="{{isInitialLoading}}">
    <view class="skeleton-card primary"></view>
    <view class="skeleton-card secondary"></view>
    <view class="skeleton-card tertiary"></view>
  </block>

  <!-- ==================== MAIN 视图 ==================== -->
  <block wx:if="{{mainVisible}}">

    <view class="mirror-main {{mainDimmed ? 'mirror-main--dimmed' : ''}}">

      <!-- ===== 一级：全息总览 (沉浸式方案中完全移除) ===== -->
      <view class="bay-header hide-page-title" style="opacity: {{headerOpacity}}; display: none;">
        <view class="bay-status-tab bay-status-tab--{{bayStatusState}}">
          <view class="bay-status-tab__dot"></view>
          <text class="bay-status-tab__label">{{bayStatusText}}</text>
        </view>
      </view>

      <view class="mirror-hero" style="opacity: {{heroOpacity}};">
        <!-- 全息扫描图 -->
        <view class="hero-radar-wrap" wx:if="{{!showMbtiPicker}}">
          <radar-chart
            id="radarChart"
            dimensions="{{radarDimensions}}"
            size="{{560}}"
            reduceMotion="{{reduceMotion}}"
            locked="{{radarLocked}}"
            heroMode="{{true}}"
          />
        </view>

        <!-- 镜像投影核心 -->
        <view class="hero-info">
          <block wx:if="{{mbti.calibrated}}">
            <text class="hero-type">{{mbti.mbtiType}}</text>
            <text class="hero-dot">·</text>
            <text class="hero-title">{{mbti.mbtiTitle}}</text>
          </block>
          <block wx:else>
            <text class="hero-uncalibrated">协议未接入 / 等待校准</text>
          </block>
        </view>

        <!-- 核心标签（默认可见） -->
        <view class="hero-signals" wx:if="{{mbti.calibrated && personaSignals.length > 0}}">
          <view class="hero-signal-tag" wx:for="{{personaSignals}}" wx:key="*this">
            <text>{{item}}</text>
          </view>
        </view>

        <!-- 状态摘要 -->
        <view class="hero-summary" wx:if="{{mbti.calibrated}}">
          <view class="summary-item">
            <text class="summary-label">协议一致率</text>
            <text class="summary-val {{personaMatchDisplayPending ? 'summary-val--pending' : 'summary-val--match'}}">{{personaMatchDisplay}}</text>
          </view>
          <view class="summary-sep"></view>
          <view class="summary-item">
            <text class="summary-label">航迹样本</text>
            <text class="summary-val summary-val--sample">{{battlePersona.sampleSize}}</text>
          </view>
        </view>

        <!-- 校准入口（未校准态） -->
        <view class="hero-actions" wx:if="{{!mbti.calibrated}}">
          <view class="term-btn" bindtap="startFullCalibration">
            <text>完整校准</text>
          </view>
          <view class="term-btn-desc">20 组信号，生成完整协议</view>
          <view class="term-btn ghost" bindtap="openMbtiPicker">
            <text>快速接入</text>
          </view>
          <view class="term-btn-desc">手动选择类型，立即接入</view>
        </view>
      </view>

      <!-- ===== 二级：协议行动 ===== -->
      <view class="mirror-protocol" style="opacity: {{sectionsOpacity}};">
        <view class="sr-card protocol-card">
          <view class="card-header">
            <view class="card-title-row">
              <text class="card-title">协议行动</text>
              <text class="protocol-state {{mbti.calibrated ? 'protocol-state--online' : ''}}">{{mbti.calibrated ? '已接入' : '待接入'}}</text>
            </view>
            <view class="sr-card-line card-line"></view>
          </view>

          <block wx:if="{{mbti.calibrated}}">
            <view class="protocol-grid">
              <view class="protocol-row">
                <text class="protocol-label">协议编号</text>
                <view class="protocol-value protocol-code">
                  <text class="pc-prefix">SR</text>
                  <text class="pc-sep">-</text>
                  <text class="pc-core">{{mbti.mbtiCode || '--'}}</text>
                  <text class="pc-sep">/</text>
                  <text class="pc-type">{{mbti.mbtiType || '--'}}</text>
                </view>
              </view>
              <view class="protocol-row">
                <text class="protocol-label">接入方式</text>
                <text class="protocol-value">{{mbti.mbtiSource === 'test' ? '完整校准' : mbti.mbtiSource === 'direct' ? '快速接入' : '未知'}}</text>
              </view>
              <view class="protocol-row">
                <text class="protocol-label">置信读数</text>
                <text class="protocol-value status-active">{{mbti.confidence || personaConfidence || 0}}%</text>
              </view>
              <view class="protocol-row">
                <text class="protocol-label">同步状态</text>
                <text class="protocol-value">{{isSilentSyncing ? '同步中' : '已稳定'}}</text>
              </view>
            </view>

            <view class="protocol-actions">
              <view class="term-btn-sm {{isSilentSyncing ? 'is-disabled' : ''}}" bindtap="refreshProfile">
                <text>{{isSilentSyncing ? '同步中' : '同步镜像'}}</text>
              </view>
            </view>
          </block>

          <block wx:else>
            <view class="protocol-empty">
              <text class="protocol-empty__title">协议尚未接入</text>
              <text class="protocol-empty__desc">完成校准后，全息扫描、协议分析和镜像图片会自动解锁。</text>
            </view>
            <view class="protocol-actions protocol-actions--split">
              <view class="term-btn-sm" bindtap="startFullCalibration">
                <text>完整校准</text>
              </view>
              <view class="term-btn-sm ghost" bindtap="openMbtiPicker">
                <text>快速接入</text>
              </view>
            </view>
          </block>
        </view>
      </view>

      <!-- ===== 二级：航迹档案 ===== -->
      <view class="mirror-track {{!mbti.calibrated ? 'mirror-track--second-screen' : ''}}" style="opacity: {{sectionsOpacity}};">
        <view class="sr-card track-archive-card" bindtap="goScoreRecords">
          <view class="card-header">
            <view class="card-title-row">
              <text class="card-title">航迹档案</text>
            </view>
            <view class="sr-card-line card-line"></view>
          </view>
          <view class="track-archive__body">
            <view class="track-archive__stat">
              <text class="track-archive__stat-val">{{bbSampleCount}}</text>
              <text class="track-archive__stat-label">已写入样本</text>
            </view>
            <view class="track-archive__sep"></view>
            <view class="track-archive__stat">
              <text class="track-archive__stat-val">{{bbRecentRoom}}</text>
              <text class="track-archive__stat-label">最近航程</text>
            </view>
            <view class="track-archive__sep"></view>
            <view class="track-archive__stat">
              <text class="track-archive__stat-val">{{bbRecentTime}}</text>
              <text class="track-archive__stat-label">封存时间</text>
            </view>
          </view>
          <view class="track-archive__footer">
            <text class="track-archive__footer-text">进入航迹回放</text>
            <view class="mirror-arrow-icon"></view>
          </view>
        </view>
      </view>

      <!-- ===== 三级：镜像投影 ===== -->
      <view class="mirror-analysis" style="opacity: {{sectionsOpacity}};" wx:if="{{mbti.calibrated}}">
        <view class="sr-card behavior-profile-card">
          <view class="card-header">
            <view class="card-title-row">
              <text class="card-title">镜像投影</text>
              <text class="behavior-profile__sample">{{battlePersona.sampleSize}} 个样本</text>
            </view>
            <view class="sr-card-line card-line"></view>
          </view>

          <block wx:if="{{battlePersona.generated}}">
            <text class="behavior-profile__title">{{battlePersona.title}}</text>
            <text class="behavior-profile__summary">{{battlePersona.summary}}</text>
          </block>
          <view class="behavior-profile__pending" wx:else>
            <text>航迹样本采集中，完成更多任务后将生成稳定画像</text>
          </view>

          <view class="behavior-dimensions">
            <view class="behavior-dimension" wx:for="{{radarDimensions}}" wx:key="key">
              <view class="behavior-dimension__head">
                <text>{{item.label}}</text>
                <text>{{radarLocked ? '--' : item.value}}</text>
              </view>
              <view class="behavior-dimension__track">
                <view class="behavior-dimension__fill" style="width: {{radarLocked ? 0 : item.value}}%;"></view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- ===== 三级：协议分析（独立卡片） ===== -->
      <view class="mirror-analysis" style="opacity: {{sectionsOpacity}};" wx:if="{{mbti.calibrated}}">
        <view class="sr-card analysis-card">
          <view class="card-header">
            <view class="card-title-row analysis-toggle">
              <text class="card-title">协议分析</text>
              <text class="analysis-toggle__state">实时判读</text>
            </view>
            <view class="sr-card-line card-line"></view>
          </view>

          <view class="analysis-body">

            <!-- 系统判读 -->
            <view class="analysis-section">
              <view class="analysis-section-header">
                <text class="analysis-section-title">系统判读</text>
              </view>

              <block wx:if="{{reading.available}}">
                <view class="reading-sub-card" wx:if="{{reading.observation}}">
                  <text class="reading-sub-label">观测</text>
                  <text class="reading-sub-text">{{reading.observation}}</text>
                </view>
                <view class="reading-sub-card" wx:if="{{reading.deviation}}">
                  <text class="reading-sub-label">偏差</text>
                  <text class="reading-sub-text">{{reading.deviation}}</text>
                </view>
                <view class="reading-sub-card" wx:if="{{reading.risk}}">
                  <text class="reading-sub-label">边界</text>
                  <text class="reading-sub-text">{{reading.risk}}</text>
                </view>
                <view class="reading-sub-card" wx:if="{{reading.growthAdvice}}">
                  <text class="reading-sub-label">成长建议</text>
                  <text class="reading-sub-text">{{reading.growthAdvice}}</text>
                </view>
                <view class="reading-sub-card" wx:if="{{!reading.observation && reading.text}}">
                  <text class="reading-sub-label">系统判断</text>
                  <text class="reading-sub-text">{{reading.text}}</text>
                </view>
              </block>

              <block wx:else>
                <view class="reading-locked">
                  <text class="reading-locked-text" wx:if="{{!mbti.calibrated}}">请先完成协议校准</text>
                  <text class="reading-locked-text" wx:elif="{{battlePersona.sampleSize < 3}}">完成 3 次封存后解锁系统判读</text>
                  <text class="reading-locked-text" wx:else>数据计算中</text>
                </view>
              </block>
            </view>

            <!-- 协议偏移 -->
            <view class="analysis-section">
              <view class="analysis-section-header">
                <text class="analysis-section-title">协议偏移</text>
              </view>

              <block wx:if="{{personaMatch.available}}">
                <view class="dev-grid">
                  <view class="dev-col">
                    <text class="dev-label">校准协议</text>
                    <text class="dev-type dev-type-blue">{{mbti.mbtiType}}</text>
                  </view>
                  <view class="dev-connector">
                    <view class="dev-arrow"></view>
                    <text class="dev-percent">{{personaMatch.deviationPercent}}%</text>
                  </view>
                  <view class="dev-col">
                    <text class="dev-label">航迹协议</text>
                    <text class="dev-type dev-type-orange">{{personaMatch.inferredMbtiType}}</text>
                  </view>
                </view>
                <view class="dev-bar-track">
                  <view class="dev-bar-fill" style="width: {{personaMatch.deviationPercent}}%;"></view>
                </view>
                <text class="dev-summary">{{personaMatch.summary}}</text>
              </block>

              <block wx:else>
                <view class="dev-empty">
                  <view class="dev-empty-grid">
                    <view class="dev-col">
                      <text class="dev-label">校准协议</text>
                      <text class="dev-type dev-type-blue">{{mbti.mbtiType || '---'}}</text>
                    </view>
                    <view class="dev-connector">
                      <view class="dev-arrow dim"></view>
                      <text class="dev-percent dim">--</text>
                    </view>
                    <view class="dev-col">
                      <text class="dev-label">航迹协议</text>
                      <text class="dev-type dev-type-dim">采集中</text>
                    </view>
                  </view>
                  <view class="dev-empty-status">
                    <text class="dev-status-text" wx:if="{{!mbti.calibrated}}">完成协议校准后解锁</text>
                    <text class="dev-status-text" wx:elif="{{battlePersona.sampleSize < 3}}">等待任务样本</text>
                    <text class="dev-status-text" wx:else>数据计算中</text>
                    <text class="dev-status-hint" wx:if="{{!mbti.calibrated || battlePersona.sampleSize < 3}}">完成 3 次封存后自动生成</text>
                  </view>
                </view>
              </block>
            </view>

            <!-- 协议演化 -->
            <view class="analysis-section">
              <view class="analysis-section-header">
                <text class="analysis-section-title">协议演化</text>
              </view>

              <block wx:if="{{evolution.length > 0}}">
                <view class="evo-timeline">
                  <view class="evo-item" wx:for="{{evolution}}" wx:key="date">
                    <view class="evo-dot {{index === 0 ? 'evo-dot-current' : ''}}"></view>
                    <view class="evo-line" wx:if="{{index < evolution.length - 1}}"></view>
                    <view class="evo-content">
                      <text class="evo-date">{{item.date}}</text>
                      <text class="evo-type">{{item.type}}</text>
                      <text class="evo-deviation">偏差 {{item.deviation}}%</text>
                    </view>
                  </view>
                </view>
              </block>

              <block wx:else>
                <view class="evo-empty">
                  <text class="evo-empty-text">协议演化轨迹将在多次校准后生成</text>
                  <text class="evo-empty-hint">每次校准将记录一次快照</text>
                </view>
              </block>
            </view>

          </view>
        </view>
      </view>

      <!-- 底部占位：action dock + tabbar + safe area -->
      <view class="mirror-bottom-spacer"></view>
    </view>

  </block>

  <!-- ==================== CALIBRATION 视图 ==================== -->
  <block wx:if="{{calibrationVisible}}">
    <view class="calibration-shell {{calibrationEntering ? 'calibration-shell--entering' : 'calibration-shell--active'}}" style="padding-top: {{customNavHeight + 16}}px;">
      <view class="ar-cockpit-console console-show">
        
        <!-- Part 1: 悬空屏幕 (Floating HUD Screen) -->
        <view class="ar-floating-screen">
          <!-- 背景层，独立负责裁剪扫描线与网格 -->
          <view class="ar-screen-bg">
            <view class="ar-screen-grid"></view>
            <view class="ar-screen-scanlines"></view>
          </view>
          
          <!-- AR 定位角 -->
          <view class="ar-hud-angle ar-hud-tl"></view>
          <view class="ar-hud-angle ar-hud-tr"></view>
          <view class="ar-hud-angle ar-hud-bl"></view>
          <view class="ar-hud-angle ar-hud-br"></view>
          
          <!-- AR 顶部系统状态栏 -->
          <view class="ar-top-bar">
            <view class="ar-system-dot"></view>
            <text class="ar-system-title">协议评测终端</text>
            <view class="ar-close-btn" bindtap="closeMbtiTest">
              <sr-hatch-close bind:close="closeMbtiTest" reduceMotion="{{reduceMotion}}" />
            </view>
          </view>
          
          <!-- 重新校准内容区 -->
          <view class="ar-content-split">
            <!-- 提交完成面板 -->
            <view class="cal-submit-panel" wx:if="{{calibrationSubmitting}}">
              <view class="cal-submit-ring {{reduceMotion ? '' : 'cal-ring-spin'}}"></view>
              <view class="cal-submit-terminal">
                <view class="cal-submit-line cal-submit-line--{{item.status}}" wx:for="{{calibrationSubmitStepViews}}" wx:key="text">
                  <text class="cal-status-dot"></text>
                  <text class="cal-line-text">{{item.text}}</text>
                </view>
              </view>
              <text class="cal-submit-error" wx:if="{{calibrationError}}">{{calibrationError}}</text>
            </view>

            <!-- 内嵌 mbti-swipe-test -->
            <view class="cal-test-wrap" wx:if="{{!calibrationSubmitting}}">
              <mbti-swipe-test
                id="mbtiSwipeTest"
                reduceMotion="{{reduceMotion}}"
                bind:complete="handleMbtiComplete"
              />
            </view>
          </view>
          
        </view> <!-- End of Floating Screen -->
        
      </view>

      <!-- 答题按钮，平级放在 calibration-shell 下，完美避免 transform 包含块劫持 -->
      <view class="swipe-actions" wx:if="{{!calibrationSubmitting}}">
        <!-- 不符合 -->
        <view class="action-btn-hardware hw-btn-adjust hw-btn-left" bindtap="handleCalibrationLeft" title="不符合">
          <view class="crystal-decor crystal-decor-l"></view>
          <view class="crystal-decor crystal-decor-r"></view>
          <view class="hw-btn-icon-arrow-left"></view>
        </view>
        
        <!-- 符合 -->
        <view class="action-btn-hardware hw-btn-adjust hw-btn-right" bindtap="handleCalibrationRight" title="符合">
          <view class="crystal-decor crystal-decor-l"></view>
          <view class="crystal-decor crystal-decor-r"></view>
          <view class="hw-btn-icon-arrow-right"></view>
        </view>
      </view>
    </view>
  </block>

  <!-- 固定操作栏：三按钮（tabbar 上方） -->
  <view class="mirror-action-dock {{reduceMotion ? '' : 'dock-glow'}}" wx:if="{{mainVisible && !calibrationVisible && mbti.calibrated}}">
    <view class="dock-btn dock-btn-primary" bindtap="generateDossier">
      <text class="dock-btn-text">生成镜像图片</text>
    </view>
    <view class="dock-btn" bindtap="startFullCalibration">
      <text class="dock-btn-text">重新校准</text>
    </view>
    <view class="dock-btn dock-btn-ghost" bindtap="openMbtiPicker">
      <text class="dock-btn-text">修改协议</text>
    </view>
  </view>

  <!-- MBTI 直接输入 -->
  <mbti-picker-modal
    wx:if="{{showMbtiPicker}}"
    id="mbtiPicker"
    reduceMotion="{{reduceMotion}}"
    customNavHeight="{{customNavHeight}}"
    syncState="{{pickerSyncState}}"
    errorText="{{pickerError}}"
    bind:confirm="handleMbtiDirectInput"
    bind:close="closeMbtiPicker"
  />

  <!-- 退出确认弹窗 -->
  <terminal-popup
    wx:if="{{showExitConfirm}}"
    visible="{{showExitConfirm}}"
    title="退出校准"
    content="本次校准尚未写入协议，确认退出？"
    cancelText="继续校准"
    confirmText="确认退出"
    confirmType="danger"
    reduceMotion="{{reduceMotion}}"
    bind:cancel="onExitCancel"
    bind:confirm="onExitConfirm"
  />

  <!-- 隐藏 Canvas -->
  <canvas type="2d" id="personaCardCanvas" class="persona-card-canvas"></canvas>

  <!-- 预览弹窗 -->
  <view wx:if="{{isCardPreview}}" class="card-preview-mask" catchtouchmove="noop">
    <view class="card-preview-panel">
      <view class="preview-head">
        <text class="preview-title">镜像档案卡</text>
        <sr-hatch-close bind:close="closeCardPreview" reduceMotion="{{reduceMotion}}" />
      </view>
      <image class="preview-img" src="{{cardTempPath}}" mode="widthFix" />
      <view class="preview-actions">
        <view class="preview-btn preview-btn-primary" bindtap="saveCard">
          <text class="preview-btn-text">保存镜像卡</text>
        </view>
        <button class="preview-btn preview-btn-share" open-type="share">
          <text class="preview-btn-text">发送给朋友</text>
        </button>
        <view class="preview-btn" bindtap="closeCardPreview">
          <text class="preview-btn-text">关闭预览</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 生成扫描匣 -->
  <view class="card-scan-layer" wx:if="{{cardOverlayVisible && !isCardPreview}}" catchtouchmove="noop">
    <view class="card-scan-box">
      <view class="card-scan-ring {{reduceMotion ? '' : 'card-scan-ring-spin'}}"></view>
      <text class="card-scan-title">镜像图片生成中</text>
      <view class="card-scan-terminal">
        <view class="card-scan-line card-scan-line--{{item.status}}" wx:for="{{cardScanStepViews}}" wx:key="text">
          <text class="scan-status-dot"></text>
          <text class="scan-line-text">{{item.text}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 镜像卡错误态 -->
  <view class="card-error-layer" wx:if="{{cardError}}" catchtouchmove="noop">
    <view class="card-error-box">
      <text class="card-error-title">镜像图片生成失败</text>
      <text class="card-error-hint">请稍后重试</text>
      <view class="card-error-actions">
        <view class="term-btn-sm" bindtap="retryCard">重新生成</view>
        <view class="term-btn-sm ghost" bindtap="closeCardError">关闭</view>
      </view>
    </view>
  </view>

  <!-- 权限确认弹窗 -->
  <terminal-popup
    wx:if="{{showPermDialog}}"
    visible="{{showPermDialog}}"
    title="需要相册权限"
    content="保存镜像图片需要相册访问权限。"
    cancelText="取消"
    confirmText="去设置"
    confirmType="primary"
    reduceMotion="{{reduceMotion}}"
    bind:cancel="onPermCancel"
    bind:confirm="onPermConfirm"
  />

  <!-- 终端 Toast -->
  <sr-toast id="srToast" reduceMotion="{{reduceMotion}}" />

</view>

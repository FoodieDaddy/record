<view class="mirror-page {{reduceMotion ? 'reduce-motion' : ''}}">

  <!-- Loading Skeleton -->
  <block wx:if="{{loading}}">
    <view class="skeleton-card primary"></view>
    <view class="skeleton-card secondary"></view>
  </block>

  <block wx:else>

    <!-- 隐藏菜单触发 -->
    <view class="menu-anchor">
      <view class="menu-dot" bindtap="toggleMenu">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
      <view class="menu-popup" wx:if="{{showMenu}}" catchtap="closeMenu">
        <view class="menu-item" catchtap="refreshProfile">同步人格</view>
        <view class="menu-item" catchtap="recalcPersona">重新计算画像</view>
      </view>
    </view>

    <!-- 1. 人格档案 -->
    <view class="card identity-card">

      <!-- 未校准 -->
      <block wx:if="{{!mbti.calibrated}}">
        <view class="card-kicker">PERSONA FILE</view>
        <view class="card-title">人格档案</view>
        <view class="card-desc">未完成人格校准</view>
        <view class="card-hint">完成 20 个快速判断，建立你的初始博弈人格模型。</view>
        <view class="card-actions">
          <view class="primary-btn" bindtap="startMbtiTest">20题校准</view>
          <view class="ghost-btn" bindtap="openMbtiPicker">直接输入</view>
        </view>
      </block>

      <!-- 已校准 -->
      <block wx:else>
        <view class="card-kicker">PERSONA FILE</view>
        <view class="id-row">
          <text class="id-type">{{mbti.mbtiType}}</text>
          <text class="id-title">{{mbti.mbtiTitle}}</text>
        </view>

        <view class="id-meta">
          <text class="id-confidence">置信度 {{mbti.confidence}}%</text>
          <text class="id-time" wx:if="{{mbti.updatedAtShort}}">更新于 {{mbti.updatedAtShort}}</text>
        </view>

        <!-- 认知特征胶囊 -->
        <view class="trait-row" wx:if="{{traits.length > 0}}">
          <view class="trait-tag" wx:for="{{traits}}" wx:key="*this">
            <text class="trait-text">{{item}}</text>
          </view>
        </view>

        <view class="card-actions compact">
          <view class="ghost-btn-sm" bindtap="startMbtiTest">重新测试</view>
          <view class="ghost-btn-sm" bindtap="openMbtiPicker">修改人格</view>
        </view>
      </block>
    </view>

    <!-- 2. 战绩镜像 -->
    <view class="card battle-card">

      <view class="card-kicker">BATTLE MIRROR</view>
      <view class="card-title">战绩镜像</view>

      <!-- 雷达图 -->
      <view class="radar-wrap">
        <radar-chart
          id="radarChart"
          dimensions="{{radarDimensions}}"
          size="{{480}}"
          reduceMotion="{{reduceMotion}}"
          locked="{{radarLocked}}"
        />
      </view>

      <!-- 锁定态：雷达下方 -->
      <view class="lock-hint-area" wx:if="{{radarLocked}}">
        <text class="lock-label">LOCKED</text>
        <text class="lock-desc">完成 3 场结算后解锁打法雷达</text>
        <text class="lock-sample">当前：{{battlePersona.sampleSize}} / 3</text>
      </view>

      <!-- 解锁后：标签 + 指标 -->
      <block wx:if="{{!radarLocked}}">
        <view class="battle-tag">
          <text class="tag-name">{{battlePersona.title}}</text>
          <text class="tag-sample">最近 {{battlePersona.sampleSize}} 场</text>
        </view>
        <view class="stat-row" wx:if="{{radarDimensions.length > 0}}">
          <view class="stat-item" wx:for="{{radarDimensions}}" wx:key="key">
            <text class="stat-label">{{item.label}}</text>
            <text class="stat-val">{{item.value}}</text>
          </view>
        </view>
      </block>
    </view>

    <!-- 3. 人格一致性 -->
    <view class="card match-card">
      <view class="card-kicker">PERSONA MATCH</view>
      <view class="card-title">人格一致性</view>

      <block wx:if="{{personaMatch.available}}">
        <view class="match-score-row">
          <text class="match-score">{{personaMatch.matchPercentage}}</text>
          <text class="match-unit">%</text>
        </view>
        <view class="match-detail">
          <view class="match-line">
            <text class="match-label">人格预测</text>
            <text class="match-val">{{personaMatch.prediction}}</text>
          </view>
          <view class="match-line">
            <text class="match-label">实际表现</text>
            <text class="match-val">{{personaMatch.actualSummary}}</text>
          </view>
        </view>
        <text class="match-summary">{{personaMatch.summary}}</text>
      </block>

      <block wx:else>
        <view class="match-empty">
          <text class="match-empty-text" wx:if="{{!mbti.calibrated}}">完成人格校准后解锁</text>
          <text class="match-empty-text" wx:elif="{{battlePersona.sampleSize < 3}}">等待战绩数据</text>
          <text class="match-empty-text" wx:else>数据计算中</text>
        </view>
      </block>
    </view>

    <!-- 4. 分享画像 -->
    <view class="cta-area">
      <view class="cta-btn" bindtap="shareRadarPoster">
        <text class="cta-text">分享画像</text>
      </view>
    </view>

  </block>

  <!-- MBTI 滑动测试 -->
  <mbti-swipe-test
    wx:if="{{showSwipeTest}}"
    reduceMotion="{{reduceMotion}}"
    bind:complete="handleMbtiComplete"
    bind:close="closeMbtiTest"
  />

  <!-- MBTI 直接输入 -->
  <mbti-picker-modal
    wx:if="{{showMbtiPicker}}"
    reduceMotion="{{reduceMotion}}"
    bind:confirm="handleMbtiDirectInput"
    bind:close="closeMbtiPicker"
  />

</view>

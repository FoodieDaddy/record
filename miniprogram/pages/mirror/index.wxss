/* 镜像首页样式 */
.mirror-page {
  min-height: 100vh;
  background: #0a0a0a;
  padding: 0 32rpx 120rpx;
  position: relative;
}

.mirror-page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(10, 132, 255, 0.06) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* Header */
.mirror-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 40rpx 0 32rpx;
  position: relative;
  z-index: 1;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 4rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.34);
  letter-spacing: 6rpx;
  margin-top: 8rpx;
  text-transform: uppercase;
}

.archive-entry {
  font-size: 28rpx;
  color: #0A84FF;
  padding: 12rpx 24rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.3);
  border-radius: 12rpx;
}

/* Section */
.section {
  margin-top: 48rpx;
  position: relative;
  z-index: 1;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
}

.section-meta {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.34);
  letter-spacing: 4rpx;
}

/* Tool Grid */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

/* Advanced List */
.advanced-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.advanced-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
}

.advanced-row.locked {
  opacity: 0.4;
}

.advanced-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.advanced-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.92);
}

.advanced-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.34);
}

.advanced-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.34);
}

.advanced-lock {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.34);
}

/* Recent List */
.recent-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.recent-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
}

.recent-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.recent-tool {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.34);
}

.recent-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.92);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  margin-left: 16rpx;
}

.recent-tag {
  font-size: 20rpx;
  color: #0A84FF;
  padding: 4rpx 12rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.3);
  border-radius: 8rpx;
}

.recent-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.34);
}

/* Empty State */
.empty-state {
  padding: 80rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.34);
}

/* Disclaimer */
.disclaimer {
  margin-top: 64rpx;
  padding: 24rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.disclaimer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.2);
}

/* Skeleton */
.skeleton-card {
  height: 200rpx;
  margin-top: 32rpx;
  border-radius: 24rpx;
}

.skeleton-grid {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.skeleton-item {
  flex: 1;
  height: 160rpx;
  border-radius: 16rpx;
}

.skeleton {
  background: rgba(255, 255, 255, 0.04);
  animation: shimmer 1.5s infinite;
}

/* Reduce Motion */
.reduce-motion * {
  animation: none !important;
  transition: none !important;
}

@keyframes shimmer {
  0% { opacity: 0.4; }
  50% { opacity: 0.8; }
  100% { opacity: 0.4; }
}

/* ---- 根容器：可滚动 ---- */
.mirror-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 28rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background:
    radial-gradient(circle at 18% 0%, rgba(10, 132, 255, 0.08), transparent 32%),
    radial-gradient(circle at 92% 12%, rgba(94, 92, 230, 0.06), transparent 30%),
    #0A0A0A;
  color: rgba(255, 255, 255, 0.92);
}

/* ---- 通用卡片 ---- */
.card {
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  padding: 24rpx 26rpx;
  margin-bottom: 16rpx;
}

.card-kicker {
  font-size: 18rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.30);
  text-transform: uppercase;
}

.card-title {
  margin-top: 4rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.88);
}

.card-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.72);
}

.card-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.5;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.card-actions.compact {
  margin-top: 14rpx;
}

/* ---- 隐藏菜单 ---- */
.menu-anchor {
  position: relative;
  display: flex;
  justify-content: flex-end;
  margin-bottom: 8rpx;
}

.menu-dot {
  display: flex;
  gap: 6rpx;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
}

.dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.35);
}

.menu-popup {
  position: absolute;
  top: 100%;
  right: 0;
  z-index: 20;
  min-width: 200rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  background: rgba(30, 30, 30, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 8rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.5);
}

.menu-item {
  padding: 16rpx 28rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.80);
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.06);
}

/* ---- 人格档案 ---- */
.identity-card .id-row {
  margin-top: 12rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.id-type {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.95);
}

.id-title {
  font-size: 24rpx;
  color: rgba(10, 132, 255, 0.80);
}

.id-meta {
  margin-top: 8rpx;
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.40);
}

.id-confidence {
  color: rgba(255, 255, 255, 0.45);
}

/* 认知特征胶囊 */
.trait-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.trait-tag {
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.03);
  display: flex;
  align-items: center;
}

.trait-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

/* 按钮 */
.primary-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 18rpx;
  background: #0A84FF;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.ghost-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.03);
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
}

.ghost-btn-sm {
  flex: 1;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.02);
  color: rgba(255, 255, 255, 0.60);
  font-size: 24rpx;
}

.ghost-btn-sm:active {
  background: rgba(255, 255, 255, 0.06);
}

/* ---- 战绩镜像 ---- */
.battle-card .card-title {
  margin-bottom: 4rpx;
}

.radar-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

/* 锁定态 */
.lock-hint-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0 4rpx;
}

.lock-label {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: rgba(255, 255, 255, 0.20);
}

.lock-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.40);
}

.lock-sample {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.25);
}

/* 解锁后 */
.battle-tag {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  margin-top: 4rpx;
}

.tag-name {
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.85);
}

.tag-sample {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.35);
}

.stat-row {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.40);
}

.stat-val {
  margin-top: 4rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(0, 212, 255, 0.85);
  font-variant-numeric: tabular-nums;
}

/* ---- 人格一致性 ---- */
.match-score-row {
  margin-top: 16rpx;
  display: flex;
  align-items: baseline;
}

.match-score {
  font-size: 56rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.92);
  font-variant-numeric: tabular-nums;
}

.match-unit {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.45);
  margin-left: 4rpx;
}

.match-detail {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.match-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.match-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.40);
}

.match-val {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
  font-weight: 500;
}

.match-summary {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.50);
  line-height: 1.5;
}

/* 匹配度为空态 */
.match-empty {
  margin-top: 20rpx;
  padding: 24rpx 0;
  display: flex;
  justify-content: center;
}

.match-empty-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.30);
}

/* ---- CTA 按钮 ---- */
.cta-area {
  margin-bottom: env(safe-area-inset-bottom);
}

.cta-btn {
  width: 100%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.03);
}

.cta-btn:active {
  background: rgba(255, 255, 255, 0.06);
}

.cta-text {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 2rpx;
}

/* ---- Skeleton ---- */
.skeleton-card {
  height: 200rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  margin-bottom: 16rpx;
  animation: shimmer 1.5s infinite;
}

.skeleton-card.secondary {
  height: 300rpx;
}

@keyframes shimmer {
  0% { opacity: 0.4; }
  50% { opacity: 0.7; }
  100% { opacity: 0.4; }
}

.reduce-motion .skeleton-card {
  animation: none !important;
}

.reduce-motion {
  animation: none !important;
  transition: none !important;
}

<view class="tool-page">
  <view class="tool-header">
    <text class="tool-name">{{config.name}}</text>
    <text class="tool-subtitle">{{config.subtitle}}</text>
  </view>

  <!-- 问题输入 -->
  <view class="form-section" wx:if="{{config.hasQuestion}}">
    <text class="form-label">你的问题</text>
    <textarea class="form-textarea" placeholder="输入你想问的问题..." value="{{question}}" bindinput="onQuestionInput" maxlength="200" />
  </view>

  <!-- 方法选择 -->
  <view class="form-section" wx:if="{{config.methods}}">
    <text class="form-label">起卦方式</text>
    <view class="method-group">
      <view
        wx:for="{{config.methods}}"
        wx:key="value"
        class="method-btn {{method === item.value ? 'active' : ''}}"
        bindtap="onMethodChange"
        data-value="{{item.value}}"
      >
        <text class="method-text">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 数字输入 -->
  <view class="form-section" wx:if="{{tool === 'meihua' && method === 'numbers'}}">
    <text class="form-label">两个数字</text>
    <view class="number-row">
      <input class="number-input" type="number" placeholder="数字1" value="{{numbers[0]}}" bindinput="onNumberInput" data-idx="0" />
      <input class="number-input" type="number" placeholder="数字2" value="{{numbers[1]}}" bindinput="onNumberInput" data-idx="1" />
    </view>
  </view>

  <!-- 牌阵选择 (塔罗) -->
  <view class="form-section" wx:if="{{tool === 'tarot'}}">
    <text class="form-label">牌阵</text>
    <view class="method-group">
      <view
        wx:for="{{config.spreads}}"
        wx:key="value"
        class="method-btn {{spread === item.value ? 'active' : ''}}"
        bindtap="onSpreadChange"
        data-value="{{item.value}}"
      >
        <text class="method-text">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 出生信息 -->
  <view wx:if="{{config.needsBirth}}">
    <view class="form-section">
      <text class="form-label">出生日期</text>
      <picker mode="date" value="{{birthDate}}" bindchange="onBirthDateChange">
        <view class="form-picker">{{birthDate || '请选择'}}</view>
      </picker>
    </view>

    <view class="form-section">
      <text class="form-label">出生时间</text>
      <picker mode="time" value="{{birthTime}}" bindchange="onBirthTimeChange">
        <view class="form-picker">{{birthTime || '请选择'}}</view>
      </picker>
    </view>

    <view class="form-section">
      <text class="form-label">性别</text>
      <view class="method-group">
        <view class="method-btn {{gender === 'male' ? 'active' : ''}}" bindtap="onGenderChange" data-value="male">
          <text class="method-text">男</text>
        </view>
        <view class="method-btn {{gender === 'female' ? 'active' : ''}}" bindtap="onGenderChange" data-value="female">
          <text class="method-text">女</text>
        </view>
      </view>
    </view>

    <view class="form-section">
      <text class="form-label">历法</text>
      <view class="method-group">
        <view class="method-btn {{calendarType === 'solar' ? 'active' : ''}}" bindtap="onCalendarChange" data-value="solar">
          <text class="method-text">阳历</text>
        </view>
        <view class="method-btn {{calendarType === 'lunar' ? 'active' : ''}}" bindtap="onCalendarChange" data-value="lunar">
          <text class="method-text">农历</text>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="checkbox-row">
        <switch checked="{{saveBirthProfile}}" bindchange="onSaveBirthChange" color="#0A84FF" />
        <text class="checkbox-label">保存为出生档案</text>
      </view>
    </view>
  </view>

  <!-- 安全提示 -->
  <view class="safety-notice">
    <text class="safety-text">请勿将结果用于金钱决策或高风险行为。</text>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-btn {{submitting ? 'loading' : ''}}" bindtap="onSubmit">
    <text class="submit-text">{{submitting ? '推演中...' : '开始测试'}}</text>
  </view>
</view>

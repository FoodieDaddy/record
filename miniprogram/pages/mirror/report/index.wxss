.report-page {
  min-height: 100vh;
  background: #0a0a0a;
  padding: 0 32rpx 120rpx;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.34);
}

.report-header {
  padding: 40rpx 0 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.report-tool {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.52);
}

.report-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.2);
}

.report-tag-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.report-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid;
  border-radius: 8rpx;
}

.report-source {
  font-size: 22rpx;
  color: rgba(255, 159, 10, 0.7);
}

.report-title-row {
  margin-bottom: 32rpx;
}

.report-title {
  font-size: 40rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
}

.report-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.34);
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.card-value {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.6;
}

.card-value.summary {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.72);
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.list-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.72);
  padding-left: 20rpx;
  position: relative;
}

.list-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 14rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.suggestion::before {
  background: #0A84FF;
}

.warning::before {
  background: #FF9F0A;
}

.raw-section {
  margin-top: 32rpx;
}

.raw-toggle {
  text-align: center;
  padding: 16rpx;
}

.raw-toggle-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.34);
}

.raw-content {
  background: rgba(255, 255, 255, 0.02);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 12rpx;
}

.raw-json {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.34);
  word-break: break-all;
  font-family: 'SF Mono', monospace;
}

.disclaimer {
  margin-top: 48rpx;
  padding: 24rpx;
  text-align: center;
}

.disclaimer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.2);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
  gap: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.34);
}

.back-btn {
  padding: 16rpx 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 12rpx;
}

.back-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.52);
}

<view class="settings-page {{!animationEnabled ? 'reduce-motion' : ''}}">
  <!-- 系统协议面板 -->
  <view class="sp-panel">
    <view class="sp-panel__head">
      <text class="sp-panel__kicker">SYSTEM PROTOCOL</text>
      <text class="sp-panel__title">系统协议</text>
    </view>
    <view class="sp-panel__divider"></view>

    <!-- 声音协议 -->
    <view class="sys-row">
      <view class="sys-row__label-group">
        <text class="sys-row__label-zh">声音协议</text>
        <text class="sys-row__label-en">VOICE</text>
      </view>
      <view class="avionics-switch {{voiceEnabled ? 'avionics-switch--on' : ''}}" bindtap="onVoiceToggle">
        <view class="avionics-switch__track {{voiceEnabled ? 'is-on' : ''}}">
          <view class="avionics-switch__thumb"></view>
        </view>
        <text class="avionics-switch__status">{{voiceEnabled ? 'ACTIVE' : 'OFF'}}</text>
      </view>
    </view>

    <!-- 音色选择入口 -->
    <view class="sys-row sys-row--sub {{voiceEnabled ? '' : 'sys-row--hidden'}}" bindtap="openVoiceSheet">
      <view class="sys-row__label-group">
        <text class="sys-row__label-zh">音色选择</text>
        <text class="sys-row__label-en">TIMBRE</text>
      </view>
      <view class="sys-row__value">
        <text class="sys-row__value-text">{{voiceName}}</text>
        <view class="svg-icon svg-icon--arrow"></view>
      </view>
    </view>

    <!-- 动效协议 -->
    <view class="sys-row">
      <view class="sys-row__label-group">
        <text class="sys-row__label-zh">动效协议</text>
        <text class="sys-row__label-en">FX</text>
      </view>
      <view class="avionics-switch {{animationEnabled ? 'avionics-switch--on' : ''}}" bindtap="onAnimationToggle">
        <view class="avionics-switch__track {{animationEnabled ? 'is-on' : ''}}">
          <view class="avionics-switch__thumb"></view>
        </view>
        <text class="avionics-switch__status">{{animationEnabled ? 'ACTIVE' : 'OFF'}}</text>
      </view>
    </view>

    <!-- 触感协议 -->
    <view class="sys-row sys-row--last">
      <view class="sys-row__label-group">
        <text class="sys-row__label-zh">触感协议</text>
        <text class="sys-row__label-en">HAPTIC</text>
      </view>
      <view class="avionics-switch {{vibrateEnabled ? 'avionics-switch--on' : ''}}" bindtap="onVibrateToggle">
        <view class="avionics-switch__track {{vibrateEnabled ? 'is-on' : ''}}">
          <view class="avionics-switch__thumb"></view>
        </view>
        <text class="avionics-switch__status">{{vibrateEnabled ? 'ACTIVE' : 'OFF'}}</text>
      </view>
    </view>
  </view>

  <!-- 音色选择抽屉 -->
  <view class="voice-sheet-mask {{voiceSheetVisible ? 'voice-sheet-mask--show' : ''}}" bindtap="closeVoiceSheet"></view>
  <view class="voice-sheet {{voiceSheetVisible ? 'voice-sheet--show' : ''}}">
    <view class="voice-sheet__handle"></view>
    <view class="voice-sheet__title">声音协议</view>
    <view class="voice-sheet__body">
      <!-- 左侧分类 -->
      <scroll-view class="voice-sheet__cat-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          class="voice-sheet__cat-item {{activeVoiceCatId === item.id ? 'voice-sheet__cat-item--active' : ''}}"
          wx:for="{{voiceCategories}}"
          wx:key="id"
          data-cat-id="{{item.id}}"
          bindtap="onCatTap"
        >{{item.name}}</view>
      </scroll-view>
      <!-- 右侧音色列表 -->
      <scroll-view
        class="voice-sheet__voice-list"
        scroll-y
        enhanced
        show-scrollbar="{{false}}"
        scroll-into-view="{{scrollToCat}}"
        scroll-with-animation
      >
        <block wx:for="{{voiceCategories}}" wx:key="id" wx:for-item="cat" wx:for-index="catIdx">
          <view class="voice-sheet__group-header" id="cat-{{cat.id}}">{{cat.name}}</view>
          <view
            class="voice-sheet__voice-item {{item.id === selectedVoiceId ? 'voice-sheet__voice-item--active' : ''}} {{playingVoiceId === item.id ? 'voice-sheet__voice-item--playing' : ''}}"
            wx:for="{{cat.voices}}"
            wx:key="id"
            data-voice="{{item}}"
            data-cat-id="{{cat.id}}"
            bindtap="onVoiceTap"
          >
            <view class="voice-sheet__voice-info">
              <text class="voice-sheet__voice-name">{{item.name}}</text>
              <text class="voice-sheet__voice-desc">{{item.desc}}</text>
            </view>
            <view class="voice-sheet__voice-right">
              <view class="voice-sheet__wave" wx:if="{{playingVoiceId === item.id}}">
                <view class="voice-sheet__wave-bar"></view>
                <view class="voice-sheet__wave-bar"></view>
                <view class="voice-sheet__wave-bar"></view>
              </view>
              <view class="voice-sheet__check" wx:elif="{{item.id === selectedVoiceId}}"></view>
            </view>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>
</view>

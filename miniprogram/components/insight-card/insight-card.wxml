<view class="insight-card">
  <!-- 卡片头部 -->
  <view class="insight-card__header">
    <view class="insight-card__icon-wrap {{typeClass}}">
      <view class="svg-icon svg-icon--{{icon}}"></view>
    </view>
    <text class="insight-card__title">{{title}}</text>
    <text class="insight-card__en">{{en}}</text>
  </view>

  <!-- 卡片内容 -->
  <view class="insight-card__body">
    <!-- 主数值/状态行 -->
    <view wx:if="{{primaryText}}" class="insight-card__primary">
      <text class="insight-card__primary-text {{primaryClass || ''}}">{{primaryText}}</text>
      <text wx:if="{{primaryHint}}" class="insight-card__primary-hint">{{primaryHint}}</text>
    </view>

    <!-- 描述文本 -->
    <text wx:if="{{description}}" class="insight-card__desc">{{description}}</text>

    <!-- 标签列表 -->
    <view wx:if="{{tags.length > 0}}" class="insight-card__tags">
      <text class="insight-card__tag {{item.type || ''}}" wx:for="{{tags}}" wx:key="index">{{item.text}}</text>
    </view>

    <!-- 数据行 -->
    <view wx:if="{{metrics.length > 0}}" class="insight-card__metrics">
      <view class="insight-card__metric" wx:for="{{metrics}}" wx:key="index">
        <text class="insight-card__metric-value {{item.valueClass || ''}}">{{item.value}}</text>
        <text class="insight-card__metric-label">{{item.label}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view wx:if="{{actionText}}" class="insight-card__action" bindtap="onActionTap">
      <text class="insight-card__action-text">{{actionText}}</text>
      <view class="svg-icon svg-icon--arrow"></view>
    </view>
  </view>
</view>

<view class="modal-mask" wx:if="{{visible}}" bindtap="onClose">
  <view class="modal-body" catchtap="">
    <!-- 得分方信息 -->
    <view class="target-user">
      <view class="target-avatar" style="background:{{targetColor}};">
        <text class="target-char">{{targetChar}}</text>
      </view>
      <text class="target-name">{{targetName}}</text>
      <text class="text-tertiary text-xs">得分方</text>
    </view>

    <!-- 分值输入 -->
    <view class="amount-section">
      <input class="amount-input" type="digit" value="{{amount}}" bindinput="onAmountInput" placeholder="输入分值" focus="{{visible}}" />
    </view>

    <!-- 快捷分值 -->
    <view class="quick-amounts">
      <view class="quick-btn" wx:for="{{quickAmounts}}" wx:key="*this" bindtap="onQuickAmount" data-value="{{item}}">
        +{{item}}
      </view>
    </view>

    <!-- 备注 -->
    <input class="remark-input" value="{{remark}}" bindinput="onRemarkInput" placeholder="添加备注（可选）" maxlength="50" />

    <!-- 操作按钮 -->
    <view class="modal-actions">
      <button class="btn-cancel" bindtap="onClose">取消</button>
      <button class="btn-confirm" bindtap="onConfirm" disabled="{{!canConfirm}}">
        确认计分
      </button>
    </view>
  </view>
</view>

.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(4, 8, 16, 0);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  transition: background 0.3s ease;
  pointer-events: none;
}

.picker-overlay.overlay-show {
  background: rgba(4, 8, 16, 0.72);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  pointer-events: auto;
}

/* ---- 退出确认遮罩 ---- */
.exit-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(4, 8, 16, 0.94);
  z-index: 1500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s;
  border-radius: 20rpx;
}

.exit-overlay.exit-active {
  opacity: 1;
  pointer-events: auto;
}

.exit-dialog {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 48rpx 40rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 175, 255, 0.24);
  background: rgba(10, 16, 28, 0.95);
  box-shadow: 0 0 30rpx rgba(0, 175, 255, 0.15);
}

.exit-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.exit-msg {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}

.exit-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
  width: 100%;
}

.exit-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.exit-btn-cancel {
  border: 1rpx solid rgba(0, 175, 255, 0.35);
  background: rgba(0, 175, 255, 0.08);
  color: rgba(0, 175, 255, 0.90);
}

.exit-btn-confirm {
  border: 1rpx solid rgba(255, 69, 58, 0.24);
  background: transparent;
  color: rgba(255, 69, 58, 0.80);
}

/* ---- 驾驶舱全息总控容器 (无背景大框，让内部独立悬浮) ---- */
.ar-cockpit-console {
  width: 690rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  position: relative;
  transform: scale(0.92) translateY(80rpx);
  opacity: 0;
  transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s;
}

.picker-overlay.overlay-show .ar-cockpit-console {
  transform: scale(1) translateY(0);
  opacity: 1;
}

/* ---- Part 1: 悬空全息屏幕 (The Floating Screen) ---- */
.ar-floating-screen {
  width: 100%;
  background: rgba(10, 16, 28, 0.72);
  border: 1rpx solid rgba(0, 175, 255, 0.22);
  border-radius: 20rpx;
  padding: 0 0 32rpx 0;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.5), inset 0 0 24rpx rgba(0, 175, 255, 0.06);
}

/* ---- AR HUD 定位角 ---- */
.ar-hud-angle {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  border-color: rgba(0, 175, 255, 0.45);
  border-style: solid;
  pointer-events: none;
  z-index: 3;
}

.ar-hud-tl { top: 12rpx; left: 12rpx; border-width: 3rpx 0 0 3rpx; }
.ar-hud-tr { top: 12rpx; right: 12rpx; border-width: 3rpx 3rpx 0 0; }
.ar-hud-bl { bottom: 12rpx; left: 12rpx; border-width: 0 0 3rpx 3rpx; }
.ar-hud-br { bottom: 12rpx; right: 12rpx; border-width: 0 3rpx 3rpx 0; }

/* ---- AR 屏幕背景特效 ---- */
.ar-screen-grid {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image: radial-gradient(rgba(0, 175, 255, 0.04) 1px, transparent 1px);
  background-size: 16rpx 16rpx;
  pointer-events: none;
  z-index: 1;
}

.ar-screen-scanlines {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(
    rgba(18, 16, 16, 0) 50%,
    rgba(0, 175, 255, 0.03) 50%
  );
  background-size: 100% 4rpx;
  pointer-events: none;
  z-index: 2;
}

.ar-screen-scanlines::after {
  content: '';
  position: absolute;
  top: -100rpx; left: 0; right: 0; height: 100rpx;
  background: linear-gradient(to bottom, transparent, rgba(0, 175, 255, 0.06), transparent);
  animation: arScan 4.5s linear infinite;
}

@keyframes arScan {
  0% { top: -100rpx; }
  100% { top: 100%; }
}

/* ---- AR 顶部状态栏 ---- */
.ar-top-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 36rpx 12rpx;
  position: relative;
  z-index: 4;
}

.ar-system-dot {
  width: 10rpx;
  height: 10rpx;
  background: #00afff;
  border-radius: 50%;
  margin-right: 12rpx;
  box-shadow: 0 0 10rpx rgba(0, 175, 255, 0.8);
  animation: arBlink 1.5s infinite;
}

.ar-system-title {
  font-size: 16rpx;
  font-weight: 700;
  color: rgba(0, 175, 255, 0.65);
  letter-spacing: 4rpx;
  font-family: 'SF Mono', monospace;
  flex: 1;
}

.ar-close-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

@keyframes arBlink {
  0%, 100% { opacity: 0.35; }
  50% { opacity: 1; }
}

/* ---- 核心分割布局 ---- */
.ar-content-split {
  display: flex;
  flex-direction: column;
  padding: 0 36rpx;
  position: relative;
  z-index: 4;
}

/* ---- 上半区：AR 全息说明 HUD ---- */
.ar-hud-panel {
  background: rgba(0, 175, 255, 0.02);
  border: 1rpx solid rgba(0, 175, 255, 0.12);
  border-radius: 8rpx;
  padding: 24rpx;
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  box-shadow: inset 0 0 20rpx rgba(0, 175, 255, 0.04);
}

.ar-hud-header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 16rpx;
}

.ar-hud-label {
  font-size: 16rpx;
  color: rgba(0, 175, 255, 0.45);
  letter-spacing: 2rpx;
  font-family: monospace;
}

.ar-glow-line {
  height: 1rpx;
  background: linear-gradient(90deg, rgba(0, 175, 255, 0.3), transparent);
}

.ar-profile-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.ar-profile-code {
  font-size: 56rpx;
  font-weight: 800;
  font-family: 'SF Mono', monospace;
  letter-spacing: 4rpx;
  color: var(--text-primary);
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.15);
  transition: color 0.25s, text-shadow 0.25s;
}

.ar-profile-code.ar-code-changed {
  color: #00afff;
  text-shadow: 0 0 16rpx rgba(0, 175, 255, 0.6);
}

.ar-profile-title {
  font-size: 26rpx;
  color: rgba(0, 175, 255, 0.9);
  font-weight: 600;
  letter-spacing: 2rpx;
}

.ar-profile-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.ar-tag {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background: rgba(0, 175, 255, 0.06);
  border: 1rpx solid rgba(0, 175, 255, 0.18);
  color: rgba(0, 175, 255, 0.85);
  letter-spacing: 1rpx;
}

.ar-profile-desc {
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(140, 176, 205, 0.8);
  min-height: 110rpx;
  margin-bottom: 12rpx;
}

.ar-hud-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 16rpx;
  color: rgba(0, 175, 255, 0.3);
  font-family: monospace;
  border-top: 1rpx dashed rgba(0, 175, 255, 0.08);
  padding-top: 10rpx;
}

/* ---- Part 2: 独立悬浮的全息校准轨道面板 (Floating Calibration Controllers) ---- */
.ar-floating-controllers {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  margin-top: 24rpx;
  position: relative;
  z-index: 4;
}

.floating-btn-card {
  background: rgba(10, 16, 28, 0.6);
  border: 1rpx solid rgba(0, 175, 255, 0.12);
  border-radius: 12rpx;
  padding: 0 32rpx;
  height: 108rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25), inset 0 0 16rpx rgba(0, 175, 255, 0.03);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.floating-btn-card:active {
  transform: scale(0.97);
  border-color: rgba(0, 175, 255, 0.35);
  box-shadow: 0 8rpx 28rpx rgba(0, 175, 255, 0.08), inset 0 0 20rpx rgba(0, 175, 255, 0.08);
}

.btn-card-header {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 4rpx;
}

.btn-card-kicker {
  font-size: 16rpx;
  color: rgba(0, 175, 255, 0.35);
  font-family: 'SF Mono', monospace;
  letter-spacing: 1rpx;
}

.btn-card-label {
  font-size: 18rpx;
  color: rgba(140, 176, 205, 0.35);
  letter-spacing: 1rpx;
}

.dim-toggle-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toggle-btn-content {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.toggle-letter {
  font-size: 36rpx;
  font-weight: 800;
  font-family: 'SF Mono', monospace;
  color: #ffffff;
  text-shadow: 0 0 12rpx rgba(0, 175, 255, 0.6), 0 0 2rpx rgba(0, 175, 255, 0.85);
  transition: text-shadow 0.25s ease;
}

.toggle-label {
  font-size: 20rpx;
  color: rgba(0, 175, 255, 0.9);
  transition: color 0.25s ease;
}

.toggle-btn-status {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 20rpx;
  height: 20rpx;
}

.toggle-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #00afff;
  box-shadow: 0 0 10rpx rgba(0, 175, 255, 0.8), 0 0 2rpx rgba(0, 175, 255, 0.9);
  animation: toggleDotPulse 2s infinite;
}

@keyframes toggleDotPulse {
  0%, 100% {
    opacity: 0.6;
    box-shadow: 0 0 6rpx rgba(0, 175, 255, 0.5);
  }
  50% {
    opacity: 1;
    box-shadow: 0 0 14rpx rgba(0, 175, 255, 0.9), 0 0 4rpx rgba(0, 175, 255, 1);
  }
}

/* ---- Part 2: 屏幕下方的独立悬浮物理按键 (Cockpit Control Crystals) ---- */
.ar-console-bottom-hardware {
  margin-top: 36rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 56rpx;
  width: 100%;
}

.hardware-btn {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.hardware-btn:active {
  transform: scale(0.9);
}

/* 放弃按键：极简无字小红色切角圆钮 */
.hw-btn-cancel {
  width: 80rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 69, 58, 0.35);
  background: rgba(255, 69, 58, 0.05);
  box-shadow: 0 0 12rpx rgba(255, 69, 58, 0.04);
}

.hw-btn-cancel:active {
  background: rgba(255, 69, 58, 0.18);
  border-color: rgba(255, 69, 58, 0.6);
  box-shadow: 0 0 20rpx rgba(255, 69, 58, 0.3);
}

/* 纯 CSS 绘制的细线取消叉号 icon */
.hw-btn-icon-close {
  width: 20rpx;
  height: 20rpx;
  position: relative;
}

.hw-btn-icon-close::before,
.hw-btn-icon-close::after {
  content: '';
  position: absolute;
  top: 9rpx;
  left: 0;
  width: 20rpx;
  height: 2rpx;
  background: rgba(255, 69, 58, 0.75);
  transition: background 0.2s;
}

.hw-btn-icon-close::before {
  transform: rotate(45deg);
}

.hw-btn-icon-close::after {
  transform: rotate(-45deg);
}

.hw-btn-cancel:active .hw-btn-icon-close::before,
.hw-btn-cancel:active .hw-btn-icon-close::after {
  background: rgba(255, 69, 58, 1);
}

/* 确认按键：极简无字青蓝色切角方块 */
.hw-btn-confirm {
  width: 140rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(0, 175, 255, 0.45);
  background: rgba(0, 175, 255, 0.08);
  box-shadow: 0 0 16rpx rgba(0, 175, 255, 0.05);
}

.hw-btn-confirm:active {
  background: rgba(0, 175, 255, 0.18);
  border-color: rgba(0, 175, 255, 0.8);
  box-shadow: 0 0 24rpx rgba(0, 175, 255, 0.25);
}

/* 确认按键：系统写入中 (syncing) */
.hw-btn-confirm.hw-syncing {
  border-color: rgba(0, 175, 255, 0.65);
  background: rgba(0, 175, 255, 0.05);
  animation: hwConfirmPulse 1.5s infinite alternate;
}

/* 确认按键：写入成功 (success) */
.hw-btn-confirm.hw-success {
  border-color: rgba(48, 209, 88, 0.55);
  background: rgba(48, 209, 88, 0.08);
  box-shadow: 0 0 20rpx rgba(48, 209, 88, 0.18);
}

/* 确认按键：写入失败 (error) */
.hw-btn-confirm.hw-error {
  border-color: rgba(255, 69, 58, 0.55);
  background: rgba(255, 69, 58, 0.08);
  box-shadow: 0 0 20rpx rgba(255, 69, 58, 0.18);
}

/* 纯 CSS 绘制的细线勾号 icon */
.hw-btn-icon-check {
  width: 22rpx;
  height: 12rpx;
  border-left: 2rpx solid rgba(0, 175, 255, 0.8);
  border-bottom: 2rpx solid rgba(0, 175, 255, 0.8);
  transform: rotate(-45deg);
  margin-top: -4rpx;
}

.hw-btn-confirm:active .hw-btn-icon-check {
  border-color: rgba(0, 175, 255, 1);
}

/* 纯 CSS 写入中 Loading 效果 */
.hw-loading-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid rgba(0, 175, 255, 0.25);
  border-top-color: rgba(0, 175, 255, 0.85);
  border-radius: 50%;
  animation: hwSpinner 0.8s linear infinite;
}

/* 纯 CSS 写入成功绿色勾号 */
.hw-success-check {
  width: 22rpx;
  height: 12rpx;
  border-left: 2rpx solid rgba(48, 209, 88, 0.85);
  border-bottom: 2rpx solid rgba(48, 209, 88, 0.85);
  transform: rotate(-45deg);
  margin-top: -4rpx;
}

/* 纯 CSS 写入失败红色惊叹号 */
.hw-error-excl {
  width: 2rpx;
  height: 16rpx;
  background: rgba(255, 69, 58, 0.85);
  position: relative;
}

.hw-error-excl::after {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: -1rpx;
  width: 3rpx;
  height: 3rpx;
  border-radius: 50%;
  background: rgba(255, 69, 58, 0.85);
}

@keyframes hwSpinner {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes hwConfirmPulse {
  0% { box-shadow: 0 0 8rpx rgba(0, 175, 255, 0.1); }
  100% { box-shadow: 0 0 24rpx rgba(0, 175, 255, 0.25); }
}

/* ---- Reduce Motion ---- */
.reduce-motion {
  transition: none !important;
}

.reduce-motion .picker-overlay,
.reduce-motion .ar-cockpit-console {
  transition: none !important;
  transform: none !important;
}

.reduce-motion .dim-btn {
  transition: none;
}

.reduce-motion .selection-type {
  transition: none;
}

.reduce-motion .exit-overlay {
  transition: none;
}

.reduce-motion .hardware-btn {
  transition: none !important;
  transform: none !important;
}

.reduce-motion .hw-loading-spinner {
  animation: none;
}

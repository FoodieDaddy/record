.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #05070A;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
}

/* ---- 同步动画遮罩 ---- */
.sync-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(5, 7, 10, 0.97);
  z-index: 2000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.sync-overlay.sync-active {
  opacity: 1;
  pointer-events: auto;
}

.sync-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 175, 255, 0.30);
  border-top-color: var(--color-cyan)
  animation: syncRingSpin 1.2s linear infinite;
}

@keyframes syncRingSpin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.sync-terminal {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: center;
}

.sync-line {
  font-size: 22rpx;
  font-family: 'SF Mono', 'Courier New', monospace;
  letter-spacing: 2rpx;
  color: rgba(0, 175, 255, 0.00);
  transition: color 0.4s;
}

.sync-line-show {
  color: rgba(0, 175, 255, 0.80);
}

/* ---- 退出确认遮罩 ---- */
.exit-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(5, 7, 10, 0.92);
  z-index: 1500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s;
}

.exit-overlay.exit-active {
  opacity: 1;
  pointer-events: auto;
}

.exit-dialog {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 48rpx 40rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 175, 255, 0.15);
  background: rgba(10, 15, 24, 0.95);
}

.exit-kicker {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 69, 58, 0.70);
}

.exit-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.exit-msg {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}

.exit-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
  width: 100%;
}

.exit-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.exit-btn-cancel {
  border: 1rpx solid rgba(0, 175, 255, 0.35);
  background: rgba(0, 175, 255, 0.08);
  color: rgba(0, 175, 255, 0.90);
}

.exit-btn-confirm {
  border: 1rpx solid rgba(255, 69, 58, 0.24);
  background: transparent;
  color: rgba(255, 69, 58, 0.80);
}

/* ---- 头部 ---- */
.picker-header {
  padding: 80rpx 0 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.picker-header-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.picker-kicker {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(10, 132, 255, 0.60);
  text-transform: uppercase;
}

.picker-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.picker-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
  padding-bottom: 20rpx;
}

.picker-divider {
  height: 1rpx;
  background: linear-gradient(90deg, rgba(0, 175, 255, 0.15), rgba(255, 255, 255, 0.06), transparent);
}

/* ---- 滚动区 ---- */
.picker-scroll {
  flex: 1;
  overflow: hidden;
}

.picker-body {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding: 28rpx 0 120rpx;
}

/* ---- 人格矩阵 ---- */
.matrix-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.matrix-kicker {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(0, 175, 255, 0.50);
}

.matrix-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.dim-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dim-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dim-row-label {
  font-size: 22rpx;
  color: rgba(140, 176, 205, 0.38);
  letter-spacing: 2rpx;
}

.dim-btns {
  display: flex;
  gap: 20rpx;
}

.dim-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(126, 156, 180, 0.10);
  background: var(--bg-card);
  transition: border-color 0.2s, background 0.2s;
}

.dim-btn-active {
  border-color: rgba(0, 175, 255, 0.45);
  background: rgba(0, 175, 255, 0.08);
}

.dim-btn-letter {
  font-size: 32rpx;
  font-weight: 800;
  font-family: 'SF Mono', 'Courier New', monospace;
  color: var(--text-disabled);
  transition: color 0.2s;
}

.dim-btn-active .dim-btn-letter {
  color: var(--color-cyan)
}

.dim-btn-label {
  font-size: 24rpx;
  color: rgba(140, 176, 205, 0.38);
  transition: color 0.2s;
}

.dim-btn-active .dim-btn-label {
  color: rgba(0, 175, 255, 0.80);
}

/* ---- 当前选择 ---- */
.selection-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.selection-kicker {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(0, 175, 255, 0.50);
}

.selection-title {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.selection-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.selection-type {
  font-size: 48rpx;
  font-weight: 800;
  font-family: 'SF Mono', 'Courier New', monospace;
  letter-spacing: 8rpx;
  color: var(--text-primary);
  transition: color 0.25s;
  white-space: nowrap;
  word-break: keep-all;
}

.selection-type.selection-changed {
  color: var(--color-cyan)
  text-shadow: 0 0 16rpx rgba(0, 175, 255, 0.30);
}

.selection-persona {
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
  white-space: nowrap;
  word-break: keep-all;
}

.selection-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

.selection-tag {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(0, 175, 255, 0.15);
  background: rgba(0, 175, 255, 0.04);
  color: rgba(0, 175, 255, 0.72);
  letter-spacing: 1rpx;
  white-space: nowrap;
}

/* ---- APPLY 按钮 ---- */
.apply-btn {
  margin-top: 8rpx;
  width: 100%;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.35);
  background: rgba(10, 132, 255, 0.08);
  transition: background 0.15s;
  position: relative;
  overflow: hidden;
}

.apply-btn:active {
  background: rgba(10, 132, 255, 0.18);
}

.apply-btn.apply-syncing {
  border-color: rgba(0, 175, 255, 0.50);
  background: rgba(0, 175, 255, 0.06);
}

.apply-btn.apply-syncing::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 175, 255, 0.60), transparent);
  animation: applyScan 1.5s linear infinite;
}

.apply-btn.apply-success {
  border-color: rgba(48, 209, 88, 0.30);
  background: rgba(48, 209, 88, 0.05);
}

.apply-btn.apply-success .apply-text {
  color: rgba(48, 209, 88, 0.85);
}

.apply-btn.apply-error {
  border-color: rgba(255, 69, 58, 0.40);
  background: rgba(255, 69, 58, 0.06);
}

.apply-error-text {
  color: rgba(255, 69, 58, 0.85) !important;
  font-size: 22rpx;
}

@keyframes applyScan {
  0% { left: -100%; }
  100% { left: 100%; }
}

.apply-kicker {
  font-size: 16rpx;
  letter-spacing: 4rpx;
  color: rgba(10, 132, 255, 0.55);
}

.apply-text {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(10, 132, 255, 0.90);
  letter-spacing: 2rpx;
  white-space: nowrap;
}

/* ---- Reduce Motion ---- */
.reduce-motion .sync-ring {
  animation: none;
}

.reduce-motion .sync-line {
  transition: none;
}

.reduce-motion .apply-btn.apply-syncing::before {
  animation: none;
}

.reduce-motion .dim-btn {
  transition: none;
}

.reduce-motion .selection-type {
  transition: none;
}

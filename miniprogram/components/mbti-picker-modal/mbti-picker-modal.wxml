<view class="picker-overlay {{reduceMotion ? 'reduce-motion' : ''}}">
  <view class="picker-header">
    <text class="picker-title">修改类型</text>
    <view class="picker-close" bindtap="onClose">
      <text class="close-icon">x</text>
    </view>
  </view>

  <view class="picker-body">
    <!-- 翻牌矩阵：4 个 3D 翻转方块 -->
    <view class="flip-row">
      <view class="flip-cell" wx:for="{{dims}}" wx:key="key" wx:for-index="dimIdx">
        <view class="flip-perspective" bindtap="onFlip" data-dimindex="{{dimIdx}}">
          <view class="flip-card {{item.flipping ? 'flip-animating' : ''}} {{item.flipDone ? 'flip-done' : ''}}">
            <!-- 正面：当前选中字母 -->
            <view class="flip-face flip-front">
              <text class="flip-letter">{{item.selected}}</text>
            </view>
            <!-- 背面：对立字母 -->
            <view class="flip-face flip-back">
              <text class="flip-letter">{{item.opposite}}</text>
            </view>
          </view>
        </view>
        <text class="flip-dim-label">{{item.dimLabel}}</text>
      </view>
    </view>

    <!-- 结果预览 -->
    <view class="preview">
      <text class="preview-type">{{mbtiType}}</text>
      <text class="preview-title">{{mbtiTitle}}</text>
    </view>

    <!-- 悬浮胶囊确认按钮 -->
    <view class="capsule-btn" bindtap="onConfirm">
      <text class="capsule-text">确认提交</text>
    </view>
  </view>
</view>

<view class="picker-overlay {{reduceMotion ? 'reduce-motion' : ''}}">

  <!-- 退出确认遮罩 -->
  <view class="exit-overlay {{showExitConfirm ? 'exit-active' : ''}}" wx:if="{{showExitConfirm}}">
    <view class="exit-dialog">
      <text class="exit-title">退出修改</text>
      <text class="exit-msg">当前协议修改尚未写入，退出后不会保存。</text>
      <view class="exit-actions">
        <view class="exit-btn exit-btn-cancel" bindtap="cancelExit">
          <text>继续编辑</text>
        </view>
        <view class="exit-btn exit-btn-confirm" bindtap="confirmExit">
          <text>放弃修改</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 头部 -->
  <view class="picker-header">
    <view class="picker-header-left">
      <text class="picker-title">修改协议</text>
    </view>
    <view class="picker-close">
      <sr-hatch-close bind:close="onClose" reduceMotion="{{reduceMotion}}" />
    </view>
  </view>

  <view class="picker-hint">选择你的协议类型。</view>

  <view class="picker-divider"></view>

  <scroll-view scroll-y class="picker-scroll">
    <view class="picker-body">

      <!-- 协议维度 -->
      <view class="matrix-section">
        <text class="matrix-title">协议维度</text>

        <view class="dim-list">
          <view class="dim-row" wx:for="{{dims}}" wx:key="key" wx:for-index="dimIdx">
            <text class="dim-row-label">{{item.dimLabel}}</text>
            <view class="dim-btns">
              <view
                class="dim-btn {{item.selected === item.options[0].code ? 'dim-btn-active' : ''}}"
                bindtap="onDimSelect"
                data-dimindex="{{dimIdx}}"
                data-value="{{item.options[0].code}}"
              >
                <text class="dim-btn-letter">{{item.options[0].code}}</text>
                <text class="dim-btn-label">{{item.options[0].label}}</text>
              </view>
              <view
                class="dim-btn {{item.selected === item.options[1].code ? 'dim-btn-active' : ''}}"
                bindtap="onDimSelect"
                data-dimindex="{{dimIdx}}"
                data-value="{{item.options[1].code}}"
              >
                <text class="dim-btn-letter">{{item.options[1].code}}</text>
                <text class="dim-btn-label">{{item.options[1].label}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="picker-divider"></view>

      <!-- 当前选择 -->
      <view class="selection-section">
        <text class="selection-title">当前选择</text>

        <view class="selection-main">
          <text class="selection-type {{mbtiType !== originalType ? 'selection-changed' : ''}}">{{mbtiType}}</text>
          <text class="selection-persona">{{mbtiTitle}}</text>
        </view>

        <view class="selection-tags">
          <text class="selection-tag" wx:for="{{mbtiTraits}}" wx:key="*this">{{item}}</text>
        </view>
      </view>

    </view>
  </scroll-view>

  <!-- 确认接入（固定底部） -->
  <view class="apply-dock">
    <view class="apply-btn {{syncState === 'syncing' ? 'apply-syncing' : ''}} {{syncState === 'success' ? 'apply-success' : ''}} {{syncState === 'error' ? 'apply-error' : ''}}" bindtap="onConfirm">
      <text class="apply-text" wx:if="{{syncState === 'syncing'}}">协议写入中…</text>
      <text class="apply-text" wx:elif="{{syncState === 'success'}}">协议已同步</text>
      <text class="apply-text apply-error-text" wx:elif="{{syncState === 'error'}}">{{errorText || '同步失败'}}</text>
      <text class="apply-text" wx:else>确认接入</text>
    </view>
  </view>
</view>

<view class="picker-overlay {{reduceMotion ? 'reduce-motion' : ''}} {{showAnimation ? 'overlay-show' : ''}}" bindtap="onOverlayTap">

  <view class="ar-cockpit-console {{showAnimation ? 'console-show' : ''}}" catchtap="noop">
    <!-- 退出确认遮罩 -->
    <view class="exit-overlay {{showExitConfirm ? 'exit-active' : ''}}" wx:if="{{showExitConfirm}}">
      <view class="exit-dialog">
        <text class="exit-title">退出修改</text>
        <text class="exit-msg">当前协议修改尚未写入，退出后不会保存。</text>
        <view class="exit-actions">
          <view class="exit-btn exit-btn-cancel" bindtap="cancelExit">
            <text>继续编辑</text>
          </view>
          <view class="exit-btn exit-btn-confirm" bindtap="confirmExit">
            <text>放弃修改</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Part 1: 悬空屏幕 (Floating HUD Screen) -->
    <view class="ar-floating-screen">
      <!-- AR 屏幕扫描线及四角定位框 -->
      <view class="ar-screen-grid"></view>
      <view class="ar-screen-scanlines"></view>
      <view class="ar-hud-angle ar-hud-tl"></view>
      <view class="ar-hud-angle ar-hud-tr"></view>
      <view class="ar-hud-angle ar-hud-bl"></view>
      <view class="ar-hud-angle ar-hud-br"></view>

      <!-- AR 顶部系统状态栏 -->
      <view class="ar-top-bar">
        <view class="ar-system-dot"></view>
        <text class="ar-system-title">协议校准终端</text>
      </view>

      <!-- 核心两区分割布局 -->
      <view class="ar-content-split">
        
        <!-- 上半区：AR 全息说明面板 (HUD Display) -->
        <view class="ar-hud-panel">
          <view class="ar-hud-header">
            <text class="ar-hud-label">目标特征全息解算</text>
            <view class="ar-glow-line"></view>
          </view>
          
          <view class="ar-hud-body">
            <view class="ar-profile-header">
              <text class="ar-profile-code {{mbtiType !== originalType ? 'ar-code-changed' : ''}}">{{mbtiType}}</text>
              <text class="ar-profile-title">{{mbtiTitle}}</text>
            </view>
            
            <!-- 人格特质标签 -->
            <view class="ar-profile-tags">
              <text class="ar-tag" wx:for="{{mbtiTraits}}" wx:key="*this">{{item}}</text>
            </view>
            
            <!-- 高级 AR 飞船适性说明 -->
            <view class="ar-profile-desc">
              <text>{{mbtiDesc}}</text>
              <view class="term-cursor {{reduceMotion ? 'reduce-motion' : ''}}" wx:if="{{isPrinting}}"></view>
            </view>
          </view>

          <!-- 虚设的实时数字流动与装饰，提供科技氛围 -->
          <view class="ar-hud-footer">
            <text class="ar-hud-system-status"><text class="ar-hud-original-status">原协议: {{originalType}}</text></text>
            <text class="ar-hud-decor-nums">频率 0.428 // 协议 NC-991</text>
          </view>
        </view>

      </view>
    </view> <!-- End of Floating Screen -->

  </view>

  <!-- Part 2 & Part 3: Flat bottom container for actions -->
  <view class="picker-bottom-actions {{showAnimation ? 'actions-show' : ''}}" catchtap="noop">
    <!-- Part 2: 维度条展示（替代旧I/N/F/P卡片按钮） -->
    <view class="ar-floating-controllers dim-bars">
      <view
        class="dim-bar"
        wx:for="{{dims}}"
        wx:key="key"
        wx:for-index="dimIdx"
        bindtap="onDimToggle"
        data-dimindex="{{dimIdx}}"
      >
        <text class="dim-bar__letter">{{item.selected}}</text>
        <text class="dim-bar__label">{{item.dimLabel}}</text>
      </view>
      <text class="dim-bars__hint">点击维度可微调协议</text>
    </view>

    <!-- Part 3: 确认/返回操作按钮 -->
    <view class="ar-console-bottom-hardware">
      <view class="picker-confirm-actions">
        <view class="picker-cmd-btn picker-cmd-btn--primary {{syncState === 'syncing' ? 'is-syncing' : ''}} {{syncState === 'success' ? 'is-success' : ''}} {{syncState === 'error' ? 'is-error' : ''}}" bindtap="onConfirm">
          <view class="picker-btn-spinner" wx:if="{{syncState === 'syncing'}}"></view>
          <text class="picker-cmd-text">{{syncState === 'syncing' ? '写入中...' : syncState === 'success' ? '已写入' : syncState === 'error' ? '写入失败' : '确认镜像'}}</text>
        </view>
        <view class="picker-cmd-btn picker-cmd-btn--ghost {{syncState === 'syncing' ? 'is-disabled' : ''}}" bindtap="onClose">
          <text class="picker-cmd-text">返回修改</text>
        </view>
      </view>
    </view>
  </view>

</view>

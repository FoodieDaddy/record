<wxs src="./matrix-overview.wxs" module="fmt" />
<wxs src="../../utils/truncate.wxs" module="t" />

<view wx:if="{{active}}" catchtouchmove="preventClose" style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:90;">
  <!-- 数值总览弹窗 -->
  <view class="matrix-panel-overlay {{visible ? 'mp-show' : ''}}" catchtap="closePanel">
    <view class="matrix-panel-sheet" catchtap="preventClose" catchtouchmove="preventClose">
      <view class="detail-header">
        <text class="section-title" style="margin-bottom:0;">数值总览</text>
        <view class="detail-close" bindtap="closePanel">×</view>
      </view>
      <view wx:if="{{memberGrid.length < 2}}" class="empty-batches">
        <text class="text-tertiary">至少需要 2 名成员</text>
      </view>
      <view wx:else class="panel-body">

        <!-- 折线图：固定在顶部，不随列表滚动（明细弹窗打开时 hidden 防 Canvas 穿透） -->
        <view wx:if="{{chartSeries.length > 0 && !chartHidden}}" hidden="{{showMatrixDetail}}" class="chart-section">
          <score-chart timestamps="{{chartTimestamps}}" series="{{chartSeries}}" visible-users="{{chartVisibleUsers}}" />
        </view>
        <!-- 分割线 -->
        <view class="panel-divider" wx:if="{{chartSeries.length > 0 && !chartHidden}}"></view>

        <!-- 关系列表：独立滚动区域 -->
        <scroll-view scroll-y="{{true}}" scroll-x="{{false}}" class="relation-scroll" catchtouchmove="preventClose"
          bindscrolltolower="onRelationScrollLower" lower-threshold="100">
          <view class="relation-section">
            <view class="relation-header">
              <text class="relation-title">我与他人的数值往来</text>
              <text class="relation-count text-tertiary">{{relationList.length}}人</text>
            </view>
            <view wx:if="{{relationListDisplay.length === 0}}" class="empty-batches">
              <text class="text-tertiary">暂无数值往来</text>
            </view>
            <view class="relation-list" wx:else>
              <view class="relation-item" wx:for="{{relationListDisplay}}" wx:key="userId"
                    bindtap="onRelationTap" data-user-id="{{item.userId}}">
                <view class="relation-left">
                  <view class="relation-avatar-wrap">
                    <view class="auto-avatar-xxs" style="background:{{item.avatarColor}};" wx:if="{{!item.avatarUrl}}">
                      <text class="auto-avatar-char-xxs">{{item.avatarChar}}</text>
                    </view>
                    <image class="relation-avatar" src="{{item.avatarUrl}}" wx:else></image>
                  </view>
                  <text class="relation-name">{{t.truncateName(item.nickname)}}</text>
                </view>
                <text class="relation-score {{item.netScore > 0 ? 'rs-pos' : 'rs-neg'}}">{{item.display}}</text>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

  <!-- 数值明细弹窗 -->
  <view class="matrix-detail-overlay {{showMatrixDetail ? 'detail-show' : ''}}" catchtap="closeMatrixDetail" catchtouchmove="preventClose">
    <view class="matrix-detail-sheet" catchtap="preventClose" catchtouchmove="preventClose">
      <view class="detail-header">
        <text class="section-title" style="margin-bottom:0;">数值明细</text>
        <view class="detail-close" bindtap="closeMatrixDetail">×</view>
      </view>
      <view class="detail-parties">
        <view class="detail-party">
          <view class="auto-avatar-sm" style="background:{{detailFrom.avatarColor}};" wx:if="{{!detailFrom.avatarUrl}}">
            <text class="auto-avatar-char-sm">{{detailFrom.avatarChar}}</text>
          </view>
          <image class="detail-avatar" src="{{detailFrom.avatarUrl}}" wx:else></image>
          <text class="detail-name">{{t.truncateName(detailFrom.nickname)}}</text>
        </view>
        <view class="detail-arrow-wrap">
          <view class="detail-arrow-line"></view>
          <view class="detail-arrow-head"></view>
        </view>
        <view class="detail-party">
          <view class="auto-avatar-sm" style="background:{{detailTo.avatarColor}};" wx:if="{{!detailTo.avatarUrl}}">
            <text class="auto-avatar-char-sm">{{detailTo.avatarChar}}</text>
          </view>
          <image class="detail-avatar" src="{{detailTo.avatarUrl}}" wx:else></image>
          <text class="detail-name">{{t.truncateName(detailTo.nickname)}}</text>
        </view>
      </view>
      <view class="detail-total">
        <text class="text-tertiary text-xs">净数值</text>
        <text class="detail-total-val {{detailNet > 0 ? 'mg-pos' : detailNet < 0 ? 'mg-neg' : ''}}">{{fmt.formatScore(detailNet)}}</text>
      </view>
      <scroll-view scroll-y="{{true}}" class="detail-scroll-list" catchtouchmove="preventClose">
        <view class="detail-item" wx:for="{{detailRecords}}" wx:key="id">
          <text class="detail-item-score {{item.amount > 0 ? 'dis-score-pos' : item.amount < 0 ? 'dis-score-neg' : ''}}">{{fmt.formatScore(item.amount)}}</text>
          <text class="detail-item-time">{{item.timeFormatted}}</text>
        </view>
        <view wx:if="{{detailRecords.length === 0}}" class="empty-batches" style="padding:24rpx 0;">
          <text class="text-tertiary">暂无记录</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>

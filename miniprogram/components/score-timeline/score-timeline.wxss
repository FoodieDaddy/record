.chart-wrap {
  position: relative;
  width: 100%;
  overflow: hidden;
}

.timeline-canvas {
  width: 100%;
  display: block;
}

.tooltip {
  position: absolute;
  pointer-events: none;
  transform: translate(-50%, -100%);
  padding: 8rpx 20rpx;
  background: rgba(10, 10, 10, 0.85);
  border: 1rpx solid rgba(79, 140, 255, 0.3);
  border-radius: 12rpx;
  white-space: nowrap;
  z-index: 10;
}

.tooltip-value {
  font-size: 26rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.pulse-stream {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  border: 1rpx solid rgba(0, 200, 255, 0.24);
  border-radius: 28rpx;
  background:
    linear-gradient(rgba(0, 200, 255, 0.022) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(0, 200, 255, 0.018) 1rpx, transparent 1rpx),
    rgba(2, 12, 19, 0.96);
  background-size: 32rpx 32rpx;
  box-shadow: inset 0 0 50rpx rgba(0, 175, 255, 0.035);
}

.pulse-stream__header,
.pulse-stream__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.pulse-stream__header {
  height: 92rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid rgba(0, 200, 255, 0.10);
  background: rgba(0, 8, 14, 0.72);
}

.pulse-stream__status {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pulse-stream__signal {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.pulse-stream__signal-dot,
.pulse-stream__signal-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.pulse-stream__signal-dot {
  width: 9rpx;
  height: 9rpx;
  background: rgba(115, 154, 168, 0.58);
}

.pulse-stream__signal-ring {
  width: 24rpx;
  height: 24rpx;
  border: 1rpx solid rgba(115, 154, 168, 0.28);
}

.pulse-stream__status.is-live .pulse-stream__signal-dot {
  background: #34E8C4;
  box-shadow: 0 0 12rpx rgba(52, 232, 196, 0.68);
  animation: pulseStreamDot 1.4s ease-in-out infinite;
}

.pulse-stream__status.is-live .pulse-stream__signal-ring {
  border-color: rgba(52, 232, 196, 0.48);
  animation: pulseStreamRing 1.4s ease-out infinite;
}

.pulse-stream__title,
.pulse-stream__subtitle {
  display: block;
}

.pulse-stream__title {
  color: rgba(224, 246, 252, 0.94);
  font-size: 25rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.pulse-stream__subtitle {
  margin-top: 3rpx;
  color: rgba(84, 176, 198, 0.52);
  font-family: Menlo, monospace;
  font-size: 15rpx;
  letter-spacing: 2rpx;
}

.pulse-stream__close {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(0, 200, 255, 0.16);
  border-radius: 50%;
}

.pulse-stream__close-icon {
  position: relative;
  width: 20rpx;
  height: 20rpx;
}

.pulse-stream__close-icon::before,
.pulse-stream__close-icon::after {
  position: absolute;
  top: 9rpx;
  left: 1rpx;
  width: 18rpx;
  height: 2rpx;
  content: '';
  background: rgba(163, 221, 237, 0.72);
}

.pulse-stream__close-icon::before { transform: rotate(45deg); }
.pulse-stream__close-icon::after { transform: rotate(-45deg); }

.pulse-stream__viewport {
  position: relative;
  height: 520rpx;
  overflow: hidden;
}

.pulse-stream__rows {
  height: 100%;
  box-sizing: border-box;
  padding: 12rpx 18rpx;
}

.pulse-stream__row {
  min-height: 58rpx;
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr) 92rpx;
  align-items: center;
  column-gap: 12rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid rgba(0, 200, 255, 0.07);
  border-left: 2rpx solid transparent;
  color: rgba(184, 214, 224, 0.64);
}

.pulse-stream__row.is-outgoing {
  color: rgba(255, 221, 184, 0.94);
  border-left-color: rgba(255, 100, 115, 0.82);
  background: linear-gradient(90deg, rgba(255, 100, 115, 0.10), transparent 72%);
}

.pulse-stream__row.is-incoming {
  color: rgba(196, 255, 239, 0.96);
  border-left-color: rgba(52, 232, 196, 0.82);
  background: linear-gradient(90deg, rgba(52, 232, 196, 0.11), transparent 72%);
}

.pulse-stream__row.is-new {
  animation: pulseStreamRow 720ms ease-out both;
}

.pulse-stream__time {
  color: rgba(101, 169, 188, 0.54);
  font-family: Menlo, monospace;
  font-size: 16rpx;
}

.pulse-stream__route {
  min-width: 0;
  overflow: hidden;
  font-size: 22rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pulse-stream__amount {
  justify-self: end;
  color: inherit;
  font-family: Menlo, monospace;
  font-size: 25rpx;
  font-weight: 800;
}

.pulse-stream__scanline {
  position: absolute;
  z-index: 2;
  top: -30rpx;
  right: 0;
  left: 0;
  height: 30rpx;
  pointer-events: none;
  background: linear-gradient(180deg, transparent, rgba(52, 232, 196, 0.10), transparent);
  animation: pulseStreamScan 3s linear infinite;
}

.pulse-stream__empty,
.pulse-stream__loading {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  color: rgba(113, 167, 188, 0.54);
  font-size: 21rpx;
  letter-spacing: 2rpx;
}

.pulse-stream__empty-signal {
  width: 80rpx;
  height: 3rpx;
  border-radius: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(52, 232, 196, 0.74), transparent);
  animation: pulseStreamIdle 1.6s ease-in-out infinite;
}

.pulse-stream__loading-bars {
  height: 32rpx;
  display: flex;
  align-items: center;
  gap: 7rpx;
}

.pulse-stream__loading-bars view {
  width: 4rpx;
  height: 12rpx;
  background: rgba(0, 200, 255, 0.68);
  animation: pulseStreamBar 900ms ease-in-out infinite alternate;
}

.pulse-stream__loading-bars view:nth-child(2) { animation-delay: 120ms; }
.pulse-stream__loading-bars view:nth-child(3) { animation-delay: 240ms; }
.pulse-stream__loading-bars view:nth-child(4) { animation-delay: 360ms; }

.pulse-stream__footer {
  min-height: 56rpx;
  padding: 0 24rpx;
  color: rgba(99, 152, 170, 0.46);
  font-family: Menlo, monospace;
  font-size: 15rpx;
  border-top: 1rpx solid rgba(0, 200, 255, 0.08);
}

@keyframes pulseStreamDot {
  0%, 100% { opacity: 0.45; transform: translate(-50%, -50%) scale(0.82); }
  50% { opacity: 1; transform: translate(-50%, -50%) scale(1.12); }
}

@keyframes pulseStreamRing {
  from { opacity: 0.72; transform: translate(-50%, -50%) scale(0.72); }
  to { opacity: 0; transform: translate(-50%, -50%) scale(1.55); }
}

@keyframes pulseStreamScan {
  from { transform: translateY(0); }
  to { transform: translateY(550rpx); }
}

@keyframes pulseStreamRow {
  from { opacity: 0; transform: translateX(18rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes pulseStreamIdle {
  0%, 100% { opacity: 0.3; transform: scaleX(0.45); }
  50% { opacity: 1; transform: scaleX(1); }
}

@keyframes pulseStreamBar {
  from { height: 8rpx; opacity: 0.35; }
  to { height: 30rpx; opacity: 1; }
}

.chart-container {
  position: relative;
  width: 100%;
}

.score-chart-canvas {
  width: 100%;
  display: block;
}

/* 悬浮 tooltip */
.chart-tooltip {
  position: absolute;
  top: 8rpx;
  transform: translateX(-50%);
  background: rgba(20, 20, 20, 0.92);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 10rpx 16rpx;
  pointer-events: none;
  z-index: 10;
  min-width: 120rpx;
  white-space: nowrap;
}

.ct-time {
  display: block;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 4rpx;
  text-align: center;
  font-variant-numeric: tabular-nums;
}

.ct-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 2rpx 0;
}

.ct-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.ct-name {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.6);
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ct-score {
  font-size: 20rpx;
  font-weight: 700;
  margin-left: auto;
  font-variant-numeric: tabular-nums;
}

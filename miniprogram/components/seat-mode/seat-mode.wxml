<wxs src="./seat-mode.wxs" module="anim" />
<wxs src="../../utils/truncate.wxs" module="t" />

<!--
  2.5D 座位模式 — 纯 CSS3 透视架构
  四层绝对定位：环境光底座 → 2.5D 舞台 → HUD → 模态层
  广告牌效应：桌面 rotateX(60deg) + 座位 counter-rotateX(-60deg)
-->
<view class="seat-arena {{!animationEnabled ? 'reduce-motion' : ''}}" id="seatArena">

  <!-- ===== Layer 1: 环境光底座 ===== -->
  <view class="ambient-layer">
    <view class="ambient-glow glow-1"></view>
    <view class="ambient-glow glow-2"></view>
  </view>

  <!-- ===== Layer 2: 2.5D 核心舞台 ===== -->
  <view class="stage">
    <div class="stage-perspective">
      <!-- 桌面 -->
      <div class="table-surface table-{{layoutType}}">
        <div class="table-felt"></div>
        <div class="table-label" wx:if="{{tableLabel}}">{{tableLabel}}</div>
      </div>

      <!-- 座位节点（广告牌） -->
      <div
        wx:for="{{seats}}"
        wx:key="userId"
        class="seat-node {{item.isMe ? 'seat-me' : ''}} {{item.isEmpty ? 'seat-empty' : ''}} {{item.isHighlight ? 'seat-highlight' : ''}}"
        style="{{item.posStyle}}"
        data-index="{{item.index}}"
        data-user-id="{{item.userId}}"
        data-is-empty="{{item.isEmpty}}"
        bindtap="onSeatTap"
        bindlongpress="onSeatLongPress"
      >
        <!-- 广告牌反向旋转容器 -->
        <div class="seat-billboard">
          <!-- 头像 -->
          <div class="seat-avatar-ring" wx:if="{{!item.isEmpty}}">
            <div class="seat-avatar" style="{{item.avatarUrl ? '' : 'background:' + item.avatarColor}}">
              <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" class="seat-avatar-img" />
              <text wx:else class="seat-avatar-char">{{item.avatarChar}}</text>
            </div>
          </div>
          <!-- 空位虚线框 -->
          <div class="seat-empty-ring" wx:if="{{item.isEmpty && editMode}}">
            <text class="seat-empty-plus">+</text>
          </div>
          <!-- 昵称 -->
          <text class="seat-name" wx:if="{{!item.isEmpty}}">{{t.truncateName(item.nickname)}}</text>
          <!-- 积分牌 -->
          <view class="seat-score-pill" wx:if="{{!item.isEmpty}}">
            <text
              class="seat-score {{item.score > 0 ? 'score-pos' : item.score < 0 ? 'score-neg' : 'score-zero'}}"
            >{{anim.formatScore(item.animValue)}}</text>
          </view>
        </div>
      </div>
    </div>
  </view>

  <!-- ===== Layer 3: HUD 悬浮操作层 ===== -->
  <view class="hud-layer" wx:if="{{showActions}}">
    <view class="hud-actions">
      <view class="hud-btn {{editMode ? 'hud-btn-active' : ''}}" wx:if="{{isOwner}}" bindtap="toggleEditMode">
        <text class="hud-btn-text">{{editMode ? '完成' : '编辑'}}</text>
      </view>
      <view class="hud-btn" bindtap="onToggleAnimation">
        <text class="hud-btn-text">{{animationEnabled ? '动效' : '静默'}}</text>
      </view>
    </view>
  </view>

  <!-- ===== Layer 4: 模态控制层 ===== -->

  <!-- 成员选择器 -->
  <view
    class="modal-mask {{showPicker ? 'visible' : ''}}"
    bindtap="closePicker"
  ></view>
  <view class="modal-sheet {{showPicker ? 'visible' : ''}}">
    <view class="modal-header">
      <text class="modal-title">选择入座成员</text>
      <view class="modal-close" bindtap="closePicker"></view>
    </view>
    <scroll-view class="modal-list" scroll-y>
      <view wx:if="{{waitingList.length === 0}}" class="modal-empty">
        <text>暂无可入座的成员</text>
      </view>
      <view
        wx:for="{{waitingList}}"
        wx:key="userId"
        class="modal-member"
        bindtap="onPickMember"
        data-user-id="{{item.userId}}"
      >
        <view class="modal-avatar" style="{{item.avatarUrl ? '' : 'background:' + item.avatarColor}}">
          <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" />
          <text wx:else class="modal-avatar-char">{{item.avatarChar}}</text>
        </view>
        <text class="modal-nickname">{{t.truncateName(item.nickname)}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 操作菜单 -->
  <view
    class="modal-mask {{showActionMenu ? 'visible' : ''}}"
    bindtap="closeActionMenu"
  ></view>
  <view class="action-menu {{showActionMenu ? 'visible' : ''}}">
    <view class="action-header">
      <text class="action-name">{{t.truncateName(actionTarget.nickname)}}</text>
      <text class="action-score">{{anim.formatScore(actionTarget.score)}}</text>
    </view>
    <view class="action-item" bindtap="onTransfer">
      <text class="action-item-text">转让积分</text>
    </view>
    <view class="action-item" wx:if="{{editMode && isOwner}}" bindtap="onRemoveSeat">
      <text class="action-item-text danger">移出座位</text>
    </view>
    <view class="action-cancel" bindtap="closeActionMenu">
      <text class="action-cancel-text">取消</text>
    </view>
  </view>
</view>

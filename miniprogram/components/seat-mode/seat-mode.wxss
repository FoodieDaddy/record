/* ===== 2.5D 座位模式 — 纯 CSS3 透视架构 ===== */

:host {
  display: block;
  width: 100%;
  height: 100%;
}

/* ===== 根容器 ===== */
.seat-arena {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  box-sizing: border-box;
  background: #0a0a0a;
}

/* ===== Layer 1: 环境光底座 ===== */
.ambient-layer {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 1;
  pointer-events: none;
}

.ambient-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.6;
}

.glow-1 {
  width: 600rpx; height: 600rpx;
  top: -200rpx; left: -100rpx;
  background: rgba(10, 132, 255, 0.06);
}

.glow-2 {
  width: 500rpx; height: 500rpx;
  bottom: -150rpx; right: -100rpx;
  background: rgba(10, 132, 255, 0.04);
}

/* ===== Layer 2: 2.5D 核心舞台 ===== */
.stage {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stage-perspective {
  position: relative;
  width: 90%;
  max-width: 750rpx;
  aspect-ratio: 1;
  max-height: 80%;
  perspective: 1000px;
  perspective-origin: 50% 40%;
}

/* ===== 桌面 ===== */
.table-surface {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) rotateX(60deg);
  transform-style: preserve-3d;
}

.table-felt {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.table-circle .table-felt {
  width: 500rpx; height: 500rpx;
  border-radius: 50%;
}

.table-rectangle .table-felt {
  width: 600rpx; height: 360rpx;
  border-radius: 24rpx;
}

.table-arc .table-felt {
  width: 520rpx; height: 300rpx;
  border-radius: 260rpx 260rpx 40rpx 40rpx;
}

.table-label {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 40rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.06);
  letter-spacing: 8rpx;
  pointer-events: none;
  user-select: none;
}

/* ===== 座位节点（绝对定位在透视容器上） ===== */
.seat-node {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 11;
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.seat-empty {
  z-index: 10;
}

/* ===== 广告牌反向旋转 ===== */
.seat-billboard {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transform: rotateX(-60deg);
  transform-origin: center center;
}

/* ===== 头像 ===== */
.seat-avatar-ring {
  width: 96rpx; height: 96rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1.5px solid rgba(255, 255, 255, 0.12);
  box-sizing: border-box;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.seat-me .seat-avatar-ring {
  border-color: rgba(10, 132, 255, 0.5);
  box-shadow: 0 0 20rpx rgba(10, 132, 255, 0.15);
}

.seat-highlight .seat-avatar-ring {
  border-color: rgba(255, 138, 101, 0.5);
  box-shadow: 0 0 24rpx rgba(255, 138, 101, 0.2);
}

.seat-avatar {
  width: 100%; height: 100%;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
}

.seat-avatar-img {
  width: 100%; height: 100%;
}

.seat-avatar-char {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* ===== 空位虚线框 ===== */
.seat-empty-ring {
  width: 96rpx; height: 96rpx;
  border-radius: 50%;
  border: 2rpx dashed rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.seat-empty-ring:active {
  border-color: rgba(10, 132, 255, 0.4);
}

.seat-empty-plus {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.2);
  font-weight: 300;
}

/* ===== 昵称 ===== */
.seat-name {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.55);
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.6);
}

.seat-me .seat-name {
  color: rgba(10, 132, 255, 0.85);
  font-weight: 500;
}

/* ===== 积分牌 ===== */
.seat-score-pill {
  min-width: 72rpx;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.seat-score {
  font-size: 22rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  font-feature-settings: "tnum";
  font-family: "SF Mono", "Menlo", "Courier New", monospace;
  letter-spacing: 0.5rpx;
}

.score-pos {
  color: #ff8a65;
  text-shadow: 0 0 12rpx rgba(255, 138, 101, 0.25);
}

.score-neg {
  color: #ff6b6b;
  text-shadow: 0 0 12rpx rgba(255, 107, 107, 0.25);
}

.score-zero {
  color: rgba(255, 255, 255, 0.25);
}

.seat-me .score-pos {
  color: #ffab91;
  text-shadow: 0 0 16rpx rgba(255, 171, 145, 0.3);
}

.seat-me .score-neg {
  color: #ff8a8a;
  text-shadow: 0 0 16rpx rgba(255, 138, 138, 0.3);
}

/* ===== Layer 3: HUD ===== */
.hud-layer {
  position: absolute;
  bottom: 40rpx;
  left: 0; right: 0;
  z-index: 50;
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.hud-actions {
  display: flex;
  gap: 16rpx;
  pointer-events: auto;
}

.hud-btn {
  padding: 12rpx 28rpx;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 999px;
  transition: all 0.2s ease;
}

.hud-btn:active {
  background: rgba(255, 255, 255, 0.12);
  transform: scale(0.95);
}

.hud-btn-active {
  background: rgba(10, 132, 255, 0.15);
  border-color: rgba(10, 132, 255, 0.3);
}

.hud-btn-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.hud-btn-active .hud-btn-text {
  color: rgba(10, 132, 255, 0.9);
}

/* ===== Layer 4: 模态层 ===== */
.modal-mask {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(10, 10, 10, 0.6);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.35s ease, visibility 0.35s ease;
}

.modal-mask.visible {
  opacity: 1;
  visibility: visible;
}

/* ===== 成员选择器 ===== */
.modal-sheet {
  position: fixed;
  left: 0; bottom: 0;
  width: 100%;
  max-height: 75vh;
  background: rgba(20, 20, 20, 0.95);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
}

.modal-sheet.visible {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 32rpx 24rpx;
  position: relative;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.modal-close {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx; height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.modal-close::before,
.modal-close::after {
  content: '';
  position: absolute;
  width: 24rpx; height: 2rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 1rpx;
}

.modal-close::before { transform: rotate(45deg); }
.modal-close::after { transform: rotate(-45deg); }

.modal-list {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx 48rpx;
  -webkit-overflow-scrolling: touch;
}

.modal-empty {
  text-align: center;
  padding: 80rpx 0;
  color: rgba(255, 255, 255, 0.3);
  font-size: 28rpx;
}

.modal-member {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  margin-bottom: 16rpx;
  transition: background 0.2s ease;
}

.modal-member:active {
  background: rgba(255, 255, 255, 0.1);
}

.modal-avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-avatar image {
  width: 100%; height: 100%;
}

.modal-avatar-char {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.modal-nickname {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 操作菜单 ===== */
.action-menu {
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  min-width: 320rpx;
  background: rgba(20, 20, 20, 0.92);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  z-index: 101;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.32, 0.72, 0, 1), visibility 0.25s ease;
  overflow: hidden;
}

.action-menu.visible {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.action-header {
  padding: 28rpx 32rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.action-name {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
}

.action-score {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 4rpx;
  font-family: "SF Mono", "Menlo", monospace;
}

.action-item {
  padding: 28rpx 32rpx;
  transition: background 0.15s ease;
}

.action-item:active {
  background: rgba(255, 255, 255, 0.08);
}

.action-item + .action-item {
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.action-item-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.action-item-text.danger {
  color: #ff6b6b;
}

.action-cancel {
  padding: 24rpx;
  text-align: center;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.action-cancel-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ===== 动效静默 ===== */
.reduce-motion .seat-node,
.reduce-motion .seat-billboard,
.reduce-motion .seat-avatar-ring,
.reduce-motion .seat-score-pill,
.reduce-motion .modal-mask,
.reduce-motion .modal-sheet,
.reduce-motion .modal-member,
.reduce-motion .action-menu,
.reduce-motion .action-item,
.reduce-motion .hud-btn {
  animation: none !important;
  transition: none !important;
}

<view class="mask" bindtap="onClose">
  <view class="modal" catchtap>
    <view class="header">
      <view class="title-area">
        <text class="title">主控填写</text>
      </view>
    </view>

    <scroll-view scroll-y class="member-list">
      <view class="member-row" wx:for="{{members}}" wx:key="userId">
        <text class="member-name">{{item.nickname}}</text>
        <input
          class="score-input"
          type="number"
          adjust-position="{{false}}"
          placeholder="0"
          value="{{scoreInputs[item.userId]}}"
          data-user-id="{{item.userId}}"
          bindinput="onScoreInput"
        />
      </view>
    </scroll-view>

    <view class="summary">
      <text class="total-label">合计</text>
      <text class="total-value {{totalScore === 0 ? 'zero' : (totalScore > 0 ? 'positive' : 'negative')}}">
        {{totalScore > 0 ? '+' : ''}}{{totalScore}}
      </text>
    </view>

    <view class="hint" wx:if="{{zeroSum === 1}}">零和模式已开启，合计必须为 0。</view>

    <view class="btn-bottom-row">
      <view class="btn-cancel" bindtap="onClose">
        <text>取消本轮</text>
      </view>
      <view class="btn-submit" bindtap="onSubmit">
        <text class="btn-submit-text">确认提交</text>
      </view>
    </view>
  </view>
</view>

.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal {
  width: 640rpx;
  background: #1c1c1e;
  border-radius: 24rpx;
  padding: 40rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}
.close-btn {
  font-size: 36rpx;
  color: #8e8e93;
  padding: 8rpx;
}
.member-list {
  max-height: 500rpx;
}
.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.member-name {
  font-size: 30rpx;
  color: #fff;
  flex: 1;
}
.score-input {
  width: 200rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 12rpx;
  text-align: center;
  color: #fff;
  font-size: 30rpx;
}
.summary {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 16rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 12rpx;
}
.total-label {
  font-size: 28rpx;
  color: #8e8e93;
}
.total-value {
  font-size: 36rpx;
  font-weight: 600;
}
.total-value.zero { color: #8e8e93; }
.total-value.positive { color: #30d158; }
.total-value.negative { color: #ff453a; }
.hint {
  font-size: 24rpx;
  color: #8e8e93;
  text-align: center;
  margin-top: 16rpx;
}
.submit-btn {
  margin-top: 32rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #0a84ff;
  color: #fff;
  font-size: 30rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4px 20px rgba(10, 132, 255, 0.35);
}
.submit-btn::after {
  border: none;
}

.mbti-card {
  margin-top: 0;
  padding: 22rpx 26rpx;
}

.primary-card {
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.09);
  border-top: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.045);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

.card-kicker {
  margin-top: 6rpx;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: rgba(126, 156, 180, 0.34);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-cyan);
  letter-spacing: 2rpx;
}

.card-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

.card-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(140, 176, 205, 0.45);
  line-height: 1.5;
}

.card-disclaimer {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: rgba(126, 156, 180, 0.30);
}

.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.primary-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 18rpx;
  background: var(--accent);
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 600;
}

.ghost-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 18rpx;
  border: 1rpx solid var(--glass-border-light);
  background: var(--bg-card);
  color: var(--text-primary);
  font-size: 26rpx;
}

/* 已校准 */
.mbti-display {
  margin-top: 18rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.mbti-type {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: var(--text-primary);
}

.mbti-title {
  font-size: 26rpx;
  color: rgba(10, 132, 255, 0.85);
}

.mbti-meta {
  margin-top: 10rpx;
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: rgba(140, 176, 205, 0.45);
}

/* AI 战术标签 — 微光边框 */
.mbti-tactic-tag {
  margin-top: 14rpx;
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  background: rgba(10, 132, 255, 0.06);
  border: 1rpx solid rgba(10, 132, 255, 0.22);
  box-shadow:
    0 0 8rpx rgba(10, 132, 255, 0.10),
    inset 0 0 6rpx rgba(10, 132, 255, 0.04);
}

.mbti-tactic-text {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--accent);
  letter-spacing: 1rpx;
}

.mbti-tactic-cursor {
  font-size: 22rpx;
  color: var(--accent);
  margin-left: 2rpx;
  animation: cursorBlink 0.6s step-end infinite;
}

@keyframes cursorBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

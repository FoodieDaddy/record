/* ===== Terminal Popup — 赛博终端弹窗 ===== */

.tp-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(12px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  opacity: 0;
  transition: opacity 0.2s ease;
  padding: 60rpx;
}

.tp-mask.tp-show {
  opacity: 1;
}

.tp-container {
  width: 100%;
  max-width: 580rpx;
  background: #0B1018;
  border: 1rpx solid rgba(0, 175, 255, 0.20);
  border-radius: 16rpx;
  box-shadow: 0 0 40rpx rgba(0, 175, 255, 0.10);
  overflow: hidden;
  transform: scale(0.95);
  transition: transform 0.25s cubic-bezier(0.23, 1, 0.32, 1);
}

.tp-show .tp-container {
  transform: scale(1);
}

.tp-header {
  padding: 32rpx 32rpx 0;
}

.tp-kicker {
  display: block;
  font-family: 'Courier New', Courier, monospace;
  font-size: 17rpx;
  letter-spacing: 3rpx;
  color: rgba(0, 175, 255, 0.25);
  text-transform: uppercase;
}

.tp-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 4rpx;
}

.tp-body {
  padding: 20rpx 32rpx 28rpx;
}

.tp-content {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.tp-actions {
  display: flex;
  border-top: 1rpx solid var(--line-subtle);
}

.tp-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.tp-btn-cancel {
  color: var(--text-secondary);
  border-right: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tp-btn-cancel:active {
  background: var(--glass-bg);
}

.tp-btn-danger {
  color: var(--danger);
}

.tp-btn-danger:active {
  background: rgba(255, 77, 79, 0.08);
}

.tp-btn-primary {
  color: var(--color-cyan);
}

.tp-btn-primary:active {
  background: rgba(0, 175, 255, 0.08);
}

/* Reduce Motion */
.reduce-motion,
.reduce-motion .tp-container {
  transition: none !important;
}

/* ===== Terminal Popup — 赛博终端弹窗 ===== */

.tp-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  backdrop-filter: blur(0px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  transition: background 220ms ease, backdrop-filter 220ms ease;
  padding: 60rpx;
  pointer-events: none;
}

.tp-mask.tp-show {
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(10px);
  pointer-events: auto;
}

.tp-container {
  width: 100%;
  max-width: 580rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(0, 175, 255, 0.08), transparent 34%),
    #081018;
  border: 1rpx solid rgba(0, 175, 255, 0.20);
  border-radius: 0;
  clip-path: polygon(18rpx 0, 100% 0, 100% calc(100% - 18rpx), calc(100% - 18rpx) 100%, 0 100%, 0 18rpx);
  box-shadow: 0 0 40rpx rgba(0, 175, 255, 0.10);
  overflow: hidden;
  transform: translateY(24rpx) scale(0.96);
  transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
}

.tp-show .tp-container {
  transform: translateY(0) scale(1);
}

.tp-body {
  padding: 24rpx 28rpx 26rpx;
}

.tp-signal {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 9rpx;
}

.tp-signal-dot {
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: rgba(0, 200, 255, 0.72);
  box-shadow: 0 0 8rpx rgba(0, 175, 255, 0.42);
}

.tp-subtitle {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.tp-content {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.tp-actions {
  display: flex;
  border-top: 1rpx solid var(--line-subtle);
}

.tp-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.tp-btn-cancel {
  color: var(--text-secondary);
  border-right: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tp-btn-cancel:active {
  background: var(--glass-bg);
}

.tp-btn-danger {
  color: var(--danger);
}

.tp-btn-danger:active {
  background: rgba(255, 77, 79, 0.08);
}

.tp-btn-primary {
  color: var(--color-cyan);
}

.tp-btn-primary:active {
  background: rgba(0, 175, 255, 0.08);
}

/* Reduce Motion */
.tp-mask.reduce-motion,
.tp-mask.reduce-motion .tp-container,
.tp-container.reduce-motion {
  transition: none !important;
  animation: none !important;
  transform: none !important;
  backdrop-filter: blur(12px) !important;
}

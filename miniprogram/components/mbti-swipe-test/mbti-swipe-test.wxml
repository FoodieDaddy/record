<view class="swipe-overlay {{reduceMotion ? 'reduce-motion' : ''}}">
  <!-- 进度光线 -->
  <view class="progress-track">
    <view class="progress-bar" style="width: {{progressPercent}}%;"></view>
  </view>

  <!-- 双卡栈：纯净题目显示区 -->
  <view class="swipe-card-area">
    <view class="card-stack">
      <!-- 当前题：直接渲染在屏幕内，没有二次卡片框包裹，确保背景透明 -->
      <view wx:if="{{currentQuestion}}" wx:key="{{currentQuestion.id}}" class="signal-card signal-card--current {{answerMotion ? 'signal-card--motion-' + answerMotion : ''}}">
        <text class="question-text">{{currentQuestion.text}}</text>
      </view>
    </view>
  </view>

  <!-- 数据加载提示 -->
  <view class="data-loading-hint" wx:if="{{dataLoading && !currentQuestion}}">
    <text class="loading-text">数据加载中…</text>
  </view>

  <!-- 底部操作：飞船操控台物理按键排，无字纯符号，左向与右向微调水晶键 -->
  <view class="swipe-actions">
    <!-- 不符合（左极偏振）：左切角水晶按键，仅有指向左的刻度箭头 -->
    <view class="action-btn-hardware hw-btn-adjust hw-btn-left" bindtap="onSwipeLeft" title="不符合">
      <view class="crystal-decor crystal-decor-l"></view>
      <view class="crystal-decor crystal-decor-r"></view>
      <view class="hw-btn-icon-arrow-left"></view>
    </view>
    
    <!-- 符合（右极偏振）：右切角水晶按键，仅有指向右的刻度箭头 -->
    <view class="action-btn-hardware hw-btn-adjust hw-btn-right" bindtap="onSwipeRight" title="符合">
      <view class="crystal-decor crystal-decor-l"></view>
      <view class="crystal-decor crystal-decor-r"></view>
      <view class="hw-btn-icon-arrow-right"></view>
    </view>
  </view>

</view>

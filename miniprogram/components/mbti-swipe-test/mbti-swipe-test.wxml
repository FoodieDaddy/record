<view class="swipe-overlay {{reduceMotion ? 'reduce-motion' : ''}}">
  <!-- 进度光线 -->
  <view class="progress-track">
    <view class="progress-bar" style="width: {{progressPercent}}%;"></view>
  </view>

  <!-- 终端流式日志输出区域 -->
  <scroll-view class="terminal-scroll" scroll-y="{{true}}" scroll-top="{{scrollTop}}" scroll-with-animation="{{!reduceMotion}}">
    <view class="terminal-body">
      <!-- 历史输出行 -->
      <view class="terminal-row {{line.type === 'system' ? 'term-row--system' : 'term-row--question'}}" wx:for="{{printedLines}}" wx:key="index">
        <text class="term-line-content">{{line.text}}</text>
        <text class="term-line-answer" wx:if="{{line.answerText}}"> [{{line.answerText}}]</text>
      </view>
      
      <!-- 当前活动行 -->
      <view class="terminal-row term-row--active" wx:if="{{activeLineText}}">
        <text class="term-line-prefix">{{activeLinePrefix}}</text>
        <text class="term-line-content">{{activeLineText}}</text>
        <view class="term-cursor {{reduceMotion ? 'reduce-motion' : ''}}"></view>
      </view>
      
      <!-- 底部垫高，使用户做题时当前题能够动态并精准保持在屏幕中轴线位置 -->
      <view class="terminal-spacer"></view>
    </view>
  </scroll-view>

  <!-- 数据加载提示 -->
  <view class="data-loading-hint" wx:if="{{dataLoading && !activeLineText && printedLines.length === 0}}">
    <text class="loading-text">数据加载中…</text>
  </view>

</view>

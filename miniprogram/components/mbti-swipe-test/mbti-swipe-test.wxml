<view class="swipe-overlay {{reduceMotion ? 'reduce-motion' : ''}}">
  <!-- 进度光线 -->
  <view class="progress-track">
    <view class="progress-bar" style="width: {{progressPercent}}%;"></view>
  </view>

  <!-- 顶部栏 -->
  <view class="swipe-top">
    <view class="top-center">
      <text class="swipe-kicker">CALIBRATION</text>
      <text class="swipe-subtitle">协议同步中</text>
      <view class="top-progress-row">
        <text class="swipe-progress">{{progress}}</text>
        <view class="progress-segments">
          <view class="seg {{index < currentIndex ? 'seg-done' : ''}}" wx:for="{{20}}" wx:key="index"></view>
        </view>
        <text class="progress-pct">{{progressPercent}}%</text>
      </view>
    </view>
    <view class="swipe-close" bindtap="onClose">
      <view class="close-icon-css"></view>
    </view>
  </view>

  <!-- 题目卡片 -->
  <view class="swipe-card-area">
    <!-- 正常卡片 -->
    <view class="swipe-card {{slideDirection === 'right' ? 'slide-right' : ''}} {{slideDirection === 'left' ? 'slide-left' : ''}}">
      <view class="card-scan-line"></view>
      <text class="signal-header">SIGNAL #{{signalIndex}}</text>
      <text class="signal-label">行为判断</text>
      <view class="question-divider-top"></view>
      <text class="question-text">{{currentQuestion.text}}</text>
      <view class="question-divider-bottom"></view>
      <view class="dim-detect">
        <text class="dim-detect-label">检测维度</text>
        <text class="dim-detect-value">{{dimensionLabel}}</text>
      </view>
    </view>
  </view>

  <!-- 数据加载提示 -->
  <view class="data-loading-hint" wx:if="{{dataLoading && !currentQuestion}}">
    <text class="loading-text">数据加载中…</text>
  </view>

  <!-- 底部操作 -->
  <view class="swipe-actions">
    <view class="action-btn action-reject" bindtap="onSwipeLeft">
      <text class="action-kicker">拒绝</text>
      <text class="action-text">否定</text>
    </view>
    <view class="action-btn action-skip" bindtap="onNotSure">
      <text class="action-kicker">跳过</text>
      <text class="action-text">跳过</text>
    </view>
    <view class="action-btn action-confirm" bindtap="onSwipeRight">
      <text class="action-kicker">确认</text>
      <text class="action-text">认同</text>
    </view>
  </view>

</view>

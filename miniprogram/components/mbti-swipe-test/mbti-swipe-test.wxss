:host {
  width: 100%;
  display: block;
  overflow: visible !important;
}

.swipe-overlay {
  position: relative;
  width: 100%;
  background: transparent;
  display: flex;
  flex-direction: column;
  padding: 24rpx 0 0 0;
  box-sizing: border-box;
  overflow: visible;
}

/* 进度光线 */
.progress-track {
  position: absolute;
  top: -8rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: rgba(0, 200, 255, 0.08);
  z-index: 3;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--color-cyan), var(--color-cyan));
  border-radius: 0 2rpx 2rpx 0;
  transition: width 0.35s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: 0 0 8rpx rgba(0, 175, 255, 0.40);
}

.swipe-card-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 0;
}

/* ---- 双卡栈 ---- */
.card-stack {
  position: relative;
  width: 85%;
  min-height: 340rpx;
}

.signal-card {
  width: 100%;
  background: transparent;
  border: none;
  padding: 40rpx 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 280rpx;
}

/* 当前题：在前方 */
.signal-card--current {
  position: relative;
  z-index: 2;
  transition: transform 0.26s ease, opacity 0.26s ease;
}

/* 当前卡滑出动画 */
.signal-card--current.signal-card--motion-right {
  opacity: 0;
  transform: translateX(120rpx) rotate(2deg) scale(0.98);
}

.signal-card--current.signal-card--motion-left {
  opacity: 0;
  transform: translateX(-120rpx) rotate(-2deg) scale(0.98);
}

.signal-card--current.signal-card--motion-skip {
  opacity: 0;
  transform: scale(0.95);
}

.question-text {
  font-size: 34rpx;
  color: var(--text-primary, #ffffff);
  line-height: 1.8;
  text-align: center;
  text-shadow: 0 0 12rpx rgba(255, 255, 255, 0.15);
  width: 100%;
}

/* 底部操作 */
.swipe-actions {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -118rpx;
  z-index: 3010;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 32rpx;
  padding: 0;
}

.action-btn-hardware {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
}

/* 不符合（左极偏振）：左切角水晶按键，仅有指向左的刻度箭头 */
.hw-btn-adjust {
  width: 220rpx;
  height: 80rpx;
  position: relative;
  background: linear-gradient(135deg, rgba(0, 175, 255, 0.08) 0%, rgba(0, 80, 155, 0.24) 100%);
  border: 1rpx solid rgba(0, 175, 255, 0.35);
  border-radius: 8rpx;
  box-shadow: inset 0 0 16rpx rgba(0, 175, 255, 0.15), 0 4rpx 16rpx rgba(0, 0, 0, 0.35);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

/* 左切角与右切角形状 */
.hw-btn-left {
  clip-path: polygon(25rpx 0%, 100% 0%, calc(100% - 10rpx) 50%, 100% 100%, 25rpx 100%, 0% 50%);
}

.hw-btn-right {
  clip-path: polygon(0% 0%, calc(100% - 25rpx) 0%, 100% 50%, calc(100% - 25rpx) 100%, 0% 100%, 10rpx 50%);
}

.hw-btn-adjust:active {
  transform: scale(0.94);
  background: linear-gradient(135deg, rgba(0, 175, 255, 0.20) 0%, rgba(0, 100, 200, 0.40) 100%);
  border-color: rgba(0, 175, 255, 0.75);
  box-shadow: inset 0 0 24rpx rgba(0, 175, 255, 0.35), 0 0 24rpx rgba(0, 175, 255, 0.25);
}

/* 精密向左和向右的 CSS 纯细线三角箭头图标 */
.hw-btn-icon-arrow-left {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-right: 14rpx solid rgba(0, 175, 255, 0.85);
  margin-right: 4rpx;
  z-index: 2;
  transition: border-color 0.2s;
}

.hw-btn-left:active .hw-btn-icon-arrow-left {
  border-right-color: rgba(0, 175, 255, 1);
}

.hw-btn-icon-arrow-right {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 14rpx solid rgba(0, 175, 255, 0.85);
  margin-left: 4rpx;
  z-index: 2;
  transition: border-color 0.2s;
}

.hw-btn-right:active .hw-btn-icon-arrow-right {
  border-left-color: rgba(0, 175, 255, 1);
}

/* 跳过：小灰色扁平按钮，仅有横杠 */
.hw-btn-skip {
  width: 120rpx;
  height: 80rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(140, 176, 205, 0.25);
  background: rgba(140, 176, 205, 0.05);
  box-shadow: 0 0 12rpx rgba(0, 0, 0, 0.25);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.hw-btn-skip:active {
  transform: scale(0.93);
  background: rgba(140, 176, 205, 0.14);
  border-color: rgba(140, 176, 205, 0.45);
}

.hw-btn-icon-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(140, 176, 205, 0.6);
  transition: background 0.2s;
}

.hw-btn-skip:active .hw-btn-icon-dot {
  background: rgba(140, 176, 205, 0.95);
}

/* 装饰性极细刻度角线 */
.crystal-decor {
  position: absolute;
  top: 18rpx;
  width: 3rpx;
  height: 44rpx;
  background: rgba(0, 175, 255, 0.45);
  transition: all 0.2s;
  z-index: 1;
}

.crystal-decor-l {
  left: 18rpx;
  box-shadow: 0 0 6rpx rgba(0, 175, 255, 0.5);
}

.crystal-decor-r {
  right: 18rpx;
  box-shadow: 0 0 6rpx rgba(0, 175, 255, 0.5);
}

.hw-btn-adjust:active .crystal-decor {
  background: rgba(0, 175, 255, 0.85);
  height: 48rpx;
  top: 16rpx;
}

/* 数据加载提示 */
.data-loading-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: rgba(0, 175, 255, 0.55);
  letter-spacing: 2rpx;
}

/* Reduce Motion */
.reduce-motion .signal-card--current {
  transition: none;
}

.reduce-motion .card-stack--promote .signal-card--next {
  transition: none;
}

.reduce-motion .card-scan-line {
  animation: none;
}

.reduce-motion .seg {
  transition: none;
}

.reduce-motion .action-btn-hardware {
  transition: none !important;
  transform: none !important;
}

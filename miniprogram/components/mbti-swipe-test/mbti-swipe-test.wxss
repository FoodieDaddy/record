:host {
  width: 100%;
  display: block;
  overflow: visible !important;
}

.swipe-overlay {
  position: relative;
  width: 100%;
  background: transparent;
  display: flex;
  flex-direction: column;
  padding: 24rpx 0 0 0;
  box-sizing: border-box;
  overflow: visible;
}

/* 进度光线 */
.progress-track {
  position: absolute;
  top: -8rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: rgba(0, 200, 255, 0.08);
  z-index: 3;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--color-cyan), var(--color-cyan));
  border-radius: 0 2rpx 2rpx 0;
  transition: width 0.35s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: 0 0 8rpx rgba(0, 175, 255, 0.40);
}

.swipe-card-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 0;
}

/* ---- 双卡栈 ---- */
.card-stack {
  position: relative;
  width: 85%;
  min-height: 340rpx;
}

.signal-card {
  width: 100%;
  background: transparent;
  border: none;
  padding: 40rpx 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 280rpx;
}

/* 当前题：在前方 */
.signal-card--current {
  position: relative;
  z-index: 2;
  transition: transform 0.26s ease, opacity 0.26s ease;
}

/* 当前卡滑出动画 */
.signal-card--current.signal-card--motion-right {
  opacity: 0;
  transform: translateX(120rpx) rotate(2deg) scale(0.98);
}

.signal-card--current.signal-card--motion-left {
  opacity: 0;
  transform: translateX(-120rpx) rotate(-2deg) scale(0.98);
}

.signal-card--current.signal-card--motion-skip {
  opacity: 0;
  transform: scale(0.95);
}

.question-text {
  font-size: 34rpx;
  color: var(--text-primary, #ffffff);
  line-height: 1.8;
  text-align: center;
  text-shadow: 0 0 12rpx rgba(255, 255, 255, 0.15);
  width: 100%;
}

/* 数据加载提示 */
.data-loading-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: rgba(0, 175, 255, 0.55);
  letter-spacing: 2rpx;
}

/* Reduce Motion */
.reduce-motion .signal-card--current {
  transition: none;
}

.reduce-motion .card-stack--promote .signal-card--next {
  transition: none;
}

.reduce-motion .card-scan-line {
  animation: none;
}

.reduce-motion .seg {
  transition: none;
}

.reduce-motion .action-btn-hardware {
  transition: none !important;
  transform: none !important;
}

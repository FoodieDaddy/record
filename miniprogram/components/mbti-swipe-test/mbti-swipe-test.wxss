:host {
  width: 100%;
  height: 100%;
  display: block;
  overflow: visible !important;
}

.swipe-overlay {
  height: 100%;
  width: 100%;
  background: transparent;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 30rpx 36rpx;
  overflow: hidden;
}

/* 分段式精密发光能量块进度条 */
.segmented-progress {
  width: 100%;
  height: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 6rpx;
  z-index: 5;
  margin-bottom: 16rpx;
}

.progress-segment {
  flex: 1;
  height: 6rpx;
  background: rgba(0, 175, 255, 0.12);
  border-radius: 2rpx;
  transform: skewX(-20deg);
  transition: background 0.3s ease, box-shadow 0.3s ease;
}

.progress-segment--active {
  background: var(--color-cyan, #00afff);
  box-shadow: 0 0 10rpx rgba(0, 175, 255, 0.70);
}

.progress-segment--current {
  background: rgba(0, 175, 255, 0.70);
  box-shadow: 0 0 12rpx rgba(0, 175, 255, 0.50);
  animation: segmentPulse 1.2s infinite ease-in-out;
}

@keyframes segmentPulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 1; }
}

.reduce-motion .progress-segment--current {
  animation: none;
  opacity: 0.8;
}

.terminal-body {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 36rpx 12rpx 0 12rpx; /* 在大屏幕顶部空出距离，首行对齐 */
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
}

.terminal-row {
  width: 100%;
  box-sizing: border-box;
}

/* 当前活动题：仅显示一道，block排列，不向上跳跃 */
.term-row--active {
  width: 100%;
  color: var(--text-primary, #ffffff);
  display: block;
}

.term-line-content {
  font-size: 32rpx; /* 舒适显眼的高级全息大字号 */
  line-height: 1.8;
  color: var(--text-primary, #ffffff);
  text-shadow: 0 0 12rpx rgba(255, 255, 255, 0.15);
  letter-spacing: 2rpx;
  word-break: break-all;
}

/* 终端闪烁光标 */
.term-cursor {
  display: inline-block;
  width: 14rpx;
  height: 30rpx;
  background: rgba(0, 175, 255, 0.85);
  margin-left: 8rpx;
  animation: cursorBlink 1s infinite steps(2);
  vertical-align: middle;
}

@keyframes cursorBlink {
  0%, 100% { opacity: 0; }
  50% { opacity: 1; }
}

.reduce-motion .term-cursor {
  animation: none;
  opacity: 0.8;
}

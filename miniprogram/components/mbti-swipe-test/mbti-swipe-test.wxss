:host {
  width: 100%;
  display: block;
  overflow: visible !important;
}

.swipe-overlay {
  position: relative;
  width: 100%;
  background: transparent;
  display: flex;
  flex-direction: column;
  padding: 24rpx 0 0 0;
  box-sizing: border-box;
  overflow: visible;
}

/* 进度光线 */
.progress-track {
  position: absolute;
  top: -8rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: rgba(0, 200, 255, 0.08);
  z-index: 3;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--color-cyan), var(--color-cyan));
  border-radius: 0 2rpx 2rpx 0;
  transition: width 0.35s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: 0 0 8rpx rgba(0, 175, 255, 0.40);
}

.swipe-card-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 0;
}

/* ---- 双卡栈 ---- */
.card-stack {
  position: relative;
  width: 85%;
  min-height: 340rpx;
}

.signal-card {
  width: 100%;
  background: rgba(0, 15, 30, 0.60);
  border: 1rpx solid rgba(0, 175, 255, 0.18);
  border-radius: 16rpx;
  padding: 0;
  min-height: 340rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* 下一题预览：在后方，弱化 */
.signal-card--next {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  opacity: 0.18;
  transform: translateY(16rpx) scale(0.96);
  z-index: 1;
  pointer-events: none;
}

/* 当前题：在前方 */
.signal-card--current {
  position: relative;
  z-index: 2;
  transition: transform 0.26s ease, opacity 0.26s ease;
}

/* 当前卡滑出动画 */
.signal-card--current.signal-card--motion-right {
  opacity: 0;
  transform: translateX(120rpx) rotate(2deg) scale(0.98);
}

.signal-card--current.signal-card--motion-left {
  opacity: 0;
  transform: translateX(-120rpx) rotate(-2deg) scale(0.98);
}

.signal-card--current.signal-card--motion-skip {
  opacity: 0;
  transform: scale(0.95);
}

/* 提升动画：下一卡升为当前卡 */
.card-stack--promote .signal-card--next {
  opacity: 1;
  transform: translateY(0) scale(1);
  transition: opacity 0.16s ease, transform 0.16s ease;
}

/* 扫描线 */
.card-scan-line {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 175, 255, 0.40), transparent);
  animation: cardScan 3s linear infinite;
}

@keyframes cardScan {
  0% { top: 0; opacity: 1; }
  100% { top: 100%; opacity: 0.3; }
}

.signal-header {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: rgba(0, 175, 255, 0.55);
  margin-top: 28rpx;
}

.signal-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.question-divider-top,
.question-divider-bottom {
  width: 80%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 175, 255, 0.20), transparent);
  margin: 16rpx 0;
}

.question-text {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.8;
  text-align: center;
  padding: 8rpx 32rpx;
}

.dim-detect {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  margin-top: 4rpx;
}

.dim-detect-label {
  font-size: 18rpx;
  color: var(--text-disabled);
  letter-spacing: 2rpx;
}

.dim-detect-value {
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(0, 175, 255, 0.70);
  letter-spacing: 2rpx;
  padding: 4rpx 14rpx;
  border: 1rpx solid rgba(0, 175, 255, 0.18);
  border-radius: 4rpx;
  background: rgba(0, 175, 255, 0.04);
}

/* 底部操作 */
.swipe-actions {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -118rpx;
  z-index: 3010;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 32rpx;
  padding: 0;
}

.action-btn-hardware {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
}

/* 不符合：极简无字小红色圆形按钮，仅有叉号 */
.hw-btn-reject {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 69, 58, 0.35);
  background: rgba(255, 69, 58, 0.05);
  box-shadow: 0 0 12rpx rgba(255, 69, 58, 0.04);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.hw-btn-reject:active {
  transform: scale(0.92);
  background: rgba(255, 69, 58, 0.18);
  border-color: rgba(255, 69, 58, 0.6);
  box-shadow: 0 0 20rpx rgba(255, 69, 58, 0.3);
}

.hw-btn-icon-close {
  width: 20rpx;
  height: 20rpx;
  position: relative;
}

.hw-btn-icon-close::before,
.hw-btn-icon-close::after {
  content: '';
  position: absolute;
  top: 9rpx;
  left: 0;
  width: 20rpx;
  height: 2rpx;
  background: rgba(255, 69, 58, 0.75);
  transition: background 0.2s;
}

.hw-btn-icon-close::before {
  transform: rotate(45deg);
}

.hw-btn-icon-close::after {
  transform: rotate(-45deg);
}

.hw-btn-reject:active .hw-btn-icon-close::before,
.hw-btn-reject:active .hw-btn-icon-close::after {
  background: rgba(255, 69, 58, 1);
}

/* 跳过：小灰色扁平按钮，仅有横杠 */
.hw-btn-skip {
  width: 120rpx;
  height: 80rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(140, 176, 205, 0.25);
  background: rgba(140, 176, 205, 0.05);
  box-shadow: 0 0 12rpx rgba(0, 0, 0, 0.25);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.hw-btn-skip:active {
  transform: scale(0.93);
  background: rgba(140, 176, 205, 0.14);
  border-color: rgba(140, 176, 205, 0.45);
}

.hw-btn-icon-skip {
  width: 16rpx;
  height: 4rpx;
  background: rgba(140, 176, 205, 0.6);
  border-radius: 1rpx;
  transition: background 0.2s;
}

.hw-btn-skip:active .hw-btn-icon-skip {
  background: rgba(140, 176, 205, 0.95);
}

/* 符合：六角切角水晶按键，仅有精密勾号 */
.hw-btn-confirm {
  width: 220rpx;
  height: 80rpx;
  background: linear-gradient(135deg, rgba(0, 175, 255, 0.08) 0%, rgba(0, 80, 155, 0.24) 100%);
  border: 1rpx solid rgba(0, 175, 255, 0.35);
  border-radius: 8rpx;
  /* 倒角切边科技感 */
  clip-path: polygon(15rpx 0%, calc(100% - 15rpx) 0%, 100% 50%, calc(100% - 15rpx) 100%, 15rpx 100%, 0% 50%);
  box-shadow: inset 0 0 16rpx rgba(0, 175, 255, 0.15), 0 4rpx 16rpx rgba(0, 0, 0, 0.35);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.hw-btn-confirm:active {
  transform: scale(0.94);
  background: linear-gradient(135deg, rgba(0, 175, 255, 0.20) 0%, rgba(0, 100, 200, 0.40) 100%);
  border-color: rgba(0, 175, 255, 0.75);
  box-shadow: inset 0 0 24rpx rgba(0, 175, 255, 0.35), 0 0 24rpx rgba(0, 175, 255, 0.25);
}

.hw-btn-icon-check {
  width: 22rpx;
  height: 12rpx;
  border-left: 2rpx solid rgba(0, 175, 255, 0.8);
  border-bottom: 2rpx solid rgba(0, 175, 255, 0.8);
  transform: rotate(-45deg);
  margin-top: -4rpx;
  z-index: 2;
}

.hw-btn-confirm:active .hw-btn-icon-check {
  border-color: rgba(0, 175, 255, 1);
}

/* 装饰性极细刻度角线 */
.crystal-decor {
  position: absolute;
  top: 18rpx;
  width: 3rpx;
  height: 44rpx;
  background: rgba(0, 175, 255, 0.45);
  transition: all 0.2s;
  z-index: 1;
}

.crystal-decor-l {
  left: 18rpx;
  box-shadow: 0 0 6rpx rgba(0, 175, 255, 0.5);
}

.crystal-decor-r {
  right: 18rpx;
  box-shadow: 0 0 6rpx rgba(0, 175, 255, 0.5);
}

.hw-btn-confirm:active .crystal-decor {
  background: rgba(0, 175, 255, 0.85);
  height: 48rpx;
  top: 16rpx;
}

/* 数据加载提示 */
.data-loading-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: rgba(0, 175, 255, 0.55);
  letter-spacing: 2rpx;
}

/* Reduce Motion */
.reduce-motion .signal-card--current {
  transition: none;
}

.reduce-motion .card-stack--promote .signal-card--next {
  transition: none;
}

.reduce-motion .card-scan-line {
  animation: none;
}

.reduce-motion .seg {
  transition: none;
}

.reduce-motion .action-btn-hardware {
  transition: none !important;
  transform: none !important;
}

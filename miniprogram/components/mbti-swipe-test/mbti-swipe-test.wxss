:host {
  width: 100%;
  height: 100%;
  display: block;
  overflow: visible !important;
}

.swipe-overlay {
  height: 100%;
  width: 100%;
  background: transparent;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 30rpx 36rpx;
  overflow: hidden;
}

/* 分段式精密发光能量块进度条 */
.segmented-progress {
  width: 100%;
  height: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 6rpx;
  z-index: 5;
  margin-bottom: 16rpx;
}

.progress-segment {
  flex: 1;
  height: 6rpx;
  background: rgba(0, 175, 255, 0.12);
  border-radius: 2rpx;
  transform: skewX(-20deg);
  transition: background 0.3s ease, box-shadow 0.3s ease;
}

.progress-segment--active {
  background: var(--color-cyan, #00afff);
  box-shadow: 0 0 10rpx rgba(0, 175, 255, 0.70);
}

.progress-segment--current {
  background: rgba(0, 175, 255, 0.70);
  box-shadow: 0 0 12rpx rgba(0, 175, 255, 0.50);
  animation: segmentPulse 1.2s infinite ease-in-out;
}

@keyframes segmentPulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 1; }
}

.reduce-motion .progress-segment--current {
  animation: none;
  opacity: 0.8;
}

.terminal-scroll {
  flex: 1;
  width: 100%;
  height: 100%;
  min-height: 0;
}

/* 隐藏右侧滚动条 */
.terminal-scroll ::-webkit-scrollbar {
  display: none !important;
  width: 0 !important;
  height: 0 !important;
  color: transparent !important;
}

.terminal-body {
  padding: 12rpx 0;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.terminal-row {
  font-size: 26rpx;
  line-height: 1.7;
  word-break: break-all;
  letter-spacing: 1rpx;
}

/* 历史题目渐淡为背景，不带前缀与后缀 */
.term-row--question {
  color: rgba(255, 255, 255, 0.28);
  text-shadow: none;
  transition: color 0.5s ease;
}

/* 当前活动题 */
.term-row--active {
  color: var(--text-primary, #ffffff);
  display: inline-flex;
  flex-wrap: wrap;
  align-items: center;
}

.term-line-content {
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.1);
}

/* 终端闪烁光标 */
.term-cursor {
  display: inline-block;
  width: 12rpx;
  height: 24rpx;
  background: rgba(0, 175, 255, 0.85);
  margin-left: 8rpx;
  animation: cursorBlink 1s infinite steps(2);
  vertical-align: middle;
}

@keyframes cursorBlink {
  0%, 100% { opacity: 0; }
  50% { opacity: 1; }
}

.reduce-motion .term-cursor {
  animation: none;
  opacity: 0.8;
}

/* 数据加载提示 */
.data-loading-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: rgba(0, 175, 255, 0.55);
  letter-spacing: 2rpx;
}

/* Reduce Motion */
.reduce-motion .signal-card--current {
  transition: none;
}

.reduce-motion .card-stack--promote .signal-card--next {
  transition: none;
}

.reduce-motion .card-scan-line {
  animation: none;
}

.reduce-motion .seg {
  transition: none;
}

.reduce-motion .action-btn-hardware {
  transition: none !important;
  transform: none !important;
}

.terminal-spacer {
  width: 100%;
  height: 220rpx; /* 撑开底部高度，使得当前题在滚动置底时能精确维持在卡片垂直正中心 */
}

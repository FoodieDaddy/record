.swipe-overlay {
  position: relative;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.88);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  box-sizing: border-box;
}

/* 进度光线 */
.progress-track {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--glass-bg);
  z-index: 10;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--color-cyan), var(--color-cyan));
  border-radius: 0 2rpx 2rpx 0;
  transition: width 0.35s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: 0 0 8rpx rgba(0, 175, 255, 0.40);
}

.swipe-top {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 80rpx 0 32rpx;
  position: relative;
}

.top-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.swipe-kicker {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: rgba(0, 175, 255, 0.65);
  text-transform: uppercase;
}

.swipe-subtitle {
  font-size: 22rpx;
  color: var(--text-tertiary);
  letter-spacing: 2rpx;
}

.top-progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.swipe-progress {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-family: 'SF Mono', 'Courier New', monospace;
}

.progress-segments {
  display: flex;
  gap: 4rpx;
}

.seg {
  width: 8rpx;
  height: 8rpx;
  border-radius: 2rpx;
  background: var(--glass-bg-hover);
  transition: background 0.3s;
}

.seg-done {
  background: var(--color-cyan);
  box-shadow: 0 0 4rpx rgba(0, 175, 255, 0.40);
}

.progress-pct {
  font-size: 22rpx;
  color: rgba(0, 175, 255, 0.55);
  font-family: 'SF Mono', 'Courier New', monospace;
  font-variant-numeric: tabular-nums;
}

.swipe-close {
  position: absolute;
  top: 60rpx;
  right: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.swipe-card-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* ---- 双卡栈 ---- */
.card-stack {
  position: relative;
  width: 85%;
  min-height: 340rpx;
}

.signal-card {
  width: 100%;
  background: rgba(0, 15, 30, 0.60);
  border: 1rpx solid rgba(0, 175, 255, 0.18);
  border-radius: 16rpx;
  padding: 0;
  min-height: 340rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* 下一题预览：在后方，弱化 */
.signal-card--next {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  opacity: 0.25;
  transform: translateY(16rpx) scale(0.96);
  z-index: 1;
  pointer-events: none;
}

/* 当前题：在前方 */
.signal-card--current {
  position: relative;
  z-index: 2;
  transition: transform 0.26s ease, opacity 0.26s ease;
}

/* 当前卡滑出动画 */
.signal-card--current.signal-card--motion-right {
  opacity: 0;
  transform: translateX(120rpx) rotate(2deg) scale(0.98);
}

.signal-card--current.signal-card--motion-left {
  opacity: 0;
  transform: translateX(-120rpx) rotate(-2deg) scale(0.98);
}

.signal-card--current.signal-card--motion-skip {
  opacity: 0;
  transform: scale(0.95);
}

/* 提升动画：下一卡升为当前卡 */
.card-stack--promote .signal-card--next {
  opacity: 1;
  transform: translateY(0) scale(1);
  transition: opacity 0.16s ease, transform 0.16s ease;
}

/* 扫描线 */
.card-scan-line {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 175, 255, 0.40), transparent);
  animation: cardScan 3s linear infinite;
}

@keyframes cardScan {
  0% { top: 0; opacity: 1; }
  100% { top: 100%; opacity: 0.3; }
}

.signal-header {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: rgba(0, 175, 255, 0.55);
  margin-top: 28rpx;
}

.signal-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.question-divider-top,
.question-divider-bottom {
  width: 80%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 175, 255, 0.20), transparent);
  margin: 16rpx 0;
}

.question-text {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.8;
  text-align: center;
  padding: 8rpx 32rpx;
}

.dim-detect {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  margin-top: 4rpx;
}

.dim-detect-label {
  font-size: 18rpx;
  color: var(--text-disabled);
  letter-spacing: 2rpx;
}

.dim-detect-value {
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(0, 175, 255, 0.70);
  letter-spacing: 2rpx;
  padding: 4rpx 14rpx;
  border: 1rpx solid rgba(0, 175, 255, 0.18);
  border-radius: 4rpx;
  background: rgba(0, 175, 255, 0.04);
}

/* 底部操作 */
.swipe-actions {
  display: flex;
  gap: 16rpx;
  padding: 32rpx 0 calc(24rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0 24rpx;
  min-height: 88rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--glass-border-light);
  background: var(--bg-card);
  transition: background 0.15s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  box-sizing: border-box;
}

.action-btn:active {
  background: var(--glass-bg);
}

.action-kicker {
  font-size: 16rpx;
  letter-spacing: 3rpx;
  font-weight: 600;
}

.action-text {
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

/* 不符合：弱灰橙，不用强红 */
.action-reject {
  border-color: rgba(180, 150, 120, 0.18);
}

.action-reject .action-kicker {
  color: rgba(180, 150, 120, 0.45);
}

.action-reject .action-text {
  color: rgba(180, 150, 120, 0.70);
}

.action-reject:active {
  background: rgba(180, 150, 120, 0.06);
}

.action-skip {
  border-color: rgba(126, 156, 180, 0.10);
}

.action-skip .action-kicker {
  color: rgba(126, 156, 180, 0.30);
}

.action-skip .action-text {
  color: rgba(140, 176, 205, 0.45);
}

.action-confirm {
  border-color: rgba(0, 175, 255, 0.35);
  background: rgba(0, 175, 255, 0.06);
  box-shadow: 0 0 16rpx rgba(0, 175, 255, 0.10);
}

.action-confirm .action-kicker {
  color: rgba(0, 175, 255, 0.60);
}

.action-confirm .action-text {
  color: var(--color-cyan);
}

.action-confirm:active {
  background: rgba(0, 175, 255, 0.14);
  box-shadow: 0 0 24rpx rgba(0, 175, 255, 0.20);
}

/* 数据加载提示 */
.data-loading-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: rgba(0, 175, 255, 0.55);
  letter-spacing: 2rpx;
}

/* Reduce Motion */
.reduce-motion .signal-card--current {
  transition: none;
}

.reduce-motion .card-stack--promote .signal-card--next {
  transition: none;
}

.reduce-motion .card-scan-line {
  animation: none;
}

.reduce-motion .seg {
  transition: none;
}

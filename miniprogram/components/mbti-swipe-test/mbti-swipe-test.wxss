:host {
  width: 100%;
  height: 100%;
  display: block;
  overflow: visible !important;
}

.swipe-overlay {
  height: 100%;
  width: 100%;
  background: transparent;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 30rpx 36rpx;
  overflow: hidden;
}

/* 进度光线 */
.progress-track {
  position: absolute;
  top: -2rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: rgba(0, 200, 255, 0.08);
  z-index: 3;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--color-cyan), var(--color-cyan));
  border-radius: 0 2rpx 2rpx 0;
  transition: width 0.35s cubic-bezier(0.23, 1, 0.32, 1);
  box-shadow: 0 0 8rpx rgba(0, 175, 255, 0.40);
}

.terminal-scroll {
  flex: 1;
  width: 100%;
  height: 100%;
  min-height: 0;
  margin-top: 10rpx;
}

.terminal-body {
  padding: 12rpx 0;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.terminal-row {
  font-size: 26rpx;
  line-height: 1.7;
  word-break: break-all;
  letter-spacing: 1rpx;
}

.term-row--system {
  color: rgba(0, 175, 255, 0.55);
}

.term-row--question {
  color: var(--text-secondary, rgba(255, 255, 255, 0.68));
}

.term-row--active {
  color: var(--text-primary, #ffffff);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.term-line-prefix {
  color: rgba(0, 175, 255, 0.85);
  font-weight: 700;
  margin-right: 8rpx;
}

.term-line-content {
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.1);
}

.term-line-answer {
  color: #00ff66;
  font-weight: 700;
  margin-left: 12rpx;
  text-shadow: 0 0 10rpx rgba(0, 255, 102, 0.35);
}

/* 终端闪烁光标 */
.term-cursor {
  display: inline-block;
  width: 12rpx;
  height: 24rpx;
  background: rgba(0, 175, 255, 0.85);
  margin-left: 8rpx;
  animation: cursorBlink 1s infinite steps(2);
  vertical-align: middle;
}

@keyframes cursorBlink {
  0%, 100% { opacity: 0; }
  50% { opacity: 1; }
}

.reduce-motion .term-cursor {
  animation: none;
  opacity: 0.8;
}

/* 数据加载提示 */
.data-loading-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: rgba(0, 175, 255, 0.55);
  letter-spacing: 2rpx;
}

/* Reduce Motion */
.reduce-motion .signal-card--current {
  transition: none;
}

.reduce-motion .card-stack--promote .signal-card--next {
  transition: none;
}

.reduce-motion .card-scan-line {
  animation: none;
}

.reduce-motion .seg {
  transition: none;
}

.reduce-motion .action-btn-hardware {
  transition: none !important;
  transform: none !important;
}

.terminal-spacer {
  width: 100%;
  height: 220rpx; /* 撑开底部高度，使得当前题在滚动置底时能精确维持在卡片垂直正中心 */
}

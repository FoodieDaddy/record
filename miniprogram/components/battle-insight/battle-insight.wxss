.bi-card {
  border-radius: 20rpx;
  border: 1rpx solid rgba(0, 175, 255, 0.12);
  background: #0A0F18;
  padding: 28rpx 26rpx;
  margin-bottom: 20rpx;
}

.bi-header {
  display: flex;
  flex-direction: column;
}

.bi-cn {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-cyan);
  letter-spacing: 2rpx;
}

.bi-en {
  font-family: 'SF Mono', 'Courier New', monospace;
  font-size: 17rpx;
  letter-spacing: 5rpx;
  color: rgba(126, 156, 180, 0.34);
  margin-top: 6rpx;
}

.bi-divider {
  /* 继承 app.wxss .sr-card-line */
}

.bi-blocks {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
}

.bi-block {
  padding: 16rpx;
  background: var(--bg-card);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.bi-block-label {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.bi-block-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bi-block-sub {
  font-size: 20rpx;
  color: var(--color-cyan);
}

.bi-block-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-cyan);
  font-family: "SF Mono", "Menlo", "Courier New", monospace;
  font-variant-numeric: tabular-nums;
}

.bi-density-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bi-density-bar {
  flex: 1;
  height: 8rpx;
  background: var(--glass-bg);
  border-radius: 4rpx;
  overflow: hidden;
}

.bi-density-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.bi-density-high { background: var(--success); }
.bi-density-mid { background: var(--color-cyan) }
.bi-density-low { background: var(--danger); }

.bi-density-text {
  font-size: 18rpx;
  color: var(--text-secondary);
  font-family: monospace;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.reduce-motion .bi-density-fill { transition: none; }

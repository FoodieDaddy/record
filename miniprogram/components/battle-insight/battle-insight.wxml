<view class="bi-card">
  <view class="bi-header">
    <text class="bi-cn">战局洞察</text>
    <text class="bi-en">BATTLE INSIGHT</text>
  </view>
  <view class="bi-divider"></view>
  <view class="bi-blocks">
    <view class="bi-block">
      <text class="bi-block-label">最活跃</text>
      <text class="bi-block-value">{{mostActiveUser.nickname || '--'}}</text>
      <text class="bi-block-sub" wx:if="{{mostActiveUser.count}}">互动{{mostActiveUser.count}}次</text>
    </view>
    <view class="bi-block">
      <text class="bi-block-label">最聚焦</text>
      <text class="bi-block-value">{{mostFocusedUser.nickname || '--'}}</text>
    </view>
    <view class="bi-block">
      <text class="bi-block-label">流转次数</text>
      <text class="bi-block-num">{{transferCount}}</text>
    </view>
    <view class="bi-block">
      <text class="bi-block-label">互动密度</text>
      <view class="bi-density-wrap">
        <view class="bi-density-bar">
          <view class="bi-density-fill {{networkDensity === 'HIGH' ? 'bi-density-high' : networkDensity === 'MEDIUM' ? 'bi-density-mid' : 'bi-density-low'}}"
            style="width:{{networkDensity === 'HIGH' ? 100 : networkDensity === 'MEDIUM' ? 60 : 25}}%;">
          </view>
        </view>
        <text class="bi-density-text">{{networkDensity}}</text>
      </view>
    </view>
  </view>
</view>

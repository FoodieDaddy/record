.battle-summary {
  border-radius: 20rpx;
  border: 1rpx solid rgba(0, 175, 255, 0.15);
  background: #0A0F18;
  padding: 28rpx 26rpx 20rpx;
  margin-bottom: 20rpx;
}

/* 标题区 */
.summary-header { margin-bottom: 20rpx; }

.summary-kicker {
  font-family: 'SF Mono', 'Courier New', monospace;
  margin-top: 6rpx;
  font-size: 17rpx;
  letter-spacing: 5rpx;
  color: rgba(126, 156, 180, 0.34);
  text-transform: uppercase;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-cyan);
  letter-spacing: 2rpx;
}

.summary-line {
  height: 1rpx;
  margin-top: 14rpx;
  background: linear-gradient(90deg, rgba(0, 175, 255, 0.25), rgba(0, 175, 255, 0.06), transparent);
}

/* 编队信息条 */
.summary-meta {
  display: flex;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.meta-value {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.meta-value.mono {
  font-family: 'SF Mono', 'Courier New', monospace;
  letter-spacing: 2rpx;
}

.summary-divider {
  height: 1rpx;
  background: var(--glass-bg);
  margin-bottom: 20rpx;
}

/* 四宫格 */
.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.summary-cell {
  background: rgba(0, 175, 255, 0.04);
  border: 1rpx solid rgba(0, 175, 255, 0.08);
  border-radius: 14rpx;
  padding: 18rpx 16rpx;
}

.cell-kicker {
  font-size: 17rpx;
  letter-spacing: 3rpx;
  color: rgba(0, 175, 255, 0.45);
  text-transform: uppercase;
  display: block;
  margin-bottom: 8rpx;
}

.cell-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cell-number {
  font-family: 'SF Mono', 'Courier New', monospace;
  font-size: 40rpx;
  font-weight: 700;
  display: block;
}

.cell-number.positive {
  color: #32D74B;
  text-shadow: 0 0 16rpx rgba(50, 215, 75, 0.30);
}

.cell-number.negative {
  color: var(--danger);
  text-shadow: 0 0 16rpx rgba(255, 69, 58, 0.25);
}

.cell-number.accent {
  color: var(--color-cyan);
  text-shadow: 0 0 16rpx rgba(0, 175, 255, 0.30);
}

/* 底部统计条 */
.summary-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.footer-stat {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.footer-num {
  font-family: 'SF Mono', 'Courier New', monospace;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.footer-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.footer-dot {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: rgba(0, 175, 255, 0.30);
}

.reduce-motion .cell-number { text-shadow: none; }

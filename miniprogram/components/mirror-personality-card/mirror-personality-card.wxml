<view class="personality-card {{profile.calibrated ? 'calibrated' : 'uncalibrated'}}">
  <view class="card-header">
    <text class="card-title">人格镜像</text>
    <text class="card-meta">MBTI CALIBRATION</text>
  </view>

  <!-- 未校准状态 -->
  <block wx:if="{{!profile.calibrated}}">
    <view class="card-body">
      <text class="uncalibrated-text">未完成人格镜像校准</text>
      <text class="uncalibrated-hint">完成 20 个快速判断，建立你的初始博弈人格模型。</text>
    </view>
    <view class="card-actions">
      <view class="btn-primary" bindtap="onStartTest">20题滑动校准</view>
      <view class="btn-ghost" bindtap="onDirectInput">直接输入</view>
    </view>
  </block>

  <!-- 已校准状态 -->
  <block wx:else>
    <view class="card-body calibrated-body">
      <text class="mbti-type">{{profile.mbtiType}}</text>
      <text class="mbti-title">{{profile.mbtiTitle}}</text>
      <text class="mbti-confidence">置信度 {{profile.confidence}}%</text>
      <text class="mbti-source">{{profile.mbtiSource === 'test' ? '滑动校准' : '直接输入'}}</text>
      <text class="mbti-time" wx:if="{{profile.calibratedAt}}">{{profile.calibratedAt}}</text>
    </view>
    <view class="card-actions">
      <view class="btn-ghost" bindtap="onStartTest">重新校准</view>
      <view class="btn-ghost" bindtap="onDirectInput">修改类型</view>
    </view>
  </block>
</view>

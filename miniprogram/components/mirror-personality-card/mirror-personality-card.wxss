.personality-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 32rpx;
  position: relative;
  overflow: hidden;
}

.personality-card.calibrated {
  border-color: rgba(10, 132, 255, 0.3);
  box-shadow: 0 0 40rpx rgba(10, 132, 255, 0.05);
}

.personality-card.calibrated::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #0A84FF, transparent);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
}

.card-meta {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.34);
  letter-spacing: 4rpx;
}

.card-body {
  margin-bottom: 32rpx;
}

.uncalibrated-text {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.52);
  margin-bottom: 12rpx;
}

.uncalibrated-hint {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.34);
  line-height: 1.6;
}

.calibrated-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0;
}

.mbti-type {
  font-size: 72rpx;
  font-weight: 700;
  color: #0A84FF;
  letter-spacing: 12rpx;
  font-family: 'SF Mono', monospace;
}

.mbti-title {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.92);
  font-weight: 500;
}

.mbti-confidence {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.52);
}

.mbti-source {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.34);
}

.mbti-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.2);
}

.card-actions {
  display: flex;
  gap: 20rpx;
}

.btn-primary {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: #0A84FF;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.btn-ghost {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.52);
}

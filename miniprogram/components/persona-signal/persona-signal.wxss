.behavior-signal {
  border-radius: 20rpx;
  border: 1rpx solid rgba(94, 92, 230, 0.15);
  background: #0A0F18;
  padding: 28rpx 26rpx;
  margin-bottom: 20rpx;
}

.signal-header { margin-bottom: 16rpx; }

.signal-kicker {
  font-family: 'SF Mono', 'Courier New', monospace;
  margin-top: 6rpx;
  font-size: 17rpx;
  letter-spacing: 5rpx;
  color: rgba(255, 255, 255, 0.34);
  text-transform: uppercase;
}

.signal-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #00C8FF;
  letter-spacing: 2rpx;
}

.signal-line {
  height: 1rpx;
  margin-top: 14rpx;
  background: linear-gradient(90deg, rgba(94, 92, 230, 0.25), rgba(94, 92, 230, 0.06), transparent);
}

/* 低样本提示 */
.signal-hint {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 16rpx;
  background: rgba(255, 159, 10, 0.06);
  border: 1rpx solid rgba(255, 159, 10, 0.15);
  border-radius: 10rpx;
  margin-bottom: 18rpx;
}

.hint-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #FF9F0A;
  flex-shrink: 0;
}

.hint-text {
  font-size: 20rpx;
  color: rgba(255, 159, 10, 0.75);
}

.signal-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.signal-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.signal-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.50);
  width: 160rpx;
  flex-shrink: 0;
}

.signal-bar-wrap {
  flex: 1;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 3rpx;
  overflow: hidden;
}

.signal-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, rgba(94, 92, 230, 0.20), #5E5CE6);
  border-radius: 3rpx;
  transition: width 0.8s cubic-bezier(0.23, 1, 0.32, 1);
}

.signal-level {
  font-size: 22rpx;
  color: #5E5CE6;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

.signal-sync {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.sync-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
}

.sync-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.30);
  flex: 1;
}

.reduce-motion .signal-bar-fill { transition: none; }

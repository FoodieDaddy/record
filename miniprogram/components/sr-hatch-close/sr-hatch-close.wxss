/* ===== sr-hatch-close — 飞船舱门式关闭按钮 ===== */

.hatch-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 八角切角感：用 clip-path 模拟 */
  clip-path: polygon(
    12% 0%, 88% 0%,
    100% 12%, 100% 88%,
    88% 100%, 12% 100%,
    0% 88%, 0% 12%
  );
  background: var(--glass-bg);
  border: none; /* clip-path 下 border 不生效，用 box-shadow 模拟描边 */
  box-shadow: inset 0 0 0 1rpx rgba(126, 156, 180, 0.16);
  position: relative;
}

.hatch-close:active,
.hatch-close.hatch-pressed {
  background: rgba(0, 175, 255, 0.12);
  box-shadow: inset 0 0 0 1rpx rgba(0, 175, 255, 0.40);
}

.hatch-close:active .hatch-line,
.hatch-close.hatch-pressed .hatch-line {
  background: rgba(0, 175, 255, 0.85);
}

/* 危险模式：红色弱描边 */
.hatch-close.hatch-danger {
  box-shadow: inset 0 0 0 1rpx rgba(255, 69, 58, 0.24);
}

.hatch-close.hatch-danger:active,
.hatch-close.hatch-danger.hatch-pressed {
  background: rgba(255, 69, 58, 0.08);
  box-shadow: inset 0 0 0 1rpx rgba(255, 69, 58, 0.40);
}

.hatch-close.hatch-danger:active .hatch-line,
.hatch-close.hatch-danger.hatch-pressed .hatch-line {
  background: rgba(255, 69, 58, 0.80);
}

/* X 线条 */
.hatch-frame {
  width: 24rpx;
  height: 24rpx;
  position: relative;
}

.hatch-line {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 20rpx;
  height: 2rpx;
  background: rgba(140, 176, 205, 0.48);
  border-radius: 1rpx;
  transition: background 0.15s;
}

.hatch-line-tl {
  transform: translate(-50%, -50%) rotate(45deg);
}

.hatch-line-tr {
  transform: translate(-50%, -50%) rotate(-45deg);
}

/* Reduce Motion */
.reduce-motion .hatch-line {
  transition: none;
}

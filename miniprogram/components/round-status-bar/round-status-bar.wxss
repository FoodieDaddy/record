.status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: rgba(0, 170, 255, 0.06);
  border: 1rpx solid rgba(0, 170, 255, 0.12);
  border-radius: 12rpx;
  margin: 16rpx 24rpx;
}
.status-text {
  font-size: 26rpx;
  color: #00AFFF;
}
.status-text.rejected {
  color: #FF453A;
}
.cancel-btn {
  font-size: 26rpx;
  color: #7C8698;
  padding: 8rpx 16rpx;
}

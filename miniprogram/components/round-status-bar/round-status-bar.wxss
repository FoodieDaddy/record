.status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: rgba(10, 132, 255, 0.06);
  border: 1rpx solid rgba(10, 132, 255, 0.12);
  border-radius: 12rpx;
  margin: 16rpx 24rpx;
}
.status-text {
  font-size: 26rpx;
  color: var(--color-cyan);
}
.status-text.rejected {
  color: var(--danger);
}
.cancel-btn {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 8rpx 16rpx;
}

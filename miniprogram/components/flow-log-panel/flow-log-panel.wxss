/* ===== FLOW LOG PANEL 流向日志终端 ===== */
.flp {
  padding: 24rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.12);
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, rgba(10, 132, 255, 0.02), transparent 40%),
    rgba(255, 255, 255, 0.02);
  margin-bottom: 16rpx;
}

/* 标题区 */
.flp-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.flp-title-group {
  display: flex;
  flex-direction: column;
}
.flp-cn {
  font-size: 28rpx;
  font-weight: 600;
  color: #00C8FF;
  letter-spacing: 2rpx;
}
.flp-en {
  font-size: 17rpx;
  color: rgba(255, 255, 255, 0.28);
  letter-spacing: 4rpx;
  font-family: monospace;
  margin-top: 2rpx;
}
.flp-controls {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.flp-matrix-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  transition: background-color 0.2s;
}
.flp-matrix-btn:active {
  background: rgba(255, 255, 255, 0.1);
}

.flp-divider {
  height: 1rpx;
  background: linear-gradient(90deg, rgba(10, 132, 255, 0.12), rgba(255, 255, 255, 0.04), transparent);
  margin: 16rpx 0;
}

/* 空状态 */
.flp-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 0 40rpx;
  gap: 10rpx;
}
.flp-empty-pulse {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #0A84FF;
  opacity: 0.3;
  animation: emptyPulse 2.5s ease-in-out infinite;
  margin-bottom: 12rpx;
}
@keyframes emptyPulse {
  0%, 100% { opacity: 0.15; transform: scale(1); }
  50% { opacity: 0.45; transform: scale(1.4); }
}
.flp-empty-hint-cn {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.42);
  letter-spacing: 2rpx;
}
.flp-empty-hint-en {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.18);
  letter-spacing: 4rpx;
  font-family: monospace;
}
.flp-empty-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.24);
  margin-top: 8rpx;
}

/* 时间组容器 */
.flp-group {
  margin-bottom: 12rpx;
}
.flp-group:last-child {
  margin-bottom: 0;
}
.flp-time-anchor {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 0 8rpx;
  position: sticky;
  top: 0;
  z-index: 5;
  background: rgba(10, 10, 10, 0.92);
}
.flp-time-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #0A84FF;
  box-shadow: 0 0 10rpx rgba(10, 132, 255, 0.5);
  flex-shrink: 0;
}
.flp-time-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.42);
  font-weight: 500;
  font-variant-numeric: tabular-nums;
  font-family: "SF Mono", "Menlo", "Courier New", monospace;
  letter-spacing: 1rpx;
}
.flp-group-body {
  background: linear-gradient(180deg, rgba(10, 132, 255, 0.03), rgba(10, 132, 255, 0.015));
  border: 1rpx solid rgba(10, 132, 255, 0.06);
  border-radius: 16rpx;
  padding: 4rpx 0;
  overflow: hidden;
}

/* 事件行 */
.flp-event {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.025);
}
.flp-event:last-child {
  border-bottom: none;
}
.flp-event-mine {
  background: rgba(10, 132, 255, 0.04);
}
.flp-event-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(10, 132, 255, 0.3);
  flex-shrink: 0;
}
.flp-event-dot-active {
  background: #0A84FF;
  box-shadow: 0 0 8rpx rgba(10, 132, 255, 0.6);
}

/* 成员名 */
.flp-name {
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 1;
  min-width: 0;
  max-width: 150rpx;
}
.flp-name-from {
  color: rgba(255, 255, 255, 0.55);
  text-align: right;
}
.flp-name-to {
  color: rgba(255, 255, 255, 0.82);
}

/* 流向核心 */
.flp-flow {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}
.flp-beam {
  width: 20rpx;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(10, 132, 255, 0.15), rgba(10, 132, 255, 0.35));
}
.flp-amount {
  font-size: 28rpx;
  font-weight: 700;
  font-family: "SF Mono", "Menlo", "Courier New", monospace;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  min-width: 60rpx;
  text-align: center;
}
.flp-amt-pos {
  color: #5BE37A;
}
.flp-amt-neg {
  color: #FF6B6B;
}
.flp-amt-neutral {
  color: rgba(255, 255, 255, 0.65);
}
.flp-arrow {
  font-size: 20rpx;
  color: rgba(10, 132, 255, 0.6);
  font-weight: 300;
}

/* 加载态 */
.flp-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx 0;
}
.flp-loading-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #0A84FF;
  animation: loadBlink 1.2s ease-in-out infinite;
}
@keyframes loadBlink {
  0%, 100% { opacity: 0.2; }
  50% { opacity: 0.8; }
}
.flp-loading-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  font-family: monospace;
  letter-spacing: 2rpx;
}

/* 结束提示 */
.flp-end {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 8rpx;
  gap: 4rpx;
}
.flp-end-cn {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.22);
  letter-spacing: 2rpx;
}
.flp-end-en {
  font-size: 15rpx;
  color: rgba(255, 255, 255, 0.12);
  letter-spacing: 4rpx;
  font-family: monospace;
}

.reduce-motion .flp-empty-pulse { animation: none; }
.reduce-motion .flp-loading-dot { animation: none; opacity: 0.4; }

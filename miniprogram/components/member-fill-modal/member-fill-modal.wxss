.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal {
  width: 560rpx;
  background: #0A0F18;
  border-radius: 28rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(0, 170, 255, 0.15);
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}
.title-area {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.kicker {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(0, 170, 255, 0.72);
  font-family: monospace;
  text-transform: uppercase;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
}
.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.03);
}
.close-icon {
  width: 24rpx;
  height: 24rpx;
  position: relative;
}
.close-icon::before,
.close-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 24rpx;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.5);
  transform-origin: center;
}
.close-icon::before {
  transform: translate(-50%, -50%) rotate(45deg);
}
.close-icon::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}
.label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.56);
  margin-bottom: 24rpx;
}
.score-input {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.92);
  font-size: 36rpx;
  margin-bottom: 32rpx;
  transition: border-color 0.2s;
}
.score-input:focus {
  border-color: rgba(0, 170, 255, 0.4);
}
.submit-btn {
  height: 80rpx;
  line-height: 80rpx;
  background: rgba(0, 170, 255, 0.15);
  color: #00AFFF;
  font-size: 30rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 170, 255, 0.4);
}
.submit-btn::after {
  border: none;
}
.submitted-state {
  text-align: center;
  padding: 32rpx 0;
}
.submitted-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.92);
  display: block;
  margin-bottom: 16rpx;
}
.submitted-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.38);
}

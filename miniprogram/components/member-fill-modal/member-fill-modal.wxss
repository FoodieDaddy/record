.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal {
  width: 560rpx;
  background: #0A0F18;
  border-radius: 28rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.15);
}
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}
.title-area {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.kicker {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(10, 132, 255, 0.72);
  font-family: monospace;
  text-transform: uppercase;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}
.score-input {
  width: 100%;
  height: 80rpx;
  background: var(--glass-bg);
  border: 1rpx solid var(--glass-border-light);
  border-radius: 12rpx;
  text-align: center;
  color: var(--text-primary);
  font-size: 36rpx;
  margin-bottom: 32rpx;
  transition: border-color 0.2s;
}
.score-input:focus {
  border-color: rgba(10, 132, 255, 0.4);
}

/* 底部按钮行 */
.btn-bottom-row {
  display: flex;
  gap: 20rpx;
}
.btn-cancel {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 1rpx solid var(--glass-border-light);
  border-radius: 16rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
  letter-spacing: 2rpx;
}
.btn-cancel:active {
  background: var(--glass-bg);
}
.btn-submit {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(10, 132, 255, 0.15);
  border: 1rpx solid rgba(10, 132, 255, 0.4);
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}
.btn-submit:active {
  background: rgba(10, 132, 255, 0.25);
}
.btn-submit-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-cyan)
  letter-spacing: 2rpx;
}

/* 已提交状态 */
.submitted-state {
  text-align: center;
  padding: 32rpx 0;
}
.submitted-text {
  font-size: 32rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}
.submitted-hint {
  font-size: 24rpx;
  color: rgba(140, 176, 205, 0.38);
}

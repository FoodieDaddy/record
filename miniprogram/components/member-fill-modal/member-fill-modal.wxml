<view class="mask" bindtap="onClose">
  <view class="modal" catchtap>
    <view class="header">
      <view class="title-area">
        <text class="kicker">MEMBER</text>
        <text class="title">提交本局</text>
      </view>
      <view class="close-btn" wx:if="{{!submitted}}" bindtap="onClose">
        <view class="close-icon"></view>
      </view>
    </view>

    <block wx:if="{{!submitted}}">
      <text class="label">请输入你本局的积分变动</text>
      <input
        class="score-input"
        type="number"
        placeholder="0"
        value="{{inputValue}}"
        bindinput="onInput"
        focus="{{true}}"
      />
      <button class="submit-btn" bindtap="onSubmit">确认提交</button>
    </block>

    <block wx:else>
      <view class="submitted-state">
        <text class="submitted-text">你已提交：{{myScore}}</text>
        <text class="submitted-hint">在所有人提交前可以修改。</text>
      </view>
    </block>
  </view>
</view>

<view class="mask" bindtap="onClose">
  <view class="modal" catchtap>
    <view class="header">
      <view class="title-area">
        <text class="kicker">MEMBER</text>
        <text class="title">提交本局</text>
      </view>
    </view>

    <block wx:if="{{!submitted}}">
      <text class="label">请输入你本轮的数值变动</text>
      <input
        class="score-input"
        type="number"
        adjust-position="{{false}}"
        placeholder="0"
        value="{{inputValue}}"
        bindinput="onInput"
        focus="{{true}}"
      />
      <view class="btn-bottom-row">
        <view class="btn-cancel" bindtap="onClose">
          <text>取消</text>
        </view>
        <view class="btn-submit" bindtap="onSubmit">
          <text class="btn-submit-text">确认提交</text>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="submitted-state">
        <text class="submitted-text">你已提交：{{myScore}}</text>
        <text class="submitted-hint">在所有人提交前可以修改。</text>
      </view>
    </block>
  </view>
</view>

.field-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 32rpx;
}

.field-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.field-title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
}

.field-meta {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.34);
  letter-spacing: 4rpx;
}

.field-body {
  margin-bottom: 24rpx;
}

.field-tag-row {
  margin-bottom: 12rpx;
}

.field-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid;
  border-radius: 8rpx;
}

.field-summary {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.52);
  line-height: 1.6;
}

.field-actions {
  display: flex;
  gap: 20rpx;
}

.field-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
}

.field-btn-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.52);
}

<view class="field-card" wx:if="{{todayField.tag}}">
  <view class="field-header">
    <text class="field-title">今日场域</text>
    <text class="field-meta">TODAY FIELD</text>
  </view>
  <view class="field-body">
    <view class="field-tag-row">
      <text class="field-tag" style="border-color: {{todayField.themeColor}}; color: {{todayField.themeColor}}">{{todayField.tag}}</text>
    </view>
    <text class="field-summary">{{todayField.summary}}</text>
  </view>
  <view class="field-actions">
    <view class="field-btn" bindtap="openAlmanac">
      <text class="field-btn-text">今日黄历</text>
    </view>
    <view class="field-btn" bindtap="openTaiyi">
      <text class="field-btn-text">太乙九星</text>
    </view>
  </view>
</view>

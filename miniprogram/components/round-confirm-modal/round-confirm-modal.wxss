.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal {
  width: 640rpx;
  background: #1c1c1e;
  border-radius: 24rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}
.header {
  margin-bottom: 32rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}
.detail-list {
  margin-bottom: 24rpx;
}
.detail-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}
.detail-name {
  flex: 1;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
}
.detail-score {
  width: 120rpx;
  text-align: right;
  font-size: 30rpx;
  font-weight: 500;
}
.detail-score.positive { color: #30d158; }
.detail-score.negative { color: #ff453a; }
.detail-score.zero { color: rgba(255, 255, 255, 0.25); }
.detail-status {
  width: 160rpx;
  text-align: right;
  font-size: 24rpx;
}
.detail-status.confirmed { color: #30d158; }
.detail-status.pending { color: rgba(255, 255, 255, 0.25); }
.summary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}
.total-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.35);
}
.total-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
.progress {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.25);
}
.actions {
  display: flex;
  gap: 24rpx;
}
.reject-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
  color: #ff453a;
  font-size: 30rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 69, 58, 0.4);
}
.reject-btn::after {
  border: none;
}
.agree-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: #0a84ff;
  color: #fff;
  font-size: 30rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4px 20px rgba(10, 132, 255, 0.35);
}
.agree-btn::after {
  border: none;
}

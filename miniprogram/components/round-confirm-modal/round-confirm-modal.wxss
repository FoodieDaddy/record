.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal {
  width: 640rpx;
  background: #0A0F18;
  border-radius: 28rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.15);
}
.header {
  margin-bottom: 32rpx;
}
.title-area {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.kicker {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: rgba(10, 132, 255, 0.72);
  font-family: monospace;
  text-transform: uppercase;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.detail-list {
  margin-bottom: 24rpx;
}
.detail-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}
.detail-name {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}
.detail-score {
  width: 120rpx;
  text-align: right;
  font-size: 30rpx;
  font-weight: 500;
}
.detail-score.positive { color: var(--success) }
.detail-score.negative { color: var(--danger) }
.detail-score.zero { color: var(--text-disabled); }
.detail-status {
  width: 160rpx;
  text-align: right;
  font-size: 24rpx;
}
.detail-status.confirmed { color: var(--success) }
.detail-status.pending { color: var(--text-disabled); }
.summary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(10, 132, 255, 0.06);
  border-radius: 12rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.12);
}
.total-label {
  font-size: 28rpx;
  color: rgba(140, 176, 205, 0.38);
}
.total-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.progress {
  font-size: 24rpx;
  color: rgba(10, 132, 255, 0.72);
}
.actions {
  display: flex;
  gap: 24rpx;
}
.reject-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
  color: var(--text-secondary);
  font-size: 30rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--glass-border-light);
}
.reject-btn::after {
  border: none;
}
.agree-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: rgba(10, 132, 255, 0.15);
  color: var(--color-cyan);
  font-size: 30rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(10, 132, 255, 0.4);
}
.agree-btn::after {
  border: none;
}

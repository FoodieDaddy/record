.radar-wrap {
  position: relative;
  display: flex;
  justify-content: center;
}

.radar-canvas {
  display: block;
}

.radar-canvas.radar-locked {
  opacity: 0.85;
}

.tooltip {
  position: absolute;
  transform: translateX(-50%);
  min-width: 200rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 175, 255, 0.25);
  background: rgba(10, 15, 24, 0.95);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  z-index: 10;
}

.tooltip-label {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
}

.tooltip-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #00AFFF;
}

.tooltip-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.56);
  text-align: center;
  line-height: 1.5;
}
